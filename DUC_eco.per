    ; Skynet constants

    ; Goals
        ; Non-temp goals (1000-9999)
            ; Global goals
                (defconst gl-position-self-x 1000)
                (defconst gl-position-self-y 1001)
                (defconst gl-vill-total 1002)
            ; DUC eco #000

        ; Global temp goals (41-99)
            (defconst gl-temp 41)
            (defconst gl-temp-x 42)
            (defconst gl-temp-y 43)
            (defconst gl-local-total 44)
