; ==== DROP SITES ====
(defrule; 2nd lumber camp for double range feudal
	(or	(goal G-build-order GV-feudal-war)
		(goal G-build-order GV-grush))
	(up-compare-goal G-age >= GV-upfeudal)
	(can-build LUMBER-CAMP)
	(or	(or	(building-type-count-total archery-range >= 2)
			(building-type-count-total stable >= 1))
		(and	(building-type-count-total blacksmith >= 1)
			(goal G-champs 1)))
	(building-type-count-total lumber-camp < 2)
	(building-type-count-total settlement < 3)
	=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-preferred-settlement-placement 3)
	(build LUMBER-CAMP)
	(disable-self))
(defrule; 2nd lumber camp up castle
	(up-compare-goal G-age >= GV-upcastle)
	(building-type-count-total lumber-camp < 2)
	(building-type-count-total settlement < 3)
	(can-build LUMBER-CAMP)
	(nand	(goal G-strat GV-klewproper)
		(building-type-count-total barracks < 2))
	(nand	(or	(goal G-strat GV-cdrop)
			(goal G-strat GV-cdropproper))
		(or	(dropsite-min-distance stone > 3)
			(up-research-status c: ri-stone-mining < research-pending)))
	=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-preferred-settlement-placement 3)
	(build LUMBER-CAMP)
	(disable-self))

(defrule
	(or	(unit-type-count 219 > 1); dead lumberjacks
		(unit-type-count 228 > 1))
	(can-build LUMBER-CAMP)
	(building-type-count-total LUMBER-CAMP < 3)
	(building-type-count-total LUMBER-CAMP >= 1)
	(current-age >= feudal-age)
	=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-preferred-settlement-placement 3)
	(build LUMBER-CAMP))
(defrule
	(dropsite-min-distance wood > 2)
	(or	(dropsite-min-distance wood > 3)
		(and	(building-type-count-total town-center >= 3)
			(wood-amount > 200)))
	(or	(or	(up-pending-objects c: LUMBER-CAMP == 0)
			(wood-amount > 280))
		(dropsite-min-distance wood > 4))
	(up-pending-objects c: LUMBER-CAMP <= 1)
	(can-build LUMBER-CAMP)
	(current-age >= feudal-age)
	=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-preferred-settlement-placement 3)
	(build LUMBER-CAMP))
(defrule
	(current-age == castle-age)
	(or	(and	(and	(building-type-count-total lumber-camp < 3)
				(building-type-count-total settlement < 5))
			(unit-type-count villager-wood >= 16))
		(or	(and	(and	(building-type-count-total lumber-camp < 2)
					(building-type-count-total settlement < 4))
				(unit-type-count villager-wood >= 11))
			(and	(and	(building-type-count-total lumber-camp < 4)
					(building-type-count-total settlement < 6))
				(unit-type-count villager-wood >= 21))))
	(can-build LUMBER-CAMP)
	=>
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-preferred-settlement-placement 3)
	(build LUMBER-CAMP))


; == mining camps ==
(defrule
	(cc-players-unit-type-count 0 gold-mine g:< G-min-gaia-gold)
	(cc-players-unit-type-count 0 stone-mine g:< G-min-gaia-stone)
	(up-compare-goal J-mining-camp > 0)
	=>
	(up-jump-direct g: J-mining-camp))

; - first gold -
(defrule
	(resource-found gold)
	(or	(or	(building-type-count-total lumber-camp >= 2)
			(building-type-count-total settlement >= 2))
		(up-compare-goal G-build-order != GV-feudal-war))
	(building-type-count-total mining-camp == 0)
	(building-type-count-total settlement < 3)
	(or	(goal G-eco-balance GV-early-feudal)
		(goal G-age GV-upfeudal))
	(up-compare-goal G-strat != GV-klewproper)
	=>
	(set-goal G-saving-wood 1))
(defrule
	(building-type-count-total mining-camp < 2)
	(building-type-count-total settlement < 4)
	(up-compare-goal G-age >= GV-upfeudal)
	(strategic-number sn-gold-gatherer-percentage > 0)
	(or	(building-type-count-total barracks > 0)
		(up-compare-goal G-build-order != GV-feudal-war))
	(can-build MINING-CAMP)
;	(resource-found gold)
	(dropsite-min-distance gold < 255)
	(dropsite-min-distance gold > 4)
	(up-compare-goal G-strat != GV-klewproper)
	=>
