(defrule
	(true)
	=>
	(up-get-rule-id J-mining-camp)
	(disable-self))

; == gathering site distance ==
(defrule
	(up-compare-goal G-camp-max-distance < 20)
	(or	(building-type-count-total lumber-camp >= 1)
		(building-type-count-total settlement >= 2))
	(building-type-count-total town-center >= 1)
	=>
	(set-goal G-camp-max-distance 20))

(defrule
	(or	(game-time >= 1200); 20min
		(current-age >= castle-age))
	=>
	(set-goal G-camp-max-distance CAMP-DIST-MIDGAME); 30 unless gold rush
	(disable-self))
(defrule
	(game-time >= 1500); 25min
	=>
	(up-modify-goal G-camp-max-distance c:+ 2)
	(disable-self))
(defrule
	(game-time g:>= G-camp-distance-time); 30min unless nomad/ln
	(up-timer-status T-60 != timer-running)
	=>
	(up-modify-goal G-camp-max-distance c:+ 2))

(defrule
	(strategic-number sn-camp-max-distance g:!= G-camp-max-distance)
;	(not	(up-pending-placement c: town-center))
	(or	(building-type-count-total lumber-camp >= 1)
		(building-type-count-total settlement >= 2))
	(building-type-count-total town-center >= 1)
	=>
	(up-modify-sn sn-camp-max-distance g:= G-camp-max-distance))

; ==== FARMING ====
(defrule; variable dark age farm number
	(current-age == dark-age)
	=>
	(set-goal G-temp1 FC-FARMS)
	(up-modify-goal G-temp1 g:- G-deers-lured))
#load-if-defined AZTEC-CIV
(defrule
	(current-age == dark-age)
	=>
	(up-modify-goal G-temp1 c:- 1))
#end-if
(defrule; dark age farms
	(up-pending-objects c: farm < 2)
	(goal G-age 1)
	(or	(building-type-count-total lumber-camp >= 1)
		(building-type-count-total settlement >= 2))
	(or	(building-type-count-total farm g:< G-temp1)
		(and	(idle-farm-count == 0)
			(unit-type-count villager-forager >= 5)))
	(up-compare-goal G-saving-wood <= 0)
	(up-compare-goal G-strat != GV-klewproper)
	(up-compare-goal G-strat != GV-trush)
	; (nand	(map-type yucatan)
	; 	(and	(civ-selected mongol)
	; 		(goal G-strat GV-krush)))
	=>
	(set-goal G-temp4 168193))
(defrule
	(goal G-temp4 168193)
	(can-build farm)
	(nand	(building-type-count-total farm >= 4)
		(goal G-build-order GV-feudal-war))
	(nand	(building-type-count-total farm >= 5)
		(and	(building-type-count-total lumber-camp < 2)
			(building-type-count-total settlement < 3)))
	=>
	(build farm))
(defrule; farms for fc build
	(current-age == dark-age)
	(or	(building-type-count-total lumber-camp >= 1)
		(building-type-count-total settlement >= 2))
	(or	(goal G-build-order GV-fast-castle)
		(goal G-build-order GV-slow-castle))
	(up-pending-objects c: farm == 0)
	(building-type-count-total farm g:< G-temp1)
	(can-build farm)
	(up-compare-goal G-strat != GV-klewproper)
	; (nand	(map-type yucatan)
	; 	(and	(civ-selected mongol)
	; 		(goal G-strat GV-krush)))
	=>
	(set-goal G-temp4 168194))
(defrule
	(goal G-temp4 168194)
	(nand	(building-type-count-total farm >= 5)
		(and	(building-type-count-total lumber-camp < 2)
			(building-type-count-total settlement < 3)))
	=>
	(build farm))
(defrule; dark age no food
	(current-age == dark-age)
	(unit-type-count villager-shepherd == 0)
	(unit-type-count villager-forager == 0)
	(unit-type-count villager-hunter == 0)
	(building-type-count town-center >= 1)
	(game-time s:> SN-emergency-mill-time)
	(idle-farm-count == 0)
	(up-pending-objects c: farm < 2)
	(can-build farm)
	=>
	(build farm))
(defrule; feudal age farms
	(goal G-build-order GV-feudal-war)
	(current-age == feudal-age)
	(up-pending-objects c: farm < 2)
	(or	(building-type-count-total lumber-camp >= 1)
		(building-type-count-total settlement >= 2))
	(building-type-count-total archery-range >= 2)
	(or	(building-type-count-total blacksmith > 0)
		(building-type-count-total farm < 8))
	(or	(building-type-count-total lumber-camp >= 2)
		(building-type-count-total settlement >= 3))
	(idle-farm-count < 2)
	(or	(idle-farm-count == 0)
		(unit-type-count villager-forager >= 5))
	(can-build farm)
	=>
	(build farm))
(defrule; feudal age farms
	(current-age == feudal-age)
	(up-pending-objects c: farm < 2)
	(or	(building-type-count-total lumber-camp >= 1)
		(building-type-count-total settlement >= 2))
	(building-type-count-total blacksmith > 0)
	(or	(building-type-count-total farm < 12)
		(or	(building-type-count-total lumber-camp >= 1)
			(building-type-count-total settlement >= 2)))
	(idle-farm-count == 0)
	(can-build farm)
	(up-compare-goal G-strat != GV-klewproper)
	(or	(up-compare-goal G-strat != GV-krush)
		(building-type-count-total stable >= 2))
	=>
	(build farm))
(defrule
	(current-age >= castle-age)
	=>
	(up-get-player-fact my-player-number building-type-count town-center G-temp1)
	(up-modify-goal G-temp1 c:max 2))
(defrule; castle and imp farming
	(current-age >= castle-age)
	(up-pending-objects c: farm g:< G-temp1)
	(idle-farm-count < 2)
	(nand	(goal G-strat GV-klewproper)
		(building-type-count-total barracks < 2))
	(can-build farm)
	=>
	(build farm))

(defrule; failsafe
	(idle-farm-count == 0)
	(up-pending-objects c: farm == 0)
	(up-compare-goal G-free-wood > 375)
	(nand	(goal G-age GV-upcastle)
		(up-compare-goal G-free-wood < 900))
	(can-build farm)
	=>
	(build farm))

