; =============================
; ==== DEFENSIVE BUILDINGS ====
; =============================
; ==== DEFENSIVE TOWER ====
; == FC tower ==
(defrule
	(up-compare-goal G-age <= GV-upcastle)
	(goal G-maptype GV-land-open)
	(or	(goal G-position GV-flank)
		(and	(goal G-starting-tcs 0)
			(up-compare-const ALLYCOUNT == 0)))
	(building-type-count-total tower-class == 0)
	(up-compare-goal G-build-order >= GV-fast-castle)
;	(up-timer-status T-clicked-up != timer-triggered); at latest 60s before reaching castle
	(players-military-population target-player >= 3)
;	(not	(town-under-attack))
	(or	(can-build watch-tower)
		(can-build donjon))
	=>
	(set-goal G-temp8 237694))

#load-if-defined UP-ALLY-IN-GAME
#load-if-defined FORTIFIED-CLEARING-MAP
(defrule
	(goal G-position GV-flank)
	(building-type-count-total tower-class < 1)
	(up-compare-goal G-age <= GV-upcastle)
	(up-compare-goal G-build-order >= GV-fast-castle)
	(players-military-population target-player >= 3)
	(or	(can-build watch-tower)
		(can-build donjon))
	; (wall-completed-percentage 2 < 100)
	; (wall-completed-percentage 1 < 100)
	=>
	(up-copy-point P-placement-x P-self-x)
	(up-get-point position-flank P-temp-x)
	(up-get-point position-center P-x)
	(up-modify-goal G-temp2 c:= PLAYERCOUNT)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-temp1 c:= 16)
	(up-modify-goal G-temp1 g:- G-temp2)
	(up-modify-goal G-temp1 c:+ 10)
	(up-modify-goal G-temp3 c:= -19)
	(up-modify-goal G-temp3 c:+ PLAYERCOUNT)
	(up-lerp-tiles P-placement-x P-temp-x g: G-temp1); 10 4v4, 14 3v3, 18 2v2
	(up-lerp-tiles P-placement-x P-x g: G-temp3); -11 4v4, -13 3v3, -15 2v2
	(up-modify-goal G-tower-count c:+ 1)
;	(up-chat-data-to-player my-player-number "building tower # %d" g: G-tower-count)
;	(up-send-flare P-placement-x)
	(up-set-target-point P-placement-x)
	(set-strategic-number sn-placement-zone-size 1)
	(set-strategic-number sn-placement-fail-delta 0); -1
	(up-build place-point 0 c: TOWER))
#end-if #end-if

; == feudal war tower ==
(defrule
	(building-type-count-total tower-class == 0)
	(goal G-build-order GV-feudal-war)
	(up-compare-goal G-age <= GV-upcastle)
	(up-timer-status T-clicked-up != timer-triggered)
	(strategic-number SN-raw-superiority < TOWER-THRESHOLD)
	(players-military-population target-player >= 5)
	(or	(players-military-population target-player >= 7)
		(and	(military-population < 3)
			(and	(players-unit-type-count target-player militiaman-line < 1)
				(players-unit-type-count target-player champi-line < 2))))
;	(not	(town-under-attack))
	(or	(can-build watch-tower)
		(can-build donjon))
	=>
	(set-goal G-temp8 237694))

; == more towers ==
(defrule
	(goal G-tower-defence 1)
	(up-compare-goal G-age <= GV-upcastle)
;	(up-timer-status T-clicked-up != timer-triggered); at latest 60s before reaching castle
	(or	(up-compare-goal G-tower-count < 6)
		(building-type-count-total tower-class < 6))
	(or	(can-build watch-tower)
		(can-build donjon))
	=>
	(set-goal G-temp8 237694))

; == DETERMINE TOWER POSITION ==
(defrule
	(or	(not (goal G-temp8 237694))
		(or	(up-pending-placement c: watch-tower)
			(up-pending-placement c: donjon)))
	(up-compare-goal J-tower > 0)
	=>
	(up-jump-direct g: J-tower))
;-----------------------------------------------------------------------
(defrule
	(up-compare-goal J-tower > 0)
	=>
	(set-goal G-temp0 0); # of current dropsite checked
;	(set-goal G-temp1 -1); ID of ditto
	(set-goal G-temp2 -1); distance from position-enemy of ditto
;	(set-goal G-temp3 -1); ID of most fwd dropsite
	(set-goal G-temp4 255); distance from position-enemy of ditto
	(set-goal P-placement-x -1); tower coords of ditto
	(set-goal P-placement-y -1)
	(up-get-point position-enemy P-temp-x)
	(set-strategic-number sn-focus-player-number my-player-number)
	(up-full-reset-search)
	(up-find-local c: town-center c: 8)
	(up-find-local c: mining-camp c: 8)
	(up-find-local c: lumber-camp c: 8)
	(up-find-local c: mill c: 8)
;	(up-find-local c: mule-cart c: 8)
	(up-find-local c: settlement c: 12)
	(up-get-search-state G-local-total))
;	(up-chat-data-to-player my-player-number "dropsites found: %d" g: G-local-total))
(defrule;~~~~new dropsite
	(up-compare-goal J-tower > 0)
	(up-compare-goal G-temp0 g:< G-local-total)
	(up-set-target-object search-local g: G-temp0)
	=>
;	(up-get-object-data object-data-id G-temp1)
	(up-get-point position-object P-object-x)
	(up-get-point-distance P-object-x P-temp-x G-temp2))
(defrule; if TC
	(up-compare-goal J-tower > 0)
	(up-compare-goal G-temp0 g:< G-local-total)
	(up-set-target-object search-local g: G-temp0)
	(up-object-data object-data-type == town-center)
	=>
;	(up-chat-data-to-player my-player-number "checking TC #%d" g: G-temp0)
	(up-lerp-tiles P-object-x P-temp-x c: 9)
	(up-set-target-point P-object-x)
	(up-reset-search 0 0 1 1)
	(up-filter-distance c: 0 c: 4)
	(up-find-remote c: tower-class c: 1)
	(up-filter-status c: status-pending c: list-active)
	(up-find-status-remote c: tower-class c: 1)
	(up-filter-status c: status-ready c: list-active)
	(up-jump-rule 1))
(defrule; else
	(up-compare-goal J-tower > 0)
	(up-compare-goal G-temp0 g:< G-local-total)
	(up-set-target-object search-local g: G-temp0)
	=>
;	(up-chat-data-to-player my-player-number "checking dropsite #%d" g: G-temp0)
	(up-lerp-tiles P-object-x P-temp-x c: 2)
	(up-set-target-point P-object-x)
	(up-reset-search 0 0 1 1)
	(up-filter-distance c: 0 c: 3)
	(up-find-remote c: tower-class c: 1)
	(up-filter-status c: status-pending c: list-active)
	(up-find-status-remote c: tower-class c: 1)
	(up-filter-status c: status-ready c: list-active))
(defrule
	(up-compare-goal J-tower > 0)
	(up-compare-goal G-temp0 g:< G-local-total)
	(up-set-target-object search-local g: G-temp0)
	(not (up-set-target-object search-remote c: 0))
	(up-compare-goal G-temp2 g:< G-temp4)
	=>
;	(chat-to-player my-player-number "more fwd")
;	(up-modify-goal G-temp3 g:= G-temp1)
	(up-modify-goal G-temp4 g:= G-temp2)
	(up-copy-point P-placement-x P-object-x))
(defrule
	(up-compare-goal J-tower > 0)
	(up-compare-goal G-temp0 g:< G-local-total)
	=>
	(up-modify-goal G-temp0 c:+ 1))
(defrule
	(up-compare-goal J-tower > 0)
	(up-compare-goal G-temp0 g:< G-local-total)
	=>
	(up-jump-rule -6)); next dropsite~~~~
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-get-rule-id J-tower)
	(disable-self))
; == BUILD THE TOWER ==
(defrule
	(up-compare-goal J-tower > 0)
	(goal G-temp8 237694)
	(or	(can-build watch-tower)
		(can-build donjon))
	=>
	(up-modify-goal G-tower-count c:+ 1)
;	(up-chat-data-to-player my-player-number "building tower # %d" g: G-tower-count)
;	(up-send-flare P-placement-x)
	(up-set-target-point P-placement-x)
	(set-strategic-number sn-placement-zone-size 1)
	(set-strategic-number sn-placement-fail-delta 0); -1
	(up-build place-point 0 c: TOWER))

; ==== CASTLE ====
(defrule
	(or	(goal G-strat GV-cdrop)
		(goal G-strat GV-cdropproper))
	(building-type-count-total castle == 0)
	=>
	(up-add-object-cost c: castle c: 1))
#load-if-defined GOLD-RUSH-MAP
(defrule; gold rush castle
	(can-build castle)
;	(or	(not	(town-under-attack))
;		(or	(goal G-strat GV-cdrop)
;			(goal G-strat GV-cdropproper)))
	=>
	(up-modify-goal G-temp1 g:= G-mapsize)
	(up-modify-goal G-temp1 c:/ 12)
	(up-get-point position-center P-placement-x)
	(up-lerp-tiles P-placement-x P-self-x g: G-temp1)
	(up-get-point position-enemy P-temp-x)
	(up-get-fact building-type-count castle G-temp2)
	(up-modify-goal G-temp2 c:* 6)
	(up-lerp-tiles P-placement-x P-temp-x g: G-temp2)
	(up-set-target-point P-placement-x)
	(set-strategic-number sn-placement-zone-size 3)
	(up-build place-point 0 c: castle))
#else
(defrule
	(can-build castle)
	(or	(or	(nand	(town-under-attack)
				(strategic-number sn-maximum-town-size <= 40))
			(strategic-number SN-raw-superiority >= 70))
		(or	(goal G-strat GV-cdrop)
			(goal G-strat GV-cdropproper)))
	=>
	(set-goal G-temp7 916642))
(defrule
	(goal G-temp7 916642)
	=>
	(set-strategic-number sn-placement-zone-size 3)
	(set-strategic-number sn-placement-fail-delta 1)
	(up-copy-point P-placement-x P-self-x)
	(up-get-point position-enemy P-temp-x)
	(up-lerp-tiles P-placement-x P-temp-x c: 12)
	(up-set-target-point P-placement-x)
	(up-build place-point 0 c: castle)
	(up-jump-rule 1))
(defrule
	(can-build castle)
	=>
	(set-strategic-number sn-placement-zone-size 10)
	(set-strategic-number sn-placement-fail-delta 1)
	(up-copy-point P-placement-x P-self-x)
	(up-get-point position-center P-temp-x)
	(up-lerp-tiles P-placement-x P-temp-x c: 5)
	(up-set-target-point P-placement-x)
	(up-build place-point 0 c: castle))
#end-if

