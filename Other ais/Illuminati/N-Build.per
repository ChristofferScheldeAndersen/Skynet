; == REBUILD ==
(defrule
	(up-compare-goal G-rebuild >= 2)
	(can-build-with-escrow town-center)
	=>
	(set-goal G-temp1 0)
	(set-goal G-temp2 0)
	(set-goal G-temp3 1)
	(set-strategic-number sn-focus-player-number 1))
(defrule;~~new player~~
	(up-compare-goal G-rebuild >= 2)
	(can-build-with-escrow town-center)
	(player-in-game focus-player)
	(stance-toward focus-player ally)
	(strategic-number sn-focus-player-number c:!= my-player-number)
	(up-get-focus-fact population 0 G-temp2)
	(up-compare-goal G-temp2 g:> G-temp1)
	=>
	(up-modify-goal G-temp1 g:= G-temp2)
	(up-modify-goal G-temp3 s:= sn-focus-player-number))
(defrule
	(up-compare-goal G-rebuild >= 2)
	(can-build-with-escrow town-center)
	(strategic-number sn-focus-player-number < PLAYERCOUNT)
	=>
	(up-modify-sn sn-focus-player-number c:+ 1)
	(up-jump-rule -2));~~~~next player
(defrule
	(up-compare-goal G-rebuild >= 2)
	(can-build-with-escrow town-center)
	=>
	(up-modify-sn sn-focus-player-number g:= G-temp3)
	(up-full-reset-search)
	(up-find-remote c: building-class c: 1)
	(up-set-target-object search-remote c: 0)
	(up-get-point position-object P-placement-x)
	(up-get-point position-enemy P-temp-x)
	(up-lerp-tiles P-placement-x P-temp-x c: -20))
(defrule
	(up-compare-goal G-rebuild >= 2)
	(can-build-with-escrow town-center)
	(up-pending-objects c: town-center == 0)
	=>
	(chat-to-player my-player-number "new tc")
	(up-set-target-point P-placement-x)
	(set-strategic-number sn-placement-zone-size 30)
	(set-strategic-number sn-placement-fail-delta -1)
	(release-escrow wood)
	(release-escrow stone)
	(up-build place-point 0 c: town-center)
	(set-strategic-number sn-percent-building-cancellation 0)
;	(up-delete-objects c: town-center c: 32767)
	(set-goal G-rebuild 3))

(defrule
	(up-compare-goal G-rebuild >= 2)
	(not	(can-build-with-escrow town-center))
	=>
	(up-add-object-cost c: town-center c: 5))

(defrule
	(up-compare-goal G-rebuild >= 2)
	(up-compare-goal J-build-per > 0)
	=>
	(up-jump-direct g: J-build-per))

; ================
; ==== HOUSES ====
; ================
#load-if-not-defined HUN-CIV
(defrule
	(up-pending-objects c: house == 0)
	(housing-headroom < 2)
	(population-headroom > 3)
	(unit-type-count villager <= 5)
	(can-build house)
	(building-type-count town-center >= 1)
	=>
	(build house))
(defrule
	(up-compare-goal G-saving-wood != 1)
	(up-pending-objects c: house < 2)
	(or	(up-pending-objects c: house == 0)
		(housing-headroom < 0))
	(housing-headroom < 4)
	(population-headroom > 0)
	(can-build house)
	(nand	(building-type-count-total house >= 3)
		(and	(goal G-strat GV-klewproper)
			(up-compare-goal G-age < GV-upcastle)))
	(building-type-count town-center >= 1)
	=>
	(build house))
(defrule; limited when saving wood for build order items
	(goal G-saving-wood 1)
	(up-pending-objects c: house < 2)
	(or	(up-pending-objects c: house == 0)
		(housing-headroom < 0))
	(housing-headroom < 3)
	(or	(housing-headroom < 1)
		(goal G-build-order GV-feudal-war))
	(population-headroom > 0)
	(can-build house)
	=>
	(set-goal G-temp8 17151311))
(defrule
	(goal G-temp8 17151311)
	(nand	(building-type-count-total house >= 3)
		(and	(goal G-strat GV-klewproper)
			(up-compare-goal G-age < GV-upcastle)))
	(building-type-count-total town-center >= 1)
	=>
	(build house))
(defrule
	(up-pending-objects c: house < 2)
	(or	(up-pending-objects c: house < 1)
		(population > 60))
	(or	(current-age >= castle-age)
		(or	(building-type-count-total archery-range >= 2)
			(building-type-count-total barracks >= 2)))
	(housing-headroom < 8)
	(population-headroom > 0)
	(can-build house)
	(building-type-count town-center >= 1)
	=>
	(build house))
(defrule
	(up-pending-objects c: house < 2)
	(current-age >= castle-age)
	(population > 100)
	(housing-headroom < 12)
	(population-headroom > 0)
	(can-build house)
	(building-type-count town-center >= 1)
	=>
	(build house))
#end-if
; =======================
; ==== ECO BUILDINGS ====
; =======================
; ==== TOWN CENTRES ====
(defrule
	(goal G-strat GV-boom)
	(up-compare-goal G-desiredtcs < 4)
	(nand	(goal G-maptype GV-land-open)
		(or	(civ-selected mayan)
			(or	(civ-selected aztec)
				(civ-selected incan))))
	=>
	(up-modify-goal G-desiredtcs c:+ 1)
	(disable-self))
(defrule
	(up-compare-goal G-start-boom < 1)
	(current-age >= castle-age)
	(nand	(goal G-strat-class1 monastery-class)
		(building-type-count-total monastery < 2))
	(nand	(goal G-strat-rax 1)
		(building-type-count-total barracks < 2))
	(nand	(goal G-strat-range 1)
		(building-type-count-total archery-range < 2))
	(nand	(goal G-strat-stable 1)
		(building-type-count-total stable < 1)); needs another or here when we want 2 stables asap
	(nand	(goal G-strat-workshop 1)
		(building-type-count-total siege-workshop < 2))
	=>
	(set-goal G-start-boom 1)
	(disable-self))

(defrule
	(current-age >= castle-age)
	(up-compare-goal G-boom-priority >= 1); 2
	(building-type-count-total town-center g:< G-desiredtcs)
	=>
	(up-add-object-cost c: town-center c: 2))
(defrule
	(goal G-start-boom 1)
	(can-build town-center)	
	(building-type-count-total town-center g:< G-desiredtcs)
	(or	(nand	(building-type-count-total castle < 1)
			(or	(goal G-strat GV-unique)
				(or	(goal G-strat GV-cdrop)
					(goal G-strat GV-cdropproper))))
		(stone-amount >= 750))
	(not	(up-pending-placement c: town-center))
	=>
	(set-goal G-temp5 64546))
(defrule
	(goal G-start-boom 1)
	(up-compare-goal G-boom-priority >= 2); 3
	(up-can-build G-zero c: town-center)	
	(building-type-count-total town-center g:< G-desiredtcs)
	(or	(nand	(building-type-count-total castle < 1)
			(or	(goal G-strat GV-unique)
				(or	(goal G-strat GV-cdrop)
					(goal G-strat GV-cdropproper))))
		(stone-amount >= 750))
	(not	(up-pending-placement c: town-center))
	=>
	(release-escrow wood)
	(set-goal G-temp5 64546))
(defrule
	(goal G-start-boom 1)
	(up-compare-goal G-boom-priority >= 3)
	(building-type-count-total town-center g:< G-desiredtcs)
	(or	(nand	(building-type-count-total castle < 1)
			(or	(goal G-strat GV-unique)
				(or	(goal G-strat GV-cdrop)
					(goal G-strat GV-cdropproper))))
		(stone-amount >= 750))
	(stone-amount >= 100)
	(not	(goal G-temp5 64546))
	(not	(up-pending-placement c: town-center))
	=>
	(up-modify-escrow wood c:max 275))
(defrule
	(goal G-temp5 64546)
	(or	(building-type-count-total town-center >= 3); 4th tc on wood
		(and	(cc-players-unit-type-count 0 gold-mine g:<= G-min-gaia-gold)
			(cc-players-unit-type-count 0 stone-mine g:<= G-min-gaia-stone)))
	=>
	(set-goal G-temp5 0)
	(set-strategic-number sn-town-center-placement lumber-camp)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(build town-center))

; - TC placement -
(defrule
	(goal G-temp5 64546)
	=>
	(set-goal G-temp1 0); current camp/tc
	(set-goal G-temp2 570); indirect goal to store id
	(up-get-point position-enemy P-x)
	(up-modify-goal P-x g:+ P-team-opposite-x)
	(up-modify-goal P-y g:+ P-team-opposite-y)
	(up-modify-goal P-x c:/ 2)
	(up-modify-goal P-y c:/ 2)
	(up-full-reset-search)
	(up-find-local c: town-center c: 10)
	(up-find-local c: MINING-CAMP c: 80)
	(up-filter-status c: status-pending c: list-active)
	(up-find-status-local c: town-center-foundation c: 3)
	(up-find-status-local c: MINING-CAMP c: 1)
	(up-get-search-state G-local-total)
	(up-set-target-point P-self-x)
	(up-filter-include -1 -1 -1 on-mainland)
	(up-filter-distance c: -1 s: sn-camp-max-distance)
	(up-filter-status c: status-resource c: list-active)
	(up-find-resource c: gold c: 200)
	(up-find-resource c: stone c: 100)
	(up-remove-objects search-remote object-data-carry < 250))
(defrule; excluded by previous attempts
	(goal G-temp5 64546)
	=>
	(up-remove-objects search-remote object-data-id g:= 570)
	(up-remove-objects search-remote object-data-id g:= 571)
	(up-remove-objects search-remote object-data-id g:= 572)
	(up-remove-objects search-remote object-data-id g:= 573)
	(up-remove-objects search-remote object-data-id g:= 574)
	(up-remove-objects search-remote object-data-id g:= 575)
	(up-remove-objects search-remote object-data-id g:= 576)
	(up-remove-objects search-remote object-data-id g:= 577)
	(up-remove-objects search-remote object-data-id g:= 578)
	(up-remove-objects search-remote object-data-id g:= 579)
	(up-remove-objects search-remote object-data-id g:= 580)
	(up-remove-objects search-remote object-data-id g:= 581)
	(up-remove-objects search-remote object-data-id g:= 582)
	(up-remove-objects search-remote object-data-id g:= 583)
	(up-remove-objects search-remote object-data-id g:= 584)
	(up-remove-objects search-remote object-data-id g:= 585)
	(up-remove-objects search-remote object-data-id g:= 586)
	(up-remove-objects search-remote object-data-id g:= 587)
	(up-remove-objects search-remote object-data-id g:= 588)
	(up-remove-objects search-remote object-data-id g:= 589)
	(up-remove-objects search-remote object-data-id g:= 590)
	(up-remove-objects search-remote object-data-id g:= 591)
	(up-remove-objects search-remote object-data-id g:= 592)
	(up-remove-objects search-remote object-data-id g:= 593)
	(up-remove-objects search-remote object-data-id g:= 594)
	(up-remove-objects search-remote object-data-id g:= 595)
	(up-remove-objects search-remote object-data-id g:= 596)
	(up-remove-objects search-remote object-data-id g:= 597)
	(up-remove-objects search-remote object-data-id g:= 598)
	(up-remove-objects search-remote object-data-id g:= 599))
(defrule
	(goal G-temp5 64546)
	(up-compare-goal G-temp1 g:< G-local-total)
	(up-set-target-object search-local g: G-temp1)
	(or	(up-object-data object-data-type == town-center)
		(up-object-data object-data-type == town-center-foundation))
	=>
	(up-get-point position-object P-temp-x)
	(up-set-target-point P-temp-x)
	(up-remove-objects search-remote object-data-distance c:< 10); ?
	(up-modify-goal G-temp1 c:+ 1)
	(up-jump-rule -1))
(defrule
	(goal G-temp5 64546)
	(up-compare-goal G-temp1 g:< G-local-total)
	(up-set-target-object search-local g: G-temp1)
	(up-object-data object-data-type == MINING-CAMP)
	=>
	(up-get-point position-object P-temp-x)
	(up-set-target-point P-temp-x)
	(up-remove-objects search-remote object-data-distance c:< 4); ?
	(up-modify-goal G-temp1 c:+ 1)
	(up-jump-rule -2))
(defrule
	(goal G-temp5 64546)
	=>
	(set-goal G-temp5 64547)
	(up-set-target-point P-x)
	(up-clean-search search-remote object-data-distance search-order-desc))
(defrule
	(goal G-temp5 64547)
	(up-set-target-object search-remote c: 0)
	=>
	(set-goal G-temp1 64548)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(up-get-point position-object P-placement-x)
	(up-set-target-point P-placement-x)
	(set-strategic-number sn-placement-zone-size 2)
	(set-strategic-number sn-placement-fail-delta 0)
	; (chat-to-all "building TC here")
	; (up-send-flare P-placement-x)
	(up-build place-point 0 c: town-center)
	(up-jump-rule 1))
(defrule; failsafe
	(goal G-temp5 64547)
	=>
	; (chat-local-to-self "TC placement failsafe: build it on wood")
	(set-strategic-number sn-town-center-placement lumber-camp)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(build town-center))

(defrule
	(goal G-temp5 64548)
	(up-compare-goal G-temp2 <= 599)
	=>
	(up-get-indirect-goal g: G-temp2 G-temp3))
(defrule
	(goal G-temp5 64548)
	(up-compare-goal G-temp2 <= 599)
	(up-compare-goal G-temp3 != -1)
	=>
	(up-modify-goal G-temp2 c:+ 1)
	(up-jump-rule -2))
(defrule; save id to exclude
	(goal G-temp5 64548)
	(up-compare-goal G-temp2 <= 599)
	=>
	(up-set-target-object search-remote c: 0)
	(up-get-object-data object-data-id G-temp4)
	(up-set-indirect-goal g: G-temp2 g:= G-temp4)
	(up-modify-goal G-temp2 c:+ 1))
(defrule; and the previous ID
	(goal G-temp5 64548)
	(up-compare-goal G-temp2 <= 599)
	=>
	(up-modify-goal G-temp4 c:- 1))
(defrule
	(goal G-temp5 64548)
	(up-compare-goal G-temp2 <= 599)
	(up-compare-goal G-temp4 g:!= 570)
	(up-compare-goal G-temp4 g:!= 571)
	(up-compare-goal G-temp4 g:!= 572)
	(up-compare-goal G-temp4 g:!= 573)
	(up-compare-goal G-temp4 g:!= 574)
	(up-compare-goal G-temp4 g:!= 575)
	(up-compare-goal G-temp4 g:!= 576)
	(up-compare-goal G-temp4 g:!= 577)
	(up-compare-goal G-temp4 g:!= 578)
	(up-compare-goal G-temp4 g:!= 579)
	(up-compare-goal G-temp4 g:!= 580)
	(up-compare-goal G-temp4 g:!= 581)
	(up-compare-goal G-temp4 g:!= 582)
	(up-compare-goal G-temp4 g:!= 583)
	(up-compare-goal G-temp4 g:!= 584)
	(up-compare-goal G-temp4 g:!= 585)
	(up-compare-goal G-temp4 g:!= 586)
	(up-compare-goal G-temp4 g:!= 587)
	(up-compare-goal G-temp4 g:!= 588)
	(up-compare-goal G-temp4 g:!= 589)
	(up-compare-goal G-temp4 g:!= 590)
	(up-compare-goal G-temp4 g:!= 591)
	(up-compare-goal G-temp4 g:!= 592)
	(up-compare-goal G-temp4 g:!= 593)
	(up-compare-goal G-temp4 g:!= 594)
	(up-compare-goal G-temp4 g:!= 595)
	(up-compare-goal G-temp4 g:!= 596)
	(up-compare-goal G-temp4 g:!= 597)
	=>
	(up-set-indirect-goal g: G-temp2 g:= G-temp4)
	(up-modify-goal G-temp2 c:+ 1))
(defrule; and the next ID
	(goal G-temp5 64548)
	(up-compare-goal G-temp2 <= 599)
	=>
	(up-modify-goal G-temp4 c:+ 2))
(defrule
	(goal G-temp5 64548)
	(up-compare-goal G-temp2 <= 599)
	(up-compare-goal G-temp4 g:!= 570)
	(up-compare-goal G-temp4 g:!= 571)
	(up-compare-goal G-temp4 g:!= 572)
	(up-compare-goal G-temp4 g:!= 573)
	(up-compare-goal G-temp4 g:!= 574)
	(up-compare-goal G-temp4 g:!= 575)
	(up-compare-goal G-temp4 g:!= 576)
	(up-compare-goal G-temp4 g:!= 577)
