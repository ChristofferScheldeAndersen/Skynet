	(can-build monastery)
	=>
	(set-strategic-number sn-maximum-town-size 6)
	(build monastery))
(defrule
	(goal G-strat GV-monkflood)
	(building-type-count-total monastery < 5)
	(or	(building-type-count-total monastery < 4)
		(up-research-status c: imperial-age >= research-pending))
	(or	(building-type-count-total town-center > 2)
		(building-type-count-total monastery < 3))
	(can-build monastery)
	=>
	(set-strategic-number sn-maximum-town-size 6)
	(build monastery))
(defrule
	(building-type-count-total monastery < 1)
	(or	(building-type-count-total town-center > 2)
		(game-time > 1500)); 25min
	(can-build monastery)
	(nand	(building-type-count-total siege-workshop == 0)
		(or	(goal G-ram 1)
			(goal G-mangonel 1)))
	(or	(building-type-count-total town-center >= 2)
		(stone-amount < 100))
	=>
	(set-strategic-number sn-maximum-town-size 8)
	(build monastery))
(defrule
	(goal G-maptype GV-land-walled)
	(building-type-count-total monastery < 1)
	(cc-players-unit-type-count 0 relic >= 3)
	(or	(cc-players-unit-type-count 0 relic >= 5)
		(up-compare-const ALLYCOUNT < 2))
	(building-type-count-total town-center >= 2)
	(or	(building-type-count-total town-center >= 3)
		(or	(stone-amount < 100)
			(up-compare-goal G-strat != GV-boom)))
	(can-build monastery)
	=>
	(set-strategic-number sn-maximum-town-size 8)
	(build monastery))

