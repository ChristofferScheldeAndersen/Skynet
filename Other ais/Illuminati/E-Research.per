(defrule
	(can-research ri-coinage)
	(current-age == imperial-age)
	(population g:> G-189-pop)
	(player-in-game any-ally)
	=>
	(research ri-coinage))
(defrule
	(can-research ri-banking)
	(current-age == imperial-age)
	(population g:>= G-189-pop)
	(player-in-game any-ally)
	=>
	(research ri-banking))
#end-if
(defrule
	(or	(population g:> G-184-pop)
		(population > 184))
	(can-research ri-guilds)
	=>
	(research ri-guilds))

