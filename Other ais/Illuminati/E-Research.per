(defrule
	(up-compare-goal G-rebuild >= 2)
	(up-compare-goal J-research-per > 0)
	=>
	(up-jump-direct g: J-research-per))

; ======================
; ==== ECO RESEARCH ====
; ======================
(defrule
	(can-research ri-loom)
	(or	(and	(unit-type-count villager >= 20)
			(or	(goal G-build-order GV-feudal-war)
				(unit-type-count-total villager g:>= G-fc-vills)))
		(or	(food-amount < 30); triggers immediately for chinese
			(or	(housing-headroom <= 0); and mayans
				(civ-selected gothic)))); and goths
	=>
	(research ri-loom))
(defrule
	(research-available ri-loom)
	(unit-type-count-total villager >= 20)
	(up-modify-goal G-temp1 g:= G-fc-vills)
	(up-modify-goal G-temp1 c:- 1)
	(or	(goal G-build-order GV-feudal-war)
		(unit-type-count-total villager g:>= G-temp1))
;	(or	(unit-type-count-total villager >= 15)
;		(dropsite-min-distance live-boar >= 20))
	=>
	(set-strategic-number sn-enable-training-queue 0)
	(disable-self))
(defrule
	(unit-type-count-total villager < 25)
	(up-research-status c: ri-loom >= research-pending)
	=>
	(set-strategic-number sn-enable-training-queue 1)
	(disable-self))

; == AGE UP ==
(defrule; feudal
	(can-research feudal-age)
	(or	(goal G-force-tc-idle 1)
		(unit-type-count-total villager g:>= G-fc-vills))
	(or	(goal G-force-tc-idle 1)
		(or	(up-compare-goal G-build-order != GV-slow-castle)
			(unit-type-count-total villager g:>= G-sc-vills)))
	=>
	(research feudal-age)
	(chat-to-allies "up feudal"))
(defrule; castle
	(can-research-with-escrow castle-age)
	=>
	(release-escrow food)
	(release-escrow gold)
	(research castle-age)
	(chat-to-allies "up castle"))
(defrule
	(up-research-status c: castle-age < research-pending)
	(up-research-status c: ri-wheel-barrow >= research-pending)
	(up-compare-goal G-build-order < GV-fish-castle)
	(or	(building-type-count-total farm >= 16)
		(food-amount > 400))
	(or	(or	(strategic-number SN-raw-superiority >= 105)
			(building-type-count TOWER >= 1))
		(goal G-escrowing castle-age))
	(or	(civilian-population >= 33)
		(civilian-population g:>= G-desired-vills))
	=>
	(set-goal G-temp5 598710))
(defrule
	(goal G-temp5 598710)
	=>
	(set-goal G-escrowing castle-age)
	(up-add-research-cost c: castle-age c: 1)
	(up-modify-escrow food c:max 800)
	(set-goal G-temp5 598712))
(defrule
	(goal G-temp5 598712)
	(food-amount > 300)
	=>
	(up-modify-escrow gold c:max 200))
(defrule
	(up-research-status c: castle-age < research-pending)
	(goal G-age GV-feudal)
	(up-compare-goal G-build-order >= GV-fish-castle)
	=>
	(set-goal G-escrowing castle-age)
	(up-add-research-cost c: castle-age c: 1)
	(up-modify-escrow food c:max 800)
	(up-modify-escrow gold c:max 200))
(defrule; imp
	(can-research-with-escrow imperial-age)
	=>
	(release-escrow food)
	(release-escrow gold)
	(research imperial-age)
	(chat-to-allies "up imp"))
#load-if-defined BYZANTINE-CIV
(defrule
	(up-research-status c: imperial-age < research-pending)
	(up-research-status c: ri-hand-cart >= research-pending)
	(or	(civilian-population >= 80)
		(population g:>= G-max-vills))
	(or	(civilian-population >= 100)
		(or	(strategic-number SN-superiority >= 90)
			(population g:>= G-160-pop)))
	(strategic-number SN-superiority >= 50)
	=>
	(set-goal G-escrowing imperial-age)
	(up-add-research-cost c: imperial-age c: 1)
	(up-modify-escrow food c:max 667)
	(up-modify-escrow gold c:max 536))
#else
(defrule
	(up-research-status c: imperial-age < research-pending)
	(up-research-status c: ri-hand-cart >= research-pending)
	(or	(or	(civilian-population >= 90)
			(and	(civ-selected bengalis)
				(civilian-population >= 86)))
		(population g:>= G-160-pop))
	(or	(or	(civilian-population >= 105)
			(and	(civ-selected bengalis)
				(civilian-population >= 99)))
		(or	(strategic-number SN-superiority >= 100)
			(population g:>= G-170-pop)))
	(strategic-number SN-superiority >= 60)
	=>
	(set-goal G-escrowing imperial-age)
	(up-add-research-cost c: imperial-age c: 1)
	(up-modify-escrow food c:max 1000)
	(up-modify-escrow gold c:max 800))
#end-if

; == TC RESEARCH ==
(defrule
	(up-compare-goal G-force-tc-idle != 1)
	(nand	(up-compare-goal G-build-order >= GV-fish-castle)
		(goal G-age GV-feudal))
	(or	(unit-type-count villager > 31)
		(unit-type-count villager g:>= G-desired-vills))
	(up-can-research G-esc-state c: ri-wheel-barrow)
	=>
	(release-escrow food)
	(release-escrow wood)
	(research ri-wheel-barrow))
(defrule
	(up-research-status c: ri-wheel-barrow < research-pending)
	(research-available ri-wheel-barrow)
	(up-compare-goal G-force-tc-idle != 1)
;	(nand	(goal G-build-order GV-fast-castle)
;		(goal G-age GV-feudal))
	(or	(unit-type-count villager > 32)
		(unit-type-count villager g:>= G-desired-vills))
	(or	(food-amount < 175)
		(wood-amount < 50))
	=>
	(up-add-research-cost c: ri-wheel-barrow c: 1)
	(up-modify-escrow food c:max 175)
	(up-modify-escrow wood c:max 50))
(defrule
	(up-can-research G-esc-state c: ri-hand-cart)
	(or	(unit-type-count villager > 50)
		(unit-type-count villager g:>= G-desired-vills))
	=>
	(release-escrow food)
	(release-escrow wood)
	(research ri-hand-cart))
(defrule
	(or	(unit-type-count villager > 50)
		(unit-type-count villager g:>= G-desired-vills))
	(up-research-status c: ri-hand-cart < research-pending)
	(research-available ri-hand-cart)
	(or	(and	(building-type-count-total town-center >= 2)
			(strategic-number SN-superiority > 85))
		(food-amount >= 200))
	=>
	(up-add-research-cost c: ri-hand-cart c: 1)
	(up-modify-escrow food c:max 300)
	(up-modify-escrow wood c:max 200))
(defrule
	(up-research-status c: ri-wheel-barrow >= research-pending)
	(food-amount >= 125)
	(building-type-count town-center >= 2)
	(or	(unit-type-count villager >= 40)
		(unit-type-count villager g:>= G-desired-vills))
	(can-research ri-town-watch)
	=>
	(research ri-town-watch))
(defrule
	(up-research-status c: ri-hand-cart >= research-pending)
	(up-research-status c: imperial-age >= research-pending)
	(food-amount >= 400)
	(gold-amount >= 300)
	(building-type-count town-center >= 2)
	(or	(unit-type-count villager >= 60)
		(unit-type-count villager g:>= G-desired-vills))
	(can-research ri-town-patrol)
	=>
	(research ri-town-patrol))

; == FEUDAL ECO UPGRADES ==
(defrule
	(current-age == feudal-age)
	(up-compare-goal G-build-order < GV-fish-castle)
	(building-type-count-total archery-range > 1)
	=>
	(set-goal G-eco-research GV-feudal-techs)
	(disable-self))
(defrule
	(up-compare-goal G-eco-research >= GV-feudal-techs)
	(nand	(goal G-strat GV-cdrop)
		(dropsite-min-distance stone > 3))
	(unit-type-count villager-stone >= 1)
	(or	(unit-type-count villager-stone >= 6)
		(population g:> G-184-pop))
	(can-research ri-stone-mining); has priority because of castle drop strats
	=>
	(research ri-stone-mining))
(defrule
	(up-compare-goal G-eco-research >= GV-feudal-techs)
	(nand	(or	(goal G-strat GV-cdrop)
			(goal G-strat GV-cdropproper))
		(or	(dropsite-min-distance stone > 3)
			(up-research-status c: ri-stone-mining < research-pending)))
	(can-research ri-double-bit-axe)
	=>
	(research ri-double-bit-axe))
(defrule
	(up-compare-goal G-build-order < GV-fish-castle)
	(can-research ri-double-bit-axe)
	(or	(building-type-count-total archery-range > 0)
		(and	(goal G-archers 0)
			(goal G-skirms 0)))
	=>
	(research ri-double-bit-axe))
(defrule
	(goal G-tower-defence 1)
	(up-can-research G-esc-state c: ri-double-bit-axe)
	=>
	(up-research G-esc-state c: ri-double-bit-axe))
(defrule
	(up-compare-goal G-eco-research >= GV-feudal-techs)
	(up-research-status c: ri-double-bit-axe != research-available)
	(unit-type-count villager-gold >= 1)
	(or	(unit-type-count villager-gold >= 5)
		(population g:> G-184-pop))
	(can-research ri-gold-mining)
	(nand	(or	(goal G-strat GV-cdrop)
			(goal G-strat GV-cdropproper))
		(dropsite-min-distance stone > 3))
	=>
	(research ri-gold-mining))
(defrule
	(up-compare-goal G-eco-research >= GV-feudal-techs)
	(or	(up-research-status c: ri-gold-mining != research-available)
		(building-type-count-total farm >= 7))
	(can-research ri-horse-collar)
	(nand	(goal G-strat GV-klewproper)
		(building-type-count-total farm < 4))
	(up-research-status c: ri-double-bit-axe >= research-pending)
	=>
	(research ri-horse-collar))
(defrule
	(up-compare-goal G-build-order < GV-fish-castle)
	(or	(or	(building-type-count-total archery-range > 1)
			(building-type-count-total blacksmith > 0))
		(or	(goal G-strat GV-ak47)
			(goal G-strat GV-trush)))
	(up-research-status c: ri-double-bit-axe >= research-pending)
	(can-research ri-horse-collar)
	=>
	(research ri-horse-collar))

; == CASTLE AGE ECO UPGRADES ==
(defrule
	(or	(or	(unit-type-count-total villager >= 40)
			(population g:> G-184-pop))
		(and	(goal G-strat GV-boom)
			(stone-amount < 100)))
	(current-age >= castle-age)
	=>
	(set-goal G-eco-research GV-castle-techs)
	(disable-self))
(defrule
	(goal G-eco-research GV-castle-techs)
	(up-can-research G-esc-state c: ri-bow-saw)
	=>
	(release-escrow food)
	(release-escrow wood)
	(research ri-bow-saw))
;(defrule
;	(goal G-eco-research GV-castle-techs)
;	(goal G-strat GV-boom)
;	(up-research-status c: ri-bow-saw < research-pending)
;	(research-available ri-bow-saw))
;	=>
;	(up-add-research-cost c: ri-bow-saw c: c: 1)
;	(up-modify-escrow food c:max 150)
;	(up-modify-escrow wood c:max 100))
(defrule
	(goal G-eco-research GV-castle-techs)
	(unit-type-count villager-gold >= 4)
	(or	(or	(unit-type-count villager-gold >= 9)
			(population g:> G-184-pop))
		(and	(up-research-status c: ri-bow-saw != research-available)
			(up-research-status c: ri-heavy-plow != research-available)))
	(can-research ri-gold-shaft-mining)
	=>
	(research ri-gold-shaft-mining))
(defrule
	(goal G-eco-research GV-castle-techs)
	(building-type-count-total farm >= 11)
	(up-can-research G-esc-state c: ri-heavy-plow)
	=>
	(release-escrow food)
	(release-escrow wood)
	(research ri-heavy-plow))
;(defrule
;	(goal G-eco-research GV-castle-techs)
;	(goal G-strat GV-boom)
;	(up-research-status c: ri-heavy-plow < research-pending)
;	(research-available ri-heavy-plow))
;	=>
;	(up-add-research-cost c: ri-heavy-plow c: c: 1)
;	(up-modify-escrow food c:max 125)
;	(up-modify-escrow wood c:max 125))
(defrule
	(goal G-eco-research GV-castle-techs)
	(building-type-count-total farm >= 20)
	(can-research ri-crop-rotation)
	=>
	(research ri-crop-rotation))

; == MARKET RESEARCHES ==
