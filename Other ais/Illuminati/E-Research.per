(defrule
	(up-can-research G-esc-state c: ri-siege-engineers)
	(or	(unit-type-count-total siege-weapon-class >= 6)
		(or	(goal G-mangonel 1)
			(or	(goal G-scorps 1)
				(goal G-bbc 1))))
	(or	(unit-type-count-total siege-weapon-class >= 4)
		(population g:>= G-184-pop))
	(or	(unit-type-count-total siege-weapon-class >= 7)
		(nand	(goal G-scorps 1)
			(up-research-status c: ri-heavy-scorpion == research-available)))
	(or	(unit-type-count-total siege-weapon-class >= 6)
		(nand	(goal G-mangonel 1)
			(or	(up-research-status c: ri-onager == research-available)
				(up-research-status c: ri-heavy-rocket-cart == research-available))))
	=>
	(release-escrow food)
	(release-escrow wood)
	(up-research G-esc-state c: ri-siege-engineers))
(defrule
	(research-available ri-siege-engineers)
	(building-type-count-total university > 0)
	(or	(unit-type-count-total siege-weapon-class >= 7)
		(or	(goal G-mangonel 1)
			(or	(goal G-scorps 1)
				(goal G-bbc 1))))
	(or	(unit-type-count-total siege-weapon-class >= 4)
		(population g:> G-184-pop))
	(or	(unit-type-count-total siege-weapon-class >= 8)
		(nand	(goal G-scorps 1)
			(up-research-status c: ri-heavy-scorpion == research-available)))
	(or	(unit-type-count-total siege-weapon-class >= 7)
		(nand	(goal G-mangonel 1)
			(or	(up-research-status c: ri-onager == research-available)
				(up-research-status c: ri-heavy-rocket-cart == research-available))))
	=>
	(up-add-research-cost c: ri-siege-engineers c: 1)
	(up-modify-escrow food c:max 500)
	(up-modify-escrow wood c:max 600))

