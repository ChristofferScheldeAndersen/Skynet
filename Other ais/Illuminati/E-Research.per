; == archer upgrades ==
(defrule
	(or	(goal G-archers 1)
		(or	(goal G-skirms 1)
			(or	(goal G-ca 1)
				(and	(goal G-uu 1)
					(or	(up-compare-const UU-CLASS == archery-class)
						(up-compare-const UU-CLASS == cavalry-archer-class))))))
	=>
	(set-goal G-temp8 12345)); archer attack ups
(defrule
	(or	(goal G-temp8 12345)
		(or	(goal G-hc 1)
			(and	(goal G-uu 1)
				(or	(up-compare-const UU-CLASS == archery-cannon-class)
					(up-compare-const UU-CLASS == cavalry-cannon-class)))))
	=>
	(set-goal G-temp9 12345)); archer armour ups
(defrule
	(or	(and	(goal G-temp8 12345)
			(up-compare-goal G-age >= GV-upcastle))
		(unit-type-count-total archery-class >= 4))
	(up-can-research G-esc-state c: ri-fletching)
	=>
	(release-escrow food)
	(release-escrow gold)
	(research ri-fletching))
(defrule
	(research-available ri-fletching)
	(building-type-count-total blacksmith > 0)
	(or	(and	(goal G-temp8 12345)
			(up-compare-goal G-age >= GV-upcastle))
		(unit-type-count-total archery-class >= 5))
	=>
	(up-add-research-cost c: ri-fletching c: 1)
	(up-modify-escrow food c:max 100)
	(up-modify-escrow gold c:max 50))
(defrule
	(or	(goal G-strat GV-xbows)
		(goal G-archers 1))
;	(unit-type-count-total archer >= 6)
	(up-compare-goal G-age >= GV-upcastle)
	(up-compare-goal G-age <= GV-castle)
	(or	(up-research-status c: ri-crossbow < research-pending)
		(up-research-status c: ri-bodkin-arrow < research-pending))
	(timer-triggered T-clicked-up)
	=>
	(set-goal G-escrowing ri-crossbow)
	(set-goal G-esc-state without-escrow)
	(up-modify-escrow food c:max 375)
	(up-modify-escrow gold c:max 200)
	(up-add-research-cost c: ri-crossbow c: 1)
	(up-add-research-cost c: ri-bodkin-arrow c: 1))
(defrule
	(goal G-escrowing ri-crossbow)
