(defrule
	(up-compare-goal G-strat != GV-monks-only)
	(can-research ri-conscription)
	=>
	(research ri-conscription))

#load-if-defined AZTEC-CIV
(defrule
	(up-can-research G-esc-state c: ri-garland-wars)
	(or	(or	(or	(goal G-eagles 1)
				(goal G-champs 1))
			(goal G-spears 1))
		(goal G-condo 1))
	(or	(unit-type-count-total infantry-class >= 14)
		(population g:>= G-184-pop))
	(nand	(goal G-skirms 1)
		(up-research-status c: ri-atlatl < research-pending))
	(up-research-status c: ri-blast-furnace >= research-pending)
	=>
	(release-escrow food)
	(release-escrow gold)
	(research ri-garland-wars))
(defrule
	(research-available ri-garland-wars)
	(or	(unit-type-count-total infantry-class >= 18)
		(population g:> G-184-pop))
;	(up-compare-goal G-strat != GV-trashwar)
	(or	(or	(or	(goal G-eagles 1)
				(goal G-champs 1))
			(goal G-spears 1))
		(goal G-condo 1))
	(nand	(goal G-skirms 1)
		(up-research-status c: ri-atlatl < research-pending))
	(building-type-count castle > 0)
	(up-research-status c: ri-blast-furnace >= research-pending)
	=>
	(up-add-research-cost c: ri-garland-wars c: 1)
	(up-modify-escrow food c:max 450)
	(up-modify-escrow gold c:max 750))

(defrule
	(up-can-research G-esc-state c: ri-atlatl)
	(goal G-skirms 1)
	(or	(unit-type-count-total skirmisher-line >= 9)
		(population g:>= G-184-pop))
	(up-research-status c: ri-bodkin-arrow >= research-pending)
	(or	(up-research-status c: ri-bracer >= research-pending)
		(current-age < imperial-age))
	=>
	(release-escrow food)
	(release-escrow gold)
	(research ri-atlatl))
(defrule
	(research-available ri-atlatl)
	(goal G-skirms 1)
	(or	(unit-type-count-total skirmisher-line >= 11)
		(population g:>= G-184-pop))
	(building-type-count castle > 0)
	(up-research-status c: ri-bodkin-arrow >= research-pending)
	(or	(up-research-status c: ri-bracer >= research-pending)
		(current-age < imperial-age))
	=>
	(up-add-research-cost c: ri-atlatl c: 1)
	(up-modify-escrow food c:max 400)
	(up-modify-escrow gold c:max 350))

(defrule
	(goal G-uu 1)
	(or	(unit-type-count-total jaguar-man-line >= 8)
		(population g:>= G-184-pop))
	(up-can-research G-esc-state c: ri-elite-jaguar-man)
	=>
	(release-escrow food)
	(release-escrow gold)
	(research ri-elite-jaguar-man))
(defrule
	(goal G-uu 1)
	(building-type-count castle > 0)
	(or	(unit-type-count-total jaguar-man-line >= 11)
		(population g:> G-184-pop))
	(research-available ri-elite-jaguar-man)
	=>
	(up-add-research-cost c: ri-elite-jaguar-man c: 1)
	(up-modify-escrow food c:max 1000)
	(up-modify-escrow gold c:max 500))
#end-if

