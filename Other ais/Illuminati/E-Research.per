(defrule
	(up-can-research G-esc-state c: ri-redemption)
	(goal G-monks 1)
	(or	(or	(unit-type-count-total monastery-class >= 11)
			(and	(or	(up-compare-goal G-field-gun-threat >= 6)
					(or	(up-compare-goal G-siege-threat >= 3)
						(up-compare-goal G-cannon-threat >= 3)))
				(or	(population g:> G-189-pop)
					(unit-type-count-total monastery-class >= 7))))
		(and	(or	(up-compare-goal G-field-gun-threat >= 10)
				(or	(up-compare-goal G-siege-threat >= 5)
					(up-compare-goal G-cannon-threat >= 5)))
			(unit-type-count-total monastery-class >= 4)))
	=>
	(release-escrow gold)
	(research ri-redemption))
(defrule
	(research-available ri-redemption)
	(goal G-monks 1)
	(or	(or	(unit-type-count-total monastery-class >= 12)
			(and	(or	(up-compare-goal G-field-gun-threat >= 7)
					(or	(up-compare-goal G-siege-threat >= 4)
						(up-compare-goal G-cannon-threat >= 4)))
				(or	(population g:> G-189-pop)
					(unit-type-count-total monastery-class >= 8))))
		(and	(or	(up-compare-goal G-field-gun-threat >= 12)
				(or	(up-compare-goal G-siege-threat >= 6)
					(up-compare-goal G-cannon-threat >= 6)))
			(unit-type-count-total monastery-class >= 6)))
	=>
	(up-add-research-cost c: ri-redemption c: 1)
	(up-modify-escrow gold c:max 475))

