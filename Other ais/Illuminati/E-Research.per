	(up-modify-goal G-temp1 g:+ G-heavy-arch-threat)
	(up-compare-goal G-temp1 c:>= 32)
	=>
	(up-add-research-cost c: ri-manipur-cavalry c: 1)
	(up-modify-escrow food c:max 300)
	(up-modify-escrow gold c:max 300))
#end-if

