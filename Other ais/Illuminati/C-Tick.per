(defrule
	(up-timer-status T-60 == timer-disabled)
	=>
	(set-goal G-esc-state with-escrow); reset escrow
	(set-goal G-escrowing 0)
	(set-escrow-percentage food 0)
	(set-escrow-percentage wood 0)
	(set-escrow-percentage gold 0)
	(set-escrow-percentage stone 0)
	(up-release-escrow))


; == REGROUP ==
#load-if-defined UP-POCKET-POSITION
(defrule
	(goal G-position GV-pocket)
	=>
	(up-jump-rule 3))
#end-if
;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-attack <= 0)
	(or	(town-under-attack)
		(strategic-number SN-enemy-units-in-town >= 8))
	=>
	(set-goal G-all-in 1)
	(up-jump-rule 2))
	;-----------------------------------------------------------------------
(defrule
	(or	(goal G-scouting GV-enemyfound)
		(military-population >= 8))
	(up-timer-status T-10 == timer-disabled); T-30
	(up-compare-goal G-attack <= 0)
	(up-compare-goal G-under-attack != 1)
	=>
	(up-set-attack-stance -1 c: stance-stand-ground)
	(up-full-reset-search)
	(up-filter-exclude -1 actionid-relic orderid-convert -1)
	(up-find-local c: monastery-class c: 240)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-filter-exclude -1 actionid-explore -1 -1)
	(up-find-local c: -1 c: 240)
	(up-remove-objects search-local object-data-id g:== ID-myscout)
	(up-target-point P-retreat-x action-move -1 stance-stand-ground))
(defrule
	(goal G-all-in 1)
	(up-timer-status T-10 == timer-disabled)
	=>
	(set-goal G-all-in -1))
	;-----------------------------------------------------------------------
;-----------------------------------------------------------------------

; == TARGET PLAYER ==
(defrule
	(up-timer-status T-30 == timer-disabled)
	(game-time >= 10)
	=>
	(up-find-player enemy find-closest G-closest-enemy)
;	(up-chat-data-to-all "closest enemy: %d" g: G-closest-enemy)
	(up-modify-sn sn-target-player-number g:= G-closest-enemy))
(defrule
	(up-players-in-game enemy > 1)
	(up-timer-status T-30 == timer-disabled)
	(current-age >= castle-age)
	(players-population target-player < 15)
	(players-building-type-count target-player town-center == 0)
	(game-time > 600)
	=>
	(up-find-next-player enemy find-closest G-closest-enemy)
;	(up-chat-data-to-all "next closest enemy: %d" g: G-closest-enemy)
	(up-modify-sn sn-target-player-number g:= G-closest-enemy))

; ======================
; ==== UPDATE GOALS ====
; ======================
(defrule; G-attack
	(goal G-attack GV-tsa-duc)
	(up-compare-goal G-tower-response != GV-duc-camps)
; expand facts when adding more tsa+duc attacks with waypoints
	=>
	(set-goal G-attack GV-tsa))
; == G-age ==
(defrule
	(up-compare-goal G-age < GV-upfeudal)
	(up-research-status c: feudal-age == research-pending)
	=>
	(set-goal G-age GV-upfeudal)
	(set-goal G-eco-balance GV-early-feudal)
	(set-goal G-force-tc-idle 0)
	(disable-timer T-clicked-up)
	(enable-timer T-clicked-up TV-up-feudal)
	(disable-self))
(defrule
	(up-compare-goal G-age < GV-feudal)
	(current-age == feudal-age)
	=>
	(set-goal G-age GV-feudal)
	(up-get-fact game-time 0 G-age-start-time)
	(disable-self))
(defrule
	(up-compare-goal G-age < GV-upcastle)
	(up-research-status c: castle-age == research-pending)
	=>
	(set-goal G-age GV-upcastle)
	(set-goal G-escrowing 0)
	(set-strategic-number sn-disable-builder-assistance 1)
	(set-strategic-number sn-number-civilian-militia 0)
	(set-goal G-eco-balance GV-early-castle)
	(set-goal G-eco-research GV-feudal-techs)
	(set-goal G-force-tc-idle 0)
	(disable-timer T-clicked-up)
	(enable-timer T-clicked-up TV-up-castle)
	(disable-self))
(defrule
	(up-compare-goal G-age < GV-castle)
	(current-age == castle-age)
	=>
	(set-goal G-age GV-castle)
	(set-goal G-eco-balance 0)
	(up-get-fact game-time 0 G-age-start-time)
	(disable-timer T-w84ups)
	(enable-timer T-w84ups TV-w84-castle-ups)
	(set-strategic-number sn-maximum-stone-drop-distance 25)
	(set-strategic-number sn-maximum-gold-drop-distance 25)
	(disable-self))
(defrule
	(up-compare-goal G-age < GV-upimp)
	(up-research-status c: imperial-age == research-pending)
	=>
	(set-goal G-age GV-upimp)
	(set-goal G-escrowing 0)
	(set-goal G-force-tc-idle 0)
	(disable-timer T-clicked-up)
	(enable-timer T-clicked-up TV-up-imp); escrow big researches after triggered
	(disable-self))
(defrule
	(up-compare-goal G-age < GV-imp)
	(current-age == imperial-age)
	=>
	(set-goal G-age GV-imp)
	(up-get-fact game-time 0 G-age-start-time)
	(disable-timer T-w84ups)
	(enable-timer T-w84ups TV-w84-imp-ups)
	(disable-self))
; == G-attacking ==
#load-if-defined UP-ALLY-IN-GAME
(defrule
	(up-compare-goal G-attacking != 0)
	(goal G-attack -1)
	=>
	(set-goal G-attacking 0))
(defrule
	(up-compare-goal G-attacking != 1)
	(up-compare-goal G-attack >= 0)
	=>
	(set-goal G-attacking 1))
#end-if
; == GOAL 11 - TOWN UNDER ATTACK ==
(defrule
	(goal G-under-attack 0)
	(goal G-attack -1)
	(town-under-attack)
	(strategic-number SN-enemy-units-in-town >= 4)
	(up-timer-status T-tsa-retreat != timer-running)
	=>
	(set-goal G-under-attack 1))
(defrule
	(goal G-under-attack 1)
	(or	(not	(town-under-attack))
		(up-compare-goal G-attack >= 0))
	=>
	(set-goal G-under-attack 0))

