	(chat-to-player my-player-number "strat SKIRM FLUSH")
	(set-goal G-strat-rax 0)
	(set-goal G-strat-range 1)
	(set-goal G-strat-stable 0)
	(set-goal G-strat-workshop 0)
	(set-goal G-boom-priority 0)
	(set-goal G-strat-bo GV-feudal-war)
	(set-goal G-strat-class1 archery-class)
	(set-goal G-strat-class2 0)
	(up-jump-direct g: J-strat-parameters))
