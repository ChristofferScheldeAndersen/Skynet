; ========================
; ==== TSA PRIORITIES ====
; ========================
(defrule
	(goal G-targeting-priorities GV-nonsiege-active)	
	(or	(or	(unit-type-count RAM >= 2); 3
			(unit-type-count trebuchet-set >= 2)); 3
		(and	(goal G-tower-response GV-wreck-it)
			(or	(players-building-type-count target-player watch-tower > 0)
				(players-building-type-count target-player donjon > 0))))
	=>
	(set-goal G-targeting-priorities GV-siege-switch))
(defrule
	(goal G-targeting-priorities GV-siege-active)	
	(unit-type-count RAM <= 1)
	(unit-type-count trebuchet-set <= 1)
	(or	(up-compare-goal G-tower-response != GV-wreck-it)
		(and	(players-building-type-count target-player watch-tower == 0)
			(players-building-type-count target-player donjon == 0)))
	=>
	(set-goal G-targeting-priorities GV-nonsiege-switch))

(defrule
	(goal G-targeting-priorities GV-nonsiege-switch)
	(goal G-maptype GV-land-walled)
	=>
	(set-strategic-number sn-wall-targeting-mode 0)
	(up-set-defense-priority c: palisade-wall c: 1500)
	(up-set-defense-priority c: stone-wall c: 10)
	(up-set-defense-priority c: gate-class c: 900))
(defrule
	(goal G-targeting-priorities GV-nonsiege-switch)
	=>
	(up-set-defense-priority c: town-center-foundation c: 6000)
	(up-set-defense-priority c: town-center c: 500)
	(up-set-defense-priority c: lumber-camp c: 5000)
	(up-set-defense-priority c: mining-camp c: 5000)
	(up-set-defense-priority c: settlement c: 5000)
	(up-set-defense-priority c: mule-cart c: 5000)
	(up-set-defense-priority c: mill c: 1000)
	(up-set-defense-priority c: house c: 20)
	(up-set-defense-priority c: castle c: 10)
	(up-set-defense-priority c: krepost c: 10)
	(up-set-defense-priority c: watch-tower c: 50)
	(up-set-defense-priority c: donjon c: 50)
	(up-set-defense-priority c: bombard-tower c: 50)
	(up-set-defense-priority c: barracks c: 2000)
	(up-set-defense-priority c: archery-range c: 2000)
	(up-set-defense-priority c: stable c: 2000)
	(up-set-defense-priority c: siege-workshop c: 2000)
	(up-set-defense-priority c: monastery c: 1000)
	(set-goal G-targeting-priorities GV-nonsiege-active))

(defrule
	(goal G-targeting-priorities GV-siege-switch)
;	(goal G-maptype GV-land-walled)
	=>
	(set-strategic-number sn-wall-targeting-mode 1)
	(up-set-defense-priority c: palisade-wall c: 1000)
	(up-set-defense-priority c: stone-wall c: 1000)
	(up-set-defense-priority c: gate-class c: 4300))
(defrule
	(goal G-targeting-priorities GV-siege-switch)
	=>
	(up-set-defense-priority c: town-center-foundation c: 6000)
	(up-set-defense-priority c: town-center c: 6000)
	(up-set-defense-priority c: lumber-camp c: 1200)
	(up-set-defense-priority c: mining-camp c: 1200)
	(up-set-defense-priority c: settlement c: 1200)
	(up-set-defense-priority c: mule-cart c: 1200)
	(up-set-defense-priority c: mill c: 1200)
	(up-set-defense-priority c: house c: 20)
	(up-set-defense-priority c: castle c: 6400)
	(up-set-defense-priority c: krepost c: 6300)
	(up-set-defense-priority c: watch-tower c: 5800)
	(up-set-defense-priority c: donjon c: 5800)
	(up-set-defense-priority c: bombard-tower c: 6200)
	(up-set-defense-priority c: barracks c: 2000)
	(up-set-defense-priority c: archery-range c: 2000)
	(up-set-defense-priority c: stable c: 2000)
	(up-set-defense-priority c: siege-workshop c: 3000)
	(up-set-defense-priority c: monastery c: 3500)
	(set-goal G-targeting-priorities GV-siege-active))

; ==========================
; ==== EVERY TICK SETUP ====
; ==========================
(defrule
	(true); before resetting cost data
	=>
	(up-get-fact wood-amount 0 G-free-wood)
	(up-get-fact food-amount 0 G-free-food)
	(up-get-fact gold-amount 0 G-free-gold)
	(up-modify-goal G-free-wood g:- G-cost-wood)
	(up-modify-goal G-free-food g:- G-cost-food)
	(up-modify-goal G-free-gold g:- G-cost-gold)
	(up-get-fact enemy-units-in-town 0 G-temp1)
	(up-modify-sn SN-enemy-units-in-town g:= G-temp1))
(defrule
	(true)
	=>
	(up-reset-cost-data G-cost-food)
	(set-goal G-temp0 -1)
	(set-goal G-temp1 -1)
	(set-goal G-temp2 -1)
	(set-goal G-temp3 -1)
	(set-goal G-temp4 -1)
	(set-goal G-temp5 -1)
	(set-goal G-temp6 -1)
	(set-goal G-temp7 -1)
	(set-goal G-temp8 -1)
	(set-goal G-temp9 -1))
