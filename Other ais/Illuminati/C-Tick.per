; ====================
; ==== UPDATE SNS ====
; ====================
(defrule
	(strategic-number sn-enable-training-queue == 1)
	(or	(unit-type-count-total villager g:>= G-fc-vills)
		(or	(food-amount > 420); blaze it
			(goal G-force-tc-idle 1)))
	=>
	(set-strategic-number sn-enable-training-queue 0))

(defrule; hunt deer if no scout to lure it
	(current-age == dark-age)
	(or	(goal G-scout-unit villager-class)
		(not	(up-set-target-by-id g: ID-myscout)))
	(strategic-number sn-maximum-hunt-drop-distance < 15)
	(unit-type-count villager >= 8)
	=>
;	(chat-to-player my-player-number "no scout, increase hunt range")
	(set-strategic-number sn-maximum-hunt-drop-distance 15))

(defrule
	(strategic-number sn-percent-building-cancellation == 1)
	(building-type-count castle > 0)
	=>
	(set-strategic-number sn-percent-building-cancellation 25))
(defrule
	(strategic-number sn-percent-building-cancellation == 1)
	(goal G-starting-tcs 0)
	(building-type-count town-center >= 1)
	(nand	(building-type-count castle == 0)
		(building-type-count-total castle == 0))
	=>
	(set-strategic-number sn-percent-building-cancellation 25))

(defrule
	(strategic-number sn-allow-adjacent-dropsites != 1)
	(or	(or	(or	(up-pending-placement c: MINING-CAMP)
				(up-pending-placement c: LUMBER-CAMP))
			(up-pending-placement c: MILL))
		(up-pending-placement c: town-center))
	=>
	(set-strategic-number sn-allow-adjacent-dropsites 1))

; civilian militia
(defrule
	(strategic-number sn-allow-civilian-offense == 2)
	(enemy-buildings-in-town)
	(nor	(up-building-type-in-town c: watch-tower > 0)
		(up-building-type-in-town c: donjon > 0))
	=>
	(set-strategic-number sn-allow-civilian-offense 0))
(defrule
	(strategic-number sn-allow-civilian-defense == 3)
	(or	(up-compare-goal G-attack >= 1)
		(or	(strategic-number sn-number-civilian-militia == 0)
			(or	(up-compare-goal G-main-arch-threat > 9)
				(or	(players-military-population any-enemy >= 10)
					(players-current-age any-enemy >= castle-age)))))
	=>
	(set-strategic-number sn-allow-civilian-defense 1)
	(set-strategic-number sn-allow-civilian-offense 0))
(defrule
	(strategic-number sn-number-civilian-militia > 0)
	(up-compare-goal P-enemytc-x > 0)
	(or	(and	(up-building-type-in-town c: town-center >= 1)
			(goal G-attack -1))
		(up-point-distance P-self-x P-enemytc-x < 36))
	=>
;	(chat-to-player my-player-number "enemy close, disabling civilian militia")
	(set-strategic-number sn-allow-civilian-defense 0)
	(set-strategic-number sn-allow-civilian-offense 0)
	(set-strategic-number sn-number-civilian-militia 0))
(defrule
	(strategic-number sn-maximum-hunt-drop-distance > 7)
	(current-age < castle-age)
	(up-compare-goal P-enemytc-x > 0)
	(or	(and	(up-building-type-in-town c: town-center >= 1)
			(goal G-attack -1))
		(up-point-distance P-self-x P-enemytc-x < 24))
	=>
;	(chat-to-player my-player-number "enemy close, reduce hunt range")
	(up-get-point-distance P-self-x P-enemytc-x G-temp1)
	(up-modify-goal G-temp1 c:- 9)
	(up-modify-goal G-temp1 c:max 6)
	(up-modify-sn sn-maximum-hunt-drop-distance g:= G-temp1))

(defrule; stop vill spaz
	(strategic-number sn-villager-attack-reset != 0)
	(goal G-trushed 1)
	=>
	(set-strategic-number sn-villager-attack-reset 0))

(defrule; back to default
	(strategic-number sn-villager-attack-reset != 1)
	(or	(strategic-number sn-allow-civilian-offense == 0)
		(nor	(up-building-type-in-town c: watch-tower > 0)
			(up-building-type-in-town c: donjon > 0)))
	=>
	(set-strategic-number sn-villager-attack-reset 1))


#load-if-not-defined TINY-MAP
(defrule
	(current-age >= castle-age)
	(strategic-number SN-superiority >= 90)
	(military-population >= 12)
	=>
	(set-strategic-number sn-number-explore-groups 2)
	(set-strategic-number sn-total-number-explorers 2)
	(disable-self))
#end-if

; ====================
; ==== TICK COUNT ====
; ====================
(defrule
	(true)
	=>
	(up-modify-goal G-tick-count c:+ 1)
	(up-modify-goal G-2nd-tick g:= G-tick-count)
	(up-modify-goal G-2nd-tick c:mod 2)
	(up-modify-goal G-3rd-tick g:= G-tick-count)
	(up-modify-goal G-3rd-tick c:mod 3)
	(up-modify-goal G-5th-tick g:= G-tick-count)
	(up-modify-goal G-5th-tick c:mod 5))

; ========================
; ==== GENERAL TIMERS ====
; ========================
(defrule
	(up-timer-status T-1 == timer-disabled)
	=>
	(enable-timer T-1 1))
(defrule
	(timer-triggered T-1)
	=>
	(disable-timer T-1))
(defrule
	(up-timer-status T-2 == timer-disabled)
	=>
	(enable-timer T-2 2))
(defrule
	(timer-triggered T-2)
	=>
	(disable-timer T-2))
(defrule
	(up-timer-status T-5 == timer-disabled)
	=>
	(enable-timer T-5 5))
(defrule
	(timer-triggered T-5)
	=>
	(disable-timer T-5))
(defrule
	(up-timer-status T-10 == timer-disabled)
	=>
	(enable-timer T-10 10))
(defrule
	(timer-triggered T-10)
	=>
	(disable-timer T-10))
(defrule
	(up-timer-status T-15 == timer-disabled)
	=>
	(enable-timer T-15 15))
(defrule
	(timer-triggered T-15)
	=>
	(disable-timer T-15))
(defrule
	(up-timer-status T-27 == timer-disabled)
	=>
	(enable-timer T-27 27))
(defrule
	(timer-triggered T-27)
	=>
	(disable-timer T-27))
(defrule
	(up-timer-status T-30 == timer-disabled)
	=>
	(enable-timer T-30 30))
(defrule
	(timer-triggered T-30)
	=>
	(disable-timer T-30))
(defrule
	(up-timer-status T-60 == timer-disabled)
	=>
	(enable-timer T-60 60))
(defrule
	(timer-triggered T-60)
	=>
	(disable-timer T-60))
(defrule
	(up-timer-status T-111 == timer-disabled)
	=>
	(enable-timer T-111 111))
(defrule
	(timer-triggered T-111)
	=>
	(disable-timer T-111))
