(defrule
	(true)
	=>
	(up-get-rule-id J-strat-parameters)
	(disable-self))
#load-if-defined GOTHIC-CIV
(defrule
	(goal G-strat-rax 0)
;	(or	(goal G-strat GV-cdrop); they only have rax strats once anarchy is researched
;		(goal G-strat GV-unique))
	(research-completed ri-anarchy)
	=>
	(set-goal G-strat-rax 1))
#end-if
(defrule
	(goal G-strat-workshop 0)
	(up-compare-goal G-age >= GV-upimp)
	=>
	(set-goal G-strat-workshop 1))

(defrule; when slung, care less about boom
	(up-compare-goal G-strat g:!= G-previous-strat)
	(goal G-sling 2)
	=>
	(up-modify-goal G-boom-priority c:- 1)
	(up-modify-goal G-boom-priority c:max 1))

(defrule; pockets prioritise boom
	(up-compare-goal G-strat g:!= G-previous-strat)
	(up-compare-goal G-boom-priority < 3)
	(goal G-position GV-pocket)
	=>
	(up-modify-goal G-boom-priority c:+ 1)
	(up-modify-goal G-boom-priority c:min 3))

(defrule
	(true)
	=>
	(up-modify-goal G-previous-strat g:= G-strat))