; == UPDATE SCOUT DATA ==
(defrule; update scout type and id
	(game-time > 10)
	(up-compare-goal G-scout-unit != villager-class)
	(up-compare-goal G-scout-unit > 0)
	(military-population > 0)
	(strategic-number sn-minimum-civilian-explorers == 0)
;	(up-compare-goal G-scout-unit != horse)
;	(up-compare-goal G-scout-unit != king)
;	(up-compare-goal G-scout-unit != trade-cart)
	=>
	(up-full-reset-search)
	(up-filter-include cmdid-military actionid-explore -1 -1)
	(up-find-local c: -1 c: 1)
	(up-filter-include -1 -1 -1 -1); in case the scout is ducking
	(up-find-local g: G-scout-unit c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-id ID-myscout)
	(up-get-object-data object-data-type G-scout-unit))
(defrule
	(game-time > 10)
	(goal G-scout-unit villager-class)
	=>
	(up-full-reset-search)
	(up-filter-include -1 actionid-explore -1 -1)
	(up-find-local c: villager-class c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-id ID-myscout))
(defrule
	(game-time > 0)
	(up-set-target-by-id g: ID-myscout)
;	(up-timer-status T-1 != timer-running)
	=>
	(up-get-object-data object-data-idling G-scoutidle)
	(up-get-point position-object P-scout-x))
;	(up-send-flare P-scout-x))

(defrule
	(up-compare-goal G-scoutidle >= 1)
	(or	(goal G-scouting GV-enemyfound)
		(goal G-scouting GV-retardscouting))
	=>
;	(chat-to-player my-player-number "resetting scouts")
	(up-reset-scouts))

; == RETREAT POINT AND TOWN SIZE ==
; town size: decrease when enemy castle close, or enemy tower close in feudal

(defrule
	(building-type-count castle <= 0)
	=>
	(up-copy-point P-retreat-x P-self-x))
;	(up-modify-goal P-retreat-x c:- 1)
;	(up-modify-goal P-retreat-y c:+ 1))
(defrule
	(building-type-count castle >= 1)
	=>
	(up-get-fact building-type-count castle G-temp1); castle count
	(up-modify-goal G-temp2 g:= G-temp1)
	(up-modify-goal G-temp2 c:+ 1); point divisor
	(up-modify-goal P-retreat-x g:= P-self-x)
	(up-modify-goal P-retreat-y g:= P-self-y)
	(up-full-reset-search)
;	(up-filter-status c: status-ready c: list-active); redundant
	(up-find-local c: castle c: 240)
	(up-modify-goal G-temp3 c:= 0)); loop counter
(defrule
	(building-type-count castle >= 1)
	(up-compare-goal G-temp3 g:< G-temp1)
	=>
	(up-set-target-object search-local g: G-temp3)
	(up-get-point position-object P-temp-x)
	(up-modify-goal P-retreat-x g:+ P-temp-x)
	(up-modify-goal P-retreat-y g:+ P-temp-y)
	(up-modify-goal G-temp3 c:+ 1)
	(up-jump-rule -1))
(defrule
	(building-type-count castle >= 1)
	=>
	(up-modify-goal P-retreat-x g:/ G-temp2)
	(up-modify-goal P-retreat-y g:/ G-temp2)
	(up-bound-point P-retreat-x P-retreat-x))

; (defrule; debug
; 	(building-type-count castle >= 1)
; 	(up-timer-status T-10 == timer-disabled)
; 	=>
; 	(up-send-flare P-retreat-x))

; retreat point behind tower?

; == idle farm count ==
(defrule
	(true)
	=>
	(up-get-fact building-type-count farm G-temp1)
	(up-get-fact unit-type-count villager-farmer G-temp2)
	(up-modify-goal G-temp1 g:- G-temp2)
	(up-modify-sn SN-idle-farm-count g:= G-temp1))

; == reset stance ==
(defrule
	; (or	(players-building-count target-player > 0)
	; 	(nand	(up-compare-goal G-scouting >= 2)
	; 		(up-compare-goal G-scouting <= 7)))
	(nand	(up-compare-goal G-boarsteal >= 3)
		(up-compare-goal G-boarsteal <= 10))
	=>
	(up-full-reset-search)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-local c: -1 c: 240)
	(up-remove-objects search-local object-data-idling < 1)
	(up-target-point P-self-x action-none -1 stance-aggressive))
(defrule
	(unit-type-count monastery-class > 0)
;	(up-research-status c: ri-theocracy < research-complete)
	=>
	(up-full-reset-search)
	(up-filter-include cmdid-monk -1 -1 -1)
	(up-find-local c: -1 c: 240)
	(up-remove-objects search-local object-data-idling < 1)
	(up-target-point P-self-x action-none -1 stance-stand-ground))
; (defrule
; 	(unit-type-count monastery-class > 0)
; 	(up-research-status c: ri-theocracy >= research-complete)
; 	=>
; 	(up-full-reset-search)
; 	(up-filter-include cmdid-monk -1 -1 -1)
; 	(up-find-local c: -1 c: 240)
; 	(up-remove-objects search-local object-data-idling < 1)
; 	(up-target-point P-self-x action-none -1 stance-aggressive))

; == reset builders ==
(defrule
      (unit-type-count villager-builder > 0)
      =>
      (up-full-reset-search)
      (up-filter-include -1 -1 orderid-build -1)
      (up-find-local c: villager-class c: 40)
      (up-remove-objects search-local object-data-target-id > -1))
(defrule
      (unit-type-count villager-builder > 0)
      (up-set-target-object search-local c: 0)
      =>
      ; (up-get-search-state G-local-total)
      ; (up-chat-data-to-all "resetting %d builders" g: G-local-total)
      (up-target-point P-self-x action-stop -1 -1))

