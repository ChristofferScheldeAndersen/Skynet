(defrule
	(goal G-trade 1)
	(building-type-count-total market < 4)
	=>
	(up-get-point-distance P-my-one-corner-x P-self-x G-temp1)
	(up-get-point-distance P-my-two-corner-x P-self-x G-temp2))
(defrule
	(goal G-trade 1)
	(building-type-count-total market < 3)
	(wood-amount > 240)
	(can-build market)
	(up-compare-goal G-temp1 g:<= G-temp2)
	(up-timer-status T-trade != timer-running)
	=>
	(set-strategic-number sn-placement-zone-size 8)
	(set-strategic-number sn-placement-to-center 1)
	(set-strategic-number sn-placement-fail-delta 1)
	(up-set-target-point P-my-one-corner-x)
	(up-build place-point 0 c: market))
(defrule
	(goal G-trade 1)
	(building-type-count-total market < 3)
	(wood-amount > 240)
	(can-build market)
	(up-compare-goal G-temp1 g:>= G-temp2)
	(up-timer-status T-trade != timer-running)
	=>
	(set-strategic-number sn-placement-zone-size 8)
	(set-strategic-number sn-placement-to-center 1)
	(set-strategic-number sn-placement-fail-delta 1)
	(up-set-target-point P-my-two-corner-x)
	(up-build place-point 0 c: market))

(defrule; quick fix
	(goal G-trade 1)
	(building-type-count-total market == 3)
	(civilian-population g:>= G-desired-vills)
	(up-compare-goal G-free-wood >= 175)
	(up-pending-objects c: market <= 0)
	(can-build market)
	(up-compare-goal G-temp1 g:<= G-temp2)
	(up-timer-status T-trade != timer-running)
	=>
	(set-strategic-number sn-placement-zone-size 8)
	(set-strategic-number sn-placement-to-center 1)
	(set-strategic-number sn-placement-fail-delta 1)
	(up-set-target-point P-my-two-corner-x)
	(up-build place-point 0 c: market))
(defrule; quick fix
	(goal G-trade 1)
	(building-type-count-total market == 3)
	(civilian-population g:>= G-desired-vills)
	(up-compare-goal G-free-wood >= 175)
	(up-pending-objects c: market <= 0)
	(can-build market)
	(up-compare-goal G-temp1 g:>= G-temp2)
	(up-timer-status T-trade != timer-running)
	=>
	(set-strategic-number sn-placement-zone-size 8)
	(set-strategic-number sn-placement-to-center 1)
	(set-strategic-number sn-placement-fail-delta 1)
	(up-set-target-point P-my-one-corner-x)
	(up-build place-point 0 c: market))

(defrule
	(goal G-trade 1)
	(building-type-count-total market >= 2)
	(unit-type-count-total trade-cart g:< G-desired-trade)
	=>
	(up-modify-goal G-cost-wood c:+ 150))
(defrule
	(goal G-trade 1)
	(building-type-count-total market >= 2)
	(unit-type-count-total trade-cart < 10)
	=>
	(up-modify-goal G-cost-wood c:+ 250))
(defrule
	(goal G-trade 1)
	(unit-type-count-total trade-cart g:< G-desired-trade)
	(can-train trade-cart)
	=>
	(train trade-cart))

; ==== END ====
(defrule
	(true)
	=>
	(up-get-rule-id J-coop-per)
	(disable-self))