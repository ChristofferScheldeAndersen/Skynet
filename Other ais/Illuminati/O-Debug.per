(defrule; ECO
	(taunt-detected any-computer 249); my-player-number
	=>
	(acknowledge-taunt this-any-computer 249)
	(chat-to-player this-any-computer "= ECO =")
	(up-chat-data-to-player this-any-computer "camp max distance: %d" s: sn-camp-max-distance)
	(up-chat-data-to-player this-any-computer "F %d" s: sn-food-gatherer-percentage)
	(up-chat-data-to-player this-any-computer "W %d" s: sn-wood-gatherer-percentage)
	(up-chat-data-to-player this-any-computer "G %d" s: sn-gold-gatherer-percentage)
	(up-chat-data-to-player this-any-computer "S %d" s: sn-stone-gatherer-percentage)
	(up-chat-data-to-player this-any-computer "esc state: %d" g: G-esc-state)
	(up-get-fact escrow-amount food G-temp1)
	(up-get-fact escrow-amount wood G-temp2)
	(up-get-fact escrow-amount gold G-temp3)
	(up-get-fact escrow-amount stone G-temp4)
	(up-chat-data-to-player this-any-computer "F escrow: %d" g: G-temp1)
	(up-chat-data-to-player this-any-computer "W escrow: %d" g: G-temp2)
	(up-chat-data-to-player this-any-computer "G escrow: %d" g: G-temp3)
	(up-chat-data-to-player this-any-computer "S escrow: %d" g: G-temp4))
