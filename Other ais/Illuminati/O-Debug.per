(defrule; resource dropsite
	(taunt-detected any-computer 238)
	=>
	(acknowledge-taunt this-any-computer 238)
	(up-get-fact dropsite-min-distance food G-temp1)
	(up-get-fact dropsite-min-distance livestock G-temp2)
	(up-get-fact dropsite-min-distance deer-hunting G-temp3)
;	(up-get-fact dropsite-min-distance  G-temp4)
	(up-get-fact dropsite-min-distance wood G-temp5)
	(up-get-fact dropsite-min-distance gold G-temp6)
	(up-get-fact dropsite-min-distance stone G-temp7)
;	(up-get-fact dropsite-min-distance  G-temp8)
	(up-chat-data-to-player this-any-computer "food distance %d" g: G-temp1)
	(up-chat-data-to-player this-any-computer "livestock distance %d" g: G-temp2)
	(up-chat-data-to-player this-any-computer "deer-hunting distance %d" g: G-temp3)
;	(up-chat-data-to-player this-any-computer " %d" g: G-temp4)
	(up-chat-data-to-player this-any-computer "wood distance %d" g: G-temp5)
	(up-chat-data-to-player this-any-computer "gold distance %d" g: G-temp6)
	(up-chat-data-to-player this-any-computer "stone distance %d" g: G-temp7))
;	(up-chat-data-to-player this-any-computer " %d" g: G-temp8)

(defrule; population
	(taunt-detected any-computer 237)
	=>
	(acknowledge-taunt this-any-computer 237)
	(up-get-fact population 0 G-temp0)
	(up-get-fact civilian-population 0 G-temp1)
	(up-get-fact housing-headroom 0 G-temp2)
	(up-get-fact population-headroom 0 G-temp3)
	(up-chat-data-to-player this-any-computer "population %d" g: G-temp0)
	(up-chat-data-to-player this-any-computer "civilian population %d" g: G-temp1)
	(up-chat-data-to-player this-any-computer "housing headroom %d" g: G-temp2)
	(up-chat-data-to-player this-any-computer "population headroom %d" g: G-temp3))



(defrule; visible flares
	(true)
	=>
	(fe-cc-effect-amount 0 274 73 3268)
	(disable-self))




