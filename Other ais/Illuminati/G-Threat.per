; ========================
; ==== ENEMY MILITARY ====
; ========================
; target player is weighed TRIPLE

(defrule; MAIN-ARCH: archer, longbow, chukonu, genoese, plume, rattan, composite, fire archer, blackwood
	(strategic-number sn-target-player-number > 0)
	=>
	(set-goal G-main-arch-threat 0)
	(up-get-fact-sum any-enemy unit-type-count archer-line G-temp1)
	(up-get-target-fact unit-type-count archer-line G-temp2)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-main-arch-threat g:+ G-temp1)
	(up-modify-goal G-main-arch-threat g:+ G-temp2)
	(up-get-fact-sum any-enemy unit-type-count longbowman-line G-temp1)
	(up-get-target-fact unit-type-count longbowman-line G-temp2)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-main-arch-threat g:+ G-temp1)
	(up-modify-goal G-main-arch-threat g:+ G-temp2)
	(up-get-fact-sum any-enemy unit-type-count chu-ko-nu-line G-temp1)
	(up-get-target-fact unit-type-count chu-ko-nu-line G-temp2)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-main-arch-threat g:+ G-temp1)
	(up-modify-goal G-main-arch-threat g:+ G-temp2)
	(up-get-fact-sum any-enemy unit-type-count genoese-crossbowman-line G-temp1)
	(up-get-target-fact unit-type-count genoese-crossbowman-line G-temp2)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-main-arch-threat g:+ G-temp1)
	(up-modify-goal G-main-arch-threat g:+ G-temp2)
	(up-get-fact-sum any-enemy unit-type-count plumed-archer-line G-temp1)
	(up-get-target-fact unit-type-count plumed-archer-line G-temp2)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-main-arch-threat g:+ G-temp1)
	(up-modify-goal G-main-arch-threat g:+ G-temp2)
	(up-get-fact-sum any-enemy unit-type-count rattan-archer-line G-temp1)
	(up-get-target-fact unit-type-count rattan-archer-line G-temp2)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-main-arch-threat g:+ G-temp1)
	(up-modify-goal G-main-arch-threat g:+ G-temp2))
