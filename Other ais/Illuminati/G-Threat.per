	(up-modify-goal G-total-threat g:+ G-cannon-threat)
	(up-modify-goal G-total-threat g:+ G-monk-threat)
	(up-modify-goal G-total-threat g:+ G-speshul-threat))


; ================
; ==== DEFCON ====
; ================
; superiority = own numbers % of enemy numbers. 100 = equal, 50 = half, 200 = double
; == raw target superioritiy ==
(defrule
	(strategic-number sn-target-player-number > 0)
	=>
	(up-get-fact military-population 0 G-temp1)
	(up-get-target-fact military-population 0 G-temp2)
	(up-modify-goal G-temp1 g:%/ G-temp2)
	(up-modify-sn SN-raw-superiority g:= G-temp1))
(defrule; divide by 0 failsafe
	(strategic-number SN-raw-superiority < 150)
	(players-military-population target-player < 2)
	=>
	(up-get-fact military-population 0 G-temp1)
	(up-modify-goal G-temp1 c:* 33)
	(up-modify-goal G-temp1 c:max 100)
	(up-modify-sn SN-raw-superiority g:= G-temp1))

; == superiority modifier ==
(defrule
	(strategic-number sn-target-player-number > 0)
	=>
	(set-strategic-number SN-superiority-modifier 100)
	(up-get-fact current-age 0 G-temp1)
	(up-get-target-fact current-age 0 G-temp2)
	(up-get-fact game-time 0 G-temp3)
	(up-modify-goal G-temp3 g:- G-age-start-time))
(defrule
	(up-timer-status T-w84ups == timer-running)
	(players-current-age-time target-player g:>= G-temp3); only if enemy upped earlier than self
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-goal G-temp1 c:- 1))
(defrule
	(players-current-age-time target-player < TV-w84-castle-ups)
	(up-timer-status T-w84ups != timer-running)
	=>
	(up-modify-goal G-temp2 c:- 1))
(defrule
	(up-compare-goal G-temp1 g:> G-temp2); age advantage
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority-modifier c:+ 75))
(defrule
	(up-compare-goal G-temp1 g:< G-temp2); age disadvantage
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority-modifier c:- 35)); 30
(defrule
	(current-age == feudal-age)
	(or	(up-compare-goal G-scout-cav-threat >= 6)
		(up-compare-goal G-main-cav-threat >= 6))
	(up-modify-goal G-temp7 g:= G-main-cav-threat)
	(up-modify-goal G-temp7 g:+ G-scout-cav-threat)
	(up-modify-goal G-temp7 c:/ 3)
	(unit-type-count spearman-line g:<= G-temp7)
	(or	(unit-type-count spearman-line < 2)
		(or	(up-compare-goal G-main-arch-threat >= 12)
			(up-compare-goal G-skirm-threat >= 18)))
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority-modifier c:- 35)); 30

(defrule
	(current-age == feudal-age)
	(goal G-build-order GV-feudal-war)
	(up-get-target-fact unit-type-count skirmisher-line G-temp4)
	(up-get-fact unit-type-count-total skirmisher-line G-temp5)
	(up-compare-goal G-temp4 g:>= G-temp5)
	(unit-type-count-total archer-line >= 2)
	(or	(goal G-archers 1)
		(unit-type-count-total archer-line >= 5))
	(unit-type-count-total militiaman-line == 0)
	(unit-type-count-total champi-line < 2)
	(unit-type-count-total scout-cavalry-line < 2)
	=>
	(up-modify-goal G-temp4 c:* 30)
	(up-modify-goal G-temp4 g:/ G-temp5)
	(up-modify-goal G-temp4 c:- 30)
	(up-modify-goal G-temp4 c:min 45)
	(up-modify-sn SN-superiority-modifier g:- G-temp4))

#load-if-defined SPANISH-CIV
(defrule
	(current-age == castle-age)
	(unit-type-count conquistador >= 5)
	(or	(players-current-age target-player <= feudal-age)
		(and	(players-current-age target-player == castle-age)
			(players-current-age-time target-player < TV-w84-castle-ups)))
	=>
	(up-modify-sn SN-superiority-modifier c:* 130)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(current-age == castle-age)
	(unit-type-count conquistador >= 2)
	(up-get-fact unit-type-count conquistador G-temp8)
	(up-modify-goal G-temp8 c:* 2)
	(up-compare-goal G-temp8 g:> G-monk-threat)
	(up-compare-goal G-temp8 g:> G-skirm-threat)
	(up-compare-goal G-temp8 g:> G-field-gun-threat)
	=>
	(up-get-fact unit-type-count conquistador G-temp4); 10
	(up-get-fact military-population 0 G-temp5); 20
	(up-modify-goal G-temp4 g:%/ G-temp5)
	(up-modify-goal G-temp4 c:+ 100)
	(up-modify-sn SN-superiority-modifier g:* G-temp4)
	(up-modify-sn SN-superiority-modifier c:z/ 100))
#end-if
#load-if-defined KOREAN-CIV
(defrule
	(up-get-fact unit-type-count war-wagon-line G-temp6)
	(up-compare-goal G-temp6 >= 2)
	(up-modify-goal G-temp6 c:* 2)
	(up-compare-goal G-temp6 g:> G-siege-threat)
	(up-compare-goal G-temp6 g:> G-field-gun-threat)
	(players-unit-type-count target-player war-wagon-line g:< G-temp6)
	=>
	(up-get-fact unit-type-count war-wagon-line G-temp4)
	(up-get-fact military-population 0 G-temp5)
	(up-modify-goal G-temp4 g:%/ G-temp5)
	(up-modify-goal G-temp4 c:+ 100)
	(up-modify-sn SN-superiority-modifier g:* G-temp4)
	(up-modify-sn SN-superiority-modifier c:z/ 100))
#end-if
(defrule
	(unit-type-count eagle-warrior-line >= 6)
	(players-unit-type-count target-player militiaman-line < 3)
	(players-unit-type-count target-player champi-line < 3)
	(players-unit-type-count target-player knight-line < 6)
	(or	(players-unit-type-count target-player skirmisher-line >= 8)
		(or	(players-unit-type-count target-player monk-set >= 3)
			(or	(or	(players-unit-type-count target-player mangonel-line >= 2)
					(players-unit-type-count target-player rocket-cart-line >= 2))
				(or	(goal G-strat GV-klewproper)
					(goal G-strat GV-klew)))))
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority-modifier c:* 130)
	(up-modify-sn SN-superiority-modifier c:/ 100)
	(up-modify-sn SN-superiority-modifier c:+ 15))
(defrule
	(unit-type-count battle-elephant-line >= 3)
	(up-get-target-fact unit-type-count spearman-line G-temp6)
	(unit-type-count battle-elephant-line g:> G-temp6)
	=>
	(up-modify-sn SN-superiority-modifier c:* 135)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(unit-type-count knight-line >= 4)
	(up-get-target-fact unit-type-count spearman-line G-temp6)
	(up-get-target-fact unit-type-count knight-line G-temp7)
	(unit-type-count knight-line g:> G-temp6)
	(unit-type-count knight-line g:> G-temp7)
	(players-unit-type-count target-player camel-line < 3)
	(players-unit-type-count target-player knight-line < 7)
	=>
	(up-modify-sn SN-superiority-modifier c:* 130)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(unit-type-count knight-line >= 4)
	(or	(players-current-age target-player <= feudal-age)
		(and	(players-current-age target-player == castle-age)
			(players-current-age-time target-player < TV-w84-castle-ups)))
	=>
	(up-modify-sn SN-superiority-modifier c:* 160)
	(up-modify-sn SN-superiority-modifier c:/ 100)
	(up-modify-sn SN-superiority-modifier c:+ 20))
(defrule
	(unit-type-count MANGO >= 2)
	(up-compare-goal G-main-cav-threat < 9)
	(up-compare-goal G-scout-cav-threat < 9)
	(or	(up-compare-goal G-field-gun-threat > 5)
		(or	(up-compare-goal G-main-arch-threat > 15)
			(up-compare-goal G-skirm-threat > 15)))
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority-modifier c:* 130)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(unit-type-count spearman-line >= 4)
	(or	(up-compare-goal G-scout-cav-threat >= 12)
		(or	(up-compare-goal G-main-cav-threat >= 12)
			(up-compare-goal G-ele-cav-threat >= 6)))
	(up-compare-goal G-main-arch-threat < 20)
	(up-compare-goal G-skirm-threat < 20)
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority-modifier c:* 120)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(unit-type-count scorpion-line >= 8)
	(up-compare-goal G-siege-threat < 5)
	(up-compare-goal G-main-cav-threat < 32)
	(up-compare-goal G-field-gun-threat < 24)
	=>
	(up-modify-sn SN-superiority-modifier c:* 120)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(unit-type-count monastery-class >= 5)
	(or	(up-compare-goal G-main-cav-threat >= 12)
		(up-compare-goal G-ele-cav-threat >= 6))
	(players-unit-type-count target-player scout-cavalry-line < 3)
	(players-unit-type-count target-player eagle-warrior-line < 4)
	(up-compare-goal G-main-arch-threat < 20)
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority-modifier c:* 130)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(or	(unit-type-count archer-line >= 8)
		(unit-type-count cavalry-archer-line >= 8))
	(or	(or	(players-unit-type-count target-player militiaman-line >= 5)
			(players-unit-type-count target-player champi-line >= 5))
		(and	(players-unit-type-count target-player spearman-line >= 5)
			(or	(goal G-knights 0)
				(goal G-elephants 0))))
	(or	(players-unit-type-count target-player skirmisher-line < 8)
		(unit-type-count-total eagle-warrior-line >= 8))
	(players-unit-type-count target-player eagle-warrior-line < 8)
	(up-compare-goal G-tank-inf-threat < 6)
	(up-compare-goal G-siege-threat < 7)
	(up-compare-goal G-field-gun-threat < 4)
	=>
	(up-modify-sn SN-superiority-modifier c:* 115)
	(up-modify-sn SN-superiority-modifier c:/ 100))
(defrule
	(strategic-number sn-target-player-number > 0)
	=>
	(up-modify-sn SN-superiority s:= SN-raw-superiority)
	(up-modify-sn SN-superiority s:* SN-superiority-modifier)
	(up-modify-sn SN-superiority c:/ 100))
(defrule
;	(or	(goal G-strat GV-smushboom)
		(or	(goal G-strat GV-monks-only)
			(goal G-strat GV-monkflood));)
	=>
	(up-get-fact unit-type-count monastery-class G-temp1)
	(up-get-fact unit-type-count mangonel-line G-temp2)
	(up-get-fact unit-type-count rocket-cart-line G-temp2)
	(up-get-fact unit-type-count scorpion-class G-temp3)
	(up-get-fact unit-type-count RAM G-temp4)
;	(up-modify-goal G-temp2 c:* 2)
	(up-modify-sn SN-superiority g:+ G-temp1)
	(up-modify-sn SN-superiority g:+ G-temp2)
	(up-modify-sn SN-superiority g:+ G-temp3)
	(up-modify-sn SN-superiority g:+ G-temp4))

; == team superiority ==
#load-if-defined UP-ALLY-IN-GAME
(defrule
	(true)
	=>
	(up-get-fact military-population 0 G-temp1)
	(up-get-fact-sum any-ally military-population 0 G-temp2)
	(up-get-fact-sum any-enemy military-population 0 G-temp3)
	(up-modify-goal G-temp1 g:+ G-temp2)
	(up-modify-goal G-temp1 g:%/ G-temp3)
	(up-modify-sn SN-team-superiority g:= G-temp1))
#else
(defrule
	(true)
	=>
	(up-modify-sn SN-team-superiority s:= SN-superiority))
#end-if


