	(up-modify-goal G-total-threat g:+ G-cav-arch-threat)
	(up-modify-goal G-total-threat g:+ G-cannoneer-threat)
	(up-modify-goal G-total-threat g:+ G-main-inf-threat)
	(up-modify-goal G-total-threat g:+ G-pike-threat)
	(up-modify-goal G-total-threat g:+ G-eagle-threat)
