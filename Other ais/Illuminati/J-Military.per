; == HIGHEST FACTORS ==
; G-temp0 - supp unit slots
; G-temp1 - current goal being checked (260-271)
; G-temp2 - current goal factor
; G-temp3 - current supp type goal (180-189)
; G-temp4 - supp1 type
; G-temp5 - supp2 type
; G-temp6 - highest unit (260-271)
; G-temp7 - highest factor
; G-temp8 - 2nd highest unit (260-271)
; G-temp9 - 2nd highest factor

(defrule
	(up-compare-goal J-supp-units > 0); not first tick
	=>
	(set-goal G-temp1 260)
	(set-goal G-temp2 -1)
	(set-goal G-temp3 170)
	(set-goal G-temp4 -1)
	(set-goal G-temp5 -1)
	(set-goal G-temp6 -1)
	(set-goal G-temp7 -1)
	(set-goal G-temp8 -1)
	(set-goal G-temp9 -1))

(defrule; ~~ start loop
	(up-compare-goal J-supp-units > 0)
	=>
	(up-get-indirect-goal g: G-temp1 G-temp2))
(defrule
	(up-compare-goal J-supp-units > 0)
	(up-compare-goal G-temp2 g:> G-temp7)
	=>
	(up-modify-goal G-temp8 g:= G-temp6)
	(up-modify-goal G-temp9 g:= G-temp7)
	(up-modify-goal G-temp5 g:= G-temp4)
	(up-modify-goal G-temp6 g:= G-temp1)
	(up-modify-goal G-temp7 g:= G-temp2)
	(up-get-indirect-goal g: G-temp3 G-temp4)
	(up-jump-rule 1))
(defrule
	(up-compare-goal J-supp-units > 0)
	(up-compare-goal G-temp2 g:> G-temp9)
	=>
	(up-modify-goal G-temp8 g:= G-temp1)
	(up-modify-goal G-temp9 g:= G-temp2)
	(up-get-indirect-goal g: G-temp3 G-temp5))
(defrule
	(up-compare-goal J-supp-units > 0)
	(up-compare-goal G-temp1 < 271)
	=>
	(up-modify-goal G-temp1 c:+ 1)
	(up-modify-goal G-temp3 c:+ 1)
	(up-jump-rule -4)); next factor~~

(defrule
	(up-compare-goal J-supp-units > 0)
	(up-compare-goal G-temp7 >= 100)
	(or	(up-compare-goal G-temp4 g:== G-strat-class1)
		(or	(up-compare-goal G-temp4 g:== G-strat-class2)
			(or	(up-compare-goal G-temp5 g:== G-strat-class1)
				(up-compare-goal G-temp5 g:== G-strat-class2))))
	=>
	(up-modify-goal G-temp0 c:+ 1))

