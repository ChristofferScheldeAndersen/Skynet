	(up-modify-goal G-temp1 g:+ G-ele-cav-threat)
	(up-modify-goal G-temp1 g:+ G-ele-cav-threat)
	(up-modify-goal G-temp1 g:+ G-heavy-arch-threat)
	(up-modify-goal G-temp1 c:* 5)
	(up-modify-goal G-temp1 c:/ 2)
	(up-modify-goal G-temp1 g:- G-main-arch-threat)
	(up-modify-goal G-temp1 g:- G-skirm-threat)
	(up-modify-goal G-temp1 g:- G-cannoneer-threat)
	(up-modify-goal G-temp1 g:- G-scout-cav-threat)
	(up-modify-goal G-temp1 g:- G-eagle-threat)
	(up-modify-goal G-temp1 c:* MONKCIV-IMP)
	(up-modify-goal G-f-monks g:max G-temp1))

