(defrule; no-supp strats
	(or	(up-compare-goal G-strat < 10)
		(or	(goal G-strat GV-trashwar)
			(up-compare-goal G-age < GV-upcastle)))
	(up-compare-goal J-supp-units > 0)
	=>
	(up-jump-direct g: J-supp-units))


; == CHAMPS ==
(defrule
	(goal G-champs 0)
	(up-compare-const CHAMPCIV >= 1)
	=>
	(up-modify-goal G-temp1 g:= G-eagle-threat)
	(up-modify-goal G-temp1 g:- G-field-gun-threat)
	(up-modify-goal G-temp1 g:- G-field-gun-threat)
	(up-modify-goal G-temp1 g:- G-cannoneer-threat)
	(up-modify-goal G-temp1 g:- G-monk-threat))
(defrule
	(goal G-champs 0)
	(up-compare-const CHAMPCIV >= 1)
	(up-compare-const CHAMP == militiaman-line)
	=>
	(up-modify-goal G-temp1 g:+ G-tank-inf-threat)
	(up-modify-goal G-temp1 g:- G-cav-arch-threat))
(defrule
	(goal G-champs 0)
	(up-compare-const CHAMPCIV >= 1)
	(up-compare-const CHAMP == champi-line)
	=>
	(up-modify-goal G-temp1 g:+ G-skirm-threat)
	(up-modify-goal G-temp1 g:+ G-siege-threat)
	(up-modify-goal G-temp1 g:+ G-siege-threat)
	(up-modify-goal G-temp1 g:+ G-cannon-threat)
	(up-modify-goal G-temp1 g:+ G-cannon-threat))
(defrule
	(goal G-champs 0)
	(up-compare-const CHAMPCIV >= 1)
	=>
	(up-modify-goal G-temp1 c:* 2)
	(up-modify-goal G-temp1 c:* CHAMPCIV)
	(up-modify-goal G-f-champs g:max G-temp1))

(defrule; win faster
	(goal G-champs 0)
	(up-compare-const SCOUTCIV == 0)
	(up-compare-const CHAMPCIV >= 1); at least 2hs and plate armour
	(strategic-number SN-superiority > 150)
	(up-compare-goal G-age >= GV-upimp)
	=>
	(up-modify-goal G-temp1 s:= SN-superiority)
	(up-modify-goal G-temp1 c:/ 2)
	(up-modify-goal G-temp1 g:- G-field-gun-threat)
	(up-modify-goal G-temp1 g:- G-field-gun-threat)
	(up-modify-goal G-temp1 g:- G-cannoneer-threat)
	(up-modify-goal G-temp1 g:- G-monk-threat)
	(up-modify-goal G-f-champs g:+ G-temp1))

