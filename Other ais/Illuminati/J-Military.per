; == POCKET CAVALIERS ==
#load-if-defined UP-POCKET-POSITION
(defrule
	(or	(up-compare-goal G-position != GV-pocket)
		(or	(building-type-count-total stable < 2)
			(or	(goal G-knights 1)
				(or	(up-compare-const KNIGHTCIV-IMP < 1)
					(or	(up-research-status c: ri-chain-barding < research-complete)
						(goal G-monks 1))))))
	=>
	(up-jump-rule 8))
