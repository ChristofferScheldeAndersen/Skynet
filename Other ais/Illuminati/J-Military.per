; ====================
; ==== CORE UNITS ====
; ====================
(defrule
	(true)
	=>
	(set-goal G-archers 0)
	(set-goal G-skirms 0)
	(set-goal G-hc 0)
	(set-goal G-ca 0)
	(set-goal G-champs 0)
	(set-goal G-spears 0)
	(set-goal G-eagles 0)
	(set-goal G-condo 0)
	(set-goal G-camels 0)
	(set-goal G-knights 0)
	(set-goal G-elephants 0)
	(set-goal G-scouts 0)
	(set-goal G-monks 0)
	(set-goal G-missionaries 0)
	(set-goal G-mangonel 0)
	(set-goal G-ram 0)
	(set-goal G-scorps 0)
	(set-goal G-uu 0)
	(set-goal G-treb 0)
	(set-goal G-firelancers 0))

(defrule
	(up-compare-goal G-rebuild >= 1)
	(up-compare-goal J-military-per > 0)
	=>
	(up-jump-direct g: J-military-per))

; == swordsmen ==
(defrule
	(or	(goal G-strat GV-vanguard)
		(or	(goal G-strat GV-longswords)
			(goal G-strat GV-champflood)))
	(nand	(goal G-strat GV-vanguard)
		(goal G-escrowing castle-age))
	(nand	(goal G-strat GV-champflood)
		(up-compare-goal G-age < GV-upcastle))
	=>
	(set-goal G-champs 1))
#load-if-defined CELTIC-CIV
(defrule
	(goal G-strat GV-siegewoads)
	(up-compare-goal G-age >= GV-upimp)
	(building-type-count castle == 0)
	=>
	(set-goal G-champs 1))
#end-if
; == fire lancers ==
(defrule
	(goal G-strat GV-firelancers)
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-goal G-firelancers 1))
; == eagles ==
(defrule
	(or	(goal G-strat GV-klew)
		(or	(goal G-strat GV-eagleflood)
			(goal G-strat GV-klewproper)))
	(up-compare-goal G-age >= GV-upcastle); so as to not do things that would delay castle-up click
	=>
	(set-goal G-eagles 1))
; == spears ==
#load-if-not-defined TURKISH-CIV
(defrule
	(or	(goal G-strat GV-siegehalbs)
		(or	(goal G-strat GV-trashwar)
			(goal G-strat GV-trashflood)))
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-goal G-spears 1))
#end-if
; == archers ==
(defrule
	(or	(goal G-strat GV-xbows)
		(goal G-strat GV-horsecock))
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-goal G-archers 1))
(defrule
	(or	(goal G-strat GV-rangedflush)
		(and	(goal G-strat GV-vanguard)
			(up-compare-const ARCHERCIV > SKIRMCIV)))
	(or	(goal G-escrowing castle-age)
		(or	(up-compare-goal G-skirm-threat < 15)
			(or	(up-compare-goal G-main-inf-threat >= 6)
				(up-compare-goal G-pike-threat > 6))))
	=>
	(set-goal G-archers 1))
; == skirms ==
(defrule
	(or	(goal G-strat GV-rangedflush)
		(or	(goal G-strat GV-vanguard)
			(and	(up-compare-goal G-age >= GV-upcastle)
				(or	(goal G-strat GV-trashwar)
					(goal G-strat GV-trashflood)))))
	(nand	(up-compare-goal G-escrowing == castle-age)
		(and	(strategic-number SN-superiority >= 85)
			(food-amount < 825)))
	=>
	(set-goal G-skirms 1))
; == cav archers ==
#load-if-defined HUN-CIV
(defrule
	(or	(goal G-strat GV-ca)
		(goal G-strat GV-horsecock))
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-goal G-ca 1))
#end-if
; == hand cannons ==
(defrule
	(goal G-strat GV-civ-lategame)
	(civ-selected turkish)
	=>
	(set-goal G-hc 1))
; == knights ==
(defrule
	(or	(goal G-strat GV-krush)
		(or	(goal G-strat GV-krushboom)
			(or	(goal G-strat GV-horsecock)
				(goal G-strat GV-mlp))))
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-goal G-knights 1))
; == elephants ==
(defrule
	(goal G-strat GV-ele)
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-goal G-elephants 1))
; == scouts ==
(defrule
	(goal G-strat GV-civ-lategame)
	(civ-selected turkish)
	=>
	(set-goal G-scouts 1))
; == camels ==
(defrule; interchangable for main stable unit
	(goal G-strat-stable 1)
	(up-compare-goal G-strat != GV-trashwar)
	(up-compare-const CAMELCIV >= 1)
	(up-compare-goal G-age >= GV-castle)
	(or	(up-compare-const CAMELCIV >= 2)
		(up-compare-goal G-age == GV-castle))
	(up-compare-goal G-total-threat > 8)
	(up-modify-goal G-temp1 g:= G-scout-cav-threat)
	(up-modify-goal G-temp1 g:+ G-main-cav-threat)
	(up-modify-goal G-temp1 g:+ G-camel-cav-threat)
	(up-modify-goal G-temp1 g:- G-pike-threat)
	(up-modify-goal G-temp1 g:- G-main-arch-threat)
	(up-modify-goal G-temp2 g:= G-total-threat)
	(up-modify-goal G-temp2 c:/ 2)
	(up-compare-goal G-temp1 g:>= G-temp2)
	=>
	(set-goal G-camels 1)
	(set-goal G-temp5 5558282))
(defrule
	(goal G-temp5 5558282)
	(up-get-fact unit-type-count-total knight-line G-temp1)
	(up-get-fact unit-type-count-total scout-cavalry-line G-temp2)
	(up-get-fact unit-type-count-total battle-elephant-line G-temp3)
	(unit-type-count-total camel-line g:<= G-temp1)
	(unit-type-count-total camel-line g:<= G-temp2)
	(unit-type-count-total camel-line g:<= G-temp3)
	=>
	(set-goal G-knights 0)
	(set-goal G-scouts 0)
	(set-goal G-elephants 0))

; == scorpions ==
(defrule
	(or	(goal G-strat GV-siegehalbs)
		(goal G-strat GV-siegewoads))
	=>
	(set-goal G-scorps 1))
; == siege ==
(defrule
	(current-age == imperial-age)
	(up-compare-const BBCCIV >= 2)
	(research-completed ri-chemistry)
	(up-compare-goal G-strat != GV-trashwar)
	(or	(or	(up-compare-goal G-siege-threat >= 9)
			(up-compare-goal G-field-gun-threat >= 12))
		(and	(goal G-strat GV-civ-lategame)
			(civ-selected turkish)))
	(unit-type-count-total bombard-cannon < 6)
	=>
;	(disable-timer T-eco)
	(up-add-object-cost c: bombard-cannon c: 2); 1
	(set-goal G-bbc 1))
; == monks ==
(defrule
;	(or	(goal G-strat GV-smushboom)
		(or	(goal G-strat GV-monks-only)
			(goal G-strat GV-monkflood));)
	=>
	(set-goal G-monks 1))
; == semi trash war==
(defrule
	(current-age == imperial-age)
	(up-compare-goal G-strat != GV-monks-only)
	(up-compare-goal G-strat != GV-trashwar)
	(food-amount > 300)
	(wood-amount > 300)
	(gold-amount < 150)
	=>
	(set-goal G-spears 1)
	(set-goal G-skirms 1))
; == unique unit ==
(defrule
	(or	(goal G-strat GV-cdrop)
		(or	(goal G-strat GV-unique)
			(goal G-strat GV-siegewoads)))
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-goal G-uu 1))

