; ==== PRIORITY UNITS ====


; == PREPARE MICHI CUT ==
(defrule
	(up-compare-goal G-michi-cut >= 1)
	(up-compare-goal G-michi-cut <= 3)
	(up-compare-goal G-age >= GV-upimp)
	(unit-type-count-total MANGO < 2)
	=>
	(set-goal G-mangonel 1)
	(set-goal G-ram 0))

; =====================
; ==== RECRUITMENT ====
; =====================
(defrule; prioritise vills over skirms
	(current-age == feudal-age)
	(or	(goal G-skirms 1)
		(goal G-champs 1))
	(goal G-vills 1)
	(up-train-site-ready c: villager)
	(or	(food-amount < 50)
		(escrow-amount food > 0))
	=>
	(set-goal G-champs 0)
	(set-goal G-skirms 0))
; == SIEGE ==
(defrule
	(goal G-ram 1)
	(up-compare-const RAM == battering-ram-line)
	(unit-type-count-total RAM < 3)
	(or	(unit-type-count-total RAM < 2)
		(or	(players-building-type-count target-player castle >= 1)
			(players-building-type-count target-player krepost >= 1)))
	(or	(unit-type-count-total RAM == 0)
		(or	(or	(players-building-type-count target-player watch-tower > 1)
				(players-building-type-count target-player donjon > 1))
			(or	(or	(players-building-type-count target-player castle >= 1)
					(players-building-type-count target-player krepost >= 1))
				(up-compare-goal G-attack >= 0))))
	(up-can-train G-esc-state c: RAM)
	=>
	(release-escrow wood)
	(release-escrow gold)
	(train RAM))
(defrule
	(goal G-ram 1)
	(up-compare-const RAM == battering-ram-line)
	(unit-type-count-total RAM < 2)
	(or	(unit-type-count-total RAM == 0)
		(or	(or	(players-building-type-count target-player watch-tower > 1)
				(players-building-type-count target-player donjon > 1))
			(or	(players-building-type-count target-player castle >= 1)
				(or	(players-building-type-count target-player krepost >= 1)
					(up-compare-goal G-attack >= 0)))))
	(building-type-count siege-workshop >= 1)
	(or	(wood-amount < 160)
		(gold-amount < 75))
	=>
	(up-modify-escrow wood c:max 160)
	(up-modify-escrow gold c:max 75)
	(up-add-object-cost c: RAM c: 1))
(defrule
	(goal G-ram 1)
	(up-compare-const RAM == armored-elephant-line)
	(unit-type-count-total RAM < 3)
	(or	(unit-type-count-total RAM < 2)
		(or	(players-building-type-count target-player castle >= 1)
			(players-building-type-count target-player krepost >= 1)))
	(or	(unit-type-count-total RAM == 0)
		(or	(or	(players-building-type-count target-player watch-tower > 1)
				(players-building-type-count target-player donjon > 1))
			(or	(or	(players-building-type-count target-player castle >= 1)
					(players-building-type-count target-player krepost >= 1))
				(up-compare-goal G-attack >= 0))))
	(up-can-train G-esc-state c: RAM)
	=>
	(release-escrow food)
	(release-escrow gold)
	(train RAM))
(defrule
	(goal G-ram 1)
	(up-compare-const RAM == armored-elephant-line)
	(unit-type-count-total RAM < 2)
	(or	(unit-type-count-total RAM == 0)
		(or	(or	(players-building-type-count target-player watch-tower > 1)
				(players-building-type-count target-player donjon > 1))
			(or	(or	(players-building-type-count target-player castle >= 1)
					(players-building-type-count target-player krepost >= 1))
				(up-compare-goal G-attack >= 0))))
	(building-type-count siege-workshop >= 1)
	(or	(food-amount < 120)
		(gold-amount < 95))
	=>
	(up-modify-escrow food c:max 120)
	(up-modify-escrow gold c:max 95)
	(up-add-object-cost c: RAM c: 1))
(defrule
	(goal G-mangonel 1)
	(unit-type-count-total MANGO < MIN-MANGOS)
	(or	(unit-type-count-total MANGO == 0)
		(or	(up-compare-goal G-main-arch-threat > 40)
			(and	(goal G-strat-class1 monastery-class)
				(up-compare-goal G-main-arch-threat > 20))))
	(up-can-train G-esc-state c: MANGO)
	=>
	(release-escrow wood)
	(release-escrow gold)
	(train MANGO))
(defrule
	(goal G-mangonel 1)
	(unit-type-count-total MANGO < MIN-MANGOS); 2 unless celts
	(or	(unit-type-count-total MANGO == 0)
		(or	(up-compare-goal G-main-arch-threat > 40)
			(and	(goal G-strat-class1 monastery-class)
				(up-compare-goal G-main-arch-threat > 20))))
	(building-type-count siege-workshop >= 1)
	(or	(wood-amount < 160)
		(gold-amount < 155))
	=>
	(up-modify-escrow wood c:max 160)
	(up-modify-escrow gold c:max 155)
	(up-add-object-cost c: MANGO c: 1))
(defrule
	(goal G-treb 1)
	(unit-type-count-total trebuchet-set < 2)
	(or	(unit-type-count-total trebuchet-set == 0)
		(or	(or	(players-building-type-count target-player castle >= 1)
				(players-building-type-count target-player krepost >= 1))
			(up-compare-goal G-attack >= 0)))
	(up-can-train G-esc-state c: trebuchet)
	=>
	(release-escrow wood)
	(release-escrow gold)
	(train trebuchet))
(defrule
	(goal G-treb 1)
	(unit-type-count-total trebuchet-set < 2)
	(or	(unit-type-count-total trebuchet-set == 0)
		(or	(or	(players-building-type-count target-player castle >= 1)
				(players-building-type-count target-player krepost >= 1))
			(up-compare-goal G-attack >= 0)))
	(building-type-count castle >= 1)
;	(up-train-site-ready c: trebuchet)
	(or	(wood-amount < 200)
		(gold-amount < 200))
	=>
	(up-modify-escrow wood c:max 200)
	(up-modify-escrow gold c:max 200)
	(up-add-object-cost c: trebuchet c: 1))
(defrule
	(goal G-treb 1)
	(or	(goal G-uu 0)
		(goal G-2nd-tick 1))
	(can-train trebuchet)
	(unit-type-count-total trebuchet-set g:< G-stopgap-pop)
	=>
	(train trebuchet))
(defrule; alternate when both unit types are being trained
	(goal G-mangonel 1)
	(can-train MANGO)
	(or	(and	(goal G-scorps 1)
			(can-train scorpion-line))
		(and	(goal G-ram 1)
			(can-train RAM)))
	(goal G-2nd-tick 1)
	=>
	(up-jump-rule 1))
(defrule
	(goal G-mangonel 1)
	(can-train MANGO)
	=>
	(train MANGO))
(defrule; alternate when both unit types are being trained
	(goal G-ram 1)
	(can-train RAM)
	(goal G-scorps 1)
	(can-train scorpion-line)
	(goal G-2nd-tick 1)
	=>
	(up-jump-rule 1))
(defrule
	(goal G-ram 1)
	(can-train RAM)
	=>
	(train RAM))
(defrule
	(goal G-scorps 1)
	(can-train scorpion-line)
	=>
	(train scorpion-line))
; == MONK ==
#load-if-defined SPANISH-CIV
(defrule
	(goal G-monks 1)
	=>
	(set-goal G-missionaries 1))
(defrule
	(or	(goal G-missionaries 1)
		(unit-type-count-total monastery-class < 2))
	(can-train missionary)
	=>
	(train missionary))
#else
(defrule
	(or	(goal G-monks 1)
		(unit-type-count-total monk-set < 2))
	(can-train monk)
	=>
	(train monk))
#end-if
; == UU ==
#load-if-defined GOTHIC-CIV
(defrule
	(research-completed ri-anarchy)
	(goal G-spears 1)
	(can-train spearman-line)
	(goal G-uu 1)
	(or	(can-train rax-huskarl)
		(can-train rax-elite-huskarl))
	(goal G-2nd-tick 0)
	=>
	(up-jump-rule 1))
(defrule
	(research-completed ri-anarchy)
	(goal G-uu 1)
	(or	(can-train rax-huskarl)
		(can-train rax-elite-huskarl))
	=>
	(train rax-huskarl)
	(train rax-elite-huskarl))
#end-if
(defrule
	(goal G-uu 1)
	(can-train my-unique-unit-line)
	=>
	(train my-unique-unit-line))
; == RANGE ==
(defrule; alternate when both unit types are being trained
	(or	(and	(goal G-archers 1)
			(can-train archer-line))
		(or	(and	(goal G-ca 1)
				(can-train cavalry-archer-line))
			(and	(goal G-hc 1)
				(can-train hand-cannoneer))))
	(goal G-skirms 1)
	(can-train skirmisher-line)
	(goal G-2nd-tick 1)
	=>
	(up-jump-rule 1))
(defrule
	(goal G-skirms 1)
	(can-train skirmisher-line)
	=>
	(train skirmisher-line))
(defrule
	(goal G-archers 1)
	(can-train archer-line)
	=>
	(train archer-line))
(defrule
	(goal G-ca 1)
	(can-train cavalry-archer-line)
	=>
	(train cavalry-archer-line))
(defrule
	(goal G-hc 1)
	(can-train hand-cannoneer)
	=>
	(train hand-cannoneer))
; == RAX ==
(defrule; alternate when both unit types are being trained
	(goal G-eagles 1)
	(can-train eagle-warrior-line)
	(or	(and	(goal G-spears 1)
			(can-train spearman-line))
		(or	(and	(goal G-champs 1)
				(can-train CHAMP))
			(and	(goal G-condo 1)
				(can-train condottiero))))
	(goal G-2nd-tick 0)
	=>
	(up-jump-rule 1))
(defrule
	(goal G-eagles 1)
	(can-train eagle-warrior-line)
	=>
	(train eagle-warrior-line))
(defrule; alternate when both unit types are being trained
	(or	(and	(goal G-champs 1)
			(can-train CHAMP))
		(or	(and	(goal G-condo 1)
				(can-train condottiero))
			(and	(goal G-firelancers 1)
				(can-train fire-lancer-line))))
	(goal G-spears 1)
	(can-train spearman-line)
	(goal G-2nd-tick 1)
	=>
	(up-jump-rule 3))
(defrule
	(goal G-firelancers 1)
	(can-train fire-lancer)
	=>
	(train fire-lancer))
(defrule
	(goal G-champs 1)
	(can-train CHAMP)
	=>
	(train CHAMP))
(defrule
	(goal G-condo 1)
	(can-train condottiero)
	=>
	(train condottiero))
(defrule
	(goal G-spears 1)
	(can-train spearman-line)
	=>
	(train spearman-line))
; == STABLE ==
(defrule; dont delay imp click
	(food-amount < 1000)
	(up-get-fact food-amount 0 G-temp1)
	(up-get-fact gold-amount 0 G-temp2)
	(or	(gold-amount >= 800)
		(and	(up-compare-goal G-temp1 g:< G-temp2)
			(gold-amount >= 500)))
	=>
	(set-goal G-champs 0)
	(set-goal G-spears 0)
	(set-goal G-knights 0)
	(set-goal G-elephants 0)
	(set-goal G-scouts 0)
	(set-goal G-camels 0))

(defrule
	(goal G-knights 1)
	(can-train knight-line)
	(nand	(goal G-2nd-tick 1)
		(or	(and	(goal G-scouts 1)
				(can-train scout-cavalry-line))
			(and	(goal G-camels 1)
				(can-train camel-line))))
	=>
	(train knight-line))
(defrule
	(goal G-elephants 1)
	(can-train battle-elephant-line)
	(nand	(goal G-2nd-tick 1)
		(or	(and	(goal G-scouts 1)
				(can-train scout-cavalry-line))
			(and	(goal G-camels 1)
				(can-train camel-line))))
	=>
	(train battle-elephant-line))
(defrule
	(goal G-scouts 1)
	(can-train scout-cavalry-line)
	(nand	(up-compare-goal G-5th-tick >= 2)
		(and	(goal G-camels 1)
			(can-train camel-line)))
	=>
	(train scout-cavalry-line))
(defrule
	(goal G-camels 1)
	(can-train camel-line)
	=>
	(train camel-line))

; ==== END ====
(defrule
	(true)
	=>
	(up-get-rule-id J-military-per)
	(disable-self))