	(true)
	=>
	(set-goal G-temp0 2))
(defrule
	(up-compare-goal G-strat-class2 c:!= 0)
	=>
	(up-modify-goal G-temp0 c:- 1))
(defrule; dope uus and pocket cavaliers have priority, increase strat core units
	(goal G-s-knights 1)
	(and	(up-compare-goal G-strat-class1 != cavalry-class)
		(up-compare-goal G-strat-class2 != cavalry-class))
	=>
	(up-modify-goal G-temp0 c:- 1))
(defrule
	(goal G-s-uu 1)
	(and	(up-compare-goal G-strat-class1 != UU-CLASS)
		(up-compare-goal G-strat-class2 != UU-CLASS))
	=>
	(up-modify-goal G-temp0 c:- 1))
(defrule; fuck this strat
	(goal G-strat GV-horsecock)
	=>
	(up-modify-goal G-temp0 c:- 1))

(defrule; no more than 1 supp in castle age
	(up-compare-goal G-age <= GV-castle)
	=>
	(up-modify-goal G-temp0 c:min 1))


