(defrule
	(true)
	=>
	(set-goal HAX0 archery-class)
	(set-goal HAX1 infantry-class)
	(set-goal HAX2 infantry-class)
	(set-goal HAX3 UU-CLASS)
	(set-goal HAX4 infantry-class)
	(set-goal HAX5 archery-class)
	(set-goal HAX6 monastery-class)
	(set-goal HAX7 archery-cannon-class)
	(set-goal HAX8 cavalry-class)
	(set-goal HAX9 cavalry-class)
	(set-goal HAX10 cavalry-class)
	(set-goal HAX11 infantry-class))
