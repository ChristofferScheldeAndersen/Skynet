; == SPEARS ==
(defrule
	(goal G-spears 0)
	(players-current-age target-player == feudal-age)
	(up-get-player-fact target-player unit-type-count scout-cavalry-line G-temp8)
	(up-get-player-fact target-player unit-type-count camel-line G-temp9)
	(up-modify-goal G-temp8 g:+ G-temp9)
	(or	(current-age == feudal-age)
		(military-population g:< G-temp8))
	(or	(unit-type-count-total spearman-line g:< G-temp8)
		(unit-type-count-total spearman-line < 3))
	(or	(players-building-type-count target-player stable >= 1)
		(up-compare-goal G-temp8 c:>= 3))
	(or	(building-type-count barracks >= 1)
		(up-compare-goal G-temp8 c:>= 3))
	=>
	(set-goal G-f-spears 200))

