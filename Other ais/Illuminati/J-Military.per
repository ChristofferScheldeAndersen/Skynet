(defrule
	(true)
	=>
	(up-get-fact-sum any-enemy unit-type-count spearman-line G-temp1)
	(up-get-player-fact target-player unit-type-count spearman-line G-temp2)
	(up-get-fact-sum any-enemy unit-type-count halberdier G-temp3)
	(up-get-player-fact target-player unit-type-count halberdier G-temp4)
	(up-modify-goal G-temp1 g:+ G-temp3)
	(up-modify-goal G-temp2 g:+ G-temp4)
	(up-get-fact-sum any-enemy unit-type-count camel-line G-temp3)
	(up-get-player-fact target-player unit-type-count camel-line G-temp4)
	(up-modify-goal G-temp1 g:+ G-temp3)
	(up-modify-goal G-temp2 g:+ G-temp4)
	(up-get-fact-sum any-enemy unit-type-count mameluke-line G-temp3)
	(up-get-player-fact target-player unit-type-count mameluke-line G-temp4)
	(up-modify-goal G-temp1 g:+ G-temp3)
	(up-modify-goal G-temp2 g:+ G-temp4))
(defrule
	(true)
	=>
	(up-get-fact-sum any-enemy unit-type-count monk-set G-temp3)
	(up-get-fact-sum any-enemy unit-type-count missionary G-temp5)
	(up-modify-goal G-temp3 g:+ G-temp5)
	(up-get-player-fact target-player unit-type-count monk-set G-temp4)
	(up-get-player-fact target-player unit-type-count missionary G-temp6)
	(up-modify-goal G-temp4 g:+ G-temp6)
	(up-modify-goal G-temp1 g:+ G-temp3)
	(up-modify-goal G-temp2 g:+ G-temp4)
	(up-modify-goal G-temp1 c:* 3); multiplier 1.5
	(up-modify-goal G-temp1 c:/ 2)
 	(up-modify-goal G-temp2 c:* 5); multiplier 2.5
	(up-modify-goal G-temp2 c:/ 2)
	(up-modify-goal G-temp1 g:+ G-temp2))
(defrule
	(goal G-age GV-upimp)
	=>
	(up-modify-goal G-temp1 c:- 30))
(defrule
	(up-research-status c: ri-cavalier >= research-pending)
	=>
	(up-modify-goal G-temp1 c:- 25))
(defrule
	(up-research-status c: ri-bloodlines >= research-pending)
	=>
	(up-modify-goal G-temp1 c:- 10))
(defrule
	(up-research-status c: ri-plate-barding >= research-pending)
	=>
	(up-modify-goal G-temp1 c:- 15))
(defrule
	(true)
	=>
;	(up-chat-data-to-self "anti-cav threat: %d" g: G-temp1)
	(up-modify-goal G-temp1 c:/ KNIGHTCIV-IMP))

