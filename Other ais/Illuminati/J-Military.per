; == FINALISE ==
(defrule; unit 1
	(up-compare-goal J-supp-units > 0)
	(up-compare-goal G-temp0 >= 1)
	(up-compare-goal G-temp7 >= 100)
	=>
	(up-modify-goal G-temp6 c:+ 15)
	(up-set-indirect-goal g: G-temp6 c: 1))
(defrule; unit 2
	(up-compare-goal J-supp-units > 0)
	(up-compare-goal G-temp0 >= 2)
	(up-compare-goal G-temp9 >= 100)
	=>
	(up-modify-goal G-temp8 c:+ 15)
	(up-set-indirect-goal g: G-temp8 c: 1))

(defrule; supp unit jump
	(true)
	=>
	(up-get-rule-id J-supp-units)
	(disable-self))



; == TRASH WAR ==
(defrule
	(goal G-strat GV-trashwar)
	(up-compare-const CHAMPCIV >= 1); has at least 2HS and plate armour
	=>
	(set-goal G-s-champs 1))

(defrule
	(goal G-strat GV-trashwar)
	(up-compare-const UU-TYPE == MAIN-INF)
	(up-compare-const UUCIV-IMP >= CHAMPCIV)
	(building-type-count castle >= 2)
	(or	(or	(up-research-status c: my-unique-unit-upgrade >= research-pending)
			(up-research-status c: ri-champion < research-pending))
		(up-compare-const UUCIV-IMP > CHAMPCIV))
	=>
	(set-goal G-s-champs 0)
	(set-goal G-s-uu 1))

; == MANGONEL ==
(defrule
	(goal G-mangonel 0)
	(or	(goal G-strat GV-xbows)
		(and	(or	(goal G-strat GV-cdrop)
				(goal G-strat GV-unique))
			(or	(up-compare-const UU-CLASS == archery-class)
				(or	(up-compare-const UU-CLASS == archery-cannon-class)
					(or	(up-compare-const UU-CLASS == cavalry-archer-class)
						(up-compare-const UU-CLASS == cavalry-cannon-class))))))
	=>
	(set-goal G-temp6 17777))
(defrule
	(goal G-temp6 17777)
	(or	(or	(up-compare-goal G-main-arch-threat c:>= 15)
			(up-compare-goal G-skirm-threat c:>= 15))
		(or	(up-compare-goal G-cannoneer-threat c:>= 15)
			(or	(up-compare-goal G-field-gun-threat c:>= 12)
				(up-compare-goal G-siege-threat c:>= 9))))
	(nand	(unit-type-count-total MANGO >= 1)
		(up-unit-type-in-town c: knight-line >= 2))
	=>
	(set-goal G-supp-siege GV-s-mangonel))
(defrule
	(goal G-mangonel 0)
	(up-compare-goal G-strat >= 20); only siege-supp-eligible castle strats
;	(up-compare-goal G-strat != GV-trashwar)
	(or	(or	(up-compare-goal G-main-arch-threat c:>= 30)
			(up-compare-goal G-skirm-threat c:>= 30))
		(or	(up-compare-goal G-cannoneer-threat c:>= 30)
			(or	(up-compare-goal G-field-gun-threat c:>= 18)
				(up-compare-goal G-siege-threat c:>= 12))))
	(strategic-number SN-raw-superiority < 120)
	(nand	(unit-type-count-total MANGO >= 1)
		(up-unit-type-in-town c: knight-line >= 2))
	=>
	(set-goal G-supp-siege GV-s-mangonel))

; == RAM ==

(defrule; all strats
	(or	(up-compare-goal G-age >= GV-upimp)
		(and	(current-age >= castle-age)
			(strategic-number SN-superiority > 120)))
	(or	(strategic-number SN-superiority > 80)
		(population g:> G-184-pop))
	(military-population > 5)
	(up-modify-goal G-temp9 g:= G-main-arch-threat)
	(up-modify-goal G-temp9 g:+ G-cav-arch-threat)
	(up-modify-goal G-temp9 g:+ G-skirm-threat)
	(up-modify-goal G-temp9 g:+ G-cannoneer-threat)
	(up-modify-goal G-temp9 g:+ G-field-gun-threat)
	(up-modify-goal G-temp2 c:= RAMCIV)
	(up-modify-goal G-temp2 c:* 2)
	(up-modify-goal G-temp4 c:= RAMCIV)
	(up-modify-goal G-temp4 c:* 4)
	=>
	(set-goal G-temp1 14558839))
(defrule
	(goal G-temp1 14558839)
	(or	(unit-type-count-total RAM g:< G-temp2); more?
		(and	(unit-type-count-total RAM g:< G-temp4)
			(or	(up-compare-const RAMCIV > 2)
				(or	(building-type-count castle < 1)
					(unit-type-count-total trebuchet-set < 2)))))
	(or	(up-compare-goal G-temp9 >= 60)
		(or	(strategic-number SN-superiority > 125)
			(and	(strategic-number SN-superiority > 100)
				(or	(building-type-count castle < 1)
					(unit-type-count-total trebuchet-set < 3)))))
	=>
	(set-goal G-supp-siege GV-s-ram))
(defrule; no castles
	(up-compare-goal G-age >= GV-upimp)
	(building-type-count-total castle < 1)
	(unit-type-count-total RAM < 8)
	(military-population > 5)
	(strategic-number SN-superiority > 135)
	=>
	(set-goal G-supp-siege GV-s-ram))
(defrule
	(or	(current-age >= castle-age)
		(civ-selected cumans))
	(unit-type-count-total trebuchet-set < 2)
	(or	(up-building-type-in-town c: castle > 0)
		(or	(up-building-type-in-town c: krepost > 0)
			(up-building-type-in-town c: tower-class > 1)))

	=>
	(set-goal G-supp-siege GV-s-ram))

; ===================
; ==== IMP SIEGE ====
; ===================
(defrule
	(building-type-count castle >= 1)
	(or	(or	(building-type-count castle >= 2)
			(up-compare-goal G-uu < 1))
		(unit-type-count-total trebuchet-set < 2))
	(current-age == imperial-age)
	(unit-type-count-total trebuchet-set < 4)
	(or	(strategic-number SN-superiority > 90)
		(population > 180))
	=>
	(set-goal G-treb 1))
(defrule
	(current-age == imperial-age)
	(goal G-treb 0)
	(population g:>= G-184-pop)
	(or	(players-building-type-count target-player castle >= 2)
		(and	(players-population target-player < 50)
			(players-building-type-count any-enemy castle >= 3)))
	=>
	(set-goal G-treb 1))

; ====================
; ==== EXCEPTIONS ====
; ====================
(defrule; pockets shouldn't make siege too early
	(goal G-position GV-pocket)
	(up-compare-const ALLYCOUNT >= 2)
	(or	(building-type-count-total town-center g:< G-desiredtcs)
		(and	(up-compare-goal G-age < GV-upimp)
			(idle-farm-count < 1)))
	=>
	(set-goal G-supp-siege 0))

; == cap siege ==
(defrule
	(goal G-supp-siege GV-s-ram)
	(unit-type-count-total RAM >= 3)
	(or	(unit-type-count-total RAM >= 5)
		(and	(players-building-type-count target-player castle == 0)
			(players-building-type-count target-player krepost == 0)))
	(building-type-count-total town-center g:< G-desiredtcs)
	=>
	(set-goal G-supp-siege 0))
(defrule
	(goal G-supp-siege GV-s-mangonel)
	(unit-type-count-total MANGO >= 4)
	(or	(unit-type-count-total MANGO >= 9)
		(building-type-count-total town-center g:< G-desiredtcs))
	=>
	(set-goal G-supp-siege 0))

