(defrule
	(up-compare-goal G-temp1 g:< G-temp2)
	(up-set-target-object search-local c: 0)
	(up-set-target-object search-remote c: 0)
	(up-object-data object-data-player != my-player-number)
	=>
;	(up-chat-data-to-all "convert %d" g: G-temp6)
	(up-modify-goal G-temp3 c:+ 1)
	(up-target-objects 1 action-default -1 -1))
(defrule
	(up-compare-goal G-temp1 g:< G-temp2); monks left
	=>
	(up-modify-goal G-temp1 c:+ 1)
	(up-jump-rule -16));~~~~ next monk
;-----------------------------------------------------------------------

; ============================
; ==== ALL IN RAM DEFENCE ====
; ============================
(defrule
	(goal G-all-in 1)
	(up-timer-status T-5 == timer-disabled)
	(unit-type-count RAM > 0)
	(or	(players-building-type-count target-player castle > 0)
		(players-building-type-count target-player krepost > 0))
	=>
;	(chat-to-player my-player-number "all in")
	(up-full-reset-search)
	(up-set-target-point P-self-x)
	(up-filter-distance c: -1 c: 50)
	(up-filter-exclude -1 actionid-attack -1 -1)
	(up-find-local c: RAM c: 40)
	(up-find-remote c: castle c: 10)
	(up-find-remote c: krepost c: 10)
	(up-target-objects 0 action-default -1 -1))

; =========================
; ==== DEAL WITH TOWER ====
; =========================
(defrule
	(up-compare-goal G-tower-response >= GV-wreck-it)
	=>
	(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
	(up-full-reset-search)
	(up-find-remote c: watch-tower c: 1)
	(up-find-remote c: donjon c: 1))
;	(up-get-search-state G-local-total))

; == WRECK IT ==
(defrule
	(goal G-tower-response GV-wreck-it)
	(up-compare-goal G-attack > 0)
	(up-timer-status T-5 == timer-disabled)
	(up-set-target-object search-remote c: 0)
;	(up-find-remote c: watch-tower c: 1)
	=>
	(up-filter-exclude -1 actionid-explore -1 -1)
	(up-find-local c: CHAMP c: 240)
	(up-find-local c: my-unique-unit-line c: 240)
	(up-find-local c: knight-line c: 240)
	(up-find-local c: RAM c: 1)
;	(up-find-remote c: watch-tower c: 1)
	(up-target-objects 0 action-default -1 stance-defensive); stance-stand-ground
	(disable-timer T-duc-attack)
	(enable-timer T-duc-attack 5)
	(up-jump-rule 1))
(defrule
	(goal G-tower-response GV-wreck-it)
	(not	(up-set-target-object search-remote c: 0))
;	(not	(up-find-remote c: watch-tower c: 1))
	=>
;	(chat-to-player my-player-number "tower == rekt")
	(set-goal G-tower-response 0)
	(disable-timer T-duc-attack))

; == HIT CAMPS AWAY FROM TOWER ==
(defrule
	(or	(up-compare-goal G-tower-response != GV-duc-camps)
		(or	(up-compare-goal G-attack <= 0)
			(not	(up-set-target-object search-remote c: 0))))
	=>
	(up-jump-rule 9))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
;	(up-find-remote c: watch-tower c: 1)
	(up-set-target-object search-remote c: 0)
	(up-get-point position-object P-enemy-tower-x)
	(up-full-reset-search)
	(up-set-target-point P-enemy-tower-x)
	(up-filter-distance c: 11 c: 50)
	(up-find-remote c: lumber-camp c: 40)
	(up-find-remote c: mining-camp c: 40)
	(up-find-remote c: settlement c: 40)
	(up-find-remote c: mule-cart c: 40)
	(up-get-search-state G-local-total))
(defrule
	(goal G-remote-total 0)
	=>
;	(chat-to-player my-player-number "no juicy targets found")
	(disable-timer T-scout)
	(enable-timer T-scout 1)
	(disable-self))
(defrule
	(up-compare-goal G-remote-total > 0)
	=>
	(up-modify-goal G-temp2 c:= 0); current object
	(up-modify-goal G-temp3 c:= 255)); closest distance to home
(defrule;~~~~NEW CAMP~~~~
	(up-compare-goal G-remote-total > 0)
	(up-compare-goal G-temp2 g:< G-remote-total)
	=>
	(up-set-target-object search-remote g: G-temp2)
	(up-get-point position-object P-temp-x)
	(up-get-point-distance P-self-x P-temp-x G-temp4)); current object distance
(defrule
	(up-compare-goal G-remote-total > 0)
	(up-compare-goal G-temp2 g:< G-remote-total)
	(up-compare-goal G-temp4 g:< G-temp3); closer to home
	=>
	(up-modify-goal G-temp3 g:= G-temp4); new closest distance
	(up-modify-goal G-temp5 g:= G-temp2)); new target object number
(defrule
	(up-compare-goal G-remote-total > 0)
	(up-compare-goal G-temp2 g:< G-remote-total)
	=>
	(up-modify-goal G-temp2 c:+ 1)
	(up-jump-rule -3));~~~~ next camp
(defrule
	(up-compare-goal G-remote-total > 0)
	(up-timer-status T-duc-attack != timer-running)
	(up-set-target-object search-remote g: G-temp5)
	=>
	(up-get-object-data object-data-id G-temp6)
	(up-get-point position-object P-waypoint1-x)
;	(up-send-flare P-waypoint1-x)
;	(chat-to-player my-player-number "hitting this camp")
	(up-full-reset-search)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-filter-exclude -1 actionid-explore -1 -1)
	(up-find-local c: -1 c: 25)
;	(up-set-target-by-id g: G-temp6)
;	(up-target-objects 1 action-move -1 stance-stand-ground)
	(up-target-point P-waypoint1-x action-move -1 stance-stand-ground)
	(disable-timer T-duc-attack)
	(enable-timer T-duc-attack 35))
(defrule
	(up-compare-goal G-remote-total > 0)
	(up-timer-status T-5 != timer-running); test
	=>
	(up-set-attack-stance -1 c: stance-defensive))
(defrule
	(up-compare-goal G-remote-total > 0)
	(up-timer-status T-duc-attack == timer-running)
	=>
	(up-full-reset-search)
	(up-set-target-point P-enemy-tower-x)
	(up-filter-distance c: -1 c: 10)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-filter-exclude -1 actionid-explore -1 -1)
	(up-find-local c: -1 c: 25)
	(up-target-point P-waypoint1-x action-move -1 stance-no-attack))
;-----------------------------------------------------------------------

; ====================
; ==== TREB MICRO ====
; ====================
(defrule
	(or	(up-timer-status T-10 != timer-disabled)
		(or	(unit-type-count packed-trebuchet-class <= 0)
			(and	(up-building-type-in-town c: castle <= 0)
				(up-building-type-in-town c: krepost <= 0))))
	=>
	(up-jump-rule 4))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-full-reset-search)
	(up-find-local c: packed-trebuchet-class c: 40)
	; (up-find-local c: unpacked-trebuchet-class c: 40)
	(up-remove-objects search-local object-data-target == unpacked-trebuchet-class)
	(up-remove-objects search-local object-data-target == siege-weapon-class)
	(up-set-target-point P-self-x)
	(up-filter-distance c: -1 s: sn-maximum-town-size)
	(set-strategic-number sn-focus-player-number 1))
(defrule;~~~~
	(stance-toward focus-player ally)
	(strategic-number sn-focus-player-number < PLAYERCOUNT)
	=>
	(up-modify-sn sn-focus-player-number c:+ 1)
	(up-jump-rule -1))
(defrule
	(not	(stance-toward focus-player ally))
	(strategic-number sn-focus-player-number <= PLAYERCOUNT)
	=>
	(up-find-remote c: castle c: 40)
	(up-find-remote c: krepost c: 40)
	(up-find-remote c: tower-class c: 40)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(up-jump-rule -2));~~~~
(defrule
	(up-set-target-object search-remote c: 0)
	=>
	(up-target-objects 0 action-default -1 stance-stand-ground))
;-----------------------------------------------------------------------

; =======================
; ==== DEAL WITH RAM ====
; =======================
(defrule
;	(up-timer-status T-5 == timer-disabled)
	(or	(up-unit-type-in-town c: battering-ram-line > 0)
		(up-unit-type-in-town c: armored-elephant-line > 0))
	(town-under-attack)
	=>
	(set-goal G-temp0 281616)
	(up-full-reset-search)
	(up-filter-range 1 -1 -1 -1); minimum garrison of 1
	(up-find-local c: town-center c: 5)
	(up-find-local c: castle c: 10)
	(up-find-local c: krepost c: 10)
	(up-find-local c: tower-class c: 40)
	(up-remove-objects search-local object-data-attacker-count < 1)
	(up-get-search-state G-local-total))
(defrule
	(goal G-temp0 281616)
	(up-compare-goal G-local-total > 0)
	=>
	(set-goal G-temp0 281617)
	(set-goal G-temp1 0))
(defrule; ~~~~
	(goal G-temp0 281617)
	(up-compare-goal G-temp1 g:< G-local-total)
	(up-set-target-object search-local g: G-temp1)
	(up-get-object-data object-data-id G-temp3); building
	(up-get-object-data object-data-attacker-id ID-target-ram)
	(up-set-target-by-id g: ID-target-ram)
	(or	(up-object-data object-data-base-type == feudal-battering-ram)
		(up-object-data object-data-base-type == armored-elephant))
	=>
	(up-full-reset-search)
	(up-add-object-by-id search-local g: G-temp3)
	(up-set-target-by-id g: ID-target-ram)
	(up-target-objects 1 action-gather -1 -1); set gather point
	(up-target-point 0 action-unload -1 -1)
	(set-strategic-number sn-disable-villager-garrison 3)
	(enable-timer T-duc-secondary 6); keep auto-garrison off for 6 seconds
;	(chat-to-all "ejecting vills to attack ram")
	(up-jump-rule 1))
(defrule
	(goal G-temp0 281617)
	(up-compare-goal G-temp1 g:< G-local-total)
	=>
	(up-modify-goal G-temp1 c:+ 1)
	(up-jump-rule -2)); ~~~~
(defrule
	(goal G-temp0 281616)
	(strategic-number sn-disable-villager-garrison == 3)
	(up-set-target-by-id g: ID-target-ram)
	(up-object-data object-data-attacker-count < 6)
	(or	(up-object-data object-data-hitpoints > 30)
		(up-object-data object-data-attacker-count < 1))
	=>
	(up-full-reset-search)
	(up-get-point position-object P-x)
	(up-set-target-point P-x)
	(up-filter-distance c: -1 c: 4)
	(up-find-local c: villager-class c: 20)
	(up-clean-search search-local object-data-distance search-order-asc)
	(up-remove-objects search-local object-data-index >= 6)
;	(chat-to-all "tasking vills to ram")
	(up-target-objects 1 action-default -1 -1))


; ========================
; ==== BUILDING MICRO ====
; ========================
; tower bug quick fix
(defrule
	(building-type-count tower-class > 0)
	=>
	(up-full-reset-search)
	(up-filter-include -1 actionid-explore -1 -1)
	(up-find-local c: tower-class c: 40)
	(up-find-local c: castle c: 40))
(defrule
	(building-type-count tower-class > 0)
	(up-set-target-object search-local c: 0)
	=>
	(chat-to-all "resetting bugged tower")
	(up-target-point P-self-x action-stop -1 -1))


