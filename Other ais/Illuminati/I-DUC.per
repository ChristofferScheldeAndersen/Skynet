	(up-copy-point P-temp-x P-object-x)
	(up-lerp-tiles P-temp-x P-x g: G-temp4)
	(up-cross-tiles P-temp-x P-x g: G-temp5))
(defrule
	(goal G-temp8 688052)
	(goal G-temp9 688053)
