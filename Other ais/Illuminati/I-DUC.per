; == HERESY CHECK ==
(defrule
	(up-timer-status T-10 == timer-disabled)
	(players-building-count target-player > 0)
	=>
	(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
	(up-full-reset-search)
	(up-find-remote c: -1 c: 1)
	(up-set-target-object search-remote c: 0)
	(up-get-object-data object-data-heresy G-heretic))

; =====================
; ==== SHEEP MICRO ====
; =====================

; === GRAB FOUND SHEEP ===
(defrule
	(or	(up-compare-goal G-age >= GV-upcastle)
		(or	(not	(up-set-target-by-id g: ID-myscout))
			(up-compare-goal G-scouting > GV-home)))
	=>
	(up-jump-rule 7))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-modify-goal G-temp1 g:= G-sheep-count)
	(up-get-fact unit-type-count livestock-class G-sheep-count))
(defrule
	(up-gaia-type-count c: livestock-class g:> G-sheep-count)
	(up-compare-goal G-scout-unit > 0)
	=>
	(set-strategic-number sn-focus-player-number 0)
	(up-full-reset-search)
;	(up-set-target-point P-scout-x)
;	(up-filter-distance c: -1 c: 5)
;	(up-find-local g: G-scout-unit c: 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-set-target-point P-self-x)
	(up-filter-distance c: 3 c: 36)
	(up-find-remote c: livestock-class c: 1)
	(up-target-objects 0 action-move -1 -1)
	(set-goal G-sheepshagger 1)
	(up-jump-rule 1))
(defrule
	(goal G-sheepshagger 1)
	=>
	(up-reset-scouts)
	(set-goal G-sheepshagger 0))
(defrule
	(goal G-sheepshagger 1)
	(up-compare-goal G-sheep-count g:> G-temp1)
	=>
	(up-reset-scouts)
	(set-goal G-sheepshagger 0))
(defrule; gather at lc (ln start)
	(goal G-starting-tcs 0)
	(building-type-count town-center < 1)
	(or	(building-type-count lumber-camp >= 1)
		(building-type-count settlement >= 1))
	(up-compare-goal P-self-precise-x > 0)
	(up-compare-goal G-sheep-count g:> G-temp1)
	=>
	(up-modify-goal P-temp-x g:= P-self-precise-x)
	(up-modify-goal P-temp-y g:= P-self-precise-y)
	(up-set-precise-target-point P-self-precise-x)
	(up-full-reset-search)
	(up-filter-distance c: 0 c: 5); i don't know if this even works with precise target point?
	(up-find-local c: villager-wood c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-precise-x P-x)
	(up-get-object-data object-data-precise-y P-y)
	(up-lerp-tiles P-temp-x P-x c: 200)
	(up-full-reset-search)
	(up-find-local c: livestock-class c: 240)
	(set-strategic-number sn-target-point-adjustment 6)
	(up-target-point P-temp-x action-move -1 -1)
	(set-strategic-number sn-target-point-adjustment 5))
(defrule; gather at tc
;	(goal G-starting-tcs 0)
	(building-type-count town-center >= 1)
	(up-compare-goal P-self-precise-x > 0)
	(up-compare-goal G-sheep-count g:> G-temp1)
	=>
	(up-modify-goal P-temp-x g:= P-self-precise-x)
	(up-modify-goal P-temp-y g:= P-self-precise-y)
	(up-modify-goal P-temp-x c:- 200)
	(up-modify-goal P-temp-y c:+ 200)
	(up-set-precise-target-point P-self-precise-x)
	(up-full-reset-search)
	(up-filter-distance c: 4 c: 255)
	(up-find-local c: livestock-class c: 240)
	(set-strategic-number sn-target-point-adjustment 6)
	(up-target-point P-temp-x action-move -1 -1)
	(set-strategic-number sn-target-point-adjustment 5))
(defrule; count sheep
	(up-compare-goal G-sheep-count g:> G-temp1)
	=>
	(up-modify-goal G-temp2 g:= G-sheep-count)
	(up-modify-goal G-temp2 g:- G-temp1)
	(up-modify-goal G-sheep-total g:+ G-temp2))
;	(up-chat-data-to-self "sheep total: %d" g: G-sheep-total))
;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-scouting > GV-home)
	=>
	(set-goal G-sheepshagger 0)
	(disable-self))
(defrule
	(current-age > feudal-age)
	=>
	(set-goal G-sheepshagger 0)
	(disable-self))

; == NOMAD GATHER ==
(defrule; lc
	(goal G-starting-tcs 0)
	(building-type-count town-center < 1)
	(or	(building-type-count lumber-camp >= 1)
		(building-type-count settlement >= 1))
	(up-compare-goal P-self-precise-x > 0)
	=>
	(up-modify-goal P-temp-x g:= P-self-precise-x)
	(up-modify-goal P-temp-y g:= P-self-precise-y)
	(up-set-precise-target-point P-self-precise-x)
	(up-full-reset-search)
	(up-filter-distance c: 0 c: 5)
	(up-find-local c: villager-wood c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-precise-x P-x)
	(up-get-object-data object-data-precise-y P-y)
	(up-lerp-tiles P-temp-x P-x c: 200)
	(up-full-reset-search)
	(up-find-local c: livestock-class c: 240)
	(set-strategic-number sn-target-point-adjustment 6)
	(up-target-point P-temp-x action-move -1 -1)
	(set-strategic-number sn-target-point-adjustment 5)
	(disable-self))
(defrule; tc
	(goal G-starting-tcs 0)
	(building-type-count town-center >= 1)
	(up-compare-goal P-self-precise-x > 0)
	=>
	(up-modify-goal P-temp-x g:= P-self-precise-x)
	(up-modify-goal P-temp-y g:= P-self-precise-y)
	(up-modify-goal P-temp-x c:- 200)
	(up-modify-goal P-temp-y c:+ 200)
	(up-set-precise-target-point P-self-precise-x)
	(up-full-reset-search)
	(up-find-local c: livestock-class c: 240)
	(set-strategic-number sn-target-point-adjustment 6)
	(up-target-point P-temp-x action-move -1 -1)
	(set-strategic-number sn-target-point-adjustment 5)
	(disable-self))
	
; === SHEEP SCOUTING ===





; =============================
; ==== DARK AGE VILL MICRO ====
; =============================
; == vills to first sheep ==
(defrule
	(unit-type-count villager <= 10)
	(housing-headroom > 1)
	(dropsite-min-distance boar-hunting > 2)
	(dropsite-min-distance deer-hunting > 2)
	(up-get-fact unit-type-count villager-shepherd G-temp1)
	(up-get-fact unit-type-count villager G-temp2)
	(up-compare-goal G-temp1 < 6)
	(up-compare-goal G-temp1 g:< G-temp2)
	=>
	(up-modify-goal G-temp2 c:- 1)
	(set-goal G-temp7 422247))
(defrule
	(goal G-temp7 422247)
	(up-compare-goal G-temp1 g:< G-temp2)
	=>
	(up-full-reset-search)
	(up-set-target-point P-self-x)
	(up-filter-distance c: -1 c: -1)
	(up-modify-sn sn-focus-player-number c:= my-player-number)
	(up-filter-exclude -1 actionid-build -1 -1)
	(set-goal G-temp7 422248))
(defrule
	(goal G-temp7 422248)
	(up-find-local c: villager-class c: 6)
	(up-set-target-object search-local c: 0)
	=>
	(up-filter-distance c: -1 c: 4)
	(up-find-remote c: livestock-class c: 1)
	(set-goal G-temp7 422249)
	(disable-self))
(defrule
	(goal G-temp7 422249)
	(up-set-target-object search-remote c: 0)
	=>
;	(chat-to-player my-player-number "retasking vills to sheep")
	(up-target-objects 0 action-default -1 -1)
	(disable-self))

; == shepherds to boar ==
(defrule
	(goal G-age GV-dark)
	=>
	(set-goal G-temp1 0))
(defrule
	(goal G-age GV-dark)
	(up-set-target-by-id g: ID-current-boar)
	(up-object-data object-data-hitpoints <= 0)
	=>
	(up-get-object-data object-data-carry G-temp2)
	(up-modify-goal G-temp2 c:+ 50)
	(up-modify-goal G-temp2 c:min 340)
	(up-modify-goal G-temp1 g:+ G-temp2))
(defrule
	(goal G-age GV-dark)
	(up-set-target-by-id g: ID-old-boar)
	(up-object-data object-data-hitpoints <= 0)
	=>
	(up-get-object-data object-data-carry G-temp2)
	(up-modify-goal G-temp2 c:+ 50)
	(up-modify-goal G-temp2 c:min 340)
	(up-modify-goal G-temp1 g:+ G-temp2))
(defrule
	(goal G-age GV-dark)
	(up-set-target-by-id g: ID-deer1)
	(up-object-data object-data-hitpoints <= 0)
	=>
	(up-get-object-data object-data-carry G-temp2)
	(up-modify-goal G-temp1 g:+ G-temp2))
(defrule
	(goal G-age GV-dark)
	(up-set-target-by-id g: ID-deer2)
	(up-object-data object-data-hitpoints <= 0)
	=>
	(up-get-object-data object-data-carry G-temp2)
	(up-modify-goal G-temp1 g:+ G-temp2))
(defrule
	(goal G-age GV-dark)
	(up-compare-goal G-temp1 > 0)
	=>
	(up-modify-goal G-temp1 c:/ 50)
	(up-get-fact unit-type-count villager G-temp2)
	(up-modify-goal G-temp2 c:* 3)
	(up-modify-goal G-temp2 c:/ 5)
	(up-modify-goal G-temp1 g:min G-temp2))
;	(up-chat-data-to-player my-player-number "desired hunters: %d" g: G-temp1))
(defrule
	(goal G-age GV-dark)
	(unit-type-count villager-hunter g:< G-temp1)
	(or	(up-set-target-by-id g: ID-old-boar)
		(up-set-target-by-id g: ID-current-boar))
	(up-object-data object-data-hitpoints <= 0)
	=>
	(set-goal G-temp9 14531945)
	(up-get-fact unit-type-count villager-hunter G-temp3)
	(up-modify-goal G-temp1 g:- G-temp3)
;	(up-chat-data-to-player my-player-number "i want %d more hunters" g: G-temp1)
	(up-full-reset-search)
	(up-set-target-point P-self-x)
	(up-filter-distance c: -1 c: 4)
	(up-find-local c: villager-class c: 240)
	(up-get-search-state G-local-total))
(defrule
	(goal G-temp9 14531945)
	=>
	(up-modify-goal G-temp7 g:= ID-current-boar)
	(set-goal G-temp4 1)
	(up-reset-search 1 1 1 1)
	(up-find-local c: villager-class c: 1))
(defrule
	(goal G-temp9 14531945)
	(up-set-target-by-id g: ID-old-boar)
	(up-object-data object-data-carry > 20)
	=>
	(up-modify-goal G-temp7 g:= ID-old-boar))
(defrule;~~~~
	(goal G-temp9 14531945)
	(up-compare-goal G-temp1 > 0)
	(up-set-target-object search-local c: 0)
	(up-object-data object-data-target == livestock-food)
	=>
;	(chat-to-all "tasking a vill to the boar")
	(up-modify-goal G-temp1 c:- 1)
	(up-set-target-by-id g: G-temp7)
	(up-target-objects 1 action-default -1 -1))
(defrule
	(goal G-temp9 14531945)
	(up-compare-goal G-temp1 > 0)
	(up-compare-goal G-temp4 g:< G-local-total)
	=>
	(up-reset-search 0 1 0 0)
	(up-find-local c: villager-class c: 1)
	(up-modify-goal G-temp4 c:+ 1)
	(up-jump-rule -2));~~~~

; == foragers to farms ==
(defrule
	(up-compare-goal G-age <= GV-feudal)
	(unit-type-count villager-forager > 5)
	(strategic-number SN-idle-farm-count > 0)
	=>
	(up-full-reset-search)
	(up-modify-sn sn-focus-player-number c:= my-player-number)
	(up-find-remote c: farm c: 40)
	(up-remove-objects search-remote object-data-tasks-count > 0)
	(up-remove-objects search-remote object-data-index > 0)
	(up-set-target-object search-remote c: 0)
	(up-get-point position-object P-x)
	(up-set-target-point P-x)
	(up-find-local c: villager-forager-m c: 8)
	(up-find-local c: villager-forager-f c: 8))
(defrule
	(up-compare-goal G-age <= GV-feudal)
	(unit-type-count villager-forager > 5)
	(strategic-number SN-idle-farm-count > 0)
	=>
;	(chat-to-all "tasking forager to farm")
	(up-clean-search search-local object-data-distance search-order-asc)
	(up-remove-objects search-local object-data-index > 0)
	(up-target-objects 0 action-default -1 -1))

; ===================
; ==== DEER LURE ====
; ===================
(defrule
	(or	(up-compare-goal G-scouting != GV-deerlure)
		(not	(up-set-target-by-id g: ID-myscout)))
	=>
	(up-jump-rule 9))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(set-strategic-number sn-focus-player-number 0))
(defrule
	(dropsite-min-distance deer-hunting <= 32)
	=>
	(up-set-target-point P-self-x)
	(up-full-reset-search)
	(up-filter-distance c: -1 c: 33)
	(up-find-remote c: deer-class c: 1)
	(up-remove-objects search-remote object-data-carry < 36)
	(up-remove-objects search-remote object-data-type == 2084); chicken
	(up-remove-objects search-remote object-data-type == 2086); chicken
	(up-remove-objects search-remote object-data-type == 2088); chicken
	(up-remove-objects search-remote object-data-type == 2098); chicken
	(up-remove-objects search-remote object-data-type == 2099); chicken
	(up-remove-objects search-remote object-data-type == 2100); chicken
	(up-get-search-state G-local-total))
(defrule
	(goal G-remote-total 0)
	=>
	(set-goal ID-target-deer -1)
	(set-goal G-scouting GV-enemy)
;	(set-strategic-number sn-number-explore-groups 0)
;	(set-strategic-number sn-total-number-explorers 0)
;	(chat-to-player my-player-number "start searching for enemy")
	(up-modify-goal G-boarsteal c:+ 1)
	(up-modify-sn sn-number-explore-groups c:- 1)
	(up-modify-sn sn-total-number-explorers c:- 1)
;	(chat-to-player my-player-number "no deer found. scouting enemy")
	(up-reset-scouts)
	(up-jump-rule 4))
	;-----------------------------------------------------------------------
(defrule
	(dropsite-min-distance deer-hunting <= 32)
	(goal ID-target-deer -1)
	=>
	(up-full-reset-search)
	(up-set-target-point P-self-x)
	(up-filter-distance c: 7 c: 33)
	(up-find-remote c: deer-class c: 8)
	(up-remove-objects search-remote object-data-carry < 20)
	(up-remove-objects search-remote object-data-type == 2084); chicken
	(up-remove-objects search-remote object-data-type == 2086); chicken
	(up-remove-objects search-remote object-data-type == 2088); chicken
	(up-remove-objects search-remote object-data-type == 2098); chicken
	(up-remove-objects search-remote object-data-type == 2099); chicken
	(up-remove-objects search-remote object-data-type == 2100); chicken
	(up-clean-search search-remote object-data-distance search-order-asc)
	(up-set-target-object search-remote c: 0)
;	(up-get-point position-object P-object-x)
	(up-get-object-data object-data-id ID-target-deer))
(defrule
	(up-set-target-by-id g: ID-target-deer)
	=>
	(up-full-reset-search)
	(up-find-local g: G-scout-unit c: 1)
	(up-set-target-by-id g: ID-target-deer)
	(up-get-point position-object P-object-x)
	(up-get-object-data object-data-precise-x P-x)
	(up-get-object-data object-data-precise-y P-y)
	(up-lerp-tiles P-x P-self-precise-x c: -100)
	(up-bound-precise-point P-x 1 c: 0)
	(set-strategic-number sn-target-point-adjustment 6)
	(up-target-point P-x action-move -1 -1)
	(set-strategic-number sn-target-point-adjustment 5))
(defrule
	(up-set-target-by-id g: ID-target-deer)
	(up-point-distance P-self-x P-object-x <= 8)
	(up-object-data object-data-hitpoints == 0)
	=>
	(up-modify-goal ID-deer2 g:= ID-deer1)
	(up-modify-goal ID-deer1 g:= ID-target-deer)
	(set-goal ID-target-deer -1)
	(up-modify-goal G-deers-lured c:+ 1)
	(set-goal G-eat-deer 1))
(defrule
	(up-set-target-by-id g: ID-target-deer)
	(up-object-data object-data-hitpoints == 0)
	=>
	(set-goal ID-target-deer -1)
	(up-modify-goal G-deers-lured c:+ 1)
	(set-goal G-eat-deer 1))
	;-----------------------------------------------------------------------
; == kill lured deer ==
(defrule
	(up-compare-goal ID-target-deer != -1)
	(up-set-target-by-id g: ID-target-deer)
	(up-object-data object-data-resource == food)
	(goal G-2nd-tick 0)
	=>
	(up-get-point position-object P-object-x))
(defrule
	(up-compare-goal ID-target-deer != -1)
	(up-set-target-by-id g: ID-target-deer)
	(up-object-data object-data-resource == food)
	(up-point-distance P-object-x P-self-x <= 5); 6
	(goal G-2nd-tick 0)
	=>
;	(chat-to-player my-player-number "kill deer")
	(up-full-reset-search)
	(up-set-target-point P-self-x)
	(up-filter-range -1 -1 -1 6)
	(up-find-local c: villager-class c: 10)
	(up-clean-search search-remote object-data-gather-type search-order-asc)
	(up-remove-objects search-local object-data-index > 3)
	(up-set-target-by-id g: ID-target-deer)
	(up-target-objects 1 action-default -1 -1))
;-----------------------------------------------------------------------

; == eat old deer ==
(defrule
	(or	(up-compare-goal G-eat-deer != 1)
		(goal ID-deer2 -1))
	=>
	(up-jump-rule 2))
;-----------------------------------------------------------------------
(defrule
	(up-set-target-by-id g: ID-deer2)
	=>
	(up-get-point position-object P-object-x))
(defrule
	(up-point-distance P-object-x P-self-x < 8)
	(up-object-data object-data-hitpoints == 0)
	=>
	(up-full-reset-search)
	(up-set-target-point P-self-x)
	(up-filter-range -1 -1 -1 7)
	(up-find-local c: villager-class c: 2)
	(up-set-target-by-id g: ID-deer2)
	(up-target-objects 1 action-default -1 -1))
;-----------------------------------------------------------------------
(defrule
	(goal G-eat-deer 1)
	=>
	(set-goal G-eat-deer 0))

; ===================
; ==== BOAR LURE ====
; ===================
; == RELURE / FAILSAFE ==
(defrule
;	(goal G-2nd-tick 1)
	(up-timer-status T-boar != timer-running); for some reason it triggers multiple times without timer
	(up-compare-goal G-boar-mode != GV-hunt-1st)
	(up-compare-goal G-boar-mode != GV-hunt-2nd)
	(up-compare-goal ID-current-boar != -1)
	(up-set-target-by-id g: ID-boarlurer)
	(or	(up-object-data object-data-action != actionid-hunt)
		(up-object-data object-data-target == deer-class))
	(up-set-target-by-id g: ID-current-boar)
	(up-object-data object-data-hitpoints > 0)
	(up-object-data object-data-action != actionid-attack)
	(dropsite-min-distance live-boar > 5)
	=>
;	(chat-to-player my-player-number "relure")
	(enable-timer T-boar 15)
	(up-modify-goal G-boar-mode c:- 1))
(defrule
;	(goal G-2nd-tick 1)
	(up-timer-status T-boar != timer-running); for some reason it triggers multiple times without timer
	(up-compare-goal G-boar-mode != GV-hunt-1st)
	(up-compare-goal G-boar-mode != GV-hunt-2nd)
	(up-compare-goal ID-current-boar != -1)
	(not	(up-set-target-by-id g: ID-boarlurer))
	(up-set-target-by-id g: ID-current-boar)
	(up-object-data object-data-hitpoints > 0)
	(up-object-data object-data-action != actionid-attack)
	(dropsite-min-distance live-boar > 5)
	=>
;	(chat-to-player my-player-number "relure")
	(enable-timer T-boar 15)
	(up-modify-goal G-boar-mode c:- 1))
; == MAIN ==
(defrule
	(or	(and	(up-compare-goal G-boar-mode != GV-hunt-1st)
			(up-compare-goal G-boar-mode != GV-hunt-2nd))
		(up-timer-status T-boar == timer-running))
	=>
	(up-jump-rule 10))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(set-strategic-number sn-focus-player-number 0)
	(set-goal G-temp3 0); current TC
	(up-get-fact building-type-count town-center G-temp2))
(defrule; ~~NEW TC~~
	(up-compare-goal G-temp3 g:< G-temp2)
	=>
	(up-full-reset-search)
	(up-find-local c: town-center g: G-temp2)
	(up-set-target-object search-local g: G-temp3)
	(up-get-point position-object P-object-x))
(defrule
	(up-compare-goal G-temp3 g:< G-temp2)
;	(dropsite-min-distance live-boar >= 20)
	(dropsite-min-distance live-boar < 35)
	(dropsite-min-distance live-boar != -1)
	(up-research-status c: ri-loom >= research-pending)
	(goal ID-current-boar -1)
	=>
;	(chat-to-player my-player-number "find boar")
	(up-full-reset-search)
	(up-set-target-point P-object-x)
	(up-filter-distance c: 0 c: 37)
	(up-find-remote c: boar-class c: 3)
	(up-remove-objects search-remote object-data-carry < 150)
	(up-clean-search search-remote object-data-carry search-order-desc)
	(up-set-target-object search-remote c: 0)
	(up-get-search-state G-local-total))
(defrule
	(up-compare-goal G-temp3 g:< G-temp2)
	(dropsite-min-distance live-boar < 25)
	(dropsite-min-distance live-boar != -1)
	(goal ID-current-boar -1)
	=>
;	(chat-to-player my-player-number "find close boar")
	(up-full-reset-search)
	(up-set-target-point P-object-x)
	(up-filter-distance c: 0 c: 27)
	(up-find-remote c: boar-class c: 3)
	(up-remove-objects search-remote object-data-carry < 120)
	(up-clean-search search-remote object-data-carry search-order-desc)
	(up-set-target-object search-remote c: 0)
	(up-get-search-state G-local-total))
(defrule
	(up-compare-goal G-remote-total <= 0)
	(up-compare-goal G-temp3 g:< G-temp2)
	(dropsite-min-distance live-boar < 35)
	(dropsite-min-distance live-boar != -1)
	(goal ID-current-boar -1)
	=>
;	(chat-to-player my-player-number "check for boar near next TC")
	(up-modify-goal G-temp3 c:+ 1)
	(up-jump-rule -4));~~~~NEXT TC
(defrule
	(dropsite-min-distance live-boar < 35)
	(dropsite-min-distance live-boar != -1)
	(goal ID-current-boar -1)
	(up-compare-goal G-remote-total > 0)
	=>
;	(chat-to-player my-player-number "get boar ID")
	(up-modify-goal ID-old-boar g:= ID-current-boar)
	(up-get-object-data object-data-id ID-current-boar))
(defrule
	(dropsite-min-distance live-boar < 35)
	(dropsite-min-distance live-boar != -1)
	(up-compare-goal ID-current-boar != -1)
	=>
;	(chat-to-player my-player-number "boar valid, find vill")
	(up-full-reset-search)
	(up-set-target-point P-object-x); can this cause the next rule to freeze? i think not
	(up-filter-distance c: -1 c: 8)
	(up-find-local c: villager-class c: 1)
	(up-get-search-state G-local-total))
(defrule
	(dropsite-min-distance live-boar < 35)
	(dropsite-min-distance live-boar != -1)
;	(goal G-boar-mode GV-hunt-2nd)
	(up-compare-goal ID-current-boar != -1)
	(up-compare-goal G-local-total > 0)
	(up-set-target-object search-local c: 0)
	(up-object-data object-data-hitpoints < 35)
	(or	(up-object-data object-data-hitpoints < 25)
		(research-completed ri-loom))
	=>
;	(chat-to-player my-player-number "low hp vill, look again")
	(up-reset-search 0 1 0 0); exclude that cunt from next search
	(up-find-local c: villager-class c: 1)
	(up-jump-rule -1))
(defrule
	(dropsite-min-distance live-boar < 35)
	(dropsite-min-distance live-boar != -1)
	(up-compare-goal ID-current-boar != -1)
	(up-compare-goal G-local-total > 0)
	(up-set-target-object search-local c: 0)
	(up-object-data object-data-class == villager-class)
	=>
;	(chat-to-player my-player-number "lure boar")
	(disable-timer T-boar)
	(enable-timer T-boar 10)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-id ID-boarlurer)
	(up-set-target-by-id g: ID-current-boar)
	(up-target-objects 1 action-default -1 -1)
	(up-modify-goal G-boar-mode c:+ 1)
	(enable-timer T-boar 15)
	(up-jump-rule 1))
(defrule
	(up-compare-goal ID-current-boar != -1)
	(up-set-target-by-id g: ID-current-boar)
	(or	(up-object-data object-data-hitpoints <= 0)
		(up-object-data object-data-action == actionid-attack))
	=>
;	(chat-to-player my-player-number "boar mode failsafe")
	(up-modify-goal G-boar-mode c:+ 1))
;-----------------------------------------------------------------------
; == KILL BOAR ==
(defrule
	(or	(dropsite-min-distance live-boar >= BOARKILLDIST)
		(or	(up-compare-goal G-boar-mode < GV-hunt-1st)
			(up-timer-status T-killboar == timer-running)))
	=>
	(up-jump-rule 6))
;-----------------------------------------------------------------------
(defrule
	(or	(not	(up-set-target-by-id g: ID-stolen-boar))
		(and	(up-set-target-by-id g: ID-stolen-boar)
			(up-object-data object-data-hitpoints <= 0)))
	(or	(not	(up-set-target-by-id g: ID-current-boar))
		(and	(up-set-target-by-id g: ID-current-boar)
			(up-object-data object-data-hitpoints <= 0)))
	=>
	(up-jump-rule 5))
	;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(set-strategic-number sn-focus-player-number 0)
	(set-goal G-temp3 0); current TC
	(up-get-fact building-type-count town-center G-temp2))
(defrule; ~~NEW TC~~
	(up-compare-goal G-temp3 g:< G-temp2)
	=>
	(up-full-reset-search)
	(up-find-local c: town-center g: G-temp2)
	(up-set-target-object search-local g: G-temp3)
	(up-get-point position-object P-object-x)
	(up-reset-search 0 1 0 0); remove tcs from found object list
	(up-set-target-point P-object-x)
	(up-filter-distance c: -1 c: BOARKILLDIST)
	(up-find-remote c: boar-class c: 3)
	(up-remove-objects search-remote object-data-carry < 150)
	(up-clean-search search-remote object-data-carry search-order-desc)
	(set-goal G-temp1 0)
	(up-get-search-state G-local-total))
(defrule
	(up-compare-goal G-temp3 g:< G-temp2)
	(up-compare-goal G-remote-total g:> G-temp1)
	(up-set-target-object search-remote g: G-temp1)
	(up-object-data object-data-hitpoints <= 0)
	=>
	(up-modify-goal G-temp1 c:+ 1); if dead boar is found, target next one
	(up-jump-rule -1))
(defrule
	(up-compare-goal G-temp3 g:< G-temp2)
	(up-compare-goal G-remote-total g:> G-temp1)
	(up-set-target-object search-remote g: G-temp1)
	(up-object-data object-data-resource == food)
	(up-object-data object-data-hitpoints > 0)
	=>
	(disable-timer T-killboar)
	(enable-timer T-killboar 5)
	(up-filter-distance c: -1 c: 7)
	(up-find-local c: villager-class c: 20)
	(up-clean-search search-local object-data-gather-type search-order-asc)
	(up-remove-objects search-local object-data-index >= BOARKILLVILLS)
;	(chat-to-player my-player-number "kill boar")
	(up-target-objects 0 action-default -1 -1))
(defrule
	(up-compare-goal G-temp3 g:< G-temp2)
	=>
	(up-modify-goal G-temp3 c:+ 1)
	(up-jump-rule -4));~~~~NEXT TC
	;-----------------------------------------------------------------------
;-----------------------------------------------------------------------
; ====================
; ==== BOAR STEAL ====
; ====================
(defrule
	(or	(up-compare-goal G-boarsteal < 2)
		(up-compare-goal G-boarsteal >= GV-finalise))
	=>
	(up-jump-rule 33)) 
;-----------------------------------------------------------------------
; == find boar ==
(defrule
	(or	(players-building-type-count target-player town-center != 1)
		(up-compare-goal G-boarsteal > GV-searchboar4))
	=>
	(up-jump-rule 13))
	;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-copy-point P-waypoint1-x P-enemytc-x)
	(up-copy-point P-waypoint2-x P-enemytc-x)
	(up-copy-point P-waypoint3-x P-enemytc-x)
	(up-copy-point P-waypoint4-x P-enemytc-x)
	(up-modify-goal P-waypoint1-x c:+ 20)
	(up-modify-goal P-waypoint1-y c:+ 20)
	(up-modify-goal P-waypoint2-x c:- 20)
	(up-modify-goal P-waypoint2-y c:+ 21)
	(up-modify-goal P-waypoint3-x c:- 21)
	(up-modify-goal P-waypoint3-y c:- 21)
	(up-modify-goal P-waypoint4-x c:+ 21)
	(up-modify-goal P-waypoint4-y c:- 20)
	(disable-self))
(defrule
	(true)
	=>
	(up-modify-goal P-waypoint1-x c:max 1)
	(up-modify-goal P-waypoint1-y c:max 1)
	(up-modify-goal P-waypoint2-x c:max 1)
	(up-modify-goal P-waypoint2-y c:max 1)
	(up-modify-goal P-waypoint3-x c:max 1)
	(up-modify-goal P-waypoint3-y c:max 1)
	(up-modify-goal P-waypoint4-x c:max 1)
	(up-modify-goal P-waypoint4-y c:max 1)
	(disable-self))
(defrule
	(true)
	=>
	(up-modify-goal G-temp6 g:= G-mapsize)
	(up-modify-goal G-temp6 c:- 1)
	(up-modify-goal P-waypoint1-x g:min G-temp6)
	(up-modify-goal P-waypoint1-y g:min G-temp6)
	(up-modify-goal P-waypoint2-x g:min G-temp6)
	(up-modify-goal P-waypoint2-y g:min G-temp6)
	(up-modify-goal P-waypoint3-x g:min G-temp6)
	(up-modify-goal P-waypoint3-y g:min G-temp6)
	(up-modify-goal P-waypoint4-x g:min G-temp6)
	(up-modify-goal P-waypoint4-y g:min G-temp6)
	(disable-self))
(defrule
	(true)
	=>
	(up-get-point-distance P-scout-x P-waypoint1-x G-temp1)
	(up-get-point-distance P-scout-x P-waypoint2-x G-temp2)
	(up-get-point-distance P-scout-x P-waypoint3-x G-temp3)
	(up-get-point-distance P-scout-x P-waypoint4-x G-temp4)
	(up-get-point-distance P-self-x P-waypoint1-x G-temp5)
	(up-get-point-distance P-self-x P-waypoint2-x G-temp6)
	(up-get-point-distance P-self-x P-waypoint3-x G-temp7)
	(up-get-point-distance P-self-x P-waypoint4-x G-temp8)
	(up-modify-goal G-temp1 g:+ G-temp5)
	(up-modify-goal G-temp2 g:+ G-temp6)
	(up-modify-goal G-temp3 g:+ G-temp7)
	(up-modify-goal G-temp4 g:+ G-temp8)
	(disable-self))
(defrule
	(up-compare-goal G-boarsteal > 2)
	=>
	(up-jump-rule 4))
		;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-temp1 g:<= G-temp2)
	(up-compare-goal G-temp1 g:<= G-temp3)
	(up-compare-goal G-temp1 g:<= G-temp4)
	=>
	(disable-timer T-scout)
