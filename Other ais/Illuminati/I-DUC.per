	(up-target-point P-waypoint2-x action-move -1 stance-stand-ground)
	(set-goal G-first-scoutpoint 2)
	(set-goal G-boarsteal GV-searchboar2))
(defrule
	(up-compare-goal G-temp3 g:<= G-temp2)
	(up-compare-goal G-temp3 g:<= G-temp1)
	(up-compare-goal G-temp3 g:<= G-temp4)
	=>
	(disable-timer T-scout)
	(enable-timer T-scout 4)
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint3-x action-move -1 stance-stand-ground)
	(set-goal G-first-scoutpoint 3)
	(set-goal G-boarsteal GV-searchboar3))
(defrule
	(up-compare-goal G-temp4 g:<= G-temp2)
	(up-compare-goal G-temp4 g:<= G-temp3)
	(up-compare-goal G-temp4 g:<= G-temp1)
	=>
	(disable-timer T-scout)
	(enable-timer T-scout 4)
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint4-x action-move -1 stance-stand-ground)
	(set-goal G-first-scoutpoint 4)
	(set-goal G-boarsteal GV-searchboar4))
		;-----------------------------------------------------------------------
(defrule
	(goal G-boarsteal GV-searchboar4)
	(or	(up-point-distance P-scout-x P-waypoint4-x < 2)
		(up-compare-goal G-scoutidle >= 1))
	(up-timer-status T-scout != timer-running)
	(up-set-target-by-id g: ID-myscout)
	=>
	(disable-timer T-scout)
