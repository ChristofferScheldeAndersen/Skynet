	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint1-x action-move -1 stance-stand-ground)
	(set-goal G-first-scoutpoint 1)
	(set-goal G-boarsteal GV-searchboar1))
(defrule
	(up-compare-goal G-temp2 g:<= G-temp1)
	(up-compare-goal G-temp2 g:<= G-temp3)
	(up-compare-goal G-temp2 g:<= G-temp4)
	=>
	(disable-timer T-scout)
	(enable-timer T-scout 4)
	(up-reset-search 1 1 1 1)
