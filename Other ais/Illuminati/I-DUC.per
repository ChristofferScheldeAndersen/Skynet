		(up-compare-goal G-scoutidle >= 1))
	(up-timer-status T-scout != timer-running)
	(up-set-target-by-id g: ID-myscout)
	=>
	(disable-timer T-scout)
	(enable-timer T-scout 10)
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint2-x action-move -1 stance-stand-ground)
	(set-goal G-boarsteal GV-searchboar2))
(defrule
	(goal G-boarsteal GV-searchboar2)
	(or	(up-point-distance P-scout-x P-waypoint2-x < 2)
		(up-compare-goal G-scoutidle >= 1))
	(up-timer-status T-scout != timer-running)
	(up-set-target-by-id g: ID-myscout)
	=>
	(disable-timer T-scout)
	(enable-timer T-scout 10)
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint3-x action-move -1 stance-stand-ground)
	(set-goal G-boarsteal GV-searchboar3))
(defrule
	(goal G-boarsteal GV-searchboar3)
	(or	(up-point-distance P-scout-x P-waypoint3-x < 2)
		(up-compare-goal G-scoutidle >= 1))
	(up-timer-status T-scout != timer-running)
	(up-set-target-by-id g: ID-myscout)
	=>
	(disable-timer T-scout)
	(enable-timer T-scout 10)
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint4-x action-move -1 stance-stand-ground)
	(set-goal G-boarsteal GV-searchboar4))
	;-----------------------------------------------------------------------
(defrule
	(or	(up-compare-goal ID-stolen-boar c:!= -1)
		(or	(up-compare-goal G-boarsteal > GV-searchboar4)
			(up-compare-goal G-scouting < GV-enemy)))
	=>
	(up-jump-rule 6))
	;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(set-goal G-remote-total -1))
(defrule
	(players-building-type-count target-player town-center > 0)
	(up-compare-goal P-enemytc-x > 0)
	=>
	(up-modify-sn sn-focus-player-number c:= 0)
	(up-set-target-point P-enemytc-x)
	(up-reset-search 1 1 1 1)
	(up-filter-distance c: 10 c: 37)
	(up-find-remote c: boar-class c: 5)
	(up-remove-objects search-remote object-data-carry < 150)
	(up-clean-search search-remote object-data-carry search-order-desc)
	(up-get-search-state G-local-total))
#load-if-not-defined YUCATAN-MAP
(defrule
	(or	(up-compare-goal G-gametype == GAMETYPE-1v1); don't steal your ally's boar
		(up-compare-goal G-gametype == GAMETYPE-1vX))
	(players-building-type-count target-player town-center == 0)
	=>
	(up-modify-sn sn-focus-player-number c:= 0)
	(up-full-reset-search)
	(up-set-target-point P-self-x)
	(up-filter-distance c: 45 c: 120)
	(up-find-remote c: boar-class c: 5)
	(up-remove-objects search-remote object-data-carry < 150)
	(up-clean-search search-remote object-data-carry search-order-desc)
	(up-get-search-state G-local-total))
(defrule (true) => (disable-self)); dummy rule for jump consistency
#else
(defrule
	(players-building-type-count target-player town-center == 0)
	(players-building-count target-player > 0)
	=>
	(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
	(up-full-reset-search)
	(up-filter-include cmdid-military-building -1 -1 -1)
	(up-find-remote c: -1 c: 5)
	(up-filter-include cmdid-civilian-building -1 -1 -1)
	(up-find-remote c: -1 c: 5)
	(up-set-target-object search-remote c: 0)
	(set-goal P-temp-x -40)
	(set-goal P-temp-y -40)
	(up-get-point position-object P-temp-x))
(defrule
	(players-building-type-count target-player town-center == 0)
	(players-building-count target-player > 0)
	=>
	(up-modify-sn sn-focus-player-number c:= 0)
	(up-full-reset-search)
	(up-set-target-point P-temp-x)
	(up-filter-distance c: -1 c: 40)
	(up-find-remote c: boar-class c: 5)
	(up-remove-objects search-remote object-data-carry < 150)
	(up-clean-search search-remote object-data-carry search-order-desc)
	(up-get-search-state G-local-total))
#end-if
(defrule
	(up-compare-goal G-remote-total c:> 0)
	(up-set-target-object search-remote c: 0)
	(up-object-data object-data-hitpoints > 0)
	(nand	(up-object-data object-data-action == actionid-attack)
		(up-object-data object-data-target == villager-class))
	=>
	(up-get-point position-object P-object-x)
;	(up-send-flare P-object-x)
	(disable-timer T-scout)
	(up-get-object-data object-data-id ID-stolen-boar)
	(set-goal G-scouting GV-boarsteal)
	(set-goal G-boarsteal GV-move-boar)
	(up-jump-rule 1))
(defrule
	(up-compare-goal G-remote-total c:> 1)
	(up-set-target-object search-remote c: 1)
	(up-object-data object-data-hitpoints > 0)
	(nand	(up-object-data object-data-action == actionid-attack)
		(up-object-data object-data-target == villager-class))
	=>
	(up-get-point position-object P-object-x)
;	(up-send-flare P-object-x)
	(disable-timer T-scout)
	(up-get-object-data object-data-id ID-stolen-boar)
	(set-goal G-scouting GV-boarsteal)
	(set-goal G-boarsteal GV-move-boar))
	;-----------------------------------------------------------------------
(defrule
	(or	(up-compare-goal G-boarsteal < GV-move-boar)
		(or	(up-compare-goal G-boarsteal >= GV-done-boar)
			(up-compare-goal ID-stolen-boar < 0)))
	=>
	(up-jump-rule 11))
	;-----------------------------------------------------------------------
(defrule; failsafe if boar gets killed early
	(up-compare-goal G-boarsteal < GV-finalise)
	(or	(not	(up-set-target-by-id g: ID-stolen-boar))
		(and	(up-set-target-by-id g: ID-stolen-boar)
			(up-object-data object-data-hitpoints <= 0)))
	=>
	(set-goal G-boarsteal GV-done-boar)
	(chat-local-to-self "boar dead, abort boar steal"))
(defrule
	(game-time > 0)
	=>
	(up-set-target-by-id g: ID-myscout)
	(up-get-object-data object-data-precise-x P-temp-x)
	(up-get-object-data object-data-precise-y P-temp-y)
	(up-get-point position-object P-scout-x)); refresh regular scout coords too, because it's half a tick later
(defrule
	(goal G-boarsteal GV-move-boar)
	=>
	(up-set-target-by-id g: ID-stolen-boar)
	(up-get-point position-object P-object-x)
;	(up-send-flare P-object-x)
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-objects 1 action-move -1 stance-no-attack))
(defrule
	(up-compare-goal ID-stolen-boar c:> 0)
	(up-compare-goal G-boarsteal c:== GV-move-boar)
	(up-point-distance P-object-x P-scout-x c:< 2)
	=>
	(set-goal G-boarsteal GV-attack-boar))
(defrule
	(goal G-boarsteal GV-attack-boar)
	(up-compare-goal ID-stolen-boar c:> 0)
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-set-target-by-id g: ID-stolen-boar)
	(up-target-objects 1 action-default -1 stance-aggressive))
(defrule
	(goal G-boarsteal GV-attack-boar)
	(up-compare-goal ID-stolen-boar c:> 0)
	(up-object-data object-data-action == actionid-attack)
	(up-object-data object-data-target-id g:== ID-myscout)
	=>
	(set-goal G-boarsteal GV-lure-boar))
(defrule
	(goal G-boarsteal GV-lure-boar)
	(up-compare-goal ID-stolen-boar c:> 0)
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-set-target-by-id g: ID-stolen-boar)
	(up-set-precise-target-point P-temp-x))
(defrule
	(goal G-boarsteal GV-lure-boar)
	(up-compare-goal ID-stolen-boar c:> 0)
	(up-object-data object-data-to-precise >= 300)
	=>
	(up-target-point P-scout-x action-stop -1 stance-no-attack)); action-move
(defrule
	(goal G-boarsteal GV-lure-boar)
	(up-compare-goal ID-stolen-boar c:> 0)
	(up-object-data object-data-to-precise < 300)
	=>
	(up-target-point P-self-x action-move -1 stance-no-attack))
(defrule
	(goal G-boarsteal GV-lure-boar)
	(up-compare-goal ID-stolen-boar c:> 0)
	(up-set-target-by-id g: ID-stolen-boar)
	(up-object-data object-data-action != actionid-attack)
	=>
;	(chat-to-player my-player-number "boar stopped, hit it again")
	(set-goal G-boarsteal GV-move-boar))
(defrule
	(goal G-boarsteal GV-lure-boar)
	(up-compare-goal ID-stolen-boar c:> 0)
	(up-point-distance P-scout-x P-self-x c:< 2)
	=>
	(set-goal G-boarsteal GV-finalise))
;-----------------------------------------------------------------------

(defrule
	(goal G-boarsteal GV-finalise)
	(up-compare-goal G-scout-unit == eagle-warrior)
	=>
;	(chat-to-player my-player-number "garrisoning eagle")
	(up-modify-sn sn-focus-player-number c:= my-player-number)
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-find-remote c: town-center c: 1)
	(up-target-objects -1 action-garrison -1 -1)
	(disable-self))
(defrule
	(goal G-boarsteal GV-finalise)
	(up-compare-goal G-scout-unit == eagle-warrior)
	(up-set-target-by-id g: ID-myscout)
	(up-object-data object-data-garrisoned == 1)
	=>
	(up-ungarrison c: town-center)
	(set-goal G-boarsteal GV-done-boar)
	(disable-self))

(defrule
	(goal G-boarsteal GV-finalise)
	(up-compare-goal G-scout-unit != eagle-warrior)
	(up-set-target-by-id g: ID-stolen-boar)
	(up-object-data object-data-hitpoints > 0)
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-self-x action-move -1 stance-no-attack))
(defrule
	(goal G-boarsteal GV-finalise)
	(up-compare-goal G-scout-unit != eagle-warrior)
	(or	(not	(up-set-target-by-id g: ID-stolen-boar))
		(and	(up-set-target-by-id g: ID-stolen-boar)
			(up-object-data object-data-hitpoints <= 0)))
	=>
	(set-goal G-boarsteal GV-done-boar)
	(disable-self))

; ==========================
; ==== SEARCH FOR ENEMY ====
; ==========================
; == SET SCOUTING WAYPOINTS ==
(defrule
	(up-compare-goal G-first-scoutpoint > 0)
	=>
	(up-jump-rule 8))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-modify-goal G-temp1 g:= G-mapsize)
	(up-modify-goal G-temp2 g:= G-mapsize)
	(up-modify-goal G-temp1 g:- P-self-x)
	(up-modify-goal G-temp2 g:- P-self-y)
	(up-modify-goal G-temp1 g:min G-temp2)
	(up-modify-goal G-temp1 g:min P-self-x)
	(up-modify-goal G-temp1 g:min P-self-y))
(defrule
	(true)
	=>
	(up-modify-goal P-waypoint1-x g:= G-temp1)
	(up-modify-goal P-waypoint1-y g:= G-temp1)
	(up-modify-goal P-waypoint2-x g:= G-temp1)
	(up-modify-goal P-waypoint2-y g:= G-mapsize)
	(up-modify-goal P-waypoint2-y g:- G-temp1)
	(up-modify-goal P-waypoint4-x g:= G-mapsize)
	(up-modify-goal P-waypoint4-x g:- G-temp1)
	(up-modify-goal P-waypoint4-y g:= P-waypoint4-x)
	(up-modify-goal P-waypoint5-x g:= G-mapsize)
	(up-modify-goal P-waypoint5-x g:- G-temp1)
	(up-modify-goal P-waypoint5-y g:= G-temp1))
(defrule
	(up-compare-goal P-waypoint2-x g:== P-self-x)
	=>
	(set-goal G-first-scoutpoint 4)
	(up-jump-rule 3))
(defrule
	(up-compare-goal P-waypoint5-x g:== P-self-x)
	=>
	(set-goal G-first-scoutpoint 2)
	(up-jump-rule 2))
(defrule
	(up-compare-goal P-waypoint1-y g:== P-self-y)
	=>
	(set-goal G-first-scoutpoint 1)
	(up-jump-rule 1))
(defrule
	(up-compare-goal P-waypoint4-y g:== P-self-y)
	=>
	(set-goal G-first-scoutpoint 3))
(defrule
	(true)
	=>
	(up-modify-goal G-temp3 g:= G-mapsize)
	(up-modify-goal G-temp3 c:/ 10)
	(up-modify-goal G-temp3 c:+ 10)
	(up-modify-goal G-temp1 c:* 3)
	(up-modify-goal G-temp1 g:+ G-temp3)
	(up-modify-goal G-temp1 c:/ 4))
(defrule
	(true)
	=>
	(up-modify-goal P-waypoint1-x g:= G-temp1)
	(up-modify-goal P-waypoint1-y g:= G-temp1)
	(up-modify-goal P-waypoint2-x g:= G-temp1)
	(up-modify-goal P-waypoint2-y g:= G-mapsize)
	(up-modify-goal P-waypoint2-y g:- G-temp1)
	(up-modify-goal P-waypoint4-x g:= G-mapsize)
	(up-modify-goal P-waypoint4-x g:- G-temp1)
	(up-modify-goal P-waypoint4-y g:= P-waypoint4-x)
	(up-modify-goal P-waypoint5-x g:= G-mapsize)
	(up-modify-goal P-waypoint5-x g:- G-temp1)
	(up-modify-goal P-waypoint5-y g:= G-temp1))
;-----------------------------------------------------------------------
(defrule
	(or	(up-compare-goal G-scouting < GV-enemy)
		(up-compare-goal G-scouting > GV-point4))
	=>
	(up-jump-rule 10))
;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-first-scoutpoint != 2)
	=>
	(up-jump-rule 2))
	;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-modify-goal G-temp1 g:= P-waypoint1-x)
	(up-modify-goal G-temp2 g:= P-waypoint1-y)
	(up-modify-goal G-temp3 g:= P-waypoint2-x)
	(up-modify-goal G-temp4 g:= P-waypoint2-y)
	(up-modify-goal G-temp5 g:= P-waypoint4-x)
	(up-modify-goal G-temp6 g:= P-waypoint4-y)
	(up-modify-goal G-temp7 g:= P-waypoint5-x)
	(up-modify-goal G-temp8 g:= P-waypoint5-y)
	(disable-self))
(defrule
	(true)
	=>
	(up-modify-goal P-waypoint2-x g:= G-temp1)
	(up-modify-goal P-waypoint2-y g:= G-temp2)
	(up-modify-goal P-waypoint4-x g:= G-temp3)
	(up-modify-goal P-waypoint4-y g:= G-temp4)
	(up-modify-goal P-waypoint5-x g:= G-temp5)
	(up-modify-goal P-waypoint5-y g:= G-temp6)
	(up-modify-goal P-waypoint1-x g:= G-temp7)
	(up-modify-goal P-waypoint1-y g:= G-temp8)
	(disable-self))
	;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-first-scoutpoint != 3)
	=>
	(up-jump-rule 2))
	;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-modify-goal G-temp1 g:= P-waypoint1-x)
	(up-modify-goal G-temp2 g:= P-waypoint1-y)
	(up-modify-goal G-temp3 g:= P-waypoint2-x)
	(up-modify-goal G-temp4 g:= P-waypoint2-y)
	(up-modify-goal G-temp5 g:= P-waypoint4-x)
	(up-modify-goal G-temp6 g:= P-waypoint4-y)
	(up-modify-goal G-temp7 g:= P-waypoint5-x)
	(up-modify-goal G-temp8 g:= P-waypoint5-y)
	(disable-self))
(defrule
	(true)
	=>
	(up-modify-goal P-waypoint4-x g:= G-temp1)
	(up-modify-goal P-waypoint4-y g:= G-temp2)
	(up-modify-goal P-waypoint5-x g:= G-temp3)
	(up-modify-goal P-waypoint5-y g:= G-temp4)
	(up-modify-goal P-waypoint1-x g:= G-temp5)
	(up-modify-goal P-waypoint1-y g:= G-temp6)
	(up-modify-goal P-waypoint2-x g:= G-temp7)
	(up-modify-goal P-waypoint2-y g:= G-temp8)
	(disable-self))
	;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-first-scoutpoint != 4)
	=>
	(up-jump-rule 2))
	;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-modify-goal G-temp1 g:= P-waypoint1-x)
	(up-modify-goal G-temp2 g:= P-waypoint1-y)
	(up-modify-goal G-temp3 g:= P-waypoint2-x)
	(up-modify-goal G-temp4 g:= P-waypoint2-y)
	(up-modify-goal G-temp5 g:= P-waypoint4-x)
	(up-modify-goal G-temp6 g:= P-waypoint4-y)
	(up-modify-goal G-temp7 g:= P-waypoint5-x)
	(up-modify-goal G-temp8 g:= P-waypoint5-y)
