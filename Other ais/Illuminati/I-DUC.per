	(disable-self))
;(defrule
;	(up-compare-goal G-temp0 < 5)
;	(up-path-distance P-temp-x 1 == 65535)
;	(goal G-temp8 688053)
;	(goal G-temp9 688053)
;	=>
;	(up-modify-goal G-temp4 c:- 1)
;	(up-modify-goal G-temp5 c:* -1)
;	(up-modify-goal G-temp6 c:* -1)
;	(up-modify-goal G-temp5 g:+ G-temp6)
;	(up-copy-point P-temp-x P-object-x)
;	(up-lerp-tiles P-temp-x P-x g: G-temp4)
;	(up-cross-tiles P-temp-x P-x g: G-temp5)
;	(up-bound-point P-temp-x P-temp-x)
;	(up-modify-goal G-temp0 c:+ 1)
;	(up-jump-rule -1))
(defrule
	(goal G-temp8 688053)
	(goal G-temp9 688053)
	(up-path-distance P-temp-x 1 != 65535)
	=>
;	(chat-to-player my-player-number "move")
;	(up-send-flare P-temp-x)
	(up-remove-objects search-local object-data-pierce-armor > 100)
	(up-target-point P-temp-x action-move -1 stance-no-attack))
(defrule
	(or	(goal G-temp8 688053)
		(goal G-temp8 688051))
	(up-compare-goal G-temp2 g:< G-remote-total)
	=>
	(up-modify-goal G-temp2 c:+ 1)
	(set-goal G-temp8 0)
	(set-goal G-temp9 0)
	(up-jump-rule -14));~~~~next building
(defrule
	(strategic-number sn-focus-player-number < PLAYERCOUNT)
	=>
	(up-modify-sn sn-focus-player-number c:+ 1)
	(set-goal G-temp8 0)
	(set-goal G-temp9 0)
	(up-jump-rule -16));~~~~next player
;-----------------------------------------------------------------------

; =====================
; ==== MANGO MICRO ====
; =====================
#load-if-not-defined UP-MULTIPLE-ENEMIES

(defrule; make mangos stop shooting
	(up-timer-status T-30 == timer-disabled); T-10
	(up-compare-goal G-attack <= 0)
	(unit-type-count MANGO >= 1)
	(unit-type-count MANGO <= 6)
	=>
	(up-full-reset-search)
	(up-filter-include -1 actionid-attack orderid-attack -1)
	(up-find-local c: MANGO c: 6)
	(up-target-point P-self-x action-stop -1 -1))
(defrule
	(or	(unit-type-count MANGO == 0)
		(or	(unit-type-count MANGO > 5); probably gets too laggy
			(or	(up-timer-status T-1 != timer-disabled)
				(or	(up-timer-status T-forced-retreat == timer-running)
					(up-timer-status T-tsa-retreat == timer-running)))))
	=>
	(up-jump-rule 14))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
	(up-get-fact unit-type-count MANGO G-temp1)
	(set-goal G-temp4 0))
(defrule;~~~~NEW MANGO~~~~
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-full-reset-search)
	(up-find-local c: MANGO g: G-temp1)
	(up-set-target-object search-local g: G-temp4); current mango
	(up-get-object-data object-data-range HAX1)
	(up-get-object-data object-data-min-range HAX2)
	(up-get-point position-object P-object-x)
	(set-goal G-temp2 0); highest unit concentration
	(set-goal P-x -1); juiciest target point
	(set-goal P-y -1)
	(set-goal G-temp5 -1); most enemy units found player number
	(set-goal G-temp6 0); most enemy units found
	(set-strategic-number sn-focus-player-number 1))
(defrule;~~new player~~
	(stance-toward focus-player enemy)
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-set-target-point P-object-x)
	(up-filter-distance c: HAX2 g: HAX1)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-remote c: -1 c: 20); cap for max targets to check
	(up-filter-include -1 -1 -1 -1)
	(up-find-remote c: villager-class c: 10); these add towards target cap too
	(up-find-remote c: monastery-class c: 10)
	(up-get-search-state G-local-total))
(defrule
	(stance-toward focus-player enemy)
	(up-compare-goal G-temp1 g:> G-temp4)
	(up-compare-goal G-remote-total g:> G-temp6)
	=>
	(up-modify-goal G-temp6 g:= G-remote-total)
	(up-modify-goal G-temp5 s:= sn-focus-player-number))
(defrule
	(up-compare-goal G-temp1 g:> G-temp4)
	(strategic-number sn-focus-player-number < PLAYERCOUNT)
	=>
	(up-full-reset-search)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(up-jump-rule -3));~~~~next player
(defrule
	(true)
	=>
	(set-goal G-temp3 0)
	(set-goal G-alt-remote-total 0); prevents P-x from being modified if 0 units are found in range of mangonel
	(up-modify-sn sn-focus-player-number g:= G-temp5))
(defrule;~~~~New potential target point~~~~
	(up-compare-goal G-remote-total c:> 0); enemy units are in range of this mangonel
	(up-compare-goal G-temp3 g:< G-remote-total); loop not exhausted yet
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-full-reset-search)
	(up-set-target-point P-object-x)
	(up-filter-distance c: HAX2 g: HAX1)
	(up-filter-include cmdid-military -1 -1 -1); mil units get priority
	(up-find-remote c: -1 g: G-remote-total); now just target one of the ones in range
	(up-filter-include -1 -1 -1 -1)
	(up-find-remote c: villager-class g: G-remote-total); lower priority
	(up-find-remote c: monastery-class g: G-remote-total)
	(up-modify-goal G-temp3 c:+ 1)); move on to next unit in range
(defrule
	(up-compare-goal G-remote-total c:> 0); enemy units are in range of this mangonel
	(up-compare-goal G-temp3 g:<= G-remote-total); loop not exhausted yet
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-set-target-object search-remote g: G-temp3)
	(up-get-point position-object P-temp-x); Looking at one of the possible target points
	(up-set-target-point P-temp-x)
	(up-reset-search 1 1 1 1)
	(up-filter-distance c: -1 c: 1)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-remote c: -1 c: 15); 15 is plenty, this is a very small area
	(up-find-local c: -1 c: 15)
	(up-filter-include -1 -1 -1 -1)
	(up-find-remote c: villager-class c: 10)
	(up-find-local c: villager-class c: 10)
	(up-find-remote c: monastery-class c: 10)
	(up-find-local c: monastery-class c: 10))
(defrule
	(up-compare-goal G-remote-total c:> 0); enemy units are in range of this mangonel
	(up-compare-goal G-temp3 g:<= G-remote-total); loop not exhausted yet
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-reset-search 1 0 1 0)
	(up-find-remote c: siege-weapon-class c: 3); count them twice!
	(up-find-local c: siege-weapon-class c: 3) 
	(up-find-remote c: scorpion-class c: 3)
	(up-find-local c: scorpion-class c: 3)
	(up-find-remote c: armored-elephant-line c: 3)
	(up-find-local c: armored-elephant-line c: 3)
	(up-find-remote c: ballista-elephant-line c: 3)
	(up-find-local c: ballista-elephant-line c: 3)
	(up-find-remote c: packed-trebuchet-class c: 2);
	(up-find-local c: packed-trebuchet-class c: 2)
	(up-find-remote c: unpacked-trebuchet-class c: 2)
	(up-find-local c: unpacked-trebuchet-class c: 2)
	(up-reset-search 1 0 1 0)
	(up-find-remote c: packed-trebuchet-class c: 2); or even thrice!
	(up-find-local c: packed-trebuchet-class c: 2)
	(up-find-remote c: unpacked-trebuchet-class c: 2)
	(up-find-local c: unpacked-trebuchet-class c: 2)
	(up-find-remote c: bombard-cannon c: 3)
	(up-find-local c: bombard-cannon c: 3)
	(up-find-remote c: mangonel-line c: 2)
	(up-find-local c: mangonel-line c: 2)
	(up-find-remote c: rocket-cart-line c: 2)
	(up-find-local c: rocket-cart-line c: 2)
	(up-get-search-state G-alt-local-total)
	(up-modify-goal G-alt-remote-total g:- G-alt-local-total)); subtract allies found in area from enemies found to get area score
(defrule
	(up-compare-goal G-alt-remote-total g:> G-temp2); If number of enemy units found is higher than highest number found so far
	(up-compare-goal G-remote-total c:> 0); enemy units are in range of this mangonel
	(up-compare-goal G-temp3 g:<= G-remote-total); loop not exhausted yet
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-modify-goal G-temp2 g:= G-alt-remote-total)
	(up-copy-point P-x P-temp-x)); P-x = juiciest target point so far
(defrule
	(up-compare-goal G-remote-total c:> 0); if it's 0 there are no more units to check
	(up-compare-goal G-temp3 g:< G-remote-total); loop not exhausted yet
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-jump-rule -5));~~~~ check next potential target
(defrule; Got past jump rule, that means target point for mangonel has been found
	(up-compare-goal G-temp1 g:> G-temp4)
	(up-compare-goal P-x c:>= 0); -1 would mean no enemy units were found in range
	(up-compare-goal P-y c:>= 0)
	=>
	(up-full-reset-search)
	(up-find-local c: MANGO g: G-temp4)
	(up-reset-search 0 1 0 0); exclude all previous mangonels
	(up-find-local c: MANGO c: 1)
;	(up-chat-data-to-self "shooting mango %d" g: G-temp4)
;	(up-send-flare P-x)
	(up-target-point P-x action-ground -1 -1))
(defrule;1 mangonel complete.
	(up-compare-goal G-temp1 g:> G-temp4)
	=>
	(up-modify-goal G-temp4 c:+ 1))
(defrule
	(up-compare-goal G-temp1 g:> G-temp4); there are mangos left
	=>
	(up-jump-rule -13));~~~~ move on to next mango
;-----------------------------------------------------------------------
#end-if

