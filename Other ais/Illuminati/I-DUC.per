	; (up-filter-status c: status-ready c: list-active)
	; (up-find-status-remote c: castle c: 240)
	; (up-find-status-remote c: krepost c: 240)
	; (up-find-status-remote c: town-center c: 240))
(defrule
	(goal G-temp8 688051)
	(up-set-target-object search-remote g: G-temp2)
	(up-object-data object-data-type == town-center)
	(up-object-data object-data-hitpoints >= 480)
;	(up-object-data object-data-garrison-count > 0); not worth the risk
	=>
	(set-goal G-temp8 688052)
	(up-get-object-data object-data-base-attack G-temp3)
	(up-modify-goal G-temp3 c:- 2); 1
	(up-get-point position-object P-x)
	(up-set-target-point P-x)
	(up-filter-distance c: -1 c: 8)
	(up-find-local c: RAM c: 1))
(defrule
	(goal G-temp8 688052)
	(not	(up-set-target-object search-local c: 0))
	=>
	(set-goal G-temp9 688052)
	(set-goal G-temp0 0); attempt count
	(set-goal G-temp4 -2); lerp distance
	(set-goal G-temp5 2); cross distance
	(set-goal G-temp6 1); cross sign
;	(up-reset-search 0 1 0 0)
	(up-get-point position-object P-x)
	(up-set-target-point P-x)
	(up-filter-distance c: -1 c: 10)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-local c: -1 c: 240)
	(up-remove-objects search-local object-data-base-type == scorpion)
	(up-remove-objects search-local object-data-base-type == mangonel)
	(up-remove-objects search-local object-data-base-type == rocket-cart)
	(up-remove-objects search-local object-data-pierce-armor g:>= G-temp3)
	(up-filter-distance c: -1 c: 9); experimental
	(up-find-local c: scorpion-line c: 40)
	(up-find-local c: mangonel-line c: 10)
	(up-find-local c: rocket-cart-line c: 10)
	(up-filter-distance c: -1 c: 10)
	(up-filter-include cmdid-monk -1 -1 -1)
	(up-find-local c: -1 c: 240)
	(up-remove-objects search-local object-data-pierce-armor > 100))
(defrule
	(goal G-temp8 688052)
	(goal G-temp9 688052)
	(up-set-target-object search-local c: 0)
	(nor	(goal G-attack GV-tsa-duc)
		(goal G-attack GV-pure-duc))
	=>
