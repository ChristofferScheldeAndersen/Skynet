	(up-modify-goal P-waypoint1-x g:= G-temp3)
	(up-modify-goal P-waypoint1-y g:= G-temp4)
	(up-modify-goal P-waypoint2-x g:= G-temp5)
	(up-modify-goal P-waypoint2-y g:= G-temp6)
	(up-modify-goal P-waypoint4-x g:= G-temp7)
	(up-modify-goal P-waypoint4-y g:= G-temp8)
	(disable-self))
	;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-first-scoutpoint > 0)
	=>
	(up-copy-point P-waypoint3-x P-waypoint2-x)
	(up-lerp-percent P-waypoint3-x P-waypoint4-x c: 50)
	(disable-self))
;-----------------------------------------------------------------------
; == SEND SCOUT ==
(defrule
	(or	(up-compare-goal G-scouting < GV-enemy)
		(up-compare-goal G-scouting > GV-point4))
	=>
	(up-jump-rule 9))
;-----------------------------------------------------------------------
(defrule
	(up-compare-goal G-scouting >= GV-point1)
	(or	(and	(up-compare-goal G-scoutidle >= 1)
			(up-timer-status T-scout == timer-running))
		(timer-triggered T-scout))
	=>
	(disable-timer T-scout))
(defrule
	(true)
	=>
	(up-get-point-distance P-self-x P-waypoint1-x G-temp2)
	(up-modify-goal G-temp1 g:= G-mapsize)
	(up-modify-goal G-temp1 c:/ 4))
(defrule; point 1
	(up-point-distance P-self-x P-waypoint1-x g:>= G-temp1)
	(goal G-scouting GV-enemy)
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint1-x action-move -1 stance-no-attack)
	(set-goal G-scouting GV-point1)
	(enable-timer T-scout 20))
(defrule; start with point 2
	(up-compare-goal G-temp2 g:< G-temp1)
	(goal G-scouting GV-enemy)
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint2-x action-move -1 stance-no-attack)
	(set-goal G-scouting GV-point2)
	(enable-timer T-scout 20))
(defrule; point 2
	(goal G-scouting GV-point1)
	(up-timer-status T-scout == timer-disabled)
	(or	(up-compare-goal G-scoutidle >= 1)
		(up-point-distance P-waypoint1-x P-scout-x < 2))
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint2-x action-move -1 stance-no-attack)
	(set-goal G-scouting GV-point2)
	(enable-timer T-scout 20))
(defrule; point 3
	(goal G-scouting GV-point2)
	(up-timer-status T-scout == timer-disabled)
	(or	(up-compare-goal G-scoutidle >= 1)
		(up-point-distance P-waypoint2-x P-scout-x < 2))
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint3-x action-move -1 stance-no-attack)
	(set-goal G-scouting GV-point25)
	(enable-timer T-scout 20))
(defrule; point 4
	(goal G-scouting GV-point25)
	(up-timer-status T-scout == timer-disabled)
	(or	(up-compare-goal G-scoutidle >= 1)
		(up-point-distance P-waypoint3-x P-scout-x < 2))
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint4-x action-move -1 stance-no-attack)
	(set-goal G-scouting GV-point3)
	(enable-timer T-scout 20))
(defrule; point 5
	(goal G-scouting GV-point3)
	(up-timer-status T-scout == timer-disabled)
	(or	(up-compare-goal G-scoutidle >= 1)
		(up-point-distance P-waypoint4-x P-scout-x < 2))
	=>
	(up-reset-search 1 1 1 1)
	(up-add-object-by-id search-local g: ID-myscout)
	(up-target-point P-waypoint5-x action-move -1 stance-no-attack)
	(set-goal G-scouting GV-point4)
	(enable-timer T-scout 20))
(defrule; failsafe
	(goal G-scouting GV-point4)
	(up-timer-status T-scout == timer-disabled)
	(or	(up-compare-goal G-scoutidle >= 1)
		(up-point-distance P-waypoint5-x P-scout-x < 2))
	=>
	(set-strategic-number sn-number-explore-groups 1)
	(set-strategic-number sn-total-number-explorers 1)
	(up-reset-scouts)
	(set-goal G-scouting GV-retardscouting)
	(enable-timer T-scout 1)
	(disable-self))
;-----------------------------------------------------------------------


; ======================================
; ==== RETREAT UNITS FROM BUILDINGS ====
; ======================================

(defrule
	(or	(and	(up-compare-goal G-boarsteal >= 3)
			(up-compare-goal G-boarsteal <= 10))
		(and	(strategic-number SN-superiority > 400)
			(military-population > 40)))
	=>
	(up-jump-rule 18))
(defrule
;	(or	(up-compare-goal G-attack <= 0)
	(current-age == imperial-age)
	(strategic-number SN-raw-superiority >= 120)
	(or	(population g:> G-184-pop)
		(or	(unit-type-count huskarl-set >= 10)
			(or	(unit-type-count eagle-warrior-line >= 16)
				(or	(unit-type-count knight-line >= 11)
					(and	(unit-type-count my-unique-unit-line >= 20)
						(up-compare-const UU-CLASS == infantry-class))))))
	=>
	(up-jump-rule 17))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(set-strategic-number sn-focus-player-number 1))

(defrule; ~~NEW PLAYER~~
	(strategic-number sn-focus-player-number <= PLAYERCOUNT)
	(not	(stance-toward focus-player ally))
	=>
	(set-goal G-temp2 0); current building
	(up-full-reset-search)
	(up-filter-status c: status-ready c: list-active)
	(up-find-status-remote c: castle c: 240)
	(up-find-status-remote c: krepost c: 240)
	(up-find-status-remote c: town-center c: 240)
	(up-get-search-state G-local-total))
(defrule; ~~NEW BUILDING~~
	(strategic-number sn-focus-player-number <= PLAYERCOUNT)
	(not	(stance-toward focus-player ally))
	(up-compare-goal G-temp2 g:< G-remote-total)
	=>
	(set-goal G-temp8 688051))
