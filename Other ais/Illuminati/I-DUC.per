; ===================
; ==== MICHI CUT ====
; ===================
(defrule
	(goal G-michi-cut 1)
	(unit-type-count MANGO >= 1)
	(or	(research-completed ri-onager)
		(research-completed ri-heavy-rocket-cart))
	=>
	(up-get-fact players-in-game ally G-cut-girth)
	(up-modify-goal G-cut-girth c:+ 1)
	(up-copy-point P-cut-x P-team-centre-x)
	(up-lerp-tiles P-cut-x P-team-opposite-x c: 2)
	(set-goal G-michi-cut 2)
;	(set-goal G-temp1 0)
	(up-full-reset-search)
	(up-find-local c: MANGO c: 2)
	(up-target-point P-cut-x action-move -1 -1))

; add a failsafe for other maps here if point is already unreachable, lerping towards self until open

(defrule
	(goal G-michi-cut 2)
	(not	(up-point-contains P-cut-x c: tree-class))
	=>
	(up-lerp-tiles P-cut-x P-team-opposite-x c: 2))
(defrule
	(goal G-michi-cut 2)
	(up-point-contains P-cut-x c: tree-class)
	=>
	(set-goal G-michi-cut 3))
(defrule
	(goal G-michi-cut 3)
	(up-timer-status T-10 == timer-disabled); occasionally do it even theyre on attack task, if close
	=>
	(up-full-reset-search)
	(up-set-target-point P-cut-x)
	(up-modify-goal G-temp0 c:= 8)
	(up-modify-goal G-temp0 g:+ G-cut-girth)
	(up-filter-distance c: -1 g: G-temp0)
	(up-filter-exclude -1 -1 orderid-retreat -1)
	(up-find-local c: MANGO c: 2)
	(up-filter-distance c: -1 g: G-cut-girth)
	(up-find-resource c: wood c: 40)
	(up-jump-rule 1))
(defrule
	(goal G-michi-cut 3)
	=>
	(up-full-reset-search)
	(up-filter-exclude -1 actionid-attack orderid-retreat -1)
	(up-find-local c: MANGO c: 2)
	(up-set-target-point P-cut-x)
	(up-filter-distance c: -1 g: G-cut-girth)
	(up-find-resource c: wood c: 40))
(defrule
	(goal G-michi-cut 3)
	(up-set-target-object search-remote c: 0)
	=>
	(up-target-objects 0 action-default -1 -1)
	(up-jump-rule 1))
(defrule
	(goal G-michi-cut 3)
	(up-point-explored P-cut-x != explored-no)
	=>
	(up-lerp-tiles P-cut-x P-team-opposite-x c: 2))
	
(defrule
	(or	(goal G-michi-cut 3)
		(goal G-michi-cut 4))
	(up-compare-goal P-cut-x g:== P-team-opposite-x)
	(up-compare-goal P-cut-y g:== P-team-opposite-y)
	=>
	(set-goal G-michi-cut 5))

