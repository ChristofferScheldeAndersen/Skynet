; =====================
; ==== ECO BALANCE ====
; =====================
; == DARK AGE ==
(defrule
	(goal G-eco-balance GV-ln-start)
	=>
	(set-strategic-number sn-food-gatherer-percentage 0)
	(set-strategic-number sn-wood-gatherer-percentage 100)
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-early-dark)
	(up-compare-goal G-starting-tcs >= 1)
	=>
	(set-strategic-number sn-food-gatherer-percentage 100)
	(set-strategic-number sn-wood-gatherer-percentage 0)
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-early-dark)
	(goal G-starting-tcs 0)
	=>
	(set-strategic-number sn-food-gatherer-percentage 80)
	(set-strategic-number sn-wood-gatherer-percentage 20)
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule; dark age economy
	(goal G-eco-balance GV-mid-dark)
	(up-compare-goal G-strat != GV-klewproper)
	=>
	(set-strategic-number sn-food-gatherer-percentage 70)
	(set-strategic-number sn-wood-gatherer-percentage 30)
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-late-dark)
	(up-compare-goal G-build-order == GV-feudal-war)
	=>
	(set-strategic-number sn-food-gatherer-percentage 64)
	(set-strategic-number sn-wood-gatherer-percentage 36)
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-late-dark)
	(up-compare-goal G-build-order >= GV-fast-castle)
	(up-compare-goal G-strat != GV-klewproper)
	=>
	(set-strategic-number sn-food-gatherer-percentage 60)
	(set-strategic-number sn-wood-gatherer-percentage 40)
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))

; == FEUDAL AGE ==
(defrule
	(goal G-eco-balance GV-early-feudal)
	(goal G-build-order GV-fast-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 50); 53
	(set-strategic-number sn-wood-gatherer-percentage 36); 35
	(set-strategic-number sn-gold-gatherer-percentage 14); 12
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-early-feudal)
	(goal G-strat GV-cdropproper)
	=>
	(set-strategic-number sn-food-gatherer-percentage 52)
	(set-strategic-number sn-wood-gatherer-percentage 26)
	(set-strategic-number sn-gold-gatherer-percentage 12)
	(set-strategic-number sn-stone-gatherer-percentage 11))
(defrule
	(goal G-eco-balance GV-early-feudal)
	(goal G-build-order GV-slow-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 48); 50
	(set-strategic-number sn-wood-gatherer-percentage 38); 36
	(set-strategic-number sn-gold-gatherer-percentage 14)
	(set-strategic-number sn-stone-gatherer-percentage 0))

; -- tower defence --
(defrule
	(up-compare-goal G-age == GV-upfeudal)
	(goal G-tower-defence 1)
	(or	(goal G-strat-bo GV-fast-castle)
		(goal G-strat-bo GV-slow-castle))
	(up-compare-goal G-strat != GV-klewproper)
	(up-compare-goal G-eco-balance >= GV-early-feudal)
	(up-compare-goal G-eco-balance < GV-early-castle)
	(dropsite-min-distance gold > 3)
	=>
	(set-strategic-number sn-food-gatherer-percentage 52); 60
	(set-strategic-number sn-wood-gatherer-percentage 48); 40
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(up-compare-goal G-age == GV-feudal)
	(goal G-tower-defence 1)
	(or	(goal G-strat-bo GV-fast-castle)
		(goal G-strat-bo GV-slow-castle))
	(up-compare-goal G-strat != GV-klewproper)
	(up-compare-goal G-eco-balance >= GV-early-feudal)
	(up-compare-goal G-eco-balance < GV-early-castle)
	(dropsite-min-distance gold > 3)
	=>
	(set-strategic-number sn-food-gatherer-percentage 60)
	(set-strategic-number sn-wood-gatherer-percentage 40)
	(set-strategic-number sn-gold-gatherer-percentage 0)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(up-compare-goal G-age == GV-feudal)
	(goal G-tower-defence 1)
	(or	(goal G-strat-bo GV-fast-castle)
		(goal G-strat-bo GV-slow-castle))
	(up-compare-goal G-strat != GV-klewproper)
	(up-compare-goal G-eco-balance >= GV-early-feudal)
	(up-compare-goal G-eco-balance < GV-early-castle)
	(dropsite-min-distance gold <= 3)
	=>
	(set-strategic-number sn-food-gatherer-percentage 50)
	(set-strategic-number sn-wood-gatherer-percentage 33)
	(set-strategic-number sn-gold-gatherer-percentage 17)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(up-compare-goal G-age == GV-feudal)
	(goal G-tower-defence 1)
	(or	(goal G-strat-bo GV-fast-castle)
		(goal G-strat-bo GV-slow-castle))
	(up-compare-goal G-strat != GV-klewproper)
	(up-compare-goal G-eco-balance >= GV-early-feudal)
	(up-compare-goal G-eco-balance < GV-early-castle)
	(dropsite-min-distance gold <= 3)
	(building-type-count-total market >= 1)
	(building-type-count-total blacksmith >= 1)
	=>
	(set-strategic-number sn-food-gatherer-percentage 56)
	(set-strategic-number sn-wood-gatherer-percentage 24)
	(set-strategic-number sn-gold-gatherer-percentage 20)
	(set-strategic-number sn-stone-gatherer-percentage 0))


; == FEUDAL WAR (legacy) ==
(defrule
	(or	(up-compare-goal G-age != GV-feudal)
		(up-compare-goal G-build-order != GV-feudal-war))
	=>
	(up-jump-rule 8))
;-----------------------------------------------------------------------
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 1)
	(goal G-skirms 0)
	(goal G-champs 0)
	(up-compare-goal G-escrowing != castle-age)
	=>
	(set-strategic-number sn-food-gatherer-percentage 31)
	(set-strategic-number sn-wood-gatherer-percentage 45)
	(set-strategic-number sn-gold-gatherer-percentage 24)
	(set-strategic-number sn-stone-gatherer-percentage 0))
#load-if-defined AZTEC-CIV
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 1)
	(goal G-skirms 0)
	(goal G-champs 0)
	(up-compare-goal G-escrowing == castle-age)
	=>
	(set-strategic-number sn-food-gatherer-percentage 39)
	(set-strategic-number sn-wood-gatherer-percentage 41)
	(set-strategic-number sn-gold-gatherer-percentage 20)
	(set-strategic-number sn-stone-gatherer-percentage 0))
#else
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 1)
	(goal G-skirms 0)
	(goal G-champs 0)
	(up-compare-goal G-escrowing == castle-age)
	=>
	(set-strategic-number sn-food-gatherer-percentage 41)
	(set-strategic-number sn-wood-gatherer-percentage 40)
	(set-strategic-number sn-gold-gatherer-percentage 19)
	(set-strategic-number sn-stone-gatherer-percentage 0))
#end-if
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 1)
	(goal G-skirms 1)
	(goal G-champs 0)
	=>
	(set-strategic-number sn-food-gatherer-percentage 43)
	(set-strategic-number sn-wood-gatherer-percentage 45)
	(set-strategic-number sn-gold-gatherer-percentage 12)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 1)
	(goal G-skirms 1)
	(goal G-champs 1)
	=>
	(set-strategic-number sn-food-gatherer-percentage 50)
	(set-strategic-number sn-wood-gatherer-percentage 40)
	(set-strategic-number sn-gold-gatherer-percentage 10)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 1)
	(goal G-skirms 0)
	(goal G-champs 1)
	=>
	(set-strategic-number sn-food-gatherer-percentage 42)
	(set-strategic-number sn-wood-gatherer-percentage 36)
	(set-strategic-number sn-gold-gatherer-percentage 22)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 0)
	(goal G-skirms 1)
	(goal G-champs 0)
	=>
	(set-strategic-number sn-food-gatherer-percentage 46)
	(set-strategic-number sn-wood-gatherer-percentage 50)
	(set-strategic-number sn-gold-gatherer-percentage 4)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(building-type-count-total archery-range > 0)
	(goal G-archers 0)
	(goal G-skirms 1)
	(goal G-champs 1)
	=>
	(set-strategic-number sn-food-gatherer-percentage 55)
	(set-strategic-number sn-wood-gatherer-percentage 38)
	(set-strategic-number sn-gold-gatherer-percentage 7)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-escrowing castle-age)
	=>
	(up-modify-sn sn-food-gatherer-percentage c:+ 4)
	(up-modify-sn sn-wood-gatherer-percentage c:- 4))
;-----------------------------------------------------------------------
; == while researching castle-up ==
(defrule
	(or	(goal G-strat GV-klew)
		(goal G-strat GV-eagleflood))
	(goal G-eco-balance GV-early-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 33)
	(set-strategic-number sn-wood-gatherer-percentage 57)
	(set-strategic-number sn-gold-gatherer-percentage 10)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(goal G-strat GV-krush)
		(goal G-strat GV-ele))
	(goal G-eco-balance GV-early-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 40)
	(set-strategic-number sn-wood-gatherer-percentage 45)
	(set-strategic-number sn-gold-gatherer-percentage 15)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-early-castle)
	;(or	(goal G-strat GV-smushboom)
		(or	(goal G-strat GV-monks-only)
			(goal G-strat GV-monkflood));)
	=>
	(set-strategic-number sn-food-gatherer-percentage 25)
	(set-strategic-number sn-wood-gatherer-percentage 55)
	(set-strategic-number sn-gold-gatherer-percentage 20)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(goal G-strat GV-xbows)
		(or	(goal G-strat GV-horsecock)
			(goal G-strat GV-ca)))
	(goal G-build-order GV-feudal-war)
	(goal G-age GV-upcastle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 22)
	(set-strategic-number sn-wood-gatherer-percentage 48)
	(set-strategic-number sn-gold-gatherer-percentage 30)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-early-castle)
	(or	(or	(goal G-strat GV-xbows)
			(and	(goal G-strat GV-horsecock)
				(not	(civ-selected hun))))
		(goal G-strat GV-ca))
	(goal G-build-order GV-slow-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 25)
	(set-strategic-number sn-wood-gatherer-percentage 50)
	(set-strategic-number sn-gold-gatherer-percentage 25)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-eco-balance GV-early-castle)
	(goal G-strat GV-firelancers)
	=>
	(set-strategic-number sn-food-gatherer-percentage 25)
	(set-strategic-number sn-wood-gatherer-percentage 50)
	(set-strategic-number sn-gold-gatherer-percentage 25)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(goal G-strat GV-klewproper)
		(goal G-strat GV-ca))
	(goal G-eco-balance GV-early-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 30)
	(set-strategic-number sn-wood-gatherer-percentage 50)
	(set-strategic-number sn-gold-gatherer-percentage 20)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-strat GV-cdrop)
	(or	(goal G-eco-balance GV-early-castle)
		(and	(building-type-count-total castle < 1)
			(up-compare-goal G-age >= GV-upcastle)))
	=>
	(set-strategic-number sn-food-gatherer-percentage 36)
	(set-strategic-number sn-wood-gatherer-percentage 24)
	(set-strategic-number sn-gold-gatherer-percentage 10)
	(set-strategic-number sn-stone-gatherer-percentage 30))
(defrule
	(goal G-strat GV-cdropproper)
	(or	(goal G-eco-balance GV-early-castle)
		(and	(building-type-count-total castle < 1)
			(up-compare-goal G-age >= GV-upcastle)))
	=>
	(set-strategic-number sn-food-gatherer-percentage 38)
	(set-strategic-number sn-wood-gatherer-percentage 30)
	(set-strategic-number sn-gold-gatherer-percentage 2)
	(set-strategic-number sn-stone-gatherer-percentage 30))
(defrule
	(goal G-strat GV-boom)
	(goal G-eco-balance GV-early-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 41)
	(set-strategic-number sn-wood-gatherer-percentage 54)
	(set-strategic-number sn-gold-gatherer-percentage 5)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-strat GV-krushboom)
	(goal G-eco-balance GV-early-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 52); 49
	(set-strategic-number sn-wood-gatherer-percentage 33); 37
	(set-strategic-number sn-gold-gatherer-percentage 15); 14
	(set-strategic-number sn-stone-gatherer-percentage 0))

; == CASTLE AGE ==
(defrule
	(or	(goal G-strat GV-longswords)
		(goal G-strat GV-champflood))
	(building-type-count-total town-center == 1)
	(up-compare-goal G-age <= GV-castle)
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 57)
	(set-strategic-number sn-wood-gatherer-percentage 30)
	(set-strategic-number sn-gold-gatherer-percentage 13)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(goal G-strat GV-longswords)
		(goal G-strat GV-champflood))
	(building-type-count-total town-center == 2)
	(up-compare-goal G-age <= GV-castle)
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 59)
	(set-strategic-number sn-wood-gatherer-percentage 28)
	(set-strategic-number sn-gold-gatherer-percentage 13)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(goal G-strat GV-longswords)
		(goal G-strat GV-champflood))
	(building-type-count-total town-center >= 3)
	(up-compare-goal G-age <= GV-castle)
	(up-compare-goal G-age >= GV-upcastle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 61)
	(set-strategic-number sn-wood-gatherer-percentage 24)
	(set-strategic-number sn-gold-gatherer-percentage 15)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(or	(goal G-strat GV-xbows)
			(goal G-strat GV-ca))
		(goal G-strat GV-firelancers))
	(building-type-count-total town-center == 1)
	(goal G-age GV-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 30)
	(set-strategic-number sn-wood-gatherer-percentage 40)
	(set-strategic-number sn-gold-gatherer-percentage 30)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(or	(goal G-strat GV-xbows)
			(goal G-strat GV-ca))
		(goal G-strat GV-firelancers))
	(building-type-count-total town-center == 2)
	(goal G-age GV-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 32)
	(set-strategic-number sn-wood-gatherer-percentage 38)
	(set-strategic-number sn-gold-gatherer-percentage 30)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(or	(or	(goal G-strat GV-xbows)
			(goal G-strat GV-ca))
		(goal G-strat GV-firelancers))
	(building-type-count-total town-center >= 3)
	(goal G-age GV-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 36)
	(set-strategic-number sn-wood-gatherer-percentage 34)
	(set-strategic-number sn-gold-gatherer-percentage 30)
	(set-strategic-number sn-stone-gatherer-percentage 0))

(defrule
	(goal G-strat GV-horsecock)
	(building-type-count-total town-center == 1)
	(goal G-age GV-castle)
	=>
	(set-strategic-number sn-food-gatherer-percentage 38)
	(set-strategic-number sn-wood-gatherer-percentage 34)
	(set-strategic-number sn-gold-gatherer-percentage 28)
	(set-strategic-number sn-stone-gatherer-percentage 0))
(defrule
	(goal G-strat GV-horsecock)
	(building-type-count-total town-center == 2)
