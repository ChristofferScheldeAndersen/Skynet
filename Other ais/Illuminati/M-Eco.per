#load-if-defined VIKING-CIV

#end-if

; ================================
; ==== DYNAMIC ECO ADJUSTMENT ====
; ================================
(defrule
	(or	(current-age == dark-age)
		(and	(current-age == feudal-age)
			(up-compare-goal G-build-order >= GV-fish-castle)))
	=>
	(up-jump-rule 3))
;-----------------------------------------------------------------------
(defrule
	(true)
	=>
	(up-get-fact food-amount 0 G-temp1)
	(up-get-fact wood-amount 0 G-temp2)
	(up-get-fact gold-amount 0 G-temp3)
	(up-modify-goal G-temp1 g:- G-cost-food)
	(up-modify-goal G-temp2 g:- G-cost-wood)
	(up-modify-goal G-temp3 g:- G-cost-gold))
(defrule
	(true)
	=>
	(up-modify-goal G-temp4 g:= G-temp1)
	(up-modify-goal G-temp4 g:+ G-temp2)
	(up-modify-goal G-temp4 g:+ G-temp3)
	(up-modify-goal G-temp4 c:/ 3)
	(up-modify-goal G-temp1 g:- G-temp4)
	(up-modify-goal G-temp2 g:- G-temp4)
	(up-modify-goal G-temp3 g:- G-temp4)
	(up-get-fact unit-type-count villager G-temp5)
	(up-modify-goal G-temp5 c:max 50)
	(up-modify-goal G-temp5 c:/ 2)
	(up-modify-goal G-temp1 g:/ G-temp5)
	(up-modify-goal G-temp2 g:/ G-temp5)
	(up-modify-goal G-temp3 g:/ G-temp5))
(defrule
	(true)
	=>
	(set-goal G-food-adj 0)
	(set-goal G-wood-adj 0)
	(set-goal G-gold-adj 0)
	(up-modify-goal G-food-adj g:- G-temp1)
	(up-modify-goal G-wood-adj g:- G-temp2)
	(up-modify-goal G-gold-adj g:- G-temp3)
	(up-modify-sn sn-food-gatherer-percentage g:+ G-food-adj)
	(up-modify-sn sn-wood-gatherer-percentage g:+ G-wood-adj)
	(up-modify-sn sn-gold-gatherer-percentage g:+ G-gold-adj))
;-----------------------------------------------------------------------
; == FC ENOUGH FOOD ==
(defrule
	(goal G-eco-balance GV-early-feudal)
	(or	(goal G-build-order GV-fast-castle)
		(goal G-build-order GV-slow-castle))
	(food-amount >= 800)
	=>
	(up-modify-sn sn-food-gatherer-percentage c:- 25)
	(up-modify-sn sn-wood-gatherer-percentage c:+ 14)
	(up-modify-sn sn-gold-gatherer-percentage c:+ 11))

; == stone for towers ==
(defrule
	(goal G-tower-defence 1)
	=>
	(up-get-fact unit-type-count villager G-temp1)
	(up-modify-goal G-temp1 c:/ 4)
	(up-modify-goal G-temp2 c:= 100)
	(up-modify-goal G-temp2 g:/ G-temp1)
	(up-modify-goal G-temp3 g:= G-temp2)
	(up-modify-goal G-temp4 g:= G-temp2)
	(up-modify-goal G-temp4 c:/ 3)
	(up-modify-goal G-temp3 g:- G-temp4)
	; (up-chat-data-to-player my-player-number "stone +%d%" g: G-temp2)
	; (up-chat-data-to-player my-player-number "food -%d%" g: G-temp3)
	; (up-chat-data-to-player my-player-number "gold -%d%" g: G-temp4)
	(up-modify-sn sn-food-gatherer-percentage g:- G-temp3)
	(up-modify-sn sn-gold-gatherer-percentage g:- G-temp4)
	(up-modify-sn sn-stone-gatherer-percentage g:+ G-temp2))

; == stone for TCs ==
(defrule
	(up-compare-goal G-age >= GV-upcastle)
	(building-type-count-total town-center g:< G-desiredtcs)
	(stone-amount < 200)
	(up-modify-goal G-temp1 g:= G-desiredtcs)
	(up-modify-goal G-temp1 c:- 1)
	(or	(building-type-count-total town-center g:< G-temp1)
		(stone-amount < 100))
	(up-compare-goal G-strat != GV-klewproper)
	(civilian-population >= 30)
	=>
	(up-modify-sn sn-food-gatherer-percentage c:- 2)
	(up-modify-sn sn-wood-gatherer-percentage c:- 5)
	(up-modify-sn sn-gold-gatherer-percentage c:- 1)
	(up-modify-sn sn-stone-gatherer-percentage c:+ 8))
(defrule
	(goal G-rebuild 2)
	(stone-amount < 100)
	(up-pending-objects c: town-center < 1)
	=>
	(up-modify-sn sn-food-gatherer-percentage c:- 4)
	(up-modify-sn sn-wood-gatherer-percentage c:- 4)
	(up-modify-sn sn-gold-gatherer-percentage c:- 4)
	(up-modify-sn sn-stone-gatherer-percentage c:+ 12))

; == failsafe ==
(defrule
	(up-modify-goal G-temp9 s:= sn-food-gatherer-percentage)
	(up-modify-goal G-temp9 s:+ sn-wood-gatherer-percentage)
	(up-modify-goal G-temp9 s:+ sn-gold-gatherer-percentage)
	(up-modify-goal G-temp9 s:+ sn-stone-gatherer-percentage)
	(up-compare-goal G-temp9 c:< 100)
	=>
	(up-modify-sn sn-food-gatherer-percentage c:+ 1)
	(up-modify-sn sn-wood-gatherer-percentage c:+ 1)
	(up-jump-rule -1))
