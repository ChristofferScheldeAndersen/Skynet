; ===================
; ==== SET GOALS ====
; ===================
; == DETERMINE MAP TYPE ==
(defrule
	(true)
	=>
	(set-goal G-maptype GV-land-open)
	(disable-self))
(defrule
	(game-time < 29)
	(building-type-count wall-class >= 8)
	=>
	(chat-to-player my-player-number "walled map")
	(set-goal G-maptype GV-land-walled)
	(disable-self))
(defrule
	(goal G-age 1)
	(game-time >= 10)
	(game-time < 29)
	(or 	(cc-players-unit-type-count 0 ocean-fish-class > FISHFACE)
		(or	(cc-players-unit-type-count 0 shore-fish-class > FISHFACE)
			(and	(cc-players-unit-type-count 0 ocean-fish-class > HALF-A-FISHFACE)
				(cc-players-unit-type-count 0 shore-fish-class > HALF-A-FISHFACE))))
	=>
;	(set-goal G-maptype GV-water-mixed)
	(chat-to-player my-player-number "water map")
;	(resign)
	(disable-self))

#load-if-defined UP-MICHI-STYLE
(defrule
	(game-time < 29)
	=>
	(chat-to-player my-player-number "michi map")
	(set-goal G-maptype GV-land-michi)
	(disable-self))
(defrule
	(game-time < 29)
	(goal G-maptype GV-land-michi)
	(nor	(civ-selected hun)
		(civ-selected turkish)); no onager civs
	=>
	(set-goal G-michi-cut 1)
	(disable-self))
#end-if

; == ENABLE DOCKING ==
;(defrule
;	(up-compare-goal G-maptype >= GV-water-walled); all water maps
;	(up-compare-goal G-docking <= 0)
;	(up-compare-goal G-starting-tcs <= 1)
;	=>
;	(set-goal G-docking 1))

; == SET MATCH-SPECIFIC VARIABLES ==
(defrule
	(true)
	=>
	(up-get-point position-self P-self-x)
	(up-get-point position-map-size P-x)
	(up-modify-goal G-mapsize g:= P-x)
	(set-goal G-position POSITION)
	(set-goal G-fc-vills FC-VILLS)
	(up-modify-goal G-fc-vills c:+ 1); too lazy to change it per civ
	(set-goal G-sc-vills SC-VILLS)
	(set-goal G-enemy-players PLAYERCOUNT)
	(up-modify-goal G-enemy-players c:- ALLYCOUNT)
	(up-modify-goal G-enemy-players c:- 1)
	(set-goal G-gametype GAMETYPE)
	(disable-self))
(defrule; 2v2v2 detection (fu esty)
	(game-time < 12)
	(up-compare-goal G-gametype == GAMETYPE-TG)
	=>
	(set-goal G-temp1 ALLYCOUNT)
	(up-modify-goal G-temp1 c:+ 1))
(defrule
	(game-time < 12)
	(up-compare-goal G-gametype == GAMETYPE-TG)
	(up-compare-goal G-enemy-players g:> G-temp1)
	=>
	(set-goal G-gametype GAMETYPE-FFA)
	(chat-to-all "team FFA detected")
	(disable-self))
(defrule
	(true)
	=>
	(up-get-fact population-cap 0 G-temp1)
	(up-modify-goal G-desired-vills g:= G-temp1)
	(up-modify-goal G-desired-vills c:* DESIREDVILLS)
	(up-modify-goal G-desired-vills c:/ 200)
	(up-modify-goal G-desired-vills c:max 18)
	(up-modify-goal G-desired-vills c:min 160); 250
	(up-modify-goal G-max-vills g:= G-temp1)
	(up-modify-goal G-max-vills c:* MAXVILLS)
	(up-modify-goal G-max-vills c:/ 200)
	(up-modify-goal G-max-vills c:max 18)
	(up-modify-goal G-desired-trade g:= G-desired-vills)
	(up-modify-goal G-trade-vills g:= G-max-vills)
	(up-modify-goal G-desired-trade c:/ DESIRED-TRADE-DIVISOR)
	(up-modify-goal G-trade-vills g:- G-desired-trade)
	(disable-self))
(defrule
	(true)
	=>
	(up-get-point position-self P-self-precise-x)
	(up-modify-goal P-self-precise-x c:* 100)
	(up-modify-goal P-self-precise-y c:* 100)
	(up-modify-goal G-stopgap-pop g:= G-temp1)
	(up-modify-goal G-stopgap-pop c:/ 15)
	(up-modify-goal G-stopgap-pop c:max 5)
	(up-modify-goal G-low-pop g:= G-temp1)
	(up-modify-goal G-low-pop c:/ 4)
	(up-modify-goal G-low-pop c:min 60)
	(up-modify-goal G-med-pop g:= G-temp1)
	(up-modify-goal G-med-pop c:/ 2)
	(up-modify-goal G-med-pop c:min 120)
	(disable-self))
(defrule
	(true)
	=>
	(up-modify-goal G-160-pop g:= G-temp1)
	(up-modify-goal G-160-pop c:%/ 125)
	(up-modify-goal G-160-pop c:min 200); increase these when increasing max vills
	(up-modify-goal G-170-pop g:= G-temp1)
	(up-modify-goal G-170-pop c:%/ 118)
	(up-modify-goal G-170-pop c:min 240)
	(up-modify-goal G-184-pop g:= G-temp1)
	(up-modify-goal G-184-pop c:%/ 109)
	(up-modify-goal G-184-pop c:min 280)
	(up-modify-goal G-189-pop g:= G-temp1)
	(up-modify-goal G-189-pop c:%/ 106)
	(up-modify-goal G-189-pop c:min 300)
	(disable-self))
(defrule
	(true)
	=>
	(set-goal G-desiredtcs 3)
	(disable-self))
(defrule
	(population-cap <= 120)
	=>
	(set-goal G-desiredtcs 2)
	(disable-self))
(defrule
	(population-cap <= 60)
	=>
	(set-goal G-desiredtcs 1)
	(disable-self))

(defrule; number of starting TCs
	(true)
	=>
	(up-full-reset-search)
	(up-find-local c: town-center c: 240)
	(up-get-search-state G-local-total)
	(up-modify-goal G-starting-tcs g:= G-local-total)
	(set-goal G-camp-distance-time 1800)
	(set-strategic-number SN-emergency-mill-time 45)
	(disable-self))

(defrule; once nomad/ln TC is built
	(goal G-starting-tcs 0)
	(building-type-count town-center > 0)
	=>
	(up-get-fact game-time 0 G-temp1)
	(up-modify-sn sn-home-exploration-time g:= G-temp1)
	(up-modify-sn sn-home-exploration-time c:+ 420)
	(up-modify-goal G-camp-distance-time g:+ G-temp1)
	(up-modify-goal G-camp-distance-time c:- 180)
	(up-modify-sn SN-emergency-mill-time g:+ G-temp1)
	(up-modify-sn SN-emergency-mill-time c:- 5)
	(up-full-reset-search)
	(up-find-local c: town-center c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-point position-object P-self-x)
	(up-send-flare P-self-x)
	(chat-to-allies "my TC")
	(disable-self))

(defrule; map explored?
	(game-time > 0)
	=>
	(up-get-fact resource-amount amount-exploration G-map-explored)
	(disable-self))

(defrule; fc vills
	(current-age == dark-age)
	(goal G-maptype GV-land-open)
	(goal G-position GV-flank)
	(up-compare-goal G-starting-tcs > 0)
	=>
	(up-modify-goal G-fc-vills c:- 1)
	(up-modify-goal G-sc-vills c:- 1)
	(disable-self))
(defrule
	(current-age == dark-age)
	(up-compare-goal G-deers-lured >= 1)
	=>
	(up-modify-goal G-fc-vills c:- 1)
	(up-modify-goal G-sc-vills c:- 1)
	(disable-self))
(defrule
	(current-age == dark-age)
	(up-compare-goal G-deers-lured >= 3)
	=>
	(up-modify-goal G-fc-vills c:- 1)
	(up-modify-goal G-sc-vills c:- 1)
	(disable-self))

(defrule; min gaia gold/stone
	(true)
	=>
	(up-modify-goal G-min-gaia-gold c:= 4)
	(up-modify-goal G-min-gaia-stone c:= 2)
	(up-modify-goal G-min-gaia-gold c:* PLAYERCOUNT)
	(up-modify-goal G-min-gaia-stone c:* PLAYERCOUNT)
	(up-modify-goal G-min-gaia-gold c:+ 2)
	(up-modify-goal G-min-gaia-stone c:+ 1)
	(disable-self))
#load-if-defined RIVERS-MAP
(defrule; min gaia gold/stone
	(true)
	=>
	(up-modify-goal G-min-gaia-gold c:+ 8)
	(disable-self))
#end-if

; == nomad flank ==
#load-if-defined UP-POCKET-POSITION
(defrule
	(goal G-starting-tcs 0)
	(goal G-age GV-dark)
	(goal G-position GV-pocket)
	(building-type-count town-center >= 1)
	(up-compare-goal P-self-x > 0)
	=>
	(up-get-point position-enemy P-temp-x)
	(up-get-point-distance P-self-x P-temp-x G-temp1))
(defrule
	(goal G-starting-tcs 0)
	(goal G-age GV-dark)
	(goal G-position GV-pocket)
	(building-type-count town-center >= 1)
	(up-compare-goal P-self-x > 0)
	(up-compare-goal G-temp1 < 40)
	=>
	(set-goal G-position GV-flank)
	(disable-self))
(defrule
	(goal G-starting-tcs 0)
	(goal G-age GV-dark)
	(up-compare-const ALLYCOUNT == 0)
	(or	(players-civ any-enemy hun)
		(players-civ any-enemy vietnamese))
	=>
	(set-goal G-position GV-flank)
	(disable-self))
#end-if

; == closest map corners, team centre and opposite ==
(defrule
	(game-time >= 20)
	(players-building-type-count every-ally town-center >= 1)
	(up-compare-goal P-self-x > 0)
	=>
	(up-modify-goal G-temp1 g:= G-mapsize); G-temp1 = half map
	(up-modify-goal G-temp1 c:/ 2)
	(up-modify-goal G-temp3 g:= G-mapsize); G-temp3 = map size -3
	(up-modify-goal G-temp3 c:- 3)
	(set-goal G-temp2 927263)
;	(chat-to-all "NOW")
	(disable-self))

#load-if-defined UP-ALLY-IN-GAME
(defrule
	(goal G-temp2 927263)
	=>
	(set-goal P-temp-x 0)
	(set-goal P-temp-y 0)
	(set-goal G-temp4 0)
	(set-strategic-number sn-focus-player-number 1))
(defrule; ~~new player~~
	(goal G-temp2 927263)
	(stance-toward focus-player ally)
	=>
	(up-full-reset-search)
	(up-find-remote c: town-center c: 1)
	(up-find-remote c: town-center-foundation c: 1))
(defrule
	(goal G-temp2 927263)
	(stance-toward focus-player ally)
	(up-set-target-object search-remote c: 0)
	=>
	(up-modify-goal G-temp4 c:+ 1)
	(up-get-point position-object P-object-x)
	(up-modify-goal P-temp-x g:+ P-object-x)
	(up-modify-goal P-temp-y g:+ P-object-y))
(defrule
	(goal G-temp2 927263)
	(strategic-number sn-focus-player-number < PLAYERCOUNT)
	=>
	(up-modify-sn sn-focus-player-number c:+ 1)
	(up-jump-rule -3));~~~~next player
(defrule
	(goal G-temp2 927263)
	=>
	(up-modify-goal P-temp-x g:/ G-temp4)
	(up-modify-goal P-temp-y g:/ G-temp4)
	(up-copy-point P-team-centre-x P-temp-x))
#else; solo
(defrule
	(goal G-temp2 927263)
	=>
	(up-copy-point P-team-centre-x P-self-x)
	(up-copy-point P-temp-x P-self-x))
#end-if
(defrule
	(goal G-temp2 927263)
	(goal G-michi-cut 1)
	=>
	(up-copy-point P-cut-x P-team-centre-x)
	(disable-self))

(defrule
	(goal G-temp2 927263)
	=>
	(up-modify-goal P-team-opposite-x g:= G-mapsize)
	(up-modify-goal P-team-opposite-y g:= G-mapsize)
	(up-modify-goal P-team-opposite-x c:- 1)
	(up-modify-goal P-team-opposite-y c:- 1)
	(up-modify-goal P-team-opposite-x g:- P-team-centre-x)
	(up-modify-goal P-team-opposite-y g:- P-team-centre-y)
	(up-modify-goal G-temp5 g:= P-temp-x)
	(up-modify-goal G-temp5 g:+ P-temp-y))

(defrule; 1
	(goal G-temp2 927263)
	(up-compare-goal P-temp-y g:<= G-temp1)
	(up-compare-goal P-temp-y g:<= P-temp-x)
	(up-compare-goal G-temp5 g:<= G-mapsize)
	=>
;	(chat-to-all "case 1")
	(up-modify-goal P-my-one-corner-x c:= 3)
	(up-modify-goal P-my-one-corner-y c:= 3)
	(up-modify-goal P-my-two-corner-x g:= G-temp3)
	(up-modify-goal P-my-two-corner-y c:= 3))
(defrule; 2
	(goal G-temp2 927263)
	(up-compare-goal P-temp-y g:>= G-temp1)
	(up-compare-goal P-temp-y g:>= P-temp-x)
	(up-compare-goal G-temp5 g:>= G-mapsize)
	=>
;	(chat-to-all "case 2")
	(up-modify-goal P-my-one-corner-x c:= 3)
	(up-modify-goal P-my-one-corner-y g:= G-temp3)
	(up-modify-goal P-my-two-corner-x g:= G-temp3)
	(up-modify-goal P-my-two-corner-y g:= G-temp3))
(defrule; 3
	(goal G-temp2 927263)
	(up-compare-goal P-temp-x g:<= G-temp1)
	(up-compare-goal P-temp-x g:<= P-temp-y)
	(up-compare-goal G-temp5 g:<= G-mapsize)
	=>
;	(chat-to-all "case 3")
	(up-modify-goal P-my-one-corner-x c:= 3)
	(up-modify-goal P-my-one-corner-y c:= 3)
	(up-modify-goal P-my-two-corner-x c:= 3)
	(up-modify-goal P-my-two-corner-y g:= G-temp3))
(defrule; 4
	(goal G-temp2 927263)
	(up-compare-goal P-temp-x g:>= G-temp1)
	(up-compare-goal P-temp-x g:>= P-temp-y)
	(up-compare-goal G-temp5 g:>= G-mapsize)
	=>
;	(chat-to-all "case 4")
	(up-modify-goal P-my-one-corner-x g:= G-temp3)
	(up-modify-goal P-my-one-corner-y c:= 3)
	(up-modify-goal P-my-two-corner-x g:= G-temp3)
	(up-modify-goal P-my-two-corner-y g:= G-temp3))

; (defrule
; 	(goal G-temp2 927263)
; 	=>
; ;	(up-send-flare P-temp-x)
; 	(up-send-flare P-team-centre-x))
; ;	(up-send-flare P-my-one-corner-x)
; ;	(up-send-flare P-my-two-corner-x))

; == GET SCOUT TYPE AND ID ==
(defrule
	(true)
	=>
	(up-full-reset-search)
	(up-find-local c: eagle-warrior-line c: 1)
	(up-find-local c: scout-cavalry-line c: 1)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-local c: -1 c: 1)
;	(up-filter-include -1 -1 -1 -1)
;	(up-find-local c: horse c: 1)
;	(up-find-local c: king-class c: 1)
;	(up-find-local c: trade-cart-class c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-type G-scout-unit)
;	(up-chat-data-to-self "scout type: %d" g: G-scout-unit)
	(disable-self))
(defrule
	(game-time < 10)
	(up-compare-goal G-scout-unit > 0)
	=>
	(up-full-reset-search)
	(up-find-local g: G-scout-unit c: 1)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-id ID-myscout)
	(disable-self))
(defrule; multiple scouts
	(game-time < 12)
	(up-compare-goal G-scout-unit > 0)
	(up-compare-goal G-scout-unit != villager-class)
	=>
	(up-full-reset-search)
	(up-find-local g: G-scout-unit c: 240)
	(up-get-search-state G-local-total)
	(up-modify-goal G-starting-scouts g:= G-local-total)
	(disable-self))
(defrule
	(goal ID-myscout 0)
	=>
	(set-goal ID-myscout -1)
	(set-goal G-scout-unit -1))

; == SET GENERAL GOALS ==
(defrule
	(true)
	=>
	(set-goal G-identity Illuminati)
	(set-goal G-esc-state with-escrow)
	(set-goal G-enemy-strategy 0)
	(set-goal G-trushed 0)
	(set-goal G-strat 0)
	(set-goal G-zero 0)
	(set-goal G-sheep-count 0)
	(set-goal G-sheep-total 0)
	(set-goal G-escrowing 0)
	(set-goal G-deers-lured 0)
	(set-goal G-age 1)
	(set-goal G-scoutidle 0)
	(disable-self))
(defrule
	(true)
	=>
	(set-goal G-shit-found 0)
	(set-goal G-strat-rax 0)
	(set-goal G-strat-range 0)
	(set-goal G-strat-stable 0)
	(set-goal G-strat-workshop 0)
	(set-goal G-food-adj 0)
	(set-goal G-wood-adj 0)
	(set-goal G-gold-adj 0)
	(set-goal G-under-attack 0)
	(up-setup-cost-data 1 G-cost-food)
	(set-goal G-age-start-time 0)
	(set-goal G-tower-count 0)
	(disable-self))

; == DETERMINE ALPHA ILLU ==
#load-if-defined UP-ALLY-IN-GAME
(defrule
	(goal G-alpha-illu -1)
	=>
	(set-strategic-number sn-focus-player-number 1))
(defrule
	(goal G-alpha-illu -1)
	(strategic-number sn-focus-player-number <= PLAYERCOUNT)
	(stance-toward focus-player ally)
	(up-allied-goal focus-player G-identity == Illuminati)
	(up-allied-goal focus-player G-alpha-illu == 1)
	=>
	(set-goal G-alpha-illu 0))
(defrule
	(goal G-alpha-illu -1)
	(strategic-number sn-focus-player-number < PLAYERCOUNT)
	=>
	(up-modify-sn sn-focus-player-number c:+ 1)
	(up-jump-rule -2))
(defrule
	(goal G-alpha-illu -1)
	=>
	(set-goal G-alpha-illu 1))
#else
(defrule
	(true)
	=>
	(set-goal G-alpha-illu 1)
	(disable-self))
#end-if

