#load-if-defined AZTEC-CIV
(defconst FC-VILLS 25)
(defconst SC-VILLS 27)
(defconst MIN-MANGOS 2); number of mangos that get escrowed vs mass archers
(defconst UU-CLASS infantry-class)
(defconst UU-RESOURCE food)
(defconst UU-TT-MULTIPLIER 2); training time multiplier. higher = faster training
(defconst UU-TYPE MAIN-INF); archetype
(defconst RAM battering-ram-line)
(defconst MANGO mangonel-line)
(defconst CHAMP militiaman-line)
(defconst LUMBER-CAMP lumber-camp)
(defconst MINING-CAMP mining-camp)
(defconst MILL mill)

(defconst UUCIV-CASTLE 2); 0 nah, 1 potentially useful, 2 great in its own right
(defconst UUCIV-IMP 2); 0-2
(defconst ARCHERCIV 1); 0 never, 1 good castle bad imp, 2 good castle+imp, 3 insane
(defconst SKIRMCIV 2); 0-3
(defconst CACIV 0); 0-3
(defconst HCCIV 0); imp only, 0-3
(defconst CHAMPCIV 2); imp only, 0-3
(defconst PIKECIV 1); 0-3
(defconst EAGLECIV 2); 0-3
(defconst FIRELANCERCIV 0); 0 never, 1 good castle bad imp, 2 good castle+imp, 3 insane
(defconst CAMELCIV 0); 0-3
(defconst KNIGHTCIV-CASTLE 0); 0-2
(defconst KNIGHTCIV-IMP 0); 0-2
(defconst SCOUTCIV 0); 0-3, 0 if missing 3 techs
(defconst ELECIV 0); 0-3
(defconst MONKCIV-CASTLE 3); 0-3
(defconst MONKCIV-IMP 3); 0-3
(defconst SCORPCIV 0); imp only, 0-3
(defconst RAMCIV 2); imp only, 0-3
(defconst MANGOCIV 2); imp only, 0-3
(defconst BBCCIV 0); imp only, 0-3
(defconst TOWERCIV 1); 0-4
(defconst BBTCIV 0); 0-3
(defconst SLINGERCIV 0)

(defconst DESIREDVILLS 124)
(defconst MAXVILLS 129)
(defconst FC-FARMS 9)
(defconst CASTLEUPIDLEFOOD 690)
#else #load-if-defined SLAVIC-CIV
(defconst DESIREDVILLS 124)
(defconst MAXVILLS 129)
(defconst FC-FARMS 9)
(defconst CASTLEUPIDLEFOOD 690)
#else #load-if-defined KOREAN-CIV
(defconst DESIREDVILLS 140)
(defconst MAXVILLS 150)
(defconst FC-FARMS 10)
(defconst CASTLEUPIDLEFOOD 700)
#else
(defconst FC-FARMS 10)
(defconst DESIREDVILLS 124)
(defconst MAXVILLS 129)
#load-if-defined ITALIAN-CIV
(defconst CASTLEUPIDLEFOOD 600)
#else
(defconst CASTLEUPIDLEFOOD 700)
#end-if #end-if #end-if #end-if

