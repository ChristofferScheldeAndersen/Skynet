; ==== SET STRATEGIC NUMBERS ====
; ===============================
(defrule
	(strategic-number sn-cap-civilian-builders != 100)
	=>
	(set-strategic-number sn-cap-civilian-builders 100)
	(set-strategic-number sn-percent-civilian-builders 100); ??
	(set-strategic-number sn-percent-civilian-gatherers 100); ??
	(set-strategic-number sn-percent-building-cancellation 25)
	(set-strategic-number sn-camp-max-distance 13)
	(set-strategic-number sn-initial-exploration-required 0)
	(set-strategic-number sn-food-dropsite-distance -1)
	(set-strategic-number sn-wood-dropsite-distance -1)
	(set-strategic-number sn-stone-dropsite-distance 25)
	(set-strategic-number sn-gold-dropsite-distance 5)
	(set-strategic-number sn-maximum-food-drop-distance 15)
	(set-strategic-number sn-maximum-wood-drop-distance 15)
	(set-strategic-number sn-maximum-stone-drop-distance 8)
	(set-strategic-number sn-maximum-gold-drop-distance 8)
	(set-strategic-number sn-maximum-hunt-drop-distance 6)
	(set-strategic-number sn-maximum-fish-boat-drop-distance 20)
	(set-strategic-number sn-preferred-settlement-placement 6))
(defrule
	(strategic-number sn-enable-patrol-attack != 1)
	=>
	(set-strategic-number sn-enable-patrol-attack 1)
	(set-strategic-number sn-town-center-placement mining-camp)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-dropsite-separation-distance 3)
	(set-strategic-number sn-mill-max-distance 15)
	(set-strategic-number sn-gold-defend-priority 1)
	(set-strategic-number sn-stone-defend-priority 0)
	(set-strategic-number sn-forage-defend-priority 0)
	(set-strategic-number sn-relic-defend-priority 0)
	(set-strategic-number sn-town-defend-priority 0)
	(set-strategic-number sn-enemy-sighted-response-distance 30)
	(set-strategic-number sn-gather-idle-soldiers-at-center 0)
	(set-strategic-number sn-number-civilian-militia 7)
	(set-strategic-number sn-allow-civilian-defense 3)
	(set-strategic-number sn-allow-civilian-offense 2))
(defrule
	(strategic-number sn-local-targeting-mode != 1)
	=>
	(set-strategic-number sn-local-targeting-mode 1)
	(set-strategic-number sn-enable-new-building-system 1)
	(set-strategic-number sn-target-evaluation-siege-weapon 80)
	(set-strategic-number sn-livestock-to-town-center 1)
	(set-strategic-number sn-number-build-attempts-before-skip 1); default is 25 jfc
	(set-strategic-number sn-enable-training-queue 1)
	(set-strategic-number sn-home-exploration-time 420); 7 minutes
	(set-strategic-number sn-maximum-gaia-attack-response 1)
	(set-strategic-number sn-enable-boar-hunting 1)
	(set-strategic-number sn-minimum-number-hunters 5)
	(set-strategic-number sn-minimum-boar-lure-group-size 1337)
	(set-strategic-number sn-minimum-boar-hunt-group-size 0)
	(set-strategic-number sn-do-not-scale-for-difficulty-level 1)
	(set-difficulty-parameter ability-to-dodge-missiles 0)
	(set-difficulty-parameter ability-to-maintain-distance 0))
(defrule
	(strategic-number sn-disable-tower-priority != 1)
	=>
	(set-strategic-number sn-disable-tower-priority 1)
	(set-strategic-number sn-target-player-number -1)
	(set-strategic-number sn-disable-builder-assistance 1)
	(set-strategic-number sn-percent-enemy-sighted-response 100)
	(set-strategic-number sn-attack-intelligence 1)
	(set-strategic-number sn-intelligent-gathering 1)
	(set-strategic-number sn-minimum-water-body-size-for-dock 800)
	(up-modify-sn sn-preferred-trade-distance g:= G-mapsize)
	(up-modify-sn sn-preferred-trade-distance c:- 5)
	(up-modify-sn sn-zero-priority-distance g:= G-mapsize)
	(set-strategic-number sn-coop-share-information 1)
	(set-strategic-number sn-retask-gather-amount 0)
	(set-strategic-number sn-target-point-adjustment 5)
	(set-strategic-number SN-ts-increment 2)
	(set-strategic-number sn-allow-serjeant-building 1)
	(set-strategic-number sn-wild-animal-exploration 1)
	(set-strategic-number sn-disable-trade-evasion 1))

(defrule
	(true)
	=>
	(set-strategic-number sn-percent-civilian-explorers 0)
	(set-strategic-number sn-minimum-civilian-explorers 0)
	(set-strategic-number sn-cap-civilian-explorers 0)
	(up-modify-sn sn-total-number-explorers g:= G-starting-scouts)
	(up-modify-sn sn-number-explore-groups g:= G-starting-scouts)
	(disable-self))

#load-if-not-defined REVEAL-NORMAL
(defrule
	(true)
	=>
	(set-strategic-number sn-unexplored-construction 1)
	(disable-self))
#end-if


