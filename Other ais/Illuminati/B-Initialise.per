(defrule
	(goal G-alpha-illu 1)
	(game-time >= 10)
	=>
	(chat-to-all "Sorry, I can only play Dark Age start.")
	(disable-self))
(defrule
	(game-time >= 15)
	=>
	(resign))
#end-if
