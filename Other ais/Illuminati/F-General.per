	(up-find-resource c: forage-bush-class c: 8)
	(up-filter-distance c: 5 c: 45)
	(up-filter-status c: status-resource c: list-active)
	(up-find-resource c: forage-bush-class c: 8)
	(up-clean-search search-remote object-data-distance search-order-asc))
