; =====================
; ==== BUILD ORDER ====
; =====================
#load-if-not-defined HUN-CIV
(defrule; first house
	(building-type-count-total house == 0)
	(up-compare-goal G-starting-tcs >= 1)
	(population-headroom > 0)
	(housing-headroom < 3)
	(can-build house)
	(building-type-count-total town-center >= 1)
	(or	(building-type-count town-center >= 1)
		(housing-headroom < 5))
	=>
	(up-assign-builders c: house c: 2)
	(up-set-placement-data my-player-number villager-class c: 1)
	(up-build place-control 0 c: house)
	(disable-self))
(defrule; 2nd house
	(building-type-count-total house == 1)
	(or	(building-type-count town-center >= 1)
		(and	(housing-headroom < 10)
			(unit-type-count villager >= 6)))
	(can-build house)
	(population-headroom > 5)
	(up-get-fact unit-type-count villager-builder G-temp7)
	(unit-type-count villager g:> G-temp7)
	=>
	(up-assign-builders c: house c: 1)
	(up-full-reset-search)
	(up-find-local c: villager-class c: 6)
	(up-remove-objects search-local object-data-action == actionid-build)
	(up-set-target-object search-local c: 0)
	(up-get-point position-object P-placement-x)
	(up-set-target-point P-placement-x)
	(up-build place-point 0 c: house)
	(disable-self))
#end-if

(defrule; food source available
	(building-type-count town-center >= 1)
	(or	(or	(or	(resource-found food)
				(or	(up-compare-goal G-sheep-total >= 2)
					(not	(sheep-and-forage-too-far))))
			(building-type-count farm >= 1))
		(and	(dropsite-min-distance hunting s:< sn-maximum-hunt-drop-distance)
			(dropsite-min-distance hunting != -1)))
	=>
	(set-goal G-eco-balance GV-early-dark)
	(up-retask-gatherers wood c: 6)
	(disable-self))


(defrule; build mill
	(building-type-count-total MILL < 1)
	(building-type-count-total town-center >= 1)
	(up-pending-objects c: MILL < 1)
	(nand	(goal G-docking 1)
		(building-type-count-total dock < 1))
	(resource-found food)
	(can-build MILL)
	(or	(unit-type-count villager >= 8)
		(and	(dropsite-min-distance food > 4)
			(and	(up-compare-goal G-sheep-count < 2)
				(or	(up-gaia-type-count c: livestock-class g:<= G-sheep-count)
					(not	(up-set-target-by-id g: ID-myscout))))))
	(unit-type-count villager-builder < 2)
	=>
	(set-goal G-temp7 1925553))
