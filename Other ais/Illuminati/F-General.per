	(goal G-age 1)
	(goal G-build-order GV-fast-castle)
	(or	(unit-type-count-total villager g:>= G-fc-vills)
		(unit-type-count-total villager g:>= G-desired-vills))
	(food-amount >= 380)
	(or	(and	(building-type-count-total lumber-camp >= 1)
			(building-type-count-total mill >= 1))
		(building-type-count-total settlement >= 2))
	=>
	(set-goal G-force-tc-idle 1)
	(disable-self))
(defrule
	(goal G-age 1)
	(goal G-build-order GV-feudal-war)
	(or	(unit-type-count-total villager >= 21)
		(unit-type-count-total villager g:>= G-desired-vills))
	(or	(unit-type-count-total villager >= 25)
		(food-amount >= 420))
	(or	(and	(building-type-count-total lumber-camp >= 1)
			(building-type-count-total mill >= 1))
		(building-type-count-total settlement >= 2))
	=>
	(set-goal G-force-tc-idle 1)
	(disable-self))
(defrule
	(goal G-age 1)
	(goal G-build-order GV-trush)
	(or	(unit-type-count-total villager >= 19)
		(unit-type-count-total villager g:>= G-desired-vills))
	(or	(unit-type-count-total villager >= 22)
		(food-amount >= 420))
	(food-amount >= 390)
	(or	(and	(building-type-count-total lumber-camp >= 1)
			(building-type-count-total mill >= 1))
		(building-type-count-total settlement >= 2))
	=>
	(set-goal G-force-tc-idle 1)
	(disable-self))

(defrule
	(goal G-age GV-feudal)
	(food-amount >= CASTLEUPIDLEFOOD)
	(gold-amount >= 170)
	(building-type-count-total blacksmith > 0)
	=>
	(set-strategic-number sn-focus-player-number my-player-number)
	(up-full-reset-search)
	(up-find-remote c: market c: 1)
	(up-find-remote c: archery-range c: 1)
	(up-find-remote c: stable c: 1))
(defrule
	(goal G-age GV-feudal)
	(food-amount >= CASTLEUPIDLEFOOD)
	(gold-amount >= 150)
	(building-type-count-total blacksmith > 0)
	(up-set-target-object search-remote c: 0)
	(up-get-object-data object-data-maxhp G-temp1)
	(up-modify-goal G-temp1 c:/ 2)
	(up-object-data object-data-hitpoints g:>= G-temp1)
	=>
	(set-goal G-force-tc-idle 1)
	(disable-self))

(defrule
	(goal G-age GV-feudal)
	(food-amount >= CASTLEUPIDLEFOOD)
	(gold-amount >= 150)
	(civ-selected khmer)
	=>
	(set-goal G-force-tc-idle 1)
	(disable-self))

(defrule
	(goal G-age GV-feudal)
	(or	(goal G-build-order GV-fast-castle)
		(goal G-build-order GV-slow-castle))
	(up-get-fact unit-type-count-total villager G-temp1)
	(up-modify-goal G-temp1 g:- G-tower-count)
	(up-compare-goal G-temp1 >= 30)
	=>
