(defrule
	(goal G-trushed 0)
	(goal G-attack -1)
	(strategic-number sn-maximum-town-size < 30)
	(or	(up-building-type-in-town c: watch-tower > 0)
		(up-building-type-in-town c: donjon > 0))
	=>
;	(chat-to-player my-player-number "enemy tower in town")
	(set-goal G-trushed 1))
(defrule
	(goal G-trushed 1)
	(or	(up-compare-goal G-attack >= 0)
		(nor	(up-building-type-in-town c: watch-tower > 0)
			(up-building-type-in-town c: donjon > 0)))
	=>
	(set-goal G-trushed 0))

; == ENEMY TC COORDS ==
(defrule
