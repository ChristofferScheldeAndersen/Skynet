(defconst gl-best-dropsite-y 1048)

(defconst gl-current-target-index 1049)
(defconst gl-first-final-retasking-rule-id 1050)
(defconst gl-max-target-index 1051)
(defconst gl-current-target-id 1052)

(defconst gl-target-x 1053)
(defconst gl-target-y 1054)

(defconst gl-top-right-x 1055)
(defconst gl-top-right-y 1056)

(defconst gl-bottom-right-x 1057)
(defconst gl-bottom-right-y 1058)

(defconst gl-bottom-left-x 1059)
(defconst gl-bottom-left-y 1060)

(defconst gl-top-left-x 1061)
(defconst gl-top-left-y 1062)

(defconst gl-new-target-id-current-goal-constant 1064)
(defconst gl-new-target-id-last-goal-constant 1065)
(defconst gl-nr-new-targets-this-pass 1066)
(defconst gl-current-index-target-id 1067)
(defconst gl-temp 1068)
(defconst gl-new-target-id-first-goal-constant 1100)
(defconst gl-new-target-id-very-last-goal-constant 1299)




	(defrule
		(true)
		=>
		(set-goal gl-current-villager-index 0)
	)

	(defrule
		(true)
		=>
		(up-get-rule-id gl-first-rule-setting-villager-groups)
	)

	(defrule
		(true)
		=>
		(set-goal gl-villager-to-be-retasked-id -1)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-max-villager-index g:= gl-local-total)
		(up-modify-goal gl-max-villager-index c:- 1)
	)

	(defrule
		(up-set-target-object search-local g: gl-current-villager-index)
		(game-time < 5)
		=>
		(up-get-point position-object gl-temp-x)
		(up-set-target-point gl-temp-x)
		(up-modify-sn sn-focus-player-number c:= my-player-number)
		(up-find-remote c: mill c: 40)
		(up-find-remote c: lumber-camp c: 40)
		(up-find-remote c: mining-camp c: 40)
		(up-find-remote c: town-center c: 40)
		(up-get-search-state gl-local-total)
		(up-clean-search search-remote object-data-distance search-order-asc)
	)

	(defrule
		(up-set-target-object search-local g: gl-current-villager-index)
		(up-set-target-object search-remote c: 0)
		=>
		(up-get-object-data object-data-type gl-current-building-type)
	)

	(defrule
		(up-compare-goal gl-current-building-type == lumber-camp)
		(up-set-target-object search-remote c: 0)
		(up-set-target-object search-local g: gl-current-villager-index)
		=>
		(up-get-object-data object-data-id gl-current-villager-id)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-remove-objects search-local object-data-group-flag != wood-villager-group)
		(up-add-object-by-id search-local g: gl-current-villager-id)
		(up-reset-group c: wood-villager-group)
		(up-modify-group-flag 0 c: wood-villager-group)
		(up-create-group 0 0 c: wood-villager-group)
		(up-modify-group-flag 1 c: wood-villager-group)
	)

	(defrule
		(up-set-target-object search-remote c: 0)
		(up-compare-goal gl-current-building-type == mining-camp)
		(up-set-target-object search-local g: gl-current-villager-index)
		=>
		(up-get-object-data object-data-id gl-current-villager-id)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-remove-objects search-local object-data-group-flag != gold-villager-group)
		(up-add-object-by-id search-local g: gl-current-villager-id)
		(up-modify-group-flag 0 c: gold-villager-group)
		(up-create-group 0 0 c: gold-villager-group)
		(up-modify-group-flag 1 c: gold-villager-group)
	)

	(defrule
		(up-set-target-object search-remote c: 0)
		(or(up-compare-goal gl-current-building-type == mill)
		(up-compare-goal gl-current-building-type == town-center))
		(up-set-target-object search-local g: gl-current-villager-index)
		=>
		(up-get-object-data object-data-id gl-current-villager-id)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-remove-objects search-local object-data-group-flag != food-villager-group)
		(up-add-object-by-id search-local g: gl-current-villager-id)
		(up-reset-group c: food-villager-group)
		(up-modify-group-flag 0 c: food-villager-group)
		(up-create-group 0 0 c: food-villager-group)
		(up-modify-group-flag 1 c: food-villager-group)
	)

	(defrule
		(up-compare-goal gl-current-villager-index g:< gl-max-villager-index)
		(up-compare-goal gl-first-rule-setting-villager-groups != -1)
		=>
		(up-modify-goal gl-current-villager-index c:+ 1)
		(up-jump-direct g: gl-first-rule-setting-villager-groups)
	)



	(defrule
		(game-time < 5)
		=>
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		;(up-reset-group c: food-villager-group)
		;(up-modify-group-flag 0 c: food-villager-group)
		;(up-create-group 0 0 c: food-villager-group)
		;(up-modify-group-flag 1 c: food-villager-group)
	)




	
	(defrule
		(true)
		=>
		(set-goal gl-current-villager-group gold-villager-group) ; 4
		(set-goal gl-current-villager-group-res 3) 
		(set-goal gl-nr-new-targets-this-pass 0)
		(set-goal gl-new-target-id-current-goal-constant gl-new-target-id-first-goal-constant)
		(set-goal gl-new-target-id-last-goal-constant gl-new-target-id-first-goal-constant)
		;(chat-to-all "new pass")
	)

	; food-worker: food → wood → gold → stone

	(defrule
		(true)
		=>
		(up-get-rule-id gl-set-new-villager-group-rule-id)
	)

	(defrule
		(true)
		=>
		(set-goal gl-current-villager-index 0)
	)

	(defrule
		(true)
		=>
		(up-get-rule-id gl-find-buggy-villager-first-rule)
		(up-full-reset-search)
		(up-set-group search-local g: gl-current-villager-group)

		;(up-remove-objects search-local object-data-carry c:> 0)
		(up-remove-objects search-local object-data-action c:== actionid-build)
		(up-remove-objects search-local object-data-action c:== actionid-attack)
		(up-remove-objects search-local object-data-action c:== actionid-explore)
		(up-remove-objects search-local object-data-tasks-count c:> 0)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-max-villager-index g:= gl-local-total)
		(up-modify-goal gl-max-villager-index c:- 1)
		(set-goal gl-villager-target-ressource -1)
	)

	(defrule
		(up-set-target-object search-local g: gl-current-villager-index)
		=>
		(up-get-object-data object-data-id gl-current-villager-id)
		(up-get-object-data object-data-language-id gl-villager-language-id)
	)

	(defrule
		(or (or (or (or (up-compare-goal gl-villager-language-id c:== lid_villager-farmer)
						(up-compare-goal gl-villager-language-id c:== lid_villager-forager))
					(up-compare-goal gl-villager-language-id c:== lid_villager-shepherd))
				(up-compare-goal gl-villager-language-id c:== lid_villager-hunter))
			(up-compare-goal gl-villager-language-id c:== lid_villager-fisherman))
		=>
		(up-modify-goal gl-villager-target-ressource c:= food))

	(defrule
		(up-compare-goal gl-villager-language-id c:== lid_villager-lumberjack)
		=>
		(up-modify-goal gl-villager-target-ressource c:= wood))

	(defrule
		(up-compare-goal gl-villager-language-id c:== lid_villager-stone-miner)
		=>
		(up-modify-goal gl-villager-target-ressource c:= stone))

	(defrule
		(up-compare-goal gl-villager-language-id c:== lid_villager-gold-miner)
		=>
		(up-modify-goal gl-villager-target-ressource c:= gold))

	(defrule
		(up-set-target-object search-local g: gl-current-villager-index)
		(or(up-compare-goal gl-villager-target-ressource g:!= gl-current-villager-group-res)
		(up-object-data object-data-idling == 1))
		(up-compare-goal gl-first-retasking-rule-id != -1)
		=>
		;up-full-reset-search)
		;(up-add-object-by-id search-local g: gl-current-villager-id)
		;(up-chat-data-to-all "wrong res is %d" g: gl-villager-target-ressource)
		;(up-target-point gl-temp-x action-stop -1 -1)
		(up-modify-goal gl-villager-to-be-retasked-id g:= gl-current-villager-id)
		;(chat-to-all "found vill to retask")
		(up-jump-direct g: gl-first-retasking-rule-id)
		)

	(defrule
		(true)
		=>
		(up-get-rule-id gl-post-retasking-rule-id)
	)

	(defrule
		(up-compare-goal gl-current-villager-index g:< gl-max-villager-index)
		(up-compare-goal gl-find-buggy-villager-first-rule != -1)
		=>
		(up-modify-goal gl-current-villager-index c:+ 1)
		(up-jump-direct g: gl-find-buggy-villager-first-rule)
	)

	(defrule
		(up-compare-goal gl-current-villager-group > 1)
		(up-compare-goal gl-set-new-villager-group-rule-id != -1)
		=>
		(up-modify-goal gl-current-villager-group c:- 1)
		(up-modify-goal gl-current-villager-group-res c:- 1)
		(up-jump-direct g: gl-set-new-villager-group-rule-id)
	)

	(defrule
		(up-compare-goal gl-end-of-retasking-rules != -1)
		=>
		(up-jump-direct g: gl-end-of-retasking-rules)
	)







	(defrule
		(true)
		=>
		(up-get-rule-id gl-first-retasking-rule-id)
	)

	(defrule
		(true)
		=>
		(set-goal gl-dropsite-index 0)
		(set-goal gl-best-dropsite-score -99999)

		(set-goal gl-villager-dropsite-distance-score-multiplier 2000) ;100
		(set-goal gl-crowding-score-multiplier 200)
		(set-goal gl-dropsite-res-count-score-multiplier 100)
		(set-goal gl-dropsite-res-distance-score-multiplier 500)
	)

	(defrule
		(true)
		=>
		(up-get-rule-id gl-first-dropsite-rule-id)
	)

	(defrule
		(up-set-target-by-id g: gl-villager-to-be-retasked-id)
		=>
		(up-get-object-data object-data-group-flag gl-current-group)
		(up-modify-goal gl-intended-target-res g:= gl-current-group)
		(up-modify-goal gl-intended-target-res c:- 1)
		(up-get-point position-object gl-villager-to-be-retasked-x)
		(up-full-reset-search)
		; evt. filter distance på 40
		(up-find-local c: town-center c: 240)
	)

	(defrule
		(up-compare-goal gl-intended-target-res == wood)
		=>
		(up-find-local c: lumber-camp c: 240)
	)

	(defrule
		(up-compare-goal gl-intended-target-res == food)
		=>
		(up-find-local c: mill c: 240)
	)

	(defrule
		(or(up-compare-goal gl-intended-target-res == gold)
		(up-compare-goal gl-intended-target-res == stone))
		=>
		(up-find-local c: mining-camp c: 240)
	)

	(defrule
		(true)
		=>
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-dropsite-max-index g:= gl-local-total)
		(up-modify-goal gl-dropsite-max-index c:- 1)
	)

	(defrule
		(up-set-target-object search-local g: gl-dropsite-index)
		(up-compare-goal gl-intended-target-res == wood)
		=>
		(up-get-object-data object-data-id gl-dropsite-id)
		(up-get-point position-object gl-dropsite-x)
		(up-get-point-distance gl-villager-to-be-retasked-x gl-dropsite-x gl-villager-dropsite-distance)
		(up-set-target-point gl-dropsite-x)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-remove-objects search-local object-data-distance > 7)
		(up-remove-objects search-local object-data-group-flag g:!= gl-current-group)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-crowding g:= gl-local-total)
		(up-filter-distance c: -1 c: 5)
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: wood c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: wood c: 40)
		(up-filter-distance c: 5 c: 7)
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: wood c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: wood c: 40)
		(up-remove-objects search-remote object-data-tasks-count > 1)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-dropsite-res-count g:= gl-remote-total)
		(up-clean-search search-remote object-data-full-distance search-order-asc)
	)

	(defrule
		(up-set-target-object search-local g: gl-dropsite-index)
		(up-compare-goal gl-intended-target-res == food)
		=>
		(up-get-object-data object-data-id gl-dropsite-id)
		(up-get-point position-object gl-dropsite-x)
		(up-get-point-distance gl-villager-to-be-retasked-x gl-dropsite-x gl-villager-dropsite-distance)
		(up-set-target-point gl-dropsite-x)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-remove-objects search-local object-data-distance > 7)
		(up-remove-objects search-local object-data-group-flag g:!= gl-current-group)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-crowding g:= gl-local-total)
		(up-filter-distance c: -1 c: 10)
		(up-modify-sn sn-focus-player-number c:= my-player-number)
		(up-find-remote c: farm-class c: 40)
		(up-remove-objects search-remote object-data-tasks-count > 0)
		(up-filter-distance c: -1 c: 6)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: food c: 40)
		(up-remove-objects search-remote object-data-tasks-count > 1)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-dropsite-res-count g:= gl-remote-total)
		(up-clean-search search-remote object-data-full-distance search-order-asc)
	)

	(defrule
		(up-set-target-object search-local g: gl-dropsite-index)
		(up-compare-goal gl-intended-target-res == gold)
		=>
		(up-get-object-data object-data-id gl-dropsite-id)
		(up-get-point position-object gl-dropsite-x)
		(up-get-point-distance gl-villager-to-be-retasked-x gl-dropsite-x gl-villager-dropsite-distance)
		(up-set-target-point gl-dropsite-x)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-remove-objects search-local object-data-distance > 7)
		(up-remove-objects search-local object-data-group-flag g:!= gl-current-group)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-crowding g:= gl-local-total)
		(up-filter-distance c: -1 c: 6)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: gold c: 40)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-dropsite-res-count g:= gl-remote-total)
		(up-clean-search search-remote object-data-full-distance search-order-asc)
	)

	(defrule
		(up-set-target-object search-local g: gl-dropsite-index)
		(up-compare-goal gl-intended-target-res == stone)
		=>
		(up-get-object-data object-data-id gl-dropsite-id)
		(up-get-point position-object gl-dropsite-x)
		(up-get-point-distance gl-villager-to-be-retasked-x gl-dropsite-x gl-villager-dropsite-distance)
		(up-set-target-point gl-dropsite-x)
		(up-full-reset-search)
		(up-find-local c: villager-class c: 200)
		(up-remove-objects search-local object-data-distance > 7)
		(up-remove-objects search-local object-data-group-flag g:!= gl-current-group)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-crowding g:= gl-local-total)
		(up-filter-distance c: -1 c: 6)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: stone c: 40)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-dropsite-res-count g:= gl-remote-total)
		(up-clean-search search-remote object-data-full-distance search-order-asc)
	)

	(defrule
		(up-set-target-object search-local g: gl-dropsite-index)
		(up-set-target-object search-remote c: 0)
		=>
		(up-get-object-data object-data-precise-distance gl-dropsite-res-precise-distance)
	)

	(defrule
		(true)
		=>
		(up-modify-goal gl-villager-dropsite-distance-score g:= gl-villager-dropsite-distance)
		(up-modify-goal gl-villager-dropsite-distance-score g:* gl-villager-dropsite-distance-score-multiplier)

		(up-modify-goal gl-crowding-score g:= gl-crowding)
		(up-modify-goal gl-crowding-score g:* gl-crowding-score-multiplier)

		(up-modify-goal gl-dropsite-res-count-score g:= gl-dropsite-res-count)
		(up-modify-goal gl-dropsite-res-count-score g:* gl-dropsite-res-count-score-multiplier)

		(up-modify-goal gl-dropsite-res-distance-score g:= gl-dropsite-res-precise-distance)
		(up-modify-goal gl-dropsite-res-distance-score g:* gl-dropsite-res-distance-score-multiplier)
		(up-modify-goal gl-dropsite-res-distance-score c:/ 100)
		
		(set-goal gl-dropsite-score 0)
		(up-modify-goal gl-dropsite-score g:- gl-villager-dropsite-distance-score)
		(up-modify-goal gl-dropsite-score g:- gl-crowding-score)
		(up-modify-goal gl-dropsite-score g:+ gl-dropsite-res-count-score)
		(up-modify-goal gl-dropsite-score g:- gl-dropsite-res-distance-score)
	)

	(defrule
		(up-compare-goal gl-best-dropsite-score g:< gl-dropsite-score)
		(up-compare-goal gl-dropsite-res-count-score > 0)
		=>
		(up-modify-goal gl-best-dropsite-id g:= gl-dropsite-id)
		(up-modify-goal gl-best-dropsite-x g:= gl-dropsite-x)
		(up-modify-goal gl-best-dropsite-y g:= gl-dropsite-y)
		(up-modify-goal gl-best-dropsite-score g:= gl-dropsite-score)
		(up-modify-goal gl-best-villager-dropsite-distance-score g:= gl-villager-dropsite-distance-score)
		(up-modify-goal gl-best-crowding-score g:= gl-crowding-score)
		(up-modify-goal gl-best-dropsite-res-count-score g:= gl-dropsite-res-count-score)
		(up-modify-goal gl-best-dropsite-res-distance-score g:= gl-dropsite-res-distance-score)

	)

	(defrule
		(up-compare-goal gl-dropsite-index g:< gl-dropsite-max-index)
		=>
		(up-modify-goal gl-dropsite-index c:+ 1)
		(up-jump-direct g: gl-first-dropsite-rule-id)
	)


	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-set-target-by-id g: gl-villager-to-be-retasked-id)
		(up-compare-goal gl-post-retasking-rule-id != -1)
		=>
		;(up-full-reset-search)
		;(up-add-object-by-id search-local g: gl-villager-to-be-retasked-id)
		;(up-add-object-by-id search-remote g: gl-best-dropsite-id)
		;(up-target-objects 0 action-default -1 -1)
		;(up-chat-data-to-all "best score: %d" g: gl-best-dropsite-score)
		;(up-chat-data-to-all "villager-dropsite distance score: %d" g: gl-best-villager-dropsite-distance-score)
		;(up-chat-data-to-all "crowding score: %d" g: gl-best-crowding-score)
		;(up-chat-data-to-all "dropsite-res count score: %d" g: gl-best-dropsite-res-count-score)
		;(up-chat-data-to-all "dropsite-res distance score: %d" g: gl-best-dropsite-res-distance-score)
		;(up-jump-direct g: gl-post-retasking-rule-id)
		;(chat-to-all "found best dropsite")
		;(up-send-flare gl-best-dropsite-x)
		(set-goal gl-current-target-index 0)
	)

	(defrule
		(true)
		=>
		(up-get-rule-id gl-first-final-retasking-rule-id)
	)

	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-compare-goal gl-intended-target-res == wood)
		=>
		(up-full-reset-search)
		(up-set-target-point gl-best-dropsite-x)
		(up-filter-distance c: -1 c: 5)
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: wood c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: wood c: 40)
		(up-filter-distance c: 5 c: 7)
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: wood c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: wood c: 40)
		(up-remove-objects search-remote object-data-tasks-count > 1)
		(set-goal gl-new-target-id-current-goal-constant gl-new-target-id-first-goal-constant)
	)
	
	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-compare-goal gl-intended-target-res == gold)
		=>
		(up-full-reset-search)
		(up-set-target-point gl-best-dropsite-x)
		(up-filter-distance c: -1 c: 6)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: gold c: 40)
		(up-remove-objects search-remote object-data-tasks-count > 1)
		(set-goal gl-new-target-id-current-goal-constant gl-new-target-id-first-goal-constant)
	)

	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-compare-goal gl-intended-target-res == food)
		=>
		(up-full-reset-search)
		(up-set-target-point gl-best-dropsite-x)
		(up-modify-sn sn-target-player-number c:= my-player-number)
		(up-filter-distance c: -1 c: 10)
		(up-find-remote c: farm-class c: 40)
		(up-remove-objects search-remote object-data-tasks-count > 0)
		(up-filter-distance c: -1 c: 6)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: food c: 40)
		(up-remove-objects search-remote object-data-tasks-count > 1)
		(set-goal gl-new-target-id-current-goal-constant gl-new-target-id-first-goal-constant)
	)

	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-compare-goal gl-new-target-id-current-goal-constant g:< gl-new-target-id-last-goal-constant)
		=>
		(up-get-indirect-goal g: gl-new-target-id-current-goal-constant gl-current-index-target-id)
	)

	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-compare-goal gl-new-target-id-current-goal-constant g:< gl-new-target-id-last-goal-constant)
		(up-set-target-by-id g: gl-current-index-target-id)
		(or(up-point-distance gl-best-dropsite-x gl-villager-to-be-retasked-x > 3)
		(up-object-data object-data-class == farm-class))
		=>
		(up-remove-objects search-remote object-data-id g:== gl-current-index-target-id)
		(up-modify-goal gl-new-target-id-current-goal-constant c:+ 1)
		(up-jump-rule -2)
	)

	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-compare-goal gl-new-target-id-current-goal-constant g:< gl-new-target-id-last-goal-constant)
		(up-set-target-by-id g: gl-current-index-target-id)
		=>
		(up-modify-goal gl-new-target-id-current-goal-constant c:+ 1)
		(up-jump-rule -3)
	)


	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		=>
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-max-target-index g:= gl-remote-total)
		(up-modify-goal gl-max-target-index c:- 1)
		(up-set-target-point gl-best-dropsite-x)
		(up-clean-search search-remote object-data-distance search-order-asc)
	)

	(defrule
		(up-point-distance gl-best-dropsite-x gl-villager-to-be-retasked-x <= 3)
		=>
		(up-set-target-point gl-villager-to-be-retasked-x)
		(up-clean-search search-remote object-data-distance search-order-asc)
	)

	(defrule
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-set-target-object search-remote g: gl-current-target-index)
		=>
		(up-get-object-data object-data-id gl-current-target-id)
		(up-get-point position-object gl-target-x)
		(up-copy-point gl-top-right-x gl-target-x)
		(up-modify-goal gl-top-right-x c:+ 1)
		(up-copy-point gl-bottom-right-x gl-target-x)
		(up-modify-goal gl-bottom-right-y c:+ 1)
		(up-copy-point gl-bottom-left-x gl-target-x)
		(up-modify-goal gl-bottom-left-x c:- 1)
		(up-copy-point gl-top-left-x gl-target-x)
		(up-modify-goal gl-top-left-y c:- 1)
	)

	(defrule
		(can-afford-building palisade-wall)
		(up-set-target-object search-remote g: gl-current-target-index)
		(or(up-object-data object-data-class == farm-class)
		(or(up-can-build-line 0 gl-top-right-x c: palisade-wall)
		(or(up-can-build-line 0 gl-bottom-right-x c: palisade-wall)
		(or(up-can-build-line 0 gl-bottom-left-x c: palisade-wall)
		(up-can-build-line 0 gl-top-left-x c: palisade-wall)))))
		=>
		(up-full-reset-search)
		(up-add-object-by-id search-local g: gl-villager-to-be-retasked-id)
		(up-add-object-by-id search-remote g: gl-current-target-id)
		(up-target-objects 0 action-default -1 -1)
		;(up-chat-data-to-all "vill nr %d retasked" g: gl-nr-new-targets-this-pass)
		(set-goal gl-new-target-id-current-goal-constant gl-new-target-id-first-goal-constant)
		(up-modify-goal gl-new-target-id-current-goal-constant g:+ gl-nr-new-targets-this-pass)
		(up-set-indirect-goal g: gl-new-target-id-current-goal-constant g: gl-current-target-id)
		;(up-chat-data-to-all "tree %d added to prev targets" g: gl-current-target-id)
		(up-modify-goal gl-new-target-id-last-goal-constant c:+ 1)
		(up-modify-goal gl-nr-new-targets-this-pass c:+ 1)
		(up-jump-rule 1)
	)

	(defrule
		(up-compare-goal gl-current-target-index g:< gl-max-target-index)
		(up-compare-goal gl-first-final-retasking-rule-id != -1)
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-set-target-by-id g: gl-villager-to-be-retasked-id)
		=>
		(up-modify-goal gl-current-target-index c:+ 1)
		(up-jump-direct g: gl-first-final-retasking-rule-id)
	)

	(defrule
		(up-compare-goal gl-post-retasking-rule-id != -1)
		(up-set-target-by-id g: gl-best-dropsite-id)
		(up-set-target-by-id g: gl-villager-to-be-retasked-id)
		=>
		(up-jump-direct g: gl-post-retasking-rule-id)
	)








	(defrule
		(true)
		=>
		(up-get-rule-id gl-end-of-retasking-rules)
	)




; ===== INPUT / OUTPUT GOALS =====
(defconst gl-vill-total      1)

(defconst gl-pct-food        2)
(defconst gl-pct-wood        3)
(defconst gl-pct-gold        4)
(defconst gl-pct-stone       5)

(defconst gl-vills-food      6)
(defconst gl-vills-wood      7)
(defconst gl-vills-gold      8)
(defconst gl-vills-stone     9)

(defconst gl-bound-food      10)
(defconst gl-bound-foodwood  11)
(defconst gl-bound-foodwoodgold 12)

(defrule
    (true)
=>
    ; hent aktuelle gather percentages
    ;(up-modify-goal gl-pct-food  s:= sn-food-gatherer-percentage)
    ;(up-modify-goal gl-pct-wood  s:= sn-wood-gatherer-percentage)
    ;(up-modify-goal gl-pct-gold  s:= sn-gold-gatherer-percentage)
    ;(up-modify-goal gl-pct-stone s:= sn-stone-gatherer-percentage)
	(up-modify-goal gl-pct-food  c:= 55)
    (up-modify-goal gl-pct-wood  c:= 25)
    (up-modify-goal gl-pct-gold  c:= 15)
    (up-modify-goal gl-pct-stone c:= 5)

    ; hent aktuelt antal villagers
    (up-get-fact unit-type-count-total villager gl-vill-total)

    ; bound_food = round(total * food / 100)
    (up-modify-goal gl-bound-food g:= gl-vill-total)
    (up-modify-goal gl-bound-food g:* gl-pct-food)
    (up-modify-goal gl-bound-food c:/ 100)

    ; bound_foodwood = round(total * (food + wood) / 100)
    (up-modify-goal gl-bound-foodwood g:= gl-pct-food)
    (up-modify-goal gl-bound-foodwood g:+ gl-pct-wood)
    (up-modify-goal gl-bound-foodwood g:* gl-vill-total)
    (up-modify-goal gl-bound-foodwood c:/ 100)

    ; bound_foodwoodgold = round(total * (food + wood + gold) / 100)
    (up-modify-goal gl-bound-foodwoodgold g:= gl-pct-food)
    (up-modify-goal gl-bound-foodwoodgold g:+ gl-pct-wood)
    (up-modify-goal gl-bound-foodwoodgold g:+ gl-pct-gold)
    (up-modify-goal gl-bound-foodwoodgold g:* gl-vill-total)
    (up-modify-goal gl-bound-foodwoodgold c:/ 100)
)

(defrule
	(true)
	=>
	; endelige mål
    (up-modify-goal gl-vills-food g:= gl-bound-food)

    (up-modify-goal gl-vills-wood g:= gl-bound-foodwood)
    (up-modify-goal gl-vills-wood g:- gl-bound-food)

    (up-modify-goal gl-vills-gold g:= gl-bound-foodwoodgold)
    (up-modify-goal gl-vills-gold g:- gl-bound-foodwood)

    (up-modify-goal gl-vills-stone g:= gl-vill-total)
    (up-modify-goal gl-vills-stone g:- gl-bound-foodwoodgold)
	;(up-chat-data-to-all "nr food: %d" g: gl-vills-food)
	;(up-chat-data-to-all "nr wood: %d" g: gl-vills-wood)
	;(up-chat-data-to-all "nr gold: %d" g: gl-vills-gold)
	;(up-chat-data-to-all "nr stone: %d" g: gl-vills-stone)
)