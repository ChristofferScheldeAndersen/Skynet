#load-if-defined HIDEOUT-MAP

(defrule
(players-building-type-count target-player town-center > 1)
=>
(up-full-reset-search)
(up-get-point position-enemy gl-dot-x)
(up-set-target-point gl-dot-x)
(up-filter-distance c: 0 c: 16)
(up-filter-status c: 0 c: 0)
(up-find-status-local c: lumber-camp c: 40)
(up-remove-objects search-local 10 > 1)
(up-target-point 0 action-delete -1 -1)
)

(defrule
(true)
=>
(up-jump-rule 7)
)

(defrule
(true)
=>
(up-full-reset-search)
(up-filter-status c: 0 c: 0)
(up-find-status-local c: lumber-camp c: 40)
(up-remove-objects search-local 10 > 1)
(up-get-search-state gl-local-total)
(up-modify-goal gl-rule-loops g:= gl-local-total)
(up-modify-goal gl-current-list-number c:= 0)
)

(defrule
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
=>
(up-modify-sn sn-focus-player-number c:= 1)
)

(defrule
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
(up-compare-sn sn-focus-player-number < 9)
(or(up-compare-sn sn-focus-player-number == my-player-number)
(or(not(player-in-game focus-player))
(players-stance focus-player ally)))
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -1)
)

(defrule
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
(up-compare-sn sn-focus-player-number < 9)
=>
(up-reset-filters)
(up-get-point position-object gl-dot-x)
(up-filter-distance c: 0 c: 16)
(up-find-remote c: town-center c: 1)
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -2)
)

(defrule
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
=>
(up-get-search-state gl-local-total)
)

(defrule
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
(up-compare-goal gl-remote-total > 0)
=>
(up-remove-objects search-local -1 g:!= gl-current-list-number)
(up-target-point 0 action-delete -1 -1)
)

(defrule
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
(up-compare-goal gl-remote-total < 1)
=>
(up-modify-goal gl-current-list-number c:+ 1)
(up-jump-rule -6)
)

#end-if

