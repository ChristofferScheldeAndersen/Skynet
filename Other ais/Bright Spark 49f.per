;##### DEBUGGING TAUNTS #########

(defrule
(or(taunt-detected my-player-number 110)
(taunt-detected any-ally 110))
=>
(acknowledge-taunt my-player-number 110)
(acknowledge-taunt this-any-ally 110)
(up-chat-data-to-player every-ally "Primary Unit: %d." g: chosen-military-unit)
(up-chat-data-to-player every-ally "Secondary Unit: %d." g: supporting-military-unit)
(up-chat-data-to-player every-ally "Halt production: %d." g: halt-production)
(up-chat-data-to-player every-ally "Halt unit production: %d." g: halt-unit-production)
(up-chat-data-to-player every-ally "Military Mode: %d." g: military-mode)
(up-chat-data-to-player every-ally "Strat: %d." g: gl-game-strategy)
(up-chat-data-to-self "scout goal: %d." g: scout-goal)
(up-chat-data-to-self "Primary Unit: %d." g: chosen-military-unit)
(up-chat-data-to-self "Secondary Unit: %d." g: supporting-military-unit)
(up-chat-data-to-self "Halt production: %d." g: halt-production)
(up-chat-data-to-self "Halt unit production: %d." g: halt-unit-production)
