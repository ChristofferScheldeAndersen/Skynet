;###### TC Garrisoning ######

(defrule
(true)
=>
(up-get-point position-self gl-home-x)
(up-modify-sn sn-focus-player-number c:= 1)
(up-full-reset-search)
)

(defrule
(or(not(player-in-game focus-player))
(not(players-stance focus-player enemy)))
(up-compare-sn sn-focus-player-number > 0)
(up-compare-sn sn-focus-player-number < 9)
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -1)
)

(defrule
(up-compare-sn sn-focus-player-number > 0)
(up-compare-sn sn-focus-player-number < 9)
=>
(up-set-target-point gl-home-x)
(up-filter-distance c: -1 c: 8);7
(up-add-object-by-id search-remote g: gl-enemy-hunnic-horse)
(up-find-remote c: -1 c: 40)
;(up-remove-objects search-remote 1 c:= 598)
(up-remove-objects search-remote 20 == my-player-number)
(up-remove-objects search-remote 10 < 1)
(up-remove-objects search-remote 46 > 64)
(up-clean-search search-remote 44 1)
(up-get-search-state gl-local-total)
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -2)
)

(defrule
(up-compare-goal gl-remote-total < 1)
=>
(up-full-reset-search)
(up-set-target-point gl-home-x)
(up-filter-distance c: -1 c: 7)
(up-find-local c: town-center c: 15)
(up-remove-objects search-local 18 == 0)
(up-gather-inside c: town-center c: 0)
(up-target-point gl-home-x action-work -1 -1)
(up-full-reset-search)
)

(defrule
(up-compare-goal gl-remote-total > 0)
=>
;(chat-local-to-self "garrisoning")
(up-remove-objects search-remote 44 >= 7)
(up-clean-search search-remote 44 1)
(up-get-search-state gl-local-total)
)

(defrule
(up-compare-goal gl-remote-total > 0)
=>
(up-full-reset-search)
(up-set-target-point gl-home-x)
(up-filter-distance c: -1 c: 7)
(up-find-local c: -1 c: 15)
(up-modify-sn sn-focus-player-number c:= my-player-number)
(up-find-remote c: town-center c: 40)
(up-clean-search search-local 44 1)
(up-remove-objects search-remote -1 > 0)
)

(defrule
(up-compare-goal gl-remote-total > 0)
(up-set-target-object search-remote c: 0)
=>
;(chat-local-to-self "garrisoning 2")
(up-target-objects 1 action-garrison -1 -1)
(up-gather-inside c: town-center c: 1)
)

