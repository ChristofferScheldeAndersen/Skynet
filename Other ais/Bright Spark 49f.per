(defrule
(true)
=>
(up-get-precise-time 0 gl-last-pass-time)
)

(defrule
(true)
=>
(enable-timer minute-timer 60)
(disable-self)
)

;(defrule
;(true)
;=>
;(up-modify-goal gl-last-pass-time c:= 0)
;(disable-self)
;)

;(defrule
;(true)
;=>
;(up-get-precise-time gl-dot-x)
;(up-modify-goal gl-dot-y g:= gl-dot-x)
;(up-modify-goal gl-dot-y g:- gl-last-pass-time)
;(up-modify-goal gl-last-pass-time g:= gl-dot-x)
;)

;(defrule
;(true)
;=>
;(up-chat-data-to-all "time between passes: %d" g: gl-dot-y)
;)

(defrule
(true)
=>
(up-modify-goal gl-anti-lag-flag c:= 0)
(disable-self)
)

(defrule
(true)
=>
(up-modify-goal gl-feudal-age-buildings c:= 0)
(disable-self)
)

(defrule
(building-type-count archery-range > 0)
=>
(up-modify-goal gl-feudal-age-buildings c:+ 1)
(disable-self)
)

(defrule
(building-type-count stable > 0)
=>
(up-modify-goal gl-feudal-age-buildings c:+ 1)
(disable-self)
)

(defrule
(building-type-count blacksmith > 0)
=>
(up-modify-goal gl-feudal-age-buildings c:+ 1)
(disable-self)
)

(defrule
(building-type-count market > 0)
=>
(up-modify-goal gl-feudal-age-buildings c:+ 1)
(disable-self)
)

(defrule
(building-type-count donjon > 0)
=>
(up-modify-goal gl-feudal-age-buildings c:+ 1)
(disable-self)
)

(defrule
(not(goal military-mode raid))
(not(goal military-mode assault))
;(up-compare-goal gl-target-navy-toggle != 907)
=>
(up-modify-goal gl-target-navy-toggle c:= 907)
(up-modify-goal gl-target-transport-ship-toggle c:= 907)
(up-modify-goal gl-target-fishing-ship-toggle c:= 907)
)

(defrule
(or(goal military-mode raid)
(goal military-mode assault))
;(up-compare-goal gl-target-navy-toggle != 922)
=>
(up-modify-goal gl-target-navy-toggle c:= 922)
(up-modify-goal gl-target-transport-ship-toggle c:= 920)
(up-modify-goal gl-target-fishing-ship-toggle c:= 921)
)

(defrule
(building-type-count town-center > 0)
=>
(up-get-point position-self gl-starting-home-x)
(disable-self)
)

(defrule
(can-build town-center);rebuild TC
(building-type-count-total town-center == 0)
(game-time > 900)
=>
(up-get-fact-max any-ally current-score 0 51)
(up-assign-builders c: town-center-foundation c: 50)
(up-set-placement-data this-any-ally town-center c: -20)
(set-strategic-number sn-placement-zone-size 4)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 0)
(up-build 2 0 c: town-center)
)

(defrule
(not(can-build town-center));release escrow to build TC
(can-build-with-escrow town-center)
(building-type-count-total town-center == 0)
(game-time > 900)
=>
(up-reset-cost-data required-food)
(up-get-fact escrow-amount food escrowed-food)
(up-get-fact escrow-amount wood escrowed-wood)
(up-get-fact escrow-amount gold escrowed-gold)
(up-get-fact escrow-amount stone escrowed-stone)
(up-add-object-cost c: town-center c: 1)
(up-modify-goal escrowed-food g:- required-food)
(up-modify-goal escrowed-wood g:- required-wood)
(up-modify-goal escrowed-gold g:- required-gold)
(up-modify-goal escrowed-stone g:- required-stone)
(up-modify-escrow food g:= escrowed-food)
(up-modify-escrow wood g:= escrowed-wood)
(up-modify-escrow gold g:= escrowed-gold)
(up-modify-escrow stone g:= escrowed-stone)
(up-get-fact-max any-ally current-score 0 51)
(up-assign-builders c: town-center-foundation c: 50)
(up-set-placement-data this-any-ally town-center c: -20)
(set-strategic-number sn-placement-zone-size 4)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 0)
(up-build 2 0 c: town-center)
)

(defrule
(can-build town-center);rebuild TC
(building-type-count-total town-center == 0)
(game-time > 900)
=>
(up-get-fact-max any-ally current-score 0 51)
(up-assign-builders c: town-center-foundation c: 50)
(up-set-placement-data this-any-ally town-center c: 20)
(set-strategic-number sn-placement-zone-size 4)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 1)
(up-build 2 0 c: town-center)
)

(defrule
(not(can-build town-center));release escrow to build TC
(can-build-with-escrow town-center)
(building-type-count-total town-center == 0)
(game-time > 900)
=>
(up-reset-cost-data required-food)
(up-get-fact escrow-amount food escrowed-food)
(up-get-fact escrow-amount wood escrowed-wood)
(up-get-fact escrow-amount gold escrowed-gold)
(up-get-fact escrow-amount stone escrowed-stone)
(up-add-object-cost c: town-center c: 1)
(up-modify-goal escrowed-food g:- required-food)
(up-modify-goal escrowed-wood g:- required-wood)
(up-modify-goal escrowed-gold g:- required-gold)
(up-modify-goal escrowed-stone g:- required-stone)
(up-modify-escrow food g:= escrowed-food)
(up-modify-escrow wood g:= escrowed-wood)
(up-modify-escrow gold g:= escrowed-gold)
(up-modify-escrow stone g:= escrowed-stone)
(up-get-fact-max any-ally current-score 0 51)
(up-assign-builders c: town-center-foundation c: 50)
(up-set-placement-data this-any-ally town-center c: 20)
(set-strategic-number sn-placement-zone-size 4)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 1)
(up-build 2 0 c: town-center)
)

(defrule
(not(map-type land-nomad))
(building-type-count-total town-center == 0)
(game-time > 40)
(resource-found food)
=>
(up-assign-builders c: town-center-foundation c: 50)
(set-strategic-number sn-town-center-placement mill)
(build town-center)
)

(defrule
(up-compare-sn sn-lumber-camp-max-distance != 0)
=>
(up-modify-sn sn-lumber-camp-max-distance c:= 0)
(disable-self)
)

(defrule
(not(map-type land-nomad))
(building-type-count-total town-center == 0)
;(game-time > 40);changing for nomad and fencrazy
;(not(resource-found food))
(resource-found wood)
(can-build town-center)
=>
(up-assign-builders c: town-center-foundation c: 50)
(up-modify-goal gl-dot-x s:= sn-lumber-camp-max-distance)
;(up-chat-data-to-self "camp dist %d" s: sn-lumber-camp-max-distance)
(up-modify-sn sn-lumber-camp-max-distance c:= 480)
(set-strategic-number sn-town-center-placement lumber-camp)
(build town-center)
;(up-modify-sn sn-lumber-camp-max-distance g:= gl-dot-x)
)

