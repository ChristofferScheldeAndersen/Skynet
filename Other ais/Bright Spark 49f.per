(up-compare-goal gl-left-wall-breach > 0)
(up-point-distance gl-dot-x gl-temp-x < 16)
=>
(up-set-target-by-id g: gl-back-wall-breach)
(up-get-object-data 10 gl-dot-x)
(up-set-target-by-id g: gl-left-wall-breach)
(up-get-object-data 10 gl-temp-x)
(up-jump-rule 1)
)

(defrule
(true)
=>
(up-jump-rule 2)
)

(defrule
(up-compare-goal gl-dot-x >= gl-temp-x)
=>
(do-nothing)
;(up-modify-goal gl-left-wall-breach c:= -1)
)

(defrule
(up-compare-goal gl-dot-x < gl-temp-x)
=>
(do-nothing)
;(up-modify-goal gl-back-wall-breach c:= -1)
)

(defrule
(false)
(or(up-compare-goal gl-left-wall-breach > 0)
(or(up-compare-goal gl-right-wall-breach > 0)
(up-compare-goal gl-back-wall-breach > 0)))
=>
(up-chat-data-to-self "left wall breach %d" g: gl-left-wall-breach)
(up-chat-data-to-self "right wall breach %d" g: gl-right-wall-breach)
(up-chat-data-to-self "back wall breach %d" g: gl-back-wall-breach)
)

#end-if


