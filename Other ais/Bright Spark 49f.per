#load-if-defined UP-MULTIPLAYER-GAME

(defrule
(false)
=>
(up-modify-goal gl-anti-lag-flag c:= 0)
(chat-to-all "Multiplayer game detected, if there is risk of lag then certain rules may get disabled")
(disable-self)
)

(defrule
(building-type-count castle >= 4)
(up-compare-flag gl-anti-lag-flag != anti-lag-level1)
=>
(up-modify-flag gl-anti-lag-flag c:+ anti-lag-level1)
(chat-to-all "implementing anti-lag level 1")
(up-modify-goal gl-peak-pass-time c:= 0)
(up-modify-goal gl-prev-pass-time3 c:= 0)
)

(defrule
(up-compare-goal gl-prev-pass-time >= 25)
(up-compare-goal gl-prev-pass-time2 >= 25)
(up-compare-goal gl-prev-pass-time3 >= 25)
;(up-compare-goal gl-peak-pass-time >= 25)
(up-compare-flag gl-anti-lag-flag != anti-lag-level1)
=>
(up-modify-flag gl-anti-lag-flag c:+ anti-lag-level1)
(chat-to-all "implementing anti-lag level 1")
(up-modify-goal gl-peak-pass-time c:= 0)
(up-modify-goal gl-prev-pass-time3 c:= 0)
(up-modify-goal 554 c:+ 1)
)

(defrule
(up-compare-goal gl-prev-pass-time < 15)
(up-compare-goal gl-prev-pass-time2 < 15)
(up-compare-goal gl-prev-pass-time3 < 15)
(up-compare-goal 554 < 10)
;(up-compare-goal gl-peak-pass-time >= 25)
(up-compare-flag gl-anti-lag-flag == anti-lag-level1)
=>
(up-modify-flag gl-anti-lag-flag c:- anti-lag-level1)
(chat-to-all "removing anti-lag level 1")
(up-modify-goal gl-peak-pass-time c:= 0)
(up-modify-goal gl-prev-pass-time3 c:= 0)
)

(defrule
(false)
