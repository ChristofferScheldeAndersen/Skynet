(disable-self)
)

(defrule
(or(not(goal gl-game-strategy drush))
(current-age >= feudal-age))
(or(up-compare-goal gl-stop-dark-age-vils c:!= 1)
(current-age >= feudal-age))
(can-research ri-loom)
(up-pending-objects c: villager < 1)
(not(can-train villager))
=>
(research ri-loom)
