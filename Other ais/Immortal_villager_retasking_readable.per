; Rule #3407.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3408-abort-early-food-retasking-id))
; Rule #3408
	; Purpose: Abort early when food retasking is blocked by the idle-farm check or when no valid villager ID was supplied.
	(defrule
		(up-modify-goal gl-scaled-idle-farm-threshold s:= sn-retask-economy-size)
		(up-modify-goal gl-scaled-idle-farm-threshold c:/ retask-idle-farm-scale-divisor)
		(or (and (and (up-compare-goal gl-target-resource c:== food)
					(up-compare-flag fl-food-idle-farm-mode c:== fl-food-idle-farm-mode-value))
				(idle-farm-count g:<= gl-scaled-idle-farm-threshold))
			(up-compare-goal gl-source-villager-id c:< 0))
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-modify-goal gl-reassign-result-code c:= -1)
		(up-jump-direct g: gl-retask-return-label))

	; Rule #3409
	; Purpose: Mark wood retasking as structure-constrained when lumber-camp support is missing.
	(defrule
		(up-compare-sn sn-retask-economy-size c:< 30)
		(or (building-type-count-total mule-cart c:== 0)
			(up-compare-goal gl-wood-dropoff-support-count c:== 0))
		(building-type-count-total lumber-camp c:== 0)
		=>
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 1))

	; Rule #3410
	; Purpose: Initialize the resource-balance weight for food retasking.
	(defrule
		(up-compare-goal gl-target-resource c:== food)
		(up-compare-goal gl-resource-balance-weight c:== -1)
		=>
		(up-modify-goal gl-resource-balance-weight c:= 1))

	; Rule #3411
	; Purpose: Initialize the resource-balance weight for wood retasking.
	(defrule
		(up-compare-goal gl-target-resource c:== wood)
		(up-compare-goal gl-resource-balance-weight c:== -1)
		=>
		(up-modify-goal gl-resource-balance-weight c:= 7))

	; Rule #3412
	; Purpose: Initialize the resource-balance weight for stone retasking.
	(defrule
		(up-compare-goal gl-target-resource c:== stone)
		(up-compare-goal gl-resource-balance-weight c:== -1)
		=>
		(up-modify-goal gl-resource-balance-weight c:= 1))

	; Rule #3413
	; Purpose: Initialize the resource-balance weight for gold retasking.
	(defrule
		(up-compare-goal gl-target-resource c:== gold)
		(up-compare-goal gl-resource-balance-weight c:== -1)
		=>
		(up-modify-goal gl-resource-balance-weight c:= 1))

	; Rule #3414
	; Purpose: Load the chosen villager's current state and initialize temporary values used by the rest of the retask search.
	(defrule
		(up-modify-goal gl-reassign-result-code c:= 0)
		=>
		(up-set-target-by-id g: gl-source-villager-id)
		(up-get-point position-curr-object gl-villager-origin-pos)
		(up-get-object-data object-data-language-id gl-source-villager-role)
		(up-get-object-data object-data-gather-type gl-source-villager-resource)
		(up-get-object-data object-data-move-x gl-villager-move-target-pos-x)
		(up-get-object-data object-data-move-y gl-villager-move-target-pos-y)
		(up-get-point position-curr-object gl-villager-distance-origin-pos)
		(up-get-point-distance gl-villager-distance-origin-pos gl-villager-move-target-pos gl-villager-to-move-target-distance)
		(up-get-object-data object-data-group-flag gl-source-villager-tag)
		(up-modify-goal gl-max-allowed-target-tasks c:= 1)
		(up-modify-goal gl-target-work-group c:= food-villager-group)
		(up-modify-goal gl-target-work-group g:+ gl-target-resource))

	; Rule #3415
	; Purpose: Reject villagers whose tag makes them ineligible for this retask routine.
	(defrule
		(nor (and (up-compare-goal gl-source-villager-tag c:>= 1)
				(up-compare-goal gl-source-villager-tag c:<= 4))
			(up-compare-goal gl-source-villager-tag c:<= -1))
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-chat-data-to-all "!! ERROR: vill to be reassigned is not allowable %d" g: gl-source-villager-tag)
		(up-modify-goal gl-reassign-result-code c:= -2)
		(up-jump-direct g: gl-retask-return-label))

	; Rule #3416
	; Purpose: Allow farmers to count as already-good food workers over a larger distance before forcing a retask.
	(defrule
		(up-compare-goal gl-forced-food-retask-mode c:== 0)
		(up-compare-goal gl-target-resource c:== food)
		(up-compare-goal gl-source-villager-role c:== lid_villager-farmer)
		=>
		(up-modify-goal gl-same-resource-stay-distance c:max 32))

	; Rule #3417
	; Purpose: Allow an already-food villager to stay put during the active timer window unless the mismatch is meaningful.
	(defrule
		(up-compare-goal gl-forced-food-retask-mode c:== 0)
		(up-compare-goal gl-target-resource c:== food)
		(up-compare-goal gl-source-villager-resource c:== food)
		(up-timer-status food-stay-put-timer c:== timer-running)
		=>
		(up-modify-goal gl-same-resource-stay-distance c:max 28))

	; Rule #3418
	; Purpose: Allow foragers to count as already-good food workers with a smaller tolerance window.
	(defrule
		(up-compare-goal gl-forced-food-retask-mode c:== 0)
		(up-compare-goal gl-target-resource c:== food)
		(up-compare-goal gl-source-villager-role c:== lid_villager-forager)
		=>
		(up-modify-goal gl-same-resource-stay-distance c:max 22))

	; Rule #3419
	; Purpose: Normalize farmer, forager, and shepherd roles into the shared food category for later comparisons.
	(defrule
		(or (or (up-compare-goal gl-source-villager-role c:== lid_villager-farmer)
				(up-compare-goal gl-source-villager-role c:== lid_villager-forager))
			(up-compare-goal gl-source-villager-role c:== lid_villager-shepherd))
		=>
		(up-modify-goal gl-source-villager-resource c:= food))

	; Rule #3420
	; Purpose: Normalize lumberjacks into the shared wood category for later comparisons.
	(defrule
		(up-compare-goal gl-source-villager-role c:== lid_villager-lumberjack)
		=>
		(up-modify-goal gl-source-villager-resource c:= wood))

	; Rule #3421
	; Purpose: Normalize stone miners into the shared stone category for later comparisons.
	(defrule
		(up-compare-goal gl-source-villager-role c:== lid_villager-stone-miner)
		=>
		(up-modify-goal gl-source-villager-resource c:= stone))

	; Rule #3422
	; Purpose: Normalize gold miners into the shared gold category for later comparisons.
	(defrule
		(up-compare-goal gl-source-villager-role c:== lid_villager-gold-miner)
		=>
		(up-modify-goal gl-source-villager-resource c:= gold))

	; Rule #3423
	; Purpose: Abort same-resource retasking when the villager is already close enough to a suitable target.
	(defrule
		(up-compare-goal gl-same-resource-stay-distance c:> 0)
		(up-compare-goal gl-source-villager-resource g:== gl-target-resource)
		(up-compare-goal gl-villager-to-move-target-distance g:< gl-same-resource-stay-distance)
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-modify-goal gl-reassign-result-code c:= -3)
		(up-jump-direct g: gl-retask-return-label))

	; Rule #3424
	; Purpose: Seed the local search state with the villager currently being reconsidered.
	(defrule
		(true)
		=>
		(up-reset-search 1 1 0 0)
		(up-add-object-by-id search-local g: gl-source-villager-id))

	; Rule #3425
	; Purpose: Skip group retagging if the villager already belongs to the desired work bucket.
	(defrule
		(up-compare-goal gl-target-work-group g:== gl-source-villager-tag)
		(up-compare-goal gl-rule-3430-derive-first-local-search-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3430-derive-first-local-search-id)) ; Jump to rule #3430

	; Rule #3426
	; Purpose: Recreate work group 1 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal gl-target-work-group c:== food-villager-group)
		=>
		(up-create-group 0 0 c: food-villager-group)
		(up-modify-group-flag 1 c: food-villager-group)
		(up-reset-group c: food-villager-group))

	; Rule #3427
	; Purpose: Recreate work group 2 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal gl-target-work-group c:== wood-villager-group)
		=>
		(up-create-group 0 0 c: wood-villager-group)
		(up-modify-group-flag 1 c: wood-villager-group)
		(up-reset-group c: wood-villager-group))

	; Rule #3428
	; Purpose: Recreate work group 3 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal gl-target-work-group c:== stone-villager-group)
		=>
		(up-create-group 0 0 c: stone-villager-group)
		(up-modify-group-flag 1 c: stone-villager-group)
		(up-reset-group c: stone-villager-group))

	; Rule #3429
	; Purpose: Recreate work group 4 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal gl-target-work-group c:== gold-villager-group)
		=>
		(up-create-group 0 0 c: gold-villager-group)
		(up-modify-group-flag 1 c: gold-villager-group)
		(up-reset-group c: gold-villager-group))

; Rule #3429.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3430-derive-first-local-search-id))
	; Rule #3430
	; Purpose: Derive the first local search radius from the villager's current movement distance and the configured limits.
	(defrule
		(up-modify-goal gl-local-anchor-search-radius g:= gl-villager-to-move-target-distance)
		(up-modify-goal gl-local-anchor-search-radius g:/ gl-local-radius-divisor)
		(up-modify-goal gl-local-anchor-search-radius g:min gl-direct-reassign-search-radius)
		(up-compare-goal gl-local-radius-divisor c:<= 0)
		=>
		(up-modify-goal gl-local-anchor-search-radius g:= gl-direct-reassign-search-radius))

	; Rule #3431
	; Purpose: Start a local anchor search around the villager using the computed search radius.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-set-precise-target-point gl-villager-origin-pos)
		(up-filter-distance c: -1 g: gl-local-anchor-search-radius))

	; Rule #3432
	; Purpose: Search town-center and mining-dropoff anchors for stone and gold retasking.
	(defrule
		(or (up-compare-goal gl-target-resource c:== stone)
			(up-compare-goal gl-target-resource c:== gold))
		=>
		(up-find-local c: town-center c: 240)
		(up-find-local g: gl-mining-drop-site-line-id c: 240)
		(up-filter-status c: status-pending c: list-active)
		(up-find-status-local g: gl-mining-drop-site-line-id c: 240)
		(up-modify-goal gl-max-allowed-target-tasks c:= 3))

	; Rule #3433
	; Purpose: Use the town center as a wood fallback anchor when normal wood dropoff support is unavailable.
	(defrule
		(or (up-compare-flag fl-wood-town-center-fallback-mode c:== fl-wood-town-center-fallback-mode-value)
			(up-compare-goal gl-wood-fallback-anchor-enabled c:== 1))
		(up-compare-goal gl-target-resource c:== wood)
		=>
		(up-find-local c: town-center c: 240))

	; Rule #3434
	; Purpose: Search lumber-camp anchors for normal wood retasking.
	(defrule
		(up-compare-goal gl-target-resource c:== wood)
		=>
		(up-find-local g: gl-wood-drop-site-line-id c: 240)
		(up-filter-status c: status-pending c: list-active)
		(up-find-status-local g: gl-wood-drop-site-line-id c: 240))

	; Rule #3435
	; Purpose: Search for available farms as the first local anchors for food retasking.
	(defrule
		(up-compare-goal gl-target-resource c:== food)
		=>
		(up-find-local c: farm-class c: 240)
		(up-remove-objects search-local object-data-tasks-count c:> 0))

	; Rule #3436
	; Purpose: Skip the broader food-anchor path when the current food situation calls for the alternate branch instead.
	(defrule
		(nand (and (up-compare-goal gl-target-resource c:== food)
				(or (up-compare-flag fl-food-idle-farm-mode c:!= fl-food-idle-farm-mode-value)
					(up-compare-goal gl-forced-food-retask-mode c:== 1)))
			(up-compare-goal gl-food-anchor-branch-lock c:!= 1))
		(up-compare-goal gl-rule-3439-clean-local-anchor-list-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3439-clean-local-anchor-list-id)) ; Jump to rule #3439

	; Rule #3437
	; Purpose: Search town-center and mill anchors for food retasking and switch to the food-specific task limit.
	(defrule
		(true)
		=>
		(up-find-local c: town-center c: 240)
		(up-find-local c: mill c: 240)
		(up-filter-status c: status-pending c: list-active)
		(up-find-status-local c: mill c: 240)
		(up-modify-goal gl-max-allowed-target-tasks c:= 4))

	; Rule #3438
	; Purpose: Relax the allowed task congestion when the economy is small or the food retask is forced.
	(defrule
		(or (up-compare-sn sn-retask-economy-size c:<= 18)
			(up-compare-goal gl-forced-food-retask-mode c:== 1))
		=>
		(up-modify-goal gl-max-allowed-target-tasks c:= 6))

; Rule #3438.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3439-clean-local-anchor-list-id))
	; Rule #3439
	; Purpose: Clean the local anchor list and reset the variables that track the best anchor candidate.
	(defrule
		(true)
		=>
		(up-remove-objects search-local object-data-group-flag c:== gold-villager-group)
		(up-remove-objects search-local object-data-group-flag c:== stone-villager-group)
		(up-remove-objects search-local object-data-group-flag c:== wood-villager-group)
		(up-remove-objects search-local object-data-group-flag c:== food-villager-group)
		(up-reset-filters)
		(up-modify-goal gl-local-anchor-index c:= 0)
		(up-modify-goal gl-best-anchor-id c:= -1)
		(up-modify-goal gl-best-anchor-score c:= 2147483647)
		(up-get-search-state gl-local-total))

; Rule #3439.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3440-exit-local-anchor-loop-id))
	; Rule #3440
	; Purpose: Exit the local-anchor loop once every candidate anchor has been evaluated.
	(defrule
		(up-compare-goal gl-local-anchor-index g:>= gl-local-total)
		(up-compare-goal gl-rule-3454-finalize-local-anchor-pass-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3454-finalize-local-anchor-pass-id)) ; Jump to rule #3454

	; Rule #3441
	; Purpose: Load the next local anchor and initialize the scoring context for evaluating it.
	(defrule
		(true)
		=>
		(up-set-target-object search-local g: gl-local-anchor-index)
		(up-modify-goal gl-local-anchor-index c:+ 1)
		(up-get-object-data object-data-id gl-current-anchor-id)
		(up-reset-filters)
		(up-set-precise-target-point gl-villager-origin-pos)
		(up-get-object-data object-data-distance gl-current-anchor-distance)
		(up-get-object-data object-data-class gl-current-anchor-class-id)
		(up-modify-goal gl-current-anchor-is-farm g:= gl-current-anchor-class-id)
		(up-modify-goal gl-current-anchor-is-farm c:- farm-class)
		(up-modify-goal gl-current-anchor-is-farm g:* gl-current-anchor-is-farm)
		(up-modify-goal gl-current-anchor-is-farm c:min 1)
		(up-get-point position-curr-object gl-current-anchor-pos)
		(up-set-precise-target-point gl-current-anchor-pos)
		(up-modify-goal gl-current-anchor-crowding-score c:= -4))

	; Rule #3442
	; Purpose: Penalize crowded farm anchors so food retasks prefer less-contested farming spots.
	(defrule
		(up-compare-goal gl-current-anchor-is-farm c:== 1)
		=>
		(up-reset-search 0 0 1 1)
		(up-filter-distance c: -1 c: 9)
		(up-find-remote c: villager-class c: 40)
		(up-modify-goal gl-required-group-tag g:= gl-target-resource)
		(up-modify-goal gl-required-group-tag c:+ 1)
		(up-remove-objects search-remote object-data-group-flag g:!= gl-required-group-tag)
		(up-remove-objects search-remote object-data-language-id c:== lid_villager-farmer)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-current-anchor-crowding-score g:= gl-remote-last)
		(up-modify-goal gl-crowding-overflow-penalty g:= gl-current-anchor-crowding-score)
		(up-modify-goal gl-crowding-overflow-penalty g:- gl-farm-crowding-threshold)
		(up-modify-goal gl-crowding-overflow-penalty c:max 0)
		(up-modify-goal gl-crowding-overflow-penalty c:* 300)
		(up-modify-goal gl-current-anchor-crowding-score g:+ gl-crowding-overflow-penalty))

	; Rule #3443
	; Purpose: Initialize scoring terms for the current anchor and skip farm-only logic when the anchor is not a farm.
	(defrule
		(up-modify-goal gl-current-anchor-resource-count-score c:= 0)
		(up-modify-goal gl-current-anchor-nearest-resource-score c:= 1)
		(up-compare-goal gl-current-anchor-is-farm c:!= 1)
		(up-compare-goal gl-rule-3451-rescale-scoring-routine-special-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3451-rescale-scoring-routine-special-id)) ; Jump to rule #3451

	; Rule #3444
	; Purpose: Search nearby resource nodes around the current anchor candidate.
	(defrule
		(true)
		=>
		(up-reset-search 0 0 1 1)
		(up-filter-distance c: -1 g: gl-anchor-resource-search-radius))

	; Rule #3445
	; Purpose: Collect nearby food targets for the current anchor candidate.
	(defrule
		(up-compare-goal gl-target-resource c:== food)
		(up-compare-goal gl-rule-3449-filter-resource-list-around-id c:!= -1)
		=>
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-filter-status c: status-gather c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-filter-status c: status-down c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-jump-direct g: gl-rule-3449-filter-resource-list-around-id)) ; Jump to rule #3449

	; Rule #3446
	; Purpose: Collect nearby wood targets for the current anchor candidate.
	(defrule
		(up-compare-goal gl-target-resource c:== wood)
		(up-compare-goal gl-rule-3449-filter-resource-list-around-id c:!= -1)
		=>
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: amount-wood c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-wood c: 40)
		(up-jump-direct g: gl-rule-3449-filter-resource-list-around-id)) ; Jump to rule #3449

	; Rule #3447
	; Purpose: Collect nearby stone targets for the current anchor candidate.
	(defrule
		(up-compare-goal gl-target-resource c:== stone)
		(up-compare-goal gl-rule-3449-filter-resource-list-around-id c:!= -1)
		=>
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-stone c: 40)
		(up-jump-direct g: gl-rule-3449-filter-resource-list-around-id)) ; Jump to rule #3449

	; Rule #3448
	; Purpose: Collect nearby gold targets for the current anchor candidate.
	(defrule
		(up-compare-goal gl-target-resource c:== gold)
		=>
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-gold c: 40))

; Rule #3448.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3449-filter-resource-list-around-id))
	; Rule #3449
	; Purpose: Filter the resource list around the anchor and compute the crowding component of its score.
	(defrule
		(true)
		=>
		(up-remove-objects search-remote object-data-player c:== my-player-number)
		(up-remove-objects search-remote object-data-class c:== farm-class)
		(up-remove-objects search-remote object-data-tasks-count g:> gl-max-allowed-target-tasks)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-current-anchor-resource-count-score g:= gl-remote-last)
		(up-modify-goal gl-resource-shortage-penalty g:= gl-resource-balance-weight)
		(up-modify-goal gl-resource-shortage-penalty g:- gl-current-anchor-resource-count-score)
		(up-modify-goal gl-resource-shortage-penalty c:max 0)
		(up-modify-goal gl-resource-shortage-penalty c:* 300)
		(up-modify-goal gl-resource-balance-score g:= gl-resource-balance-weight)
		(up-modify-goal gl-resource-balance-score c:+ 4)
		(up-modify-goal gl-resource-balance-score c:min 26)
		(up-modify-goal gl-resource-balance-score g:min gl-current-anchor-resource-count-score)
		(up-modify-goal gl-resource-balance-score c:/ 2)
		(up-modify-goal gl-resource-balance-score g:- gl-resource-shortage-penalty)
		(up-modify-goal gl-current-anchor-resource-count-score g:= gl-resource-balance-score))

	; Rule #3450
	; Purpose: Convert the closest resource distance into a score term for the current anchor.
	(defrule
		(up-compare-goal gl-remote-last c:!= 0)
		=>
		(up-clean-search search-remote object-data-full-distance search_order-ascending)
		(up-set-target-object search-remote c: 0)
		(up-get-object-data object-data-distance gl-adjusted-nearest-resource-distance)
		(up-modify-goal gl-adjusted-nearest-resource-distance c:- 2)
		(up-modify-goal gl-adjusted-nearest-resource-distance c:max 0)
		(up-modify-goal gl-current-anchor-nearest-resource-score g:= gl-adjusted-nearest-resource-distance))

; Rule #3450.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3451-rescale-scoring-routine-special-id))
	; Rule #3451
	; Purpose: Rescale scoring when the routine is in the special forced-food branch.
	(defrule
		(up-compare-goal gl-forced-food-retask-mode c:== 1)
		=>
		(up-modify-goal gl-current-anchor-distance c:* 3)
		(up-modify-goal gl-current-anchor-crowding-score c:/ 6))

	; Rule #3452
	; Purpose: Update the remembered best anchor when the current anchor scores better than the previous best.
	(defrule
		(up-modify-goal gl-weighted-crowding-score g:= gl-current-anchor-crowding-score)
		(up-modify-goal gl-weighted-crowding-score c:* 6)
		(up-modify-goal gl-current-anchor-total-score g:= gl-current-anchor-nearest-resource-score)
		(up-modify-goal gl-current-anchor-total-score c:* 3)
		(up-modify-goal gl-current-anchor-total-score g:+ gl-current-anchor-distance)
		(up-modify-goal gl-current-anchor-total-score g:+ gl-weighted-crowding-score)
		(up-modify-goal gl-current-anchor-total-score g:- gl-current-anchor-resource-count-score)
		(up-compare-goal gl-current-anchor-total-score g:< gl-best-anchor-score)
		=>
		(up-modify-goal gl-best-anchor-score g:= gl-current-anchor-total-score)
		(up-modify-goal gl-best-anchor-id g:= gl-current-anchor-id))

	; Rule #3453
	; Purpose: Loop back to evaluate the next local anchor candidate.
	(defrule
		(true)
		(up-compare-goal gl-rule-3440-exit-local-anchor-loop-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3440-exit-local-anchor-loop-id)) ; Jump to rule #3440

; Rule #3453.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3454-finalize-local-anchor-pass-id))
	; Rule #3454
	; Purpose: Finalize the local-anchor pass and snapshot its search state.
	(defrule
		(true)
		=>
		(up-get-search-state gl-local-total))

	; Rule #3455
	; Purpose: Jump to the fallback path when no usable anchor/resource combination was found.
	(defrule
		(nand (up-compare-goal gl-local-total c:!= 0)
			(up-compare-goal gl-best-anchor-id c:!= -1))
		(up-compare-goal gl-rule-3503-abort-fallback-anchor-survived-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3503-abort-fallback-anchor-survived-id)) ; Jump to rule #3503

	; Rule #3456
	; Purpose: Prepare a direct retask around the best anchor that was selected by scoring.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-add-object-by-id search-local g: gl-source-villager-id)
		(up-set-target-by-id g: gl-best-anchor-id)
		(up-get-point position-curr-object gl-best-anchor-pos)
		(up-set-precise-target-point gl-best-anchor-pos)
		(up-get-object-data object-data-class gl-best-anchor-class-id))

	; Rule #3457
	; Purpose: Branch away from the immediate farm-handling path when the chosen anchor is not a farm.
	(defrule
		(up-compare-goal gl-best-anchor-class-id c:!= farm-class)
		(up-compare-goal gl-rule-3464-roll-random-value-decide-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3464-roll-random-value-decide-id)) ; Jump to rule #3464

	; Rule #3458
	; Purpose: Issue the immediate retask order for the successful farm-based choice.
	(defrule
		(true)
		=>
		(up-modify-sn sn-keystates c:= 2)
		(up-target-objects 1 action-default formation-ignore stance-ignore)
		(up-modify-sn sn-keystates c:= 0)
		(up-remove-objects search-local object-data-group-flag g:== gl-target-work-group))

	; Rule #3459
	; Purpose: Recreate work group 1 after a successful immediate farm retask.
	(defrule
		(up-compare-goal gl-target-work-group c:== food-villager-group)
		=>
		(up-create-group 0 0 c: food-villager-group)
		(up-modify-group-flag 1 c: food-villager-group)
		(up-reset-group c: food-villager-group))

	; Rule #3460
	; Purpose: Recreate work group 2 after a successful immediate farm retask.
	(defrule
		(up-compare-goal gl-target-work-group c:== wood-villager-group)
		=>
		(up-create-group 0 0 c: wood-villager-group)
		(up-modify-group-flag 1 c: wood-villager-group)
		(up-reset-group c: wood-villager-group))

	; Rule #3461
	; Purpose: Recreate work group 3 after a successful immediate farm retask.
	(defrule
		(up-compare-goal gl-target-work-group c:== stone-villager-group)
		=>
		(up-create-group 0 0 c: stone-villager-group)
		(up-modify-group-flag 1 c: stone-villager-group)
		(up-reset-group c: stone-villager-group))

	; Rule #3462
	; Purpose: Recreate work group 4 after a successful immediate farm retask.
	(defrule
		(up-compare-goal gl-target-work-group c:== gold-villager-group)
		=>
		(up-create-group 0 0 c: gold-villager-group)
		(up-modify-group-flag 1 c: gold-villager-group)
		(up-reset-group c: gold-villager-group))

	; Rule #3463
	; Purpose: Return after a successful immediate farm retask.
	(defrule
		(true)
		(up-compare-goal gl-retask-return-label c:!= -1)
