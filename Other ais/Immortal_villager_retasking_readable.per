	; Purpose: Dispatch the villager using the structure-based fallback target and clear its old tag.
	(defrule
		(true)
		=>
		(up-modify-sn sn-keystates c:= 2)
		(up-target-objects 1 action-default formation-ignore stance-ignore)
		(up-modify-sn sn-keystates c:= 0)
		(up-remove-objects search-local object-data-group-flag g:== gl-target-work-group))

	; Rule #3513
	; Purpose: Recreate work group 1 after a successful fallback dispatch.
	(defrule
		(up-compare-goal gl-target-work-group c:== food-villager-group)
		=>
		(up-create-group 0 0 c: food-villager-group)
		(up-modify-group-flag 1 c: food-villager-group)
		(up-reset-group c: food-villager-group))

	; Rule #3514
	; Purpose: Recreate work group 2 after a successful fallback dispatch.
	(defrule
		(up-compare-goal gl-target-work-group c:== wood-villager-group)
		=>
		(up-create-group 0 0 c: wood-villager-group)
		(up-modify-group-flag 1 c: wood-villager-group)
		(up-reset-group c: wood-villager-group))

	; Rule #3515
	; Purpose: Recreate work group 3 after a successful fallback dispatch.
	(defrule
		(up-compare-goal gl-target-work-group c:== stone-villager-group)
		=>
		(up-create-group 0 0 c: stone-villager-group)
		(up-modify-group-flag 1 c: stone-villager-group)
		(up-reset-group c: stone-villager-group))

	; Rule #3516
	; Purpose: Recreate work group 4 after a successful fallback dispatch.
	(defrule
		(up-compare-goal gl-target-work-group c:== gold-villager-group)
		=>
		(up-create-group 0 0 c: gold-villager-group)
		(up-modify-group-flag 1 c: gold-villager-group)
		(up-reset-group c: gold-villager-group))

	; Rule #3517
	; Purpose: Return after a successful fallback dispatch.
	(defrule
		(true)
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-jump-direct g: gl-retask-return-label))

; Rule #3517.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3518-set-final-failure-code-id))
	; Rule #3518
	; Purpose: Set the final failure code for retask attempts that found no workable destination.
	(defrule
		(up-modify-goal gl-reassign-result-code c:= -6)
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-jump-direct g: gl-retask-return-label))

	; Rule #3519
	; Purpose: Gate the special unload-support branch so it only runs for the intended SN 82 state.
	(defrule
		(up-modify-goal gl-required-unload-sn82-state c:= 3)
		(up-modify-goal gl-required-unload-sn82-state g:+ gl-unload-state-offset)
		(up-compare-sn sn-unload-support-state g:!= gl-required-unload-sn82-state)
		(up-compare-goal gl-rule-3531-start-vill-hopping-branch-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3531-start-vill-hopping-branch-id)) ; Jump to rule #3531

	; Rule #3520
	; Purpose: Search for town centers that still have garrisoned villagers for the unload-support cleanup.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-find-local c: town-center c: 240)
		(up-remove-objects search-local object-data-garrison-count c:== 0)
		(up-remove-objects search-local object-data-index c:>= 1))

	; Rule #3521
	; Purpose: When the unload timer fires, order the unload and clear the temporary unload state.
	(defrule
		(up-timer-status unload-support-timer c:== timer-triggered)
		=>
		(up-modify-sn sn-unload-support-state c:= 0)
		(up-target-point 0 action-unload formation-ignore stance-ignore)
		(up-reset-search 1 1 0 0)
		(disable-timer unload-support-timer))

	; Rule #3522
	; Purpose: Start the unload timer when unload support is pending but not yet running.
	(defrule
		(up-timer-status unload-support-timer c:!= timer-running)
		=>
		(up-set-timer c: unload-support-timer c: 8))

	; Rule #3523
	; Purpose: Snapshot the unload-support search state.
	(defrule
		(true)
		=>
		(up-get-search-state gl-local-total))

	; Rule #3524
	; Purpose: Skip the unload-support action when no eligible garrisoned town center exists.
	(defrule
		(up-compare-goal gl-local-total c:== 0)
		(up-compare-goal gl-rule-3531-start-vill-hopping-branch-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3531-start-vill-hopping-branch-id)) ; Jump to rule #3531

	; Rule #3525
	; Purpose: Select the first eligible garrisoned town center for the unload-support action.
	(defrule
		(true)
		=>
		(up-set-target-object search-local c: 0))

	; Rule #3526
	; Purpose: Shorten the unload timer once a valid town center has already been selected.
	(defrule
		(up-timer-status unload-support-timer c:!= timer-running)
		=>
		(up-set-timer c: unload-support-timer c: 4))

; Rule #3530.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3531-start-vill-hopping-branch-id))
	; Rule #3531
	; Purpose: Start the vill-hopping recovery branch by sampling the source town center state and nearby hunter/shepherd pressure.
	(defrule
		(true)
		=>
		(up-set-target-by-id g: gl-vill-hopping-source-town-center-id)
		(up-get-fact unit-type-count-total villager-hunter gl-vill-hopping-hunter-count)
		(up-get-fact unit-type-count-total villager-shepherd gl-vill-hopping-hunter-shepherd-count)
		(up-modify-goal gl-vill-hopping-hunter-shepherd-count g:+ gl-vill-hopping-hunter-count)
		(up-modify-goal gl-vill-hopping-time-modulo g:= timeMilli)
		(up-modify-goal gl-vill-hopping-time-modulo c:mod 1300)
		(up-get-object-data object-data-garrison-count gl-vill-hopping-source-garrison-count))
	; Rule #3532
	; Purpose: Abort the branch when the source town center does not currently justify a vill-hopping rescue attempt.
	(defrule
		(nand (and (and (and (up-compare-goal gl-vill-hopping-source-garrison-count c:== 0)
						(up-compare-sn sn-unload-support-state c:== 0))
					(up-compare-goal gl-vill-hopping-time-modulo g:< msecPerLoop))
					(up-compare-goal gl-vill-hopping-hunter-shepherd-count c:>= 2))
			(up-compare-sn sn-retask-economy-size c:>= 9))
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-jump-direct g: gl-retask-return-label))
	; Rule #3533
	; Purpose: Count same-role villagers near the anchor point and separately count nearby tagged workers that are free to be reassigned.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-set-precise-target-point gl-vill-hopping-center-pos)
		(up-filter-distance c: -1 c: 9)
		(up-find-local c: villager-class c: 240)
		(up-remove-objects search-local object-data-language-id g:!= gl-vill-hopping-required-villager-role)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-vill-hopping-nearby-same-role-count g:= gl-local-total)
		(up-reset-search 1 1 0 0)
		(up-find-local c: villager-class c: 240)
		(up-remove-objects search-local object-data-group-flag c:!= 1)
		(up-remove-objects search-local object-data-target-class-id c:== farm-class)
		(up-remove-objects search-local object-data-target-class-id c:== berry-bush-class)
		(up-remove-objects search-local object-data-action c:== actionid-enter)
		(up-remove-objects search-local object-data-action c:== actionid-attack)
		(up-remove-objects search-local object-data-tasks-count c:> 0)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-vill-hopping-nearby-tagged-worker-count g:= gl-local-total))
	; Rule #3534
	; Purpose: Stop the branch early when there are too few nearby free workers to justify the rescue.
	(defrule
		(up-compare-goal gl-vill-hopping-nearby-tagged-worker-count c:< 2)
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-jump-direct g: gl-retask-return-label))
	; Rule #3535
	; Purpose: Narrow the nearby worker list to non-builders that are still reasonably close to the anchor.
	(defrule
		(true)
		=>
		(up-remove-objects search-local object-data-action c:== actionid-build)
		(up-remove-objects search-local object-data-precise-distance c:> 500)
		(up-get-search-state gl-local-total))
	; Rule #3536
	; Purpose: Abort when the refined nearby worker list ended up empty.
	(defrule
		(up-compare-goal gl-local-total c:== 0)
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-jump-direct g: gl-retask-return-label))
	; Rule #3537
	; Purpose: Select the nearest eligible worker and reset the branch state used to search for a drop site and matching resource.
	(defrule
		(true)
		=>
		(up-clean-search search-local object-data-precise-distance search_order-ascending)
		(up-set-target-object search-local c: 0)
		(up-get-object-data object-data-id gl-vill-hopping-selected-worker-id)
		(up-modify-goal gl-vill-hopping-best-drop-site-id c:= -1)
		(up-modify-goal gl-vill-hopping-found-resource-id c:= -1)
		(up-modify-flag fl-vill-hopping-wood-fallback-needed c:- 1))
	; Rule #3538
	; Purpose: Enable a wood-specific fallback when local drop-site support is weak or wood pressure is otherwise high.
	(defrule
		(or (and (building-type-count-total lumber-camp c:== 0)
				(or (up-compare-goal gl-search-state-scratch-base_W c:== 0)
					(building-type-count-total mule-cart c:== 0)))
			(and (and (up-compare-sn sn-retask-economy-size c:>= 18)
					(up-compare-goal gl-vill-hopping-nearby-tagged-worker-count c:<= 4))
				(up-compare-goal gl-vill-hopping-nearby-same-role-count c:< 2)))
		(up-compare-goal gl-vill-hopping-target-resource c:== wood)
		=>
		(up-modify-flag fl-vill-hopping-wood-fallback-needed c:+ 1))
	; Rule #3539
	; Purpose: Enable the same wood fallback during the flagged opening state when wood-role counts are especially thin.
	(defrule
		(up-compare-sn 75 c:< 100)
		(up-compare-sn sn-retask-economy-size c:< 30)
		(up-compare-goal gl-vill-hopping-nearby-same-role-count c:< 5)
		(up-compare-flag fl-opening-wood-priority c:== fl-opening-wood-priority-value)
		(up-compare-sn 75 c:> 0)
		(up-compare-goal gl-vill-hopping-target-resource c:== wood)
		=>
		(up-modify-flag fl-vill-hopping-wood-fallback-needed c:+ 1))
	; Rule #3540
	; Purpose: Enable the wood fallback for the specific midgame flag combination where wood pressure is still undersupplied.
	(defrule
		(up-compare-goal gl-vill-hopping-nearby-same-role-count c:<= 3)
		(up-compare-flag fl-midgame-wood-support-a c:== fl-midgame-wood-support-a-value)
		(up-compare-flag fl-midgame-wood-support-b c:== fl-midgame-wood-support-b-value)
		(unit-type-count-total villager-wood c:>= 8)
		(up-compare-sn sn-retask-economy-size c:>= 20)
		(up-compare-sn sn-retask-economy-size c:< 35)
		(up-compare-goal gl-vill-hopping-target-resource c:== wood)
		=>
		(up-modify-flag fl-vill-hopping-wood-fallback-needed c:+ 1))
	; Rule #3541
	; Purpose: Skip the drop-site search immediately when the wood fallback says to avoid relying on a local drop site.
	(defrule
		(up-compare-flag fl-vill-hopping-wood-fallback-needed c:== 1)
		(up-compare-goal gl-rule-3549-finalize-drop-site-selection-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3549-finalize-drop-site-selection-id)) ; Jump to rule #3549
	; Rule #3542
	; Purpose: Search for nearby drop sites of the required line around the anchor point.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-set-precise-target-point gl-vill-hopping-center-pos)
		(up-filter-distance c: -1 c: 28)
		(up-find-local g: gl-vill-hopping-required-drop-site-line c: 240)
		(up-remove-objects search-local object-data-group-flag c:!= -2)
		(up-clean-search search-local object-data-full-distance search_order-ascending)
		(up-remove-objects search-local object-data-index c:>= 3)
		(up-get-search-state gl-local-total))
	; Rule #3543
	; Purpose: Skip the drop-site scoring loop when no nearby drop site of the right line exists.
	(defrule
		(up-compare-goal gl-local-total c:== 0)
		(up-compare-goal gl-rule-3549-finalize-drop-site-selection-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3549-finalize-drop-site-selection-id)) ; Jump to rule #3549
	; Rule #3544
	; Purpose: Reset the loop state used to score candidate drop sites and keep the best one.
	(defrule
		(up-modify-goal gl-vill-hopping-best-drop-site-score c:= -1)
		=>
		(up-modify-goal gl-vill-hopping-drop-site-loop-index c:= 0)
		(up-modify-goal gl-vill-hopping-best-drop-site-id c:= -1)
		(up-modify-goal gl-vill-hopping-best-drop-site-score c:= 2147483647))
; Rule #3544.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3545-evaluate-next-drop-site-candidate-id))
	; Rule #3545
	; Purpose: End the drop-site scoring loop after all shortlisted candidates have been evaluated.
	(defrule
		(up-compare-goal gl-vill-hopping-drop-site-loop-index g:>= gl-local-total)
		(up-compare-goal gl-rule-3549-finalize-drop-site-selection-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3549-finalize-drop-site-selection-id)) ; Jump to rule #3549
	; Rule #3546
	; Purpose: Score the current drop-site candidate by combining nearby-role support and distance from the anchor.
	(defrule
		(true)
		=>
		(up-set-target-object search-local g: gl-vill-hopping-drop-site-loop-index)
		(up-modify-goal gl-vill-hopping-drop-site-loop-index c:+ 1)
		(up-get-object-data object-data-id gl-vill-hopping-selected-drop-site-id)
		(up-get-point position-curr-object gl-vill-hopping-current-drop-site-pos)
		(up-set-precise-target-point gl-vill-hopping-current-drop-site-pos)
		(up-filter-distance c: -1 c: 7)
		(up-reset-search 0 0 1 1)
		(up-find-remote c: villager-class c: 40)
		(up-remove-objects search-remote object-data-language-id g:!= gl-vill-hopping-required-villager-role)
		(up-get-point-distance gl-vill-hopping-current-drop-site-pos gl-vill-hopping-center-pos gl-vill-hopping-current-drop-site-distance-score)
		(up-modify-goal gl-vill-hopping-current-drop-site-distance-score c:/ 10)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-vill-hopping-current-drop-site-total-score g:= gl-remote-total)
		(up-modify-goal gl-vill-hopping-current-drop-site-total-score c:* 2)
		(up-modify-goal gl-vill-hopping-current-drop-site-total-score g:+ gl-vill-hopping-current-drop-site-distance-score))
	; Rule #3547
	; Purpose: Remember the best drop site found so far when the current score improves on the previous best.
	(defrule
		(up-compare-goal gl-vill-hopping-current-drop-site-total-score g:< gl-vill-hopping-best-drop-site-score)
		=>
		(up-modify-goal gl-vill-hopping-best-drop-site-score g:= gl-vill-hopping-current-drop-site-total-score)
		(up-modify-goal gl-vill-hopping-best-drop-site-id g:= gl-vill-hopping-selected-drop-site-id))
	; Rule #3548
	; Purpose: Continue the drop-site scoring loop with the next candidate.
	(defrule
		(true)
		(up-compare-goal gl-rule-3545-evaluate-next-drop-site-candidate-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3545-evaluate-next-drop-site-candidate-id)) ; Jump to rule #3545
; Rule #3548.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3549-finalize-drop-site-selection-id))
	; Rule #3549
	; Purpose: Skip the main resource search when no suitable drop site was found.
	(defrule
		(up-compare-goal gl-vill-hopping-best-drop-site-id c:< 0)
		(up-compare-goal gl-rule-3557-check-nearby-wood-fallback-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3557-check-nearby-wood-fallback-id)) ; Jump to rule #3557
	; Rule #3550
	; Purpose: Center the resource search on the best drop site and scale the search radius with current economy size.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-set-target-by-id g: gl-vill-hopping-best-drop-site-id)
		(up-get-point position-curr-object gl-vill-hopping-nearby-drop-site-pos)
		(up-set-precise-target-point gl-vill-hopping-nearby-drop-site-pos)
		(up-modify-goal gl-vill-hopping-search-radius s:= sn-retask-economy-size)
		(up-modify-goal gl-vill-hopping-search-radius c:/ 48)
		(up-modify-goal gl-vill-hopping-search-radius c:* 2)
		(up-modify-goal gl-vill-hopping-search-radius c:+ 4)
		(up-filter-distance c: -1 g: gl-vill-hopping-search-radius))
	; Rule #3551
	; Purpose: Search for food resources around the chosen drop site.
	(defrule
		(up-compare-goal gl-vill-hopping-target-resource c:== food)
		(up-compare-goal gl-rule-3555-filter-found-resource-targets-id c:!= -1)
		=>
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-filter-status c: status-gather c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-filter-status c: status-down c: list-active)
		(up-find-resource c: amount-food c: 40)
		(up-jump-direct g: gl-rule-3555-filter-found-resource-targets-id)) ; Jump to rule #3555
	; Rule #3552
	; Purpose: Search for wood resources around the chosen drop site.
	(defrule
		(up-compare-goal gl-vill-hopping-target-resource c:== wood)
		(up-compare-goal gl-rule-3555-filter-found-resource-targets-id c:!= -1)
		=>
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: amount-wood c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-wood c: 40)
		(up-jump-direct g: gl-rule-3555-filter-found-resource-targets-id)) ; Jump to rule #3555
	; Rule #3553
	; Purpose: Search for stone resources around the chosen drop site.
	(defrule
		(up-compare-goal gl-vill-hopping-target-resource c:== stone)
		(up-compare-goal gl-rule-3555-filter-found-resource-targets-id c:!= -1)
		=>
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-stone c: 40)
		(up-jump-direct g: gl-rule-3555-filter-found-resource-targets-id)) ; Jump to rule #3555
	; Rule #3554
	; Purpose: Search for gold resources around the chosen drop site.
	(defrule
		(up-compare-goal gl-vill-hopping-target-resource c:== gold)
		=>
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-gold c: 40))
; Rule #3554.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3555-filter-found-resource-targets-id))
	; Rule #3555
	; Purpose: Remove over-assigned resource targets and snapshot whether any usable resource remains.
	(defrule
		(true)
		=>
		(up-remove-objects search-remote object-data-tasks-count c:> 2)
		(up-get-search-state gl-local-total))
	; Rule #3556
	; Purpose: Keep the nearest found resource target when the filtered resource list is non-empty.
	(defrule
		(up-compare-goal gl-remote-total c:!= 0)
		=>
		(up-clean-search search-remote object-data-precise-distance search_order-ascending)
		(up-set-target-object search-remote c: 0)
		(up-get-object-data object-data-id gl-vill-hopping-primary-resource-id)
		(up-modify-goal gl-vill-hopping-found-resource-id g:= gl-vill-hopping-primary-resource-id))
; Rule #3556.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3557-check-nearby-wood-fallback-id))
	; Rule #3557
	; Purpose: Only fall back to a nearby wood search when wood was the target and the main search did not already succeed cleanly.
	(defrule
		(nand (or (up-compare-flag fl-vill-hopping-wood-fallback-needed c:== 1)
				(up-compare-goal gl-vill-hopping-found-resource-id c:== -1))
			(up-compare-goal gl-vill-hopping-target-resource c:== wood))
		(up-compare-goal gl-rule-3560-abort-without-resource-target-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3560-abort-without-resource-target-id)) ; Jump to rule #3560
	; Rule #3558
	; Purpose: Search a tighter area around the original anchor for any nearby wood that can serve as the fallback target.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-set-precise-target-point gl-vill-hopping-center-pos)
		(up-filter-distance c: -1 c: 8)
		(up-filter-status c: status-ready c: list-active)
		(up-find-resource c: amount-wood c: 40)
		(up-filter-status c: status-resource c: list-active)
		(up-find-resource c: amount-wood c: 40)
		(up-get-search-state gl-local-total))
	; Rule #3559
	; Purpose: Use the nearest fallback wood target when that tighter search found one.
	(defrule
		(up-compare-goal gl-remote-total c:!= 0)
		=>
		(up-clean-search search-remote object-data-precise-distance search_order-ascending)
		(up-set-target-object search-remote c: 0)
		(up-get-object-data object-data-id gl-vill-hopping-primary-resource-id)
		(up-modify-goal gl-vill-hopping-found-resource-id g:= gl-vill-hopping-primary-resource-id))
; Rule #3559.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3560-abort-without-resource-target-id))
	; Rule #3560
	; Purpose: Abort the branch when no final resource target could be found.
	(defrule
		(up-compare-goal gl-vill-hopping-found-resource-id c:<= 0)
		(up-compare-goal gl-rule-3572-return-from-vill-hopping-branch-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-3572-return-from-vill-hopping-branch-id)) ; Jump to rule #3572
	; Rule #3561
	; Purpose: Restore the selected worker and source town center as the active objects for the final rescue order sequence.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-add-object-by-id search-local g: gl-vill-hopping-selected-worker-id)
		(up-set-target-by-id g: gl-vill-hopping-source-town-center-id))
	; Rule #3562
	; Purpose: Recreate work group 1 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== food-villager-group)
		=>
		(up-create-group 0 0 c: food-villager-group)
		(up-modify-group-flag 1 c: food-villager-group)
		(up-reset-group c: food-villager-group))
	; Rule #3563
	; Purpose: Recreate work group 2 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== wood-villager-group)
		=>
		(up-create-group 0 0 c: wood-villager-group)
		(up-modify-group-flag 1 c: wood-villager-group)
		(up-reset-group c: wood-villager-group))
	; Rule #3564
	; Purpose: Recreate work group 3 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== stone-villager-group)
		=>
		(up-create-group 0 0 c: stone-villager-group)
		(up-modify-group-flag 1 c: stone-villager-group)
		(up-reset-group c: stone-villager-group))
	; Rule #3565
	; Purpose: Recreate work group 4 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== gold-villager-group)
		=>
		(up-create-group 0 0 c: gold-villager-group)
		(up-modify-group-flag 1 c: gold-villager-group)
		(up-reset-group c: gold-villager-group))
	; Rule #3566
	; Purpose: Recreate work group 5 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== generic-work-group-5)
		=>
		(up-create-group 0 0 c: generic-work-group-5)
		(up-modify-group-flag 1 c: generic-work-group-5)
		(up-reset-group c: generic-work-group-5))
	; Rule #3567
	; Purpose: Recreate work group 6 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== generic-work-group-6)
		=>
		(up-create-group 0 0 c: generic-work-group-6)
		(up-modify-group-flag 1 c: generic-work-group-6)
		(up-reset-group c: generic-work-group-6))
	; Rule #3568
	; Purpose: Recreate work group 7 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== generic-work-group-7)
		=>
		(up-create-group 0 0 c: generic-work-group-7)
		(up-modify-group-flag 1 c: generic-work-group-7)
		(up-reset-group c: generic-work-group-7))
	; Rule #3569
	; Purpose: Recreate work group 8 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== generic-work-group-8)
		=>
		(up-create-group 0 0 c: generic-work-group-8)
		(up-modify-group-flag 1 c: generic-work-group-8)
		(up-reset-group c: generic-work-group-8))
	; Rule #3570
	; Purpose: Recreate work group 9 before reissuing the rescued villager order.
	(defrule
		(up-compare-goal gl-vill-hopping-target-group c:== generic-work-group-9)
		=>
		(up-create-group 0 0 c: generic-work-group-9)
		(up-modify-group-flag 1 c: generic-work-group-9)
		(up-reset-group c: generic-work-group-9))
	; Rule #3571
	; Purpose: Garrison the rescued villager, update the unload-support state, and point the source town center at the chosen resource target.
	(defrule
		(true)
		=>
		(up-target-objects 1 action-garrison formation-ignore stance-ignore)
		(up-modify-goal gl-vill-hopping-next-unload-state c:= 3)
		(up-modify-goal gl-vill-hopping-next-unload-state g:+ gl-vill-hopping-target-resource)
		(up-modify-sn sn-unload-support-state g:= gl-vill-hopping-next-unload-state)
		(up-modify-goal gl-vill-hopping-gather-point-target-id g:= gl-vill-hopping-found-resource-id)
		(up-gather-inside c: town-center c: old-only)
		(up-reset-search 1 1 0 0)
		(up-add-object-by-id search-local g: gl-vill-hopping-source-town-center-id)
		(up-set-target-by-id g: gl-vill-hopping-gather-point-target-id)
		(up-target-objects 1 action-set-gather-point formation-ignore stance-ignore))
; Rule #3571.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-3572-return-from-vill-hopping-branch-id))
	; Rule #3572
	; Purpose: Return from the vill-hopping recovery branch to the caller workflow.
	(defrule
		(true)
		(up-compare-goal gl-retask-return-label c:!= -1)
		=>
		(up-jump-direct g: gl-retask-return-label))

























; =========================================================
; EXPANDED CALLER WORKFLOW AROUND THE VILLAGER RETASK ENGINE
; Added from the original Immortal file so this excerpt now includes
; the main caller-side selection, cleanup, fallback and cooldown logic.
; =========================================================

	; Rule #9406
	; Purpose: Enable the wood-specific fallback mode before the direct retask attempt when lumber support is low.
	(defrule
		(unit-type-count-total villager-wood c:< 14)
		(up-compare-sn 484 c:== wood)
		(up-compare-flag fl-wood-town-center-fallback-mode c:== 524288)
		=>
		(up-modify-goal gl-direct-reassign-resource-balance-weight c:= 2))
	; Rule #9407
	; Purpose: Configure and invoke the direct retask attempt for the preselected villager and current strategic-number target resource.
	(defrule
		(up-modify-goal gl-target-resource s:= sn-retask-economy-size)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-source-villager-id g:= gl-preselected-source-villager-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 41)
		(up-modify-goal gl-same-resource-stay-distance c:= 0)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 14)
		(up-modify-goal gl-resource-balance-weight g:= gl-direct-reassign-resource-balance-weight)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius c:= 6)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 0)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9408-skip-immediate-food-clean-id) ; Jump to rule #9408 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9407.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9408-skip-immediate-food-clean-id))
	; Rule #9408
	; Purpose: Skip the immediate food clean-up when the surrounding food setup does not warrant an extra follow-up order.
	(defrule
		(nand (and (and (and (up-compare-goal gl-search-state-scratch-base_W c:> 0)
						(up-compare-sn 71 c:< 10))
					(building-type-count-total town-center c:> 0))
				(unit-type-count-total villager-food c:>= 8))
			(up-compare-goal gl-search-state-scratch-base_F c:== 7))
		(up-compare-goal gl-rule-9413-gate-first-large-retask-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9413-gate-first-large-retask-id)) ; Jump to rule #9413
	; Rule #9409
	; Purpose: Find loaded food villagers in the work group that may need a nearby town center follow-up after the direct retask.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-find-local c: villager-class c: 240)
		(up-remove-objects search-local object-data-group-flag c:!= 2)
		(up-remove-objects search-local object-data-gather-type c:!= food)
		(up-remove-objects search-local object-data-tasks-count c:!= 0)
		(up-remove-objects search-local object-data-carry c:== 0)
		(up-remove-objects search-local object-data-target-class-id c:== building-class)
		(disable-timer retask-first-cleanup-cooldown-timer)
		(up-get-search-state gl-local-total))
	; Rule #9410
	; Purpose: Skip the food follow-up when no eligible loaded food villager was found.
	(defrule
		(up-compare-goal gl-local-total c:== 0)
		(up-compare-goal gl-rule-9413-gate-first-large-retask-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9413-gate-first-large-retask-id)) ; Jump to rule #9413
	; Rule #9411
	; Purpose: Anchor the selected food villager and look for a nearby town center to receive a default order.
	(defrule
		(true)
		=>
		(up-remove-objects search-local object-data-index c:>= 1)
		(up-set-target-object search-local c: 0)
		(up-get-point position-curr-object gl-food-followup-anchor-pos)
		(up-set-precise-target-point gl-food-followup-anchor-pos)
		(up-filter-distance c: -1 c: 6)
		(up-modify-sn sn-focus-player c:= my-player-number)
		(up-find-remote c: town-center c: 1)
		(up-get-search-state gl-local-total))
	; Rule #9412
	; Purpose: Issue the town-center follow-up order when a nearby anchor was found.
	(defrule
		(up-compare-goal gl-remote-last c:!= 0)
		=>
		(up-target-objects 0 action-default formation-ignore stance-ignore))
; Rule #9412.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9413-gate-first-large-retask-id))
	; Rule #9413
	; Purpose: Gate the first large retask-cleanup pass behind its cooldown and controlling flag.
	(defrule
		(nand (up-timer-status retask-first-cleanup-cooldown-timer c:!= timer-running)
			(up-compare-flag fl-retask-workflow-handoff c:!= 262144))
		(up-compare-goal gl-rule-9427-gate-second-cleanup-pass-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9427-gate-second-cleanup-pass-id)) ; Jump to rule #9427
	; Rule #9414
	; Purpose: Build a candidate group of idle-safe villagers whose tag and actual work may need reconciliation.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-find-local c: villager-class c: 240)
		(up-remove-objects search-local object-data-carry c:> 0)
		(up-remove-objects search-local object-data-action c:== actionid-build)
		(up-remove-objects search-local object-data-action c:== actionid-attack)
		(up-remove-objects search-local object-data-action c:== actionid-explore)
		(up-remove-objects search-local object-data-tasks-count c:> 0)
		(up-remove-objects search-local object-data-group-flag c:< 1)
		(up-remove-objects search-local object-data-group-flag c:> 4)
		(up-create-group 0 0 c: 0)
		(up-get-group-size c: 0 gl-first-cleanup-candidate-index))
; Rule #9414.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9415-skip-first-cleanup-pass-id))
	; Rule #9415
	; Purpose: Skip the first cleanup pass when no eligible villagers were gathered.
	(defrule
		(up-compare-goal gl-first-cleanup-candidate-index c:<= 0)
		(up-compare-goal gl-rule-9427-gate-second-cleanup-pass-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9427-gate-second-cleanup-pass-id)) ; Jump to rule #9427
	; Rule #9416
	; Purpose: Load one cleanup candidate and snapshot its tag, work type, villager type and id for evaluation.
	(defrule
		(up-modify-goal gl-first-cleanup-candidate-index c:- 1)
		=>
		(up-reset-search 1 1 0 0)
		(up-set-group search-local c: 0)
		(up-remove-objects search-local object-data-index g:!= gl-first-cleanup-candidate-index)
		(up-set-target-object search-local c: 0)
		(up-get-object-data object-data-group-flag gl-first-cleanup-tag-resource)
		(up-modify-goal gl-first-cleanup-tag-resource c:- 1)
		(up-get-object-data object-data-gather-type gl-first-cleanup-normalized-resource)
		(up-get-object-data object-data-language-id gl-first-cleanup-language-id)
		(up-get-object-data object-data-id gl-first-cleanup-candidate-id))
	; Rule #9417
	; Purpose: Normalize all food-style villager types into the shared food resource bucket for mismatch checking.
	(defrule
		(or (or (or (or (up-compare-goal gl-first-cleanup-language-id c:== lid_villager-farmer)
						(up-compare-goal gl-first-cleanup-language-id c:== lid_villager-forager))
					(up-compare-goal gl-first-cleanup-language-id c:== lid_villager-shepherd))
				(up-compare-goal gl-first-cleanup-language-id c:== lid_villager-hunter))
			(up-compare-goal gl-first-cleanup-language-id c:== lid_villager-fisherman))
		=>
		(up-modify-goal gl-first-cleanup-normalized-resource c:= food))
	; Rule #9418
	; Purpose: Normalize lumberjacks into the wood resource bucket for mismatch checking.
	(defrule
		(up-compare-goal gl-first-cleanup-language-id c:== lid_villager-lumberjack)
		=>
		(up-modify-goal gl-first-cleanup-normalized-resource c:= wood))
	; Rule #9419
	; Purpose: Normalize stone miners into the stone bucket for mismatch checking.
	(defrule
		(up-compare-goal gl-first-cleanup-language-id c:== lid_villager-stone-miner)
		=>
		(up-modify-goal gl-first-cleanup-normalized-resource c:= stone))
	; Rule #9420
	; Purpose: Normalize gold miners into the gold bucket for mismatch checking.
	(defrule
		(up-compare-goal gl-first-cleanup-language-id c:== lid_villager-gold-miner)
		=>
		(up-modify-goal gl-first-cleanup-normalized-resource c:= gold))
	; Rule #9421
	; Purpose: Skip retasking when the villager tag already matches the actual resource or the data is unusable.
	(defrule
		(nand (and (up-compare-goal gl-first-cleanup-tag-resource g:!= gl-first-cleanup-normalized-resource)
				(up-compare-goal gl-first-cleanup-normalized-resource c:>= 0))
			(up-compare-goal gl-first-cleanup-tag-resource c:>= 0))
		(up-compare-goal gl-rule-9426-continue-scanning-remaining-candidates-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9426-continue-scanning-remaining-candidates-id)) ; Jump to rule #9426
	; Rule #9422
	; Purpose: Configure and invoke the first cleanup retask using the villager tag as the desired target resource.
	(defrule
		(up-modify-goal gl-target-resource g:= gl-first-cleanup-tag-resource)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-source-villager-id g:= gl-first-cleanup-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 40)
		(up-modify-goal gl-same-resource-stay-distance c:= 0)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 17)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius c:= 8)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 0)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9423-start-first-cleanup-cooldown-id) ; Jump to rule #9423 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9422.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9423-start-first-cleanup-cooldown-id))
	; Rule #9423
	; Purpose: Start the first cleanup cooldown after a failed tag-vs-work correction attempt.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		=>
		(up-set-timer c: retask-first-cleanup-cooldown-timer c: 8))
	; Rule #9424
	; Purpose: Lengthen that cooldown later in the game after a failed correction.
	(defrule
		(up-compare-goal timeSec c:> 1500)
		(up-compare-goal gl-reassign-result-code c:< 0)
		=>
		(up-set-timer c: retask-first-cleanup-cooldown-timer c: 16))
	; Rule #9425
	; Purpose: Leave the first cleanup loop early when the correction succeeded.
	(defrule
		(up-compare-goal gl-reassign-result-code c:>= 0)
		(up-compare-goal gl-rule-9427-gate-second-cleanup-pass-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9427-gate-second-cleanup-pass-id)) ; Jump to rule #9427
; Rule #9425.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9426-continue-scanning-remaining-candidates-id))
	; Rule #9426
	; Purpose: Continue scanning the remaining candidates in the first cleanup group.
	(defrule
		(true)
		(up-compare-goal gl-rule-9415-skip-first-cleanup-pass-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9415-skip-first-cleanup-pass-id)) ; Jump to rule #9415
; Rule #9426.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9427-gate-second-cleanup-pass-id))
	; Rule #9427
	; Purpose: Gate the second cleanup pass behind timing, cooldown and control-flag checks.
	(defrule
		(up-modify-goal gl-first-cleanup-tick-modulo g:= timeMilli)
		(up-modify-goal gl-first-cleanup-tick-modulo c:mod 1000)
		(nand (and (and (up-compare-goal gl-first-cleanup-tick-modulo g:< msecPerLoop)
					(up-timer-status retask-second-cleanup-cooldown-timer c:!= timer-running))
				(up-compare-sn 124 c:<= 12))
			(up-compare-flag fl-retask-workflow-handoff c:!= 262144))
		(up-compare-goal gl-rule-9441-gate-broad-fallback-retask-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9441-gate-broad-fallback-retask-id)) ; Jump to rule #9441
	; Rule #9428
	; Purpose: Build a candidate group of active gatherers whose movement and target situation may be inconsistent.
	(defrule
		(true)
		=>
		(up-full-reset-search)
		(up-find-local c: villager-class c: 240)
		(up-remove-objects search-local object-data-target-unique-id c:<= 0)
		(up-remove-objects search-local object-data-tasks-count c:> 0)
		(up-remove-objects search-local object-data-gather-type c:<= -1)
		(up-remove-objects search-local object-data-action c:< actionid-gather)
		(up-remove-objects search-local object-data-action c:> actionid-hunt)
		(up-remove-objects search-local object-data-group-flag c:< 1)
		(up-remove-objects search-local object-data-group-flag c:> 4)
		(up-remove-objects search-local object-data-index c:>= 40)
		(up-create-group 0 0 c: 0)
		(up-get-group-size c: 0 gl-second-cleanup-candidate-index))
; Rule #9428.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9429-skip-second-cleanup-pass-id))
	; Rule #9429
	; Purpose: Skip the second cleanup pass when no active-gather candidates remain.
	(defrule
		(up-compare-goal gl-second-cleanup-candidate-index c:<= 0)
		(up-compare-goal gl-rule-9441-gate-broad-fallback-retask-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9441-gate-broad-fallback-retask-id)) ; Jump to rule #9441
	; Rule #9430
	; Purpose: Load one active gatherer candidate and snapshot its id, tag, gather type, move target and distance.
	(defrule
		(up-modify-goal gl-second-cleanup-candidate-index c:- 1)
		=>
		(up-reset-search 1 1 0 0)
		(up-set-group search-local c: 0)
		(up-remove-objects search-local object-data-index g:!= gl-second-cleanup-candidate-index)
		(up-set-target-object search-local c: 0)
		(up-get-object-data object-data-id gl-second-cleanup-candidate-id)
		(up-get-object-data object-data-group-flag gl-second-cleanup-candidate-group-flag)
		(up-get-object-data object-data-gather-type gl-second-cleanup-candidate-resource)
		(up-get-object-data object-data-move-x gl-second-cleanup-candidate-move-target-pos_x)
		(up-get-object-data object-data-move-y gl-second-cleanup-candidate-move-target-pos_y)
		(up-get-point position-curr-object gl-second-cleanup-candidate-current-pos)
		(up-get-point-distance gl-second-cleanup-candidate-current-pos gl-second-cleanup-candidate-move-target-pos gl-second-cleanup-move-distance)
		(up-modify-goal gl-food-anchor-branch-lock c:= 0)
		(up-get-object-data object-data-target-class-id gl-second-cleanup-target-class))
	; Rule #9431
	; Purpose: Mark farm targets specially so later distance and threshold logic can treat them as farm work.
	(defrule
		(up-compare-goal gl-second-cleanup-target-class c:== farm-class)
		=>
		(up-modify-goal gl-food-anchor-branch-lock c:= 1))
	; Rule #9432
	; Purpose: Skip candidates whose current tag already fits their gather type or whose move target is still close enough.
	(defrule
		(up-modify-goal gl-second-cleanup-target-group-plus-one g:= gl-second-cleanup-candidate-resource)
		(up-modify-goal gl-second-cleanup-target-group-plus-one c:+ 1)
		(or (up-compare-goal gl-second-cleanup-target-group-plus-one g:!= gl-second-cleanup-candidate-group-flag)
			(up-compare-goal gl-second-cleanup-move-distance c:< 9))
		(up-compare-goal gl-rule-9429-skip-second-cleanup-pass-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9429-skip-second-cleanup-pass-id)) ; Jump to rule #9429
	; Rule #9433
	; Purpose: Initialize the default retask thresholds used for food-style gatherers in the second cleanup pass.
	(defrule
		(up-modify-goal gl-second-pass-direct-search-radius c:= 30)
		(up-modify-goal gl-second-pass-stay-distance-threshold c:= 9)
		(up-modify-goal gl-second-pass-local-radius-divisor c:= 3)
		(up-modify-goal gl-second-pass-wood-alt-search-mode c:= 0)
		(up-modify-goal gl-second-pass-farm-crowding-threshold c:= 14)
		(up-modify-goal gl-second-pass-resource-balance-weight c:= 2)
		(up-modify-goal gl-second-pass-anchor-resource-search-radius c:= 5)
		(up-compare-goal gl-second-cleanup-candidate-resource c:== wood)
		=>
		(up-modify-goal gl-second-pass-direct-search-radius c:= 38)
		(up-modify-goal gl-second-pass-stay-distance-threshold c:= 13)
		(up-modify-goal gl-second-pass-local-radius-divisor c:= 3)
		(up-modify-goal gl-second-pass-wood-alt-search-mode c:= 1)
		(up-modify-goal gl-second-pass-farm-crowding-threshold c:= 14)
		(up-modify-goal gl-second-pass-resource-balance-weight c:= 20)
		(up-modify-goal gl-second-pass-anchor-resource-search-radius c:= 6))
	; Rule #9434
	; Purpose: Override those thresholds for stone gatherers.
	(defrule
		(up-compare-goal gl-second-cleanup-candidate-resource c:== stone)
		=>
		(up-modify-goal gl-second-pass-direct-search-radius c:= 40)
		(up-modify-goal gl-second-pass-stay-distance-threshold c:= 13)
		(up-modify-goal gl-second-pass-local-radius-divisor c:= 3)
		(up-modify-goal gl-second-pass-wood-alt-search-mode c:= 0)
		(up-modify-goal gl-second-pass-farm-crowding-threshold c:= 9)
		(up-modify-goal gl-second-pass-resource-balance-weight c:= 1)
		(up-modify-goal gl-second-pass-anchor-resource-search-radius c:= 5))
	; Rule #9435
	; Purpose: Override those thresholds for gold gatherers.
	(defrule
		(up-compare-goal gl-second-cleanup-candidate-resource c:== gold)
		=>
		(up-modify-goal gl-second-pass-direct-search-radius c:= 40)
		(up-modify-goal gl-second-pass-stay-distance-threshold c:= 13)
		(up-modify-goal gl-second-pass-local-radius-divisor c:= 3)
		(up-modify-goal gl-second-pass-wood-alt-search-mode c:= 0)
		(up-modify-goal gl-second-pass-farm-crowding-threshold c:= 10)
		(up-modify-goal gl-second-pass-resource-balance-weight c:= 2)
		(up-modify-goal gl-second-pass-anchor-resource-search-radius c:= 5))
	; Rule #9436
	; Purpose: Skip retasking if the gatherer is still close enough to its move target.
	(defrule
		(up-compare-goal gl-second-cleanup-move-distance g:< gl-second-pass-stay-distance-threshold)
		(up-compare-goal gl-rule-9440-continue-scanning-remaining-active-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9440-continue-scanning-remaining-active-id)) ; Jump to rule #9440
	; Rule #9437
	; Purpose: Configure and invoke the second cleanup retask using thresholds tuned to the current gather type.
	(defrule
		(up-modify-goal gl-target-resource g:= gl-second-cleanup-candidate-resource)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-source-villager-id g:= gl-second-cleanup-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius g:= gl-second-pass-direct-search-radius)
		(up-modify-goal gl-same-resource-stay-distance g:= gl-second-pass-stay-distance-threshold)
		(up-modify-goal gl-local-radius-divisor g:= gl-second-pass-local-radius-divisor)
		(up-modify-goal gl-farm-crowding-threshold g:= gl-second-pass-farm-crowding-threshold)
		(up-modify-goal gl-resource-balance-weight g:= gl-second-pass-resource-balance-weight)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius g:= gl-second-pass-anchor-resource-search-radius)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 0)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9438-start-second-cleanup-cooldown-id) ; Jump to rule #9438 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9437.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9438-start-second-cleanup-cooldown-id))
	; Rule #9438
	; Purpose: Start the second cleanup cooldown after a failed active-gather correction attempt.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		=>
		(up-set-timer c: retask-second-cleanup-cooldown-timer c: 5))
	; Rule #9439
	; Purpose: Lengthen the second cleanup cooldown later in the game after failure and then exit the pass.
	(defrule
		(up-compare-goal timeSec c:> 1620)
		(up-compare-goal gl-reassign-result-code c:< 0)
		(up-compare-goal gl-rule-9441-gate-broad-fallback-retask-id c:!= -1)
		=>
		(up-set-timer c: retask-second-cleanup-cooldown-timer c: 20)
		(up-jump-direct g: gl-rule-9441-gate-broad-fallback-retask-id)) ; Jump to rule #9441
; Rule #9439.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9440-continue-scanning-remaining-active-id))
	; Rule #9440
	; Purpose: Continue scanning the remaining active-gather candidates.
	(defrule
		(true)
		(up-compare-goal gl-rule-9429-skip-second-cleanup-pass-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9429-skip-second-cleanup-pass-id)) ; Jump to rule #9429
; Rule #9440.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9441-gate-broad-fallback-retask-id))
	; Rule #9441
	; Purpose: Gate the broad fallback retask sweep behind timing and its own cooldown timer.
	(defrule
		(up-modify-goal gl-food-anchor-branch-lock c:= 0)
		(up-modify-goal gl-second-cleanup-tick-modulo g:= timeMilli)
		(up-modify-goal gl-second-cleanup-tick-modulo c:mod 1400)
		(nand (up-compare-goal gl-second-cleanup-tick-modulo g:< msecPerLoop)
			(up-timer-status retask-fallback-cooldown-timer c:!= timer-running))
		(up-compare-goal gl-rule-9498-refresh-top-level-resource-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9498-refresh-top-level-resource-id)) ; Jump to rule #9498
	; Rule #9442
	; Purpose: Build a broad candidate set of villagers with valid targets for fallback resource reassignment.
	(defrule
		(up-modify-goal gl-fallback-pass-attempts-remaining c:= 5)
		=>
		(up-full-reset-search)
		(up-find-local c: villager-class c: 240)
		(up-remove-objects search-local object-data-group-flag c:> 4)
		(up-remove-objects search-local object-data-action c:== actionid-attack)
		(up-remove-objects search-local object-data-action c:== actionid-enter)
		(up-remove-objects search-local object-data-language-id c:== lid_villager-builder)
		(up-remove-objects search-local object-data-target-unique-id c:<= 0)
		(up-get-search-state gl-local-total)
		(up-modify-goal gl-nearby-farm-scan-index g:= gl-local-total)
		(up-modify-goal gl-nearby-farm-scan-index c:- 1))
; Rule #9442.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9443-stop-pruning-broad-candidates-id))
	; Rule #9443
	; Purpose: Stop pruning when no more broad candidates remain to inspect.
	(defrule
		(up-compare-goal gl-nearby-farm-scan-index c:< 0)
		(up-compare-goal gl-rule-9447-freeze-pruned-candidate-set-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9447-freeze-pruned-candidate-set-id)) ; Jump to rule #9447
	; Rule #9444
	; Purpose: Load one broad candidate and measure how far it is from its current move target.
	(defrule
		(true)
		=>
		(up-set-target-object search-local g: gl-nearby-farm-scan-index)
		(up-get-object-data object-data-move-x gl-nearby-farm-candidate-move-target-pos_x)
		(up-get-object-data object-data-move-y gl-nearby-farm-candidate-move-target-pos_y)
		(up-get-point position-curr-object gl-nearby-farm-candidate-current-pos)
		(up-get-point-distance gl-nearby-farm-candidate-current-pos gl-nearby-farm-candidate-move-target-pos gl-nearby-farm-move-distance))
	; Rule #9445
	; Purpose: Remove villagers that are already close enough to their move target from the fallback candidate set.
	(defrule
		(up-compare-goal gl-nearby-farm-move-distance c:< 9)
		=>
		(up-remove-objects search-local object-data-index g:== gl-nearby-farm-scan-index))
	; Rule #9446
	; Purpose: Continue pruning the broad candidate set one villager at a time.
	(defrule
		(up-modify-goal gl-nearby-farm-scan-index c:- 1)
		(up-compare-goal gl-rule-9443-stop-pruning-broad-candidates-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9443-stop-pruning-broad-candidates-id)) ; Jump to rule #9443
; Rule #9446.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9447-freeze-pruned-candidate-set-id))
	; Rule #9447
	; Purpose: Freeze the pruned candidate set into a group for the fallback sweep.
	(defrule
		(true)
		=>
		(up-create-group 0 0 c: 0)
		(up-get-group-size c: 0 gl-fallback-candidate-index))
; Rule #9447.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9448-end-fallback-sweep-grouped-id))
	; Rule #9448
	; Purpose: End the fallback sweep when the grouped candidates are exhausted.
	(defrule
		(up-compare-goal gl-fallback-candidate-index c:<= 0)
		(up-compare-goal gl-rule-9498-refresh-top-level-resource-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9498-refresh-top-level-resource-id)) ; Jump to rule #9498
	; Rule #9449
	; Purpose: Load one villager from the fallback group for resource-family fallback evaluation.
	(defrule
		(up-modify-goal gl-fallback-candidate-index c:- 1)
		=>
		(up-reset-search 1 1 0 0)
		(up-set-group search-local c: 0)
		(up-remove-objects search-local object-data-index g:!= gl-fallback-candidate-index)
		(up-set-target-object search-local c: 0))
	; Rule #9450
	; Purpose: Stop the fallback sweep when the per-pass attempt budget is exhausted.
	(defrule
		(up-compare-goal gl-fallback-pass-attempts-remaining c:<= 0)
		(up-compare-goal gl-rule-9498-refresh-top-level-resource-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9498-refresh-top-level-resource-id)) ; Jump to rule #9498
	; Rule #9451
	; Purpose: Prefer the villager tag as the current resource-family hint when it is valid.
	(defrule
		(up-get-object-data object-data-id gl-fallback-candidate-id)
		(up-get-object-data object-data-group-flag gl-fallback-candidate-group-flag)
		(up-modify-goal gl-fallback-candidate-resource g:= gl-fallback-candidate-group-flag)
		(up-modify-goal gl-fallback-candidate-resource c:- 1)
		(up-compare-goal gl-fallback-candidate-group-flag c:>= 1)
		(up-compare-goal gl-rule-9457-snapshot-candidate-villager-target-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9457-snapshot-candidate-villager-target-id)) ; Jump to rule #9457
	; Rule #9452
	; Purpose: Otherwise fall back to the current gather type as the resource-family hint when available.
	(defrule
		(up-get-object-data object-data-gather-type gl-fallback-candidate-gather-type)
		(up-modify-goal gl-fallback-candidate-resource g:= gl-fallback-candidate-gather-type)
		(up-compare-goal gl-fallback-candidate-resource c:>= 0)
		(up-compare-goal gl-rule-9457-snapshot-candidate-villager-target-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9457-snapshot-candidate-villager-target-id)) ; Jump to rule #9457
	; Rule #9453
	; Purpose: Derive wood as the current resource-family hint from villager type when tag and gather type were not usable.
	(defrule
		(up-get-object-data object-data-language-id gl-fallback-candidate-language-id)
		(up-modify-goal gl-fallback-candidate-resource g:= gl-fallback-candidate-language-id)
		(up-compare-goal gl-fallback-candidate-resource c:== lid_villager-lumberjack)
		(up-compare-goal gl-rule-9457-snapshot-candidate-villager-target-id c:!= -1)
		=>
		(up-modify-goal gl-fallback-candidate-resource c:= wood)
		(up-jump-direct g: gl-rule-9457-snapshot-candidate-villager-target-id)) ; Jump to rule #9457
	; Rule #9454
	; Purpose: Derive gold as the current resource-family hint from villager type.
	(defrule
		(up-compare-goal gl-fallback-candidate-resource c:== lid_villager-gold-miner)
		(up-compare-goal gl-rule-9457-snapshot-candidate-villager-target-id c:!= -1)
		=>
		(up-modify-goal gl-fallback-candidate-resource c:= gold)
		(up-jump-direct g: gl-rule-9457-snapshot-candidate-villager-target-id)) ; Jump to rule #9457
	; Rule #9455
	; Purpose: Derive stone as the current resource-family hint from villager type.
	(defrule
		(up-compare-goal gl-fallback-candidate-resource c:== lid_villager-stone-miner)
		(up-compare-goal gl-rule-9457-snapshot-candidate-villager-target-id c:!= -1)
		=>
		(up-modify-goal gl-fallback-candidate-resource c:= stone)
		(up-jump-direct g: gl-rule-9457-snapshot-candidate-villager-target-id)) ; Jump to rule #9457
	; Rule #9456
	; Purpose: Derive food as the current resource-family hint from food-style villager types.
	(defrule
		(or (up-compare-goal gl-fallback-candidate-resource c:== lid_villager-farmer)
			(up-compare-goal gl-fallback-candidate-resource c:== lid_villager-forager))
		=>
		(up-modify-goal gl-fallback-candidate-resource c:= food))
; Rule #9456.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9457-snapshot-candidate-villager-target-id))
	; Rule #9457
	; Purpose: Snapshot the candidate villager target and carry state, then inspect the target unit for its tag.
	(defrule
		(up-get-object-data object-data-language-id gl-fallback-target-language-id)
		=>
		(up-get-object-data object-data-target-unique-id gl-fallback-current-target-id)
		(up-get-object-data object-data-carry gl-fallback-candidate-carry-amount)
		(up-set-target-by-id g: gl-fallback-current-target-id)
		(up-get-object-data object-data-group-flag gl-fallback-target-group-flag-min)
		(up-get-object-data object-data-group-flag gl-fallback-target-group-flag-max))
	; Rule #9458
	; Purpose: Reject farmers whose current target does not look like a valid tagged work anchor.
	(defrule
		(or (up-compare-goal gl-fallback-target-group-flag-max c:> 4)
			(up-compare-goal gl-fallback-target-group-flag-min c:< 1))
		(up-compare-goal gl-fallback-target-language-id c:== lid_villager-farmer)
		(up-compare-goal gl-rule-9448-end-fallback-sweep-grouped-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9448-end-fallback-sweep-grouped-id)) ; Jump to rule #9448
	; Rule #9459
	; Purpose: Farmers with an acceptable target skip the extra nearby-dropoff validation and go straight to fallback selection.
	(defrule
		(up-compare-goal gl-fallback-target-language-id c:== lid_villager-farmer)
		(up-compare-goal gl-rule-9464-route-non-food-villagers-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9464-route-non-food-villagers-id)) ; Jump to rule #9464
	; Rule #9460
	; Purpose: For non-farmers, look for a nearby dropoff structure around the current target before attempting fallback retasks.
	(defrule
		(true)
		=>
		(up-reset-filters)
		(up-set-target-by-id g: gl-fallback-current-target-id)
		(up-get-point position-curr-object gl-fallback-target-anchor-pos)
		(up-set-precise-target-point gl-fallback-target-anchor-pos)
		(up-filter-distance c: -1 c: 9)
		(up-modify-sn sn-focus-player c:= my-player-number)
		(up-reset-search 0 0 1 1)
		(up-find-remote c: mill c: 40)
		(up-find-remote c: mining-camp c: 40)
		(up-find-remote c: lumber-camp c: 40)
		(up-find-remote c: town-center c: 40)
		(up-find-remote c: mule-cart c: 40)
		(up-get-search-state gl-local-total))
	; Rule #9461
	; Purpose: Reject the candidate when no nearby dropoff structure was found.
	(defrule
		(up-compare-goal gl-remote-last c:== 0)
		(up-compare-goal gl-rule-9448-end-fallback-sweep-grouped-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9448-end-fallback-sweep-grouped-id)) ; Jump to rule #9448
	; Rule #9462
	; Purpose: Select the nearest acceptable dropoff structure and inspect its tag range.
	(defrule
		(true)
		=>
		(up-clean-search search-remote object-data-full-distance search_order-ascending)
		(up-set-target-object search-remote c: 0)
		(up-get-object-data object-data-group-flag gl-nearby-dropoff-group-flag-min)
		(up-get-object-data object-data-group-flag gl-nearby-dropoff-group-flag-max))
	; Rule #9463
	; Purpose: Reject the candidate when the nearby dropoff structure does not have a valid work tag.
	(defrule
		(or (up-compare-goal gl-nearby-dropoff-group-flag-max c:> 4)
			(up-compare-goal gl-nearby-dropoff-group-flag-min c:< 1))
		(up-compare-goal gl-rule-9448-end-fallback-sweep-grouped-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9448-end-fallback-sweep-grouped-id)) ; Jump to rule #9448
; Rule #9463.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9464-route-non-food-villagers-id))
	; Rule #9464
	; Purpose: Route non-food villagers to the next resource-family fallback chain.
	(defrule
		(up-compare-goal gl-fallback-candidate-resource c:!= food)
		(up-compare-goal gl-rule-9472-route-non-wood-villagers-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9472-route-non-wood-villagers-id)) ; Jump to rule #9472
	; Rule #9465
	; Purpose: First try to keep a food-family villager on food through the shared retask engine.
	(defrule
		(up-modify-goal gl-target-resource c:= food)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-source-villager-id g:= gl-fallback-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 30)
		(up-modify-goal gl-same-resource-stay-distance c:= -1)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 18)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius c:= 7)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 1)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9466-skip-further-fallback-attempts-id) ; Jump to rule #9466 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9465.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9466-skip-further-fallback-attempts-id))
	; Rule #9466
	; Purpose: Skip further fallback attempts for loaded food-family villagers that are already carrying resources.
	(defrule
		(up-compare-goal gl-fallback-candidate-carry-amount c:> 1)
		(up-compare-goal gl-rule-9471-exit-food-family-fallback-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9471-exit-food-family-fallback-id)) ; Jump to rule #9471
	; Rule #9467
	; Purpose: If food failed, try moving the villager to wood with the primary wood search mode.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-target-resource c:= wood)
		(up-modify-goal gl-source-villager-id g:= gl-fallback-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 30)
		(up-modify-goal gl-same-resource-stay-distance c:= -1)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 18)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius c:= 7)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 1)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9468-first-wood-attempt-failed-id) ; Jump to rule #9468 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9467.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9468-first-wood-attempt-failed-id))
	; Rule #9468
	; Purpose: If the first wood attempt failed, try wood again with the alternate wood search mode.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-target-resource c:= wood)
		(up-modify-goal gl-source-villager-id g:= gl-fallback-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 30)
		(up-modify-goal gl-same-resource-stay-distance c:= -1)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 18)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 1)
		(up-modify-goal gl-anchor-resource-search-radius c:= 7)
