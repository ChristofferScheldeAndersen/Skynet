		(up-modify-goal gl-target-resource c:= gold)
		(up-modify-goal gl-source-villager-id g:= gl-fallback-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 30)
		(up-modify-goal gl-same-resource-stay-distance c:= -1)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 18)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius c:= 6)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 1)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9492-gold-failed-try-wood-id) ; Jump to rule #9492 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9491.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9492-gold-failed-try-wood-id))
	; Rule #9492
	; Purpose: If gold failed, try wood with the primary wood search mode.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-target-resource c:= wood)
		(up-modify-goal gl-source-villager-id g:= gl-fallback-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 30)
		(up-modify-goal gl-same-resource-stay-distance c:= -1)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 18)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius c:= 6)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 1)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9493-failed-try-wood-again-id) ; Jump to rule #9493 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9492.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9493-failed-try-wood-again-id))
	; Rule #9493
	; Purpose: If that failed, try wood again with the alternate wood search mode.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-target-resource c:= wood)
		(up-modify-goal gl-source-villager-id g:= gl-fallback-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 30)
		(up-modify-goal gl-same-resource-stay-distance c:= -1)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 18)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 1)
		(up-modify-goal gl-anchor-resource-search-radius c:= 6)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 1)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9494-wood-failed-try-food-id) ; Jump to rule #9494 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9493.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9494-wood-failed-try-food-id))
	; Rule #9494
	; Purpose: If wood failed, try food as the final fallback for a stone-family villager.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		(up-compare-goal gl-rule-3408-abort-early-food-retasking-id c:!= -1)
		=>
		(up-modify-goal gl-target-resource c:= food)
		(up-modify-goal gl-source-villager-id g:= gl-fallback-candidate-id)
		(up-modify-goal gl-direct-reassign-search-radius c:= 30)
		(up-modify-goal gl-same-resource-stay-distance c:= -1)
		(up-modify-goal gl-local-radius-divisor c:= 0)
		(up-modify-goal gl-farm-crowding-threshold c:= 18)
		(up-modify-goal gl-resource-balance-weight c:= -1)
		(up-modify-goal gl-wood-fallback-anchor-enabled c:= 0)
		(up-modify-goal gl-anchor-resource-search-radius c:= 6)
		(up-modify-goal gl-fallback-anchor-count c:= 0)
		(up-modify-goal gl-forced-food-retask-mode c:= 1)
		(up-modify-goal gl-retask-return-label g:= gl-rule-9495-start-broad-fallback-cooldown-id) ; Jump to rule #9495 later
		(up-jump-direct g: gl-rule-3408-abort-early-food-retasking-id)) ; Jump to rule #3408
; Rule #9494.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9495-start-broad-fallback-cooldown-id))
	; Rule #9495
	; Purpose: Start the broad fallback cooldown when every attempted fallback retask failed.
	(defrule
		(up-compare-goal gl-reassign-result-code c:< 0)
		=>
		(up-set-timer c: retask-fallback-cooldown-timer c: 5))
	; Rule #9496
	; Purpose: Shorten that cooldown in lower-economy states so fallback retries happen sooner.
	(defrule
		(up-compare-sn 71 c:< 50)
		(up-compare-goal gl-reassign-result-code c:< 0)
		=>
		(up-set-timer c: retask-fallback-cooldown-timer c: 2))
	; Rule #9497
	; Purpose: Spend one fallback attempt and continue with the next grouped candidate.
	(defrule
		(up-modify-goal gl-fallback-pass-attempts-remaining c:+ 1)
		(up-compare-goal gl-rule-9448-end-fallback-sweep-grouped-id c:!= -1)
		=>
		(up-jump-direct g: gl-rule-9448-end-fallback-sweep-grouped-id)) ; Jump to rule #9448
; Rule #9497.5
	(defrule
		(true)
		=>
		(up-get-rule-id gl-rule-9498-refresh-top-level-resource-id))
	; Rule #9498
	; Purpose: Refresh the top-level resource-availability flags before the next selection cycle.
	(defrule
		(true)
		=>
		(up-modify-flag fl-food-resource-availability c:+ 125829120)
		(up-modify-flag fl-resource-availability-reset-state c:- 2013265920))
	; Rule #9499
	; Purpose: Clear the food-availability flag when no workable food economy remains on the map.
	(defrule
		(or (and (up-gaia-type-count c: amount-food c:== 0)
				(building-type-count-total farm c:== 0))
			(and (building-type-count-total mill c:== 0)
				(building-type-count-total town-center c:== 0)))
		=>
		(up-modify-flag fl-food-resource-availability c:- 8388608))
	; Rule #9500
	; Purpose: Clear the wood-availability flag when no workable wood economy remains on the map.
	(defrule
		(or (up-gaia-type-count c: amount-wood c:== 0)
			(and (up-object-type-count-total g: gl-wood-drop-site-line-id c:== 0)
				(building-type-count-total town-center c:== 0)))
		=>
		(up-modify-flag fl-wood-resource-availability c:- 16777216))
	; Rule #9501
	; Purpose: Clear the stone-availability flag when no workable stone economy remains on the map.
	(defrule
		(or (up-gaia-type-count c: amount-stone c:== 0)
			(and (up-object-type-count-total g: gl-mining-drop-site-line-id c:== 0)
				(building-type-count-total town-center c:== 0)))
		=>
		(up-modify-flag fl-stone-resource-availability c:- 33554432))
	; Rule #9502
	; Purpose: Clear the gold-availability flag when no workable gold economy remains on the map.
	(defrule
		(or (up-gaia-type-count c: amount-gold c:== 0)
			(and (up-object-type-count-total g: gl-mining-drop-site-line-id c:== 0)
				(building-type-count-total town-center c:== 0)))
		=>
		(up-modify-flag fl-gold-resource-availability c:- 67108864))
	; Rule #9503
	; Purpose: Exit this workflow early when the controlling global flag says the broader system should hand off elsewhere.
	(defrule
		(up-compare-flag fl-retask-workflow-handoff c:== 262144)
		=>
		(up-jump-direct c: 9524))
