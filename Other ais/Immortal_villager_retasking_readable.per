						(up-compare-sn sn-reassign-target-resource c:== gold)))
				(and (up-object-type-count-total g: gl-wood-drop-site-line-id c:== 0)
					(up-compare-sn sn-reassign-target-resource c:== wood)))
			(and (building-type-count-total mill c:== 0)
				(up-compare-sn sn-reassign-target-resource c:== food)))
		(up-compare-goal gl-rule-3518-set-final-failure-code-id c:!= -1)
		=>
