		(up-get-point position-curr-object gl-probe-east-pos)
		(up-copy-point gl-probe-south-pos gl-probe-east-pos)
		(up-copy-point gl-probe-west-pos gl-probe-east-pos)
		(up-copy-point gl-probe-north-pos gl-probe-east-pos)
		(up-modify-goal gl-probe-east-pos-x c:+ 1)
		(up-modify-goal gl-probe-south-pos-y c:+ 1)
		(up-modify-goal gl-probe-west-pos-x c:- 1)
		(up-modify-goal gl-probe-north-pos-y c:- 1))

	; Rule #3486
	; Purpose: Discard second-pass targets whose surrounding tiles fail the routine's buildability/pathing checks.
	(defrule
		(nor (not (up-can-build 0 g: gl-buildability-probe-line-id))
			(or (or (or (up-can-build-line build-line-check-mode gl-probe-east-pos g: gl-buildability-probe-line-id)
						(up-can-build-line build-line-check-mode gl-probe-south-pos g: gl-buildability-probe-line-id))
					(up-can-build-line build-line-check-mode gl-probe-west-pos g: gl-buildability-probe-line-id))
				(up-can-build-line build-line-check-mode gl-probe-north-pos g: gl-buildability-probe-line-id)))
