(up-find-local c: 912 c: 240)
(up-find-local c: 913 c: 240)
(up-find-local c: 936 c: 240)
(up-find-local c: 944 c: 240)
(up-find-local c: 955 c: 240)
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-modify-sn sn-focus-player-number c:= 1)
)

(defrule
(goal military-mode shield)
(or(not(player-in-game focus-player))
(not(players-stance focus-player enemy)))
(up-compare-sn sn-focus-player-number > 0)
(up-compare-sn sn-focus-player-number < 9)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -1)
)

(defrule
(goal military-mode shield)
(up-compare-sn sn-focus-player-number > 0)
(up-compare-sn sn-focus-player-number < 9)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-find-remote c: town-center c: 40)
(up-find-remote c: castle c: 40)
(up-remove-objects search-remote 19 c:== 0)
)

(defrule
(goal military-mode shield)
(up-compare-sn sn-focus-player-number > 0)
(up-compare-sn sn-focus-player-number < 9)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
(up-object-data 12 > 0) 
=>
(up-find-remote c: 952 c: 40)
(up-find-remote c: donjon c: 40)
(up-find-remote c: krepost c: 40)
(up-remove-objects search-remote 20 == my-player-number)
(up-remove-objects search-remote 19 c:== 0)
)

(defrule
(goal military-mode shield)
(up-compare-sn sn-focus-player-number > 0)
(up-compare-sn sn-focus-player-number < 9)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -4)
)

(defrule
(goal military-mode shield)
(up-set-target-object search-local g: gl-current-list-number)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-get-point position-object gl-current-raiders-x)
(up-set-target-point gl-current-raiders-x)
(up-clean-search search-remote 44 1)
)

(defrule
(goal military-mode shield)
(up-set-target-object search-remote c: 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-get-object-data 12 gl-enemy-building-range)
(up-get-point position-object gl-danger-x)
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-full-reset-search)
(up-set-target-point gl-danger-x)
(up-modify-goal gl-range-variable g:= gl-enemy-building-range)
(up-modify-goal gl-range-variable c:+ 4)
(up-filter-distance c: -1 g: gl-range-variable)
;(up-find-local c: 918 c: 240)
;(up-remove-objects search-local -1 == 0);remove first monk
(up-find-local c: scout-cavalry-line c: 240)
(up-find-local c: 900 c: 240)
(up-find-local c: 906 c: 240)
(up-find-local c: 912 c: 240)
(up-find-local c: 913 c: 240)
(up-find-local c: 936 c: 240)
(up-find-local c: 944 c: 240)
(up-find-local c: 955 c: 240)
(up-get-search-state gl-local-total)
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
=>
(up-get-point position-object gl-current-raiders-x)
(up-copy-point gl-dot-x gl-danger-x)
(up-modify-goal gl-range-variable g:= gl-enemy-building-range)
(up-modify-goal gl-range-variable c:+ 6)
(up-lerp-tiles gl-dot-x gl-current-raiders-x g: gl-range-variable)
(up-cross-tiles gl-dot-x gl-current-raiders-x c: 2)
(up-bound-point gl-dot-x gl-dot-x)
(up-remove-objects search-local -1 g:!= gl-current-list-number)
(up-target-point gl-dot-x action-move -1 2)
(up-modify-goal gl-current-list-number c:+ 1)
;(chat-local-to-self "Dodging fortification")
(up-jump-rule -10)
)