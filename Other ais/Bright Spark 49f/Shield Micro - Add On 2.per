(up-get-search-state gl-local-total)
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -2)
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(or(up-point-distance gl-self-x gl-current-raiders-x < 6)
(and(up-compare-goal gl-remote-total < 1)
(up-object-data 12 < 1)))
=>
(up-modify-goal gl-current-list-number c:+ 1)
(up-jump-rule -6)
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-compare-goal gl-local-total > 0)
=>
(up-target-point gl-self-x action-default -1 2)
(up-modify-goal gl-current-list-number c:+ 1)
;(chat-local-to-self "Running home")
(up-jump-rule -7)
)

(defrule
(goal military-mode shield)
(true)
=>
(up-full-reset-search)
