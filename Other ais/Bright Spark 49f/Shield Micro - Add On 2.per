;(up-remove-objects search-local -1 == 0);remove first monk
(up-find-local c: scout-cavalry-line c: 240)
(up-find-local c: 900 c: 240)
(up-find-local c: 906 c: 240)
(up-find-local c: 912 c: 240)
(up-find-local c: 913 c: 240)
(up-find-local c: 936 c: 240)
(up-find-local c: 944 c: 240)
(up-find-local c: 955 c: 240)
(up-get-search-state gl-local-total)
(up-reset-filters)
)

(defrule
(goal military-mode shield)
(true)
=>
(up-modify-goal gl-rule-loops g:= gl-local-total)
(up-modify-goal gl-current-list-number c:= 0)
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-full-reset-search)
;(up-find-local c: 918 c: 240)
;(up-remove-objects search-local -1 == 0);remove first monk
(up-find-local c: scout-cavalry-line c: 240)
(up-find-local c: 900 c: 240)
