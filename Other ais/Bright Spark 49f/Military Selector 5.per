(defconst building-type-goal2 197)
(defconst supporting-military-unit 198)
(defconst building-type-goal 199)
(defconst chosen-military-unit 200)
(defconst chosen-barracks-unit 201)
(defconst chosen-archery-range-unit 202)
(defconst chosen-stable-unit 203)
(defconst chosen-siege-workshop-unit 204)
(defconst chosen-dock-unit 215)

(defconst military-voting-timer 16)
(defconst voting-time 5);30

(defrule
(true)
=>
(enable-timer military-voting-timer voting-time)
(disable-self)
)

(defrule
(timer-triggered military-voting-timer)
=>
(enable-timer military-voting-timer voting-time)
)

(defrule
(true)
=>
(up-modify-goal gl-dot-x g:= militiaman-votes)
)

(defrule
(true)
=>
(up-modify-goal gl-dot-x g:max spearman-votes)
(up-modify-goal gl-dot-x g:max fire-lancer-votes)
(up-modify-goal gl-dot-x g:max champi-scout-votes)
(up-modify-goal gl-dot-x g:max archer-votes)
(up-modify-goal gl-dot-x g:max skirmisher-votes)
(up-modify-goal gl-dot-x g:max cavalry-archer-votes)
(up-modify-goal gl-dot-x g:max scout-cavalry-votes)
(up-modify-goal gl-dot-x g:max knight-votes)
(up-modify-goal gl-dot-x g:max camel-votes)
(up-modify-goal gl-dot-x g:max battle-elephant-votes)
(up-modify-goal gl-dot-x g:max monk-votes)
(up-modify-goal gl-dot-x g:max eagle-warrior-votes)
(up-modify-goal gl-dot-x g:max hand-cannoneer-votes)
(up-modify-goal gl-dot-x g:max genitour-votes)
(up-modify-goal gl-dot-x g:max mangonel-votes)
(up-modify-goal gl-dot-x g:max mounted-trebuchet-votes)
(up-modify-goal gl-dot-x g:max elephant-archer-votes)
(up-modify-goal gl-dot-x g:max condottiero-votes)
(up-modify-goal gl-dot-x g:max my-special-unit-votes)
)

(defrule
(up-compare-goal militiaman-votes g:== gl-dot-x)
=>
(generate-random-number 8)
(up-get-fact 33 0 gl-dot-y)
(up-modify-goal gl-dot-y c:- 4)
(up-modify-goal militiaman-votes g:+ gl-dot-y)
)

