(defrule 
(not(goal chosen-military-unit militiaman-line))
(up-compare-goal militiaman-votes g:> spearman-votes)
(up-compare-goal militiaman-votes g:> fire-lancer-votes)
(up-compare-goal militiaman-votes g:> champi-scout-votes)
(up-compare-goal militiaman-votes g:> archer-votes)
(up-compare-goal militiaman-votes g:> skirmisher-votes)
(up-compare-goal militiaman-votes g:> cavalry-archer-votes)
(up-compare-goal militiaman-votes g:> scout-cavalry-votes)
(up-compare-goal militiaman-votes g:> knight-votes)
(up-compare-goal militiaman-votes g:> camel-votes)
(up-compare-goal militiaman-votes g:> battle-elephant-votes)
(up-compare-goal militiaman-votes g:> monk-votes)
(up-compare-goal militiaman-votes g:> eagle-warrior-votes)
(up-compare-goal militiaman-votes g:> hand-cannoneer-votes)
(up-compare-goal militiaman-votes g:> scorpion-votes)
(up-compare-goal militiaman-votes g:> genitour-votes)
(up-compare-goal militiaman-votes g:> mangonel-votes)
(up-compare-goal militiaman-votes g:> mounted-trebuchet-votes)
(up-compare-goal militiaman-votes g:> elephant-archer-votes)
(up-compare-goal militiaman-votes g:> condottiero-votes)
(up-compare-goal militiaman-votes g:> my-special-unit-votes)
=>
(up-modify-goal supporting-military-unit g:= chosen-military-unit)
(set-goal chosen-military-unit militiaman-line)
;(chat-local-to-self "Preferred unit is now militiaman")
)

