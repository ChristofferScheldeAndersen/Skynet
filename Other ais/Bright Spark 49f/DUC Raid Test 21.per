(defrule
;(players-building-type-count target-player wall-class >= 10)
(goal gl-siege-wall-target-id -1)
=>
(up-full-reset-search)
(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
(up-find-remote c: wall-class c: 500)
(up-find-remote c: gate-class c: 500)
(up-set-target-point gl-centre-x)
(up-clean-search search-remote 44 1)
(up-get-search-state gl-local-total)
)

(defrule
;(players-building-type-count target-player wall-class >= 10)
(goal gl-siege-wall-target-id -1)
(up-compare-goal gl-remote-total >= 15)
(up-set-target-object search-remote c: 0)
=>
(up-get-object-data 0 gl-siege-wall-target-id)
(disable-self)
)

(defrule
(up-compare-goal gl-siege-wall-target-id != -1)
(not(up-set-target-by-id g: gl-siege-wall-target-id))
=>
(up-modify-goal gl-siege-wall-target-id c:= -1)
(enable-timer assault-timer 0)
(chat-local-to-self "wall breached")
)

(defrule
(false)
(up-compare-goal gl-siege-wall-target-id != -1)
=>
(up-set-target-by-id g: gl-siege-wall-target-id)
)

(defrule
(false)
(up-compare-goal gl-siege-wall-target-id != -1)
(up-object-data 10 <= 0)
=>
(up-modify-goal gl-siege-wall-target-id c:= -1)
(chat-local-to-self "wall breached")
)

(defrule
(false)
(up-compare-goal gl-siege-wall-target-id != -1)
=>
(up-full-reset-search)
(up-add-object-by-id search-remote g: gl-siege-wall-target-id)
(up-remove-objects search-remote 10 <= 0)
(up-get-search-state gl-local-total)
)

(defrule
(false)
(up-compare-goal gl-siege-wall-target-id != -1)
(up-compare-goal gl-remote-total < 1)
=>
(up-modify-goal gl-siege-wall-target-id c:= -1)
(chat-local-to-self "wall breached")
)

(defrule
(false)
(up-compare-goal gl-siege-wall-target-id != -1)
=>
(chat-local-to-self "breach spot located")
(up-set-target-by-id g: gl-siege-wall-target-id)
(up-get-point position-object gl-dot-x)
(up-send-flare gl-dot-x)
)

#end-if

(defrule
(true)
=>
(up-modify-sn sn-disable-defend-groups c:= 1);7
(disable-self)
)

(defrule
(true)
=>
(up-get-point position-self gl-station-x)
