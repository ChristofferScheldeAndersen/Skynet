(or(up-point-terrain gl-dot-x == 1)
(or(up-point-terrain gl-dot-x == 2)
(or(up-point-terrain gl-dot-x == 15)
(or(up-point-terrain gl-dot-x == 22)
(or(up-point-terrain gl-dot-x == 23)
(or(up-point-terrain gl-dot-x == 57)
(or(up-point-terrain gl-dot-x == 58)
(or(up-point-terrain gl-dot-x == 59)
(or(up-point-terrain gl-dot-x == 95)
(or(up-point-terrain gl-dot-x == 96)
(or(up-point-terrain gl-dot-x == 114)
(or(up-point-terrain gl-dot-x == 115)
(up-point-terrain gl-dot-x == 116)))))))))))))
(up-point-distance gl-temp-x gl-dot-x >= 1)
;(up-point-distance gl-self-x gl-dot-x < 10)
=>
(up-jump-rule -3)
)

(defrule
;(false)
;(true)
(timer-triggered navy-timer)
=>
(up-lerp-tiles gl-dot-x gl-temp-x c: 2);3
(up-copy-point gl-transport-drop-off-x gl-dot-x)
;(up-send-flare gl-transport-drop-off-x)
;(up-get-point-terrain gl-dot-x gl-dot-x)
;(up-chat-data-to-all "terrain %d" g: gl-dot-x)
)

(defrule
(true)
=>
(up-full-reset-search)
(up-find-local c: dock c: 240)
(up-clean-search search-local 0 2)
(up-get-point position-self gl-latest-dock-x)
)

(defrule
(up-set-target-object search-local c: 0)
=>
(up-get-point position-object gl-latest-dock-x)
)

(defrule
(timer-triggered navy-timer)
=>
(enable-timer navy-timer 20);10
)