(disable-self)
)

(defrule
(false)
(goal military-mode shield)
(not(up-timer-status go-home-timer == timer-running))
=>
(enable-timer go-home-timer 30)
)

(defrule
(goal military-mode shield)
(timer-triggered go-home-timer)
;(unit-type-count 274 == 0)
=>
(disable-timer go-home-timer)
(up-modify-goal gl-shield-target c:= -1)
(set-goal military-mode hold)
(chat-local-to-self "switching away from shield mode")
;(disable-self)
)

(defrule
(not(goal military-mode shield))
(timer-triggered go-home-timer)
=>
(disable-timer go-home-timer)
)

(defrule
;(false)
;(unit-type-count 274 > 0)
;(or(not(goal military-mode raid))
(current-age == feudal-age)
(not(goal military-mode raid))
(not(goal military-mode shield))
(not(goal military-mode assault))
(military-population > 5)
;(up-enemy-units-in-town < 2)
(not(town-under-attack))
(taunt-detected any-ally 48)
=>
;(up-find-flare gl-flared-x)
(acknowledge-taunt this-any-ally 48)
(up-get-player-fact this-any-ally 36 gl-self-x gl-flared-x)
(up-get-player-fact this-any-ally 36 gl-self-y gl-flared-y)
(up-get-player-fact this-any-ally 22 0 gl-shield-target)
(set-goal military-mode shield)
(enable-timer go-home-timer 30);120 90
)

(defrule
;(false)
;(unit-type-count 274 > 0)
;(or(not(goal military-mode raid))
(current-age >= castle-age)
(not(goal military-mode raid));changed since raiding updated
(not(goal military-mode shield))
(not(goal military-mode assault))
(military-population > 5)
;(up-enemy-units-in-town < 2)
(not(town-under-attack))
(taunt-detected any-ally 48)
=>
;(up-find-flare gl-flared-x)
(acknowledge-taunt this-any-ally 48)
(up-get-player-fact this-any-ally 36 gl-self-x gl-attacked-location-x);gl-flared-x
(up-get-player-fact this-any-ally 36 gl-self-y gl-attacked-location-y);gl-flared-y
(up-get-player-fact this-any-ally 22 0 gl-shield-target)
(set-goal military-mode shield)
(enable-timer go-home-timer 30);120 90
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-flared-x == -1)
(up-compare-goal gl-flared-y == -1)
(up-compare-goal gl-shield-target c:!= my-player-number)
=>
(up-modify-sn sn-focus-player-number g:= gl-shield-target)
(up-get-point position-focus gl-flared-x)
)

(defrule
(current-age >= castle-age)
;(not(goal military-mode assault))
(military-population > 5)
(taunt-detected my-player-number 48)
=>
;(up-find-flare gl-flared-x)
(acknowledge-taunt my-player-number 48)
(up-get-player-fact my-player-number 36 gl-self-x gl-flared-x)
(up-get-player-fact my-player-number 36 gl-self-y gl-flared-y)
(up-modify-goal gl-shield-target c:= my-player-number)
(set-goal military-mode shield)
(enable-timer go-home-timer 30);120 90
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-flared-x == -1)
(up-compare-goal gl-flared-y == -1)
(up-compare-goal gl-shield-target c:== my-player-number)
=>
(up-full-reset-search)
(up-find-local c: castle c: 1)
(up-find-local c: villager c: 1)
(up-find-local c: -1 c: 1)
)

(defrule
(goal military-mode shield)
(up-compare-goal gl-flared-x == -1)
