(players-unit-type-count any-enemy thirisadai >= low-units)
(players-unit-type-count any-enemy thirisadai < mid-units)
=>
(set-goal thirisadai-presence low-presence)
)

(defrule
(not(goal thirisadai-presence mid-presence))
(players-unit-type-count any-enemy thirisadai >= mid-units)
(players-unit-type-count any-enemy thirisadai < high-units)
=>
(set-goal thirisadai-presence mid-presence)
)

(defrule
(not(goal thirisadai-presence high-presence))
(players-unit-type-count any-enemy thirisadai >= high-units)
=>
(set-goal thirisadai-presence high-presence)
)