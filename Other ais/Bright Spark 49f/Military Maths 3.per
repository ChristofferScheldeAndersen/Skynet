(defconst low-units 1)
(defconst mid-units 4)
(defconst high-units 15)

(defconst low-presence 15)
(defconst mid-presence 30)
(defconst high-presence 45)

(defconst militiaman-presence 150)
(defconst spearman-presence 151)
(defconst archer-presence 152)
(defconst skirmisher-presence 153)
(defconst cavalry-archer-presence 154)
(defconst scout-cavalry-presence 155)
(defconst knight-presence 156)
(defconst camel-presence 157)
(defconst battle-elephant-presence 158)
(defconst monk-presence 159)
(defconst eagle-warrior-presence 160)
(defconst hand-cannoneer-presence 161)
(defconst scorpion-presence 162)
(defconst battering-ram-presence 163)
(defconst mangonel-presence 164)
(defconst bombard-cannon-presence 165)
(defconst trebuchet-presence 166)
(defconst galley-presence 167)
(defconst fire-ship-presence 168)
(defconst demo-ship-presence 169)
(defconst turtle-ship-presence 170)
(defconst longboat-presence 171)
(defconst caravel-presence 172)
(defconst thirisadai-presence 173)
(defconst fire-lancer-presence 174)
(defconst hulk-presence 175)

(defrule
(not(goal militiaman-presence 0))
(players-unit-type-count any-enemy militiaman-line < low-units)
=>
(set-goal militiaman-presence 0)
)

(defrule
(not(goal militiaman-presence low-presence))
(players-unit-type-count any-enemy militiaman-line >= low-units)
(players-unit-type-count any-enemy militiaman-line < mid-units)
=>
(set-goal militiaman-presence low-presence)
)

(defrule
(not(goal militiaman-presence mid-presence))
(players-unit-type-count any-enemy militiaman-line >= mid-units)
(players-unit-type-count any-enemy militiaman-line < high-units)
=>
(set-goal militiaman-presence mid-presence)
)

(defrule
(not(goal militiaman-presence high-presence))
(players-unit-type-count any-enemy militiaman-line >= high-units)
=>
(set-goal militiaman-presence high-presence)
)

(defrule
(players-unit-type-count any-enemy berserk-line >= low-units)
(players-unit-type-count any-enemy berserk-line < mid-units)
=>
(up-modify-goal militiaman-presence c:+ low-presence)
)

(defrule
(players-unit-type-count any-enemy berserk-line >= mid-units)
(players-unit-type-count any-enemy berserk-line < high-units)
=>
(up-modify-goal militiaman-presence c:+ mid-presence)
)

(defrule
(players-unit-type-count any-enemy berserk-line >= high-units)
=>
(up-modify-goal militiaman-presence c:+ high-presence)
)

