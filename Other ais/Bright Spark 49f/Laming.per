#load-if-defined GURJARAS-CIV

(defconst boar-chase-damage 4)

#else

(defconst boar-chase-damage 5)

#end-if

#load-if-defined AZTEC-CIV

(defconst boar-chase-distance 375)

#end-if

#load-if-defined MAYAN-CIV

(defconst boar-chase-distance 375)

#end-if

#load-if-defined INCAN-CIV

(defconst boar-chase-distance 375)

#end-if

#load-if-not-defined AZTEC-CIV

#load-if-not-defined MAYAN-CIV

#load-if-not-defined INCAN-CIV

(defconst boar-chase-distance 325)

#end-if

#end-if

#end-if

(defrule
(map-type arabia)
(game-time < 600)
=>
(up-full-reset-search)
(up-set-target-point gl-self-x)
(up-filter-distance c: -1 c: 25)
(up-modify-sn sn-focus-player-number c:= 0)
(up-find-remote c: 2084 c: 500)
(up-find-remote c: 2086 c: 500)
(up-find-remote c: 2088 c: 500)
(up-find-remote c: 2098 c: 500)
(up-find-remote c: 2099 c: 500)
(up-find-remote c: 2100 c: 500)
(up-remove-objects search-remote 44 c:> 25)
(up-get-search-state gl-local-total)
)

(defrule
(map-type arabia)
(game-time < 600)
(up-compare-goal gl-boar-found-state c:== 3)
(up-compare-goal gl-remote-total > 0)
(not(goal scout-goal lame-boar))
(not(goal scout-goal lame-boar-run))
(not(goal scout-goal 22))
(or(up-compare-goal scout-goal > 0)
(up-compare-goal scout-goal == -8))
(up-compare-goal scout-goal < 10)
=>
(set-goal scout-goal 22)
;(disable-self)
)

(defrule
(players-building-type-count target-player town-center > 0)
=>
(up-full-reset-search)
(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
(up-find-remote c: town-center c: 1)
)

(defrule
(players-building-type-count target-player town-center > 0)
(up-set-target-object search-remote c: 0)
=>
(up-get-point position-object gl-danger-x)
)

(defrule
(true)
=>
(up-full-reset-search)
;(up-modify-goal gl-dot-x c:= boar-chase-distance)
;(up-modify-goal gl-dot-y c:= boar-chase-damage)
;(up-chat-data-to-self "distance %d" g: gl-dot-x)
;(up-chat-data-to-self "damage %d" g: gl-dot-y)
)

(defrule
(building-type-count town-center > 0)
(up-compare-goal gl-position-line c:== flank)
(not(goal scout-goal lame-boar))
(not(goal scout-goal lame-boar-run))
;(goal scout-goal lame-boar)
=>
(up-full-reset-search)
;(up-add-object-by-id search-local gl-scout-id)
(up-set-group search-local c: 0)
(up-remove-objects search-local 2 c:== villager-class)
(up-set-target-point gl-self-x)
(up-remove-objects search-local 32 >= 1)
(up-filter-distance c: 35 c: -1)
(up-modify-sn sn-focus-player-number c:= 0)
(up-find-remote c: 48 c: 40)
(up-find-remote c: 822 c: 40)
(up-find-remote c: 1301 c: 40)
(up-find-remote c: 1139 c: 40)
(up-find-remote c: 2589 c: 40)
(up-remove-objects search-remote 44 < 35)
(up-remove-objects search-remote 32 > 2)
(up-remove-objects search-remote 10 < 1)
(up-remove-objects search-remote 2 != 910)
(up-get-search-state gl-local-total)
;(up-chat-data-to-all "boar HP %d" g: gl-boar-two-hit-hp)
)

(defrule
(building-type-count town-center > 0)
(up-set-target-object search-local c: 0)
(up-compare-goal gl-remote-total > 0)
(not(goal scout-goal lame-boar))
(not(goal scout-goal lame-boar-run))
=>
;(chat-local-to-self "We have a boar I can lame!")
(up-get-point position-object gl-dot-x)
(up-set-target-point gl-danger-x)
(up-remove-objects search-remote 44 < 10)
(up-set-target-point gl-dot-x)
(up-remove-objects search-remote 44 > 5);5
(up-clean-search search-remote 44 1)
(up-set-target-object search-remote c: 0)
(up-get-point position-object gl-dot-x)
)

(defrule
(building-type-count town-center > 0)
(up-set-target-object search-remote c: 0)
(up-compare-goal gl-local-total > 0)
(not(goal scout-goal lame-boar))
(not(goal scout-goal lame-boar-run))
(up-point-explored gl-dot-x != 0)
=>
(set-goal scout-goal lame-boar)
(set-goal active-scout-goal lame-boar)
(up-get-object-data 10 gl-boar-two-hit-hp)
(up-modify-goal gl-boar-two-hit-hp c:- boar-chase-damage)
(disable-self)
)

(defrule
(up-set-target-object search-remote c: 0)
(up-compare-goal gl-local-total > 0)
(goal scout-goal lame-boar)
(current-age == dark-age)
(not(goal military-mode hold))
=>
(set-goal military-mode hold)
)

(defrule
(false);this is a backup for the 3 rules below
(up-set-target-object search-remote c: 0)
(up-compare-goal gl-local-total > 0)
(goal scout-goal lame-boar)
(goal military-mode hold)
=>
(up-get-object-data 0 gl-laming-boar-id)
(up-target-objects 1 action-default -1 2)
;(chat-local-to-self "attack the boar target!")
)

(defrule
;(up-compare-goal gl-local-total > 0)
(goal scout-goal lame-boar)
(goal military-mode hold)
(up-compare-goal gl-laming-boar-id != -1)
;(up-compare-goal gl-remote-total < 1)
=>
(up-full-reset-search)
(up-set-group search-local c: 0)
(up-add-object-by-id search-remote g: gl-laming-boar-id)
(up-remove-objects search-remote 10 < 1)
;(chat-local-to-self "adding target boar ID")
(up-get-search-state gl-local-total)
)

(defrule
(up-set-target-object search-remote c: 0)
(up-compare-goal gl-local-total > 0)
(goal scout-goal lame-boar)
(goal military-mode hold)
=>
(up-get-object-data 0 gl-laming-boar-id)
(up-get-point position-object gl-dot-x)
(up-lerp-tiles gl-dot-x gl-self-x c: 2)
(up-set-target-point gl-dot-x)
)

(defrule
(up-set-target-object search-local c: 0)
(up-compare-goal gl-local-total > 0)
(goal scout-goal lame-boar)
(goal military-mode hold)
(up-object-data 44 > 1)
(up-set-target-object search-remote c: 0)
=>
(up-target-point gl-dot-x action-move -1 -1)
)

(defrule
(up-set-target-object search-local c: 0)
