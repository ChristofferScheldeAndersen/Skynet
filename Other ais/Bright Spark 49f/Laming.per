(defrule
(not(goal scout-goal lame-boar))
(not(goal scout-goal lame-boar-run))
(not(goal scout-goal 10))
(or(game-time > 400);400I think this and below turn boar laming on
(goal scout-goal 22))
(game-time > 400);280;400 - I think this turned boar laming off
(current-age == dark-age)
=>
;(chat-local-to-self "deer deer deer")
(set-goal scout-goal 10)
;(chat-local-to-self "boar laming script timed out, switching to scout goal 10")
(set-goal active-scout-goal 10)
(set-goal deer-luring 1)
(set-goal military-mode hold)
(set-goal active-military-mode hold)
(up-modify-sn sn-number-explore-groups c:= 1)
)

