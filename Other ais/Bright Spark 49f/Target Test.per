;/////// Target Enemy With Lowest Score ///////

(defrule
(goal 77 1)
(goal strategy-goal last-place-enemy)
=>
(set-strategic-number sn-focus-player-number 0)
)

(defrule
(goal 77 1)
(goal strategy-goal last-place-enemy)
(strategic-number sn-focus-player-number == 0)
=>
(set-strategic-number sn-focus-player-number 1)
(up-get-fact-max any-enemy current-score 0 enemy-low-score)
(up-get-fact-max this-any-enemy player-number 0 lowest-scoring-enemy)
)

(defrule
(goal 77 1)
(goal strategy-goal last-place-enemy)
(strategic-number sn-focus-player-number > 0)
(stance-toward focus-player enemy)
(player-in-game focus-player)
=>
(up-get-focus-fact current-score 0 focus-player-score)
)

(defrule
(goal 77 1)
(goal strategy-goal last-place-enemy)
(strategic-number sn-focus-player-number > 0)
(stance-toward focus-player enemy)
(player-in-game focus-player)
(up-compare-goal focus-player-score g:< enemy-low-score)
=>
(up-get-focus-fact current-score 0 enemy-low-score)
(up-get-focus-fact player-number 0 lowest-scoring-enemy)
)

(defrule
(goal 77 1)
(goal strategy-goal last-place-enemy)
(strategic-number sn-focus-player-number < 9)
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -3)
)

(defrule
(goal 77 1)
(goal strategy-goal last-place-enemy)
(up-compare-sn sn-target-player-number g:!= lowest-scoring-enemy)
;(up-compare-sn sn-target-player-number c:> 0)
=>
(up-modify-sn sn-target-player-number g:= lowest-scoring-enemy)
(up-chat-data-to-player every-ally "/6%d" s: sn-target-player-number)
;(enable-timer 8 180)
;(up-modify-sn sn-focus-player-number c:+ 1)
)

(defrule
(false)
(goal 77 1)
(goal strategy-goal last-place-enemy)
(strategic-number sn-focus-player-number == 9)
(strategic-number sn-target-player-number > 0)
=>
(up-modify-sn sn-target-player-number g:= lowest-scoring-enemy)
(up-chat-data-to-player every-ally "/6%d" s: sn-target-player-number)
(enable-timer 8 180)
(up-modify-sn sn-focus-player-number c:+ 1)
)

(defrule
(false)
(goal 77 1)
