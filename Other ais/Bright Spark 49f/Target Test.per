(defconst closest-enemy-goal 48)
(defconst strategy-goal 49)
(defconst closest-enemy 1)
(defconst last-place-enemy 2)
(defconst random-enemy 3)
(defconst weakest-enemy 4)
(defconst destroy-the-wonder 5)

(defconst leader-player-number 41)
(defconst weakest-player 42)
(defconst lowest-enemy-military 43)
(defconst focus-player-military 44)
(defconst focus-player-score 45)
(defconst enemy-low-score 46)
(defconst lowest-scoring-enemy 47)
(defconst player-with-wonder 52)

;//////// Decide Leader /////////////

(defrule
(true)
=>
(set-goal 77 1)
(set-strategic-number sn-target-player-number 0)
(disable-self)
)

(defrule
(false)
(goal military-mode assault)
=>
(set-goal 77 0)
(generate-random-number 100)
(disable-self)
)

(defrule
(goal 77 0)
(random-number != 7)
=>
(generate-random-number 100)
)

(defrule
(goal 77 0)
(random-number == 7)
=>
(set-goal 77 1)
(chat-to-allies "I'm the leader")
(chat-to-allies "/17")
)

(defrule
(goal 77 0)
(taunt-detected any-ally 17)
=>
(acknowledge-taunt this-any-ally 17)
(up-get-player-fact this-any-ally player-number 0 leader-player-number)
(up-chat-data-to-player every-ally "Long live the king! Player %d." g: leader-player-number)
(set-goal 77 -1)
)

