;/////// Target The Wonder ///////

(defrule
(not(goal strategy-goal destroy-the-wonder))
(players-building-type-count any-enemy wonder > 0)
=>
(set-goal strategy-goal destroy-the-wonder)
(chat-local-to-self "Changing targeting to Wonder")
)

(defrule
(goal strategy-goal destroy-the-wonder)
(players-building-type-count any-enemy wonder > 0)
(up-get-player-fact this-any-enemy player-number 0 player-with-wonder)
(up-compare-sn sn-target-player-number g:!= player-with-wonder)
=>
(up-modify-sn sn-target-player-number g:= player-with-wonder)
)

(defrule
(goal strategy-goal destroy-the-wonder)
(players-building-type-count target-player wonder == 0)
=>
(set-goal strategy-goal closest-enemy)
(chat-local-to-self "Reverting targeting")
)

