;//////// Player Commands ///////////

(defrule
(or(taunt-detected my-player-number 60)
(taunt-detected any-ally 60))
=>
(acknowledge-taunt my-player-number 60)
(acknowledge-taunt this-any-ally 60)
(up-chat-data-to-player every-ally "The target is player %d." s: sn-target-player-number)
(up-chat-data-to-player every-ally "The focus is player %d." s: sn-focus-player-number)
(up-chat-data-to-self "The target is player %d." s: sn-target-player-number)
(up-chat-data-to-self "The focus is player %d." s: sn-focus-player-number)
)

(defrule
(taunt-detected any-ally 18)
=>
(acknowledge-taunt this-any-ally 18)
(attack-now)
)

;/////// Attack Closest Enemy ////////

;Identify closest enemy

(defrule
(goal 77 1)
(goal strategy-goal closest-enemy)
(or(players-population every-enemy < 10)
(game-time < 1170))
=>
(up-jump-rule 7)
)

(defrule
(goal 77 1)
(goal strategy-goal closest-enemy)
(or(strategic-number sn-target-player-number <= 0)
(players-population target-player < 10))
=>
(up-find-player enemy find-closest closest-enemy-goal)
(up-modify-sn sn-target-player-number g:= closest-enemy-goal)
)

