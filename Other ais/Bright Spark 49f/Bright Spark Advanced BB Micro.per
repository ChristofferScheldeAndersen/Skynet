(up-find-remote c: trebuchet c: 40)
(up-find-remote c: 42 c: 40)
(up-remove-objects search-remote 20 == my-player-number)
(up-clean-search search-remote 46 1)
(up-set-target-object search-remote c: 0)
(up-get-object-data 0 gl-closest-enemy-id)
;(up-set-target-by-id g: gl-selected-unit-id)
(up-clean-search search-remote 10 1);44
(up-set-target-object search-remote c: 0)
(up-get-object-data 10 gl-data)
(up-remove-objects search-remote 10 g:> gl-data)
