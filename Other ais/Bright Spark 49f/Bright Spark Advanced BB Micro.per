=>
(up-get-point position-enemy gl-dot-x)
(up-remove-objects search-local 0 g:!= gl-selected-unit-id)
(up-target-point gl-dot-x action-move -1 3)
;(up-modify-goal gl-current-list-number c:+ 1)
;(chat-local-to-self "moving to protect home")
;(up-jump-rule -22)
)

(defrule
(up-modify-goal gl-script-pass-count == 2)
(up-compare-goal military-mode == shield)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-by-id g: gl-selected-unit-id)
;(up-object-data 55 g:< gl-reload-time)
(up-object-data 55 <= 0)
(up-compare-goal gl-remote-total < 1)
;(up-object-data 73 != 1)
=>
(up-get-point position-self gl-dot-x)
(up-remove-objects search-local 0 g:!= gl-selected-unit-id)
(up-target-point gl-flared-x action-move -1 1)
;(up-modify-goal gl-current-list-number c:+ 1)
;(chat-local-to-self "moving to protect home")
;(up-jump-rule -22)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
;(up-object-data 73 != 1)
;(up-object-data 55 < 1650)
=>
;(up-chat-data-to-self "Fault with Archer %d" g: gl-current-list-number)
(up-modify-goal gl-current-list-number c:+ 1)
;(chat-local-to-self "Something has gone wrong")
(up-jump-rule -27)
)