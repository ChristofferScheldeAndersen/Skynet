(defrule
(false)
=>
(up-modify-sn sn-target-player-number c:= 2)
(disable-self)
)

(defrule
(true)
=>
(up-modify-goal gl-script-pass-count c:+ 1)
)

(defrule
(true)
=>
(up-modify-goal gl-script-pass-count c:= 0)
(disable-self)
)

(defrule
(up-compare-goal gl-script-pass-count >= 3)
=>
(up-modify-goal gl-script-pass-count c:= 0)
)

(defrule
(true)
=>
;(chat-local-to-self "I am a micro test")
(up-modify-goal gl-timed-edit c:= 1)
(generate-random-number 12)
(up-get-fact 33 0 gl-dot-x)
(up-modify-goal gl-dot-x c:+ 66)
(up-set-timer c: t-direction-change g: gl-dot-x)
(disable-self)
)

(defrule
(timer-triggered t-direction-change)
=>
(up-modify-goal gl-timed-edit c:* -1)
;(up-chat-data-to-all "gl-timed-edit %d" g: gl-timed-edit)
(generate-random-number 12)
(up-get-fact 33 0 gl-dot-x)
(up-modify-goal gl-dot-x c:+ 66)
(up-set-timer c: t-direction-change g: gl-dot-x)
)

(defrule
(or(unit-type-count bombard-cannon-line < 1)
(up-compare-flag gl-anti-lag-flag c:== anti-lag-level4))
=>
(up-jump-rule 29)
)

(defrule
(true)
=>
(up-modify-goal gl-closest-enemy-id c:= -1)
(up-full-reset-search)
(up-find-local c: bombard-cannon-line c: 240)
(up-clean-search search-local 0 1)
(up-get-search-state gl-local-total)
)

(defrule
(true)
;(up-compare-goal gl-local-total > 0)
=>
(up-modify-goal gl-rule-loops g:= gl-local-total)
;(up-chat-data-to-self "archers found %d" g: gl-rule-loops)
(up-modify-goal gl-current-list-number c:= 0)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-full-reset-search)
(up-find-local c: bombard-cannon-line c: 240)
(up-clean-search search-local 0 1)
(up-get-search-state gl-local-total)
(up-modify-goal gl-temp-range c:= 12);1
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
=>
(up-modify-goal gl-closest-enemy-id c:= -1)
(up-get-object-data 0 gl-selected-unit-id)
;(up-remove-objects search-local -1 g:!= gl-current-list-number)
(up-get-point position-object gl-dot-x)
(up-set-target-point gl-dot-x)
(up-get-object-data 12 gl-object-max-range)
(up-modify-goal gl-object-max-range c:+ 2)
(up-get-object-data 62 gl-object-min-range)
(up-get-object-data 54 gl-reload-time)
(up-modify-goal gl-reload-time c:- 210)
(up-get-object-data 55 gl-next-attack)
(up-get-object-data 0 gl-direction)
(up-modify-goal gl-direction c:mod 2);5
(up-modify-goal gl-direction c:* 2)
(up-modify-goal gl-direction c:- 1);- 3
;(up-chat-data-to-self "next attack %d" g: gl-next-attack)
(up-filter-distance g: gl-object-min-range g: gl-temp-range);gl-object-max-range
;(up-filter-distance c: 0 c: 12)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(or(up-object-data 55 <= 0)
(up-modify-goal gl-script-pass-count == 2))
(up-object-data 73 == 1)
=>
(up-create-group 0 0 c: 1)
(up-modify-group-flag 0 c: 1)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
;(up-set-target-object search-local g: gl-current-list-number)
=>
(up-modify-sn sn-focus-player-number c:= 0)
;(up-find-remote c: 910 c: 40)
;(up-remove-objects search-remote 1 == 48)
;(up-remove-objects search-remote 1 == 1139)
