(up-set-target-by-id g: gl-selected-unit-id)
;(up-remove-objects search-remote -1 > 2)
;(up-clean-search search-remote 10 1)
(up-remove-objects search-remote -1 > 0)
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -2)
)

