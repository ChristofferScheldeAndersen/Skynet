#load-if-defined INCAN-CIV

(defrule
(up-players-in-game ally < 3)
(current-age == dark-age)
=>
(up-modify-goal gl-drush-score c:= 2000)
)

(defrule
(up-players-in-game ally < 3)
(or(current-age > dark-age)
(or(players-building-type-count any-enemy palisade-wall >= 30)
(players-building-type-count any-enemy watch-tower-line >= 4)))
=>
(up-modify-goal gl-drush-score c:= -2000)
(up-modify-goal gl-castle-military-score c:= 2000)
)

#end-if

