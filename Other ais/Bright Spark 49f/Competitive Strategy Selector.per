(defconst is-flank 0)
(defconst is-pocket 1)

#load-if-defined UP-POCKET-POSITION

(defconst my-position is-pocket)

#else

(defconst my-position is-flank)

#end-if

(defrule
(or(up-compare-const my-position == is-flank)
(up-players-in-game ally < 3))
=>
(up-modify-goal gl-feudal-rush-score c:= 1000)
)

(defrule
(up-compare-const my-position == is-pocket)
(up-players-in-game ally >= 3)
=>
(up-modify-goal gl-castle-military-score c:= 1000)
)

#load-if-defined ARMENIANS-CIV

