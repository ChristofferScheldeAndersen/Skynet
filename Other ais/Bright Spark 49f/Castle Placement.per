(up-modify-goal gl-tile-score c:= 0)
)

(defrule
(up-timer-status castle-build-timer != timer-running)
(building-type-count-total castle < 1)
(can-build castle)
(map-type arena)
(up-compare-goal gl-game-strategy == castle-drop)
(up-compare-goal gl-remote-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-remote g: gl-current-list-number)
=>
(up-modify-goal gl-piece-id c:= 0)
(up-get-point position-object gl-dot-x)
(up-modify-goal gl-dot-y c:+ 1)
(up-get-point position-object gl-temp-x)
(up-modify-goal gl-temp-y c:- 1)
(up-get-point position-custom gl-enemy-area-x);position-enemy
;(up-send-flare gl-enemy-area-x)
)

(defrule
(up-timer-status castle-build-timer != timer-running)
