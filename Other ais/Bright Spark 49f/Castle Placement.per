(defrule
(building-type-count-total castle < 1)
(up-timer-status castle-build-timer == timer-running)
=>
(chat-local-to-self "castle build timer running")
)

(defrule
(up-timer-status castle-build-timer != timer-running)
(building-type-count-total castle < 1)
(can-build castle)
(map-type arena)
(up-compare-goal gl-game-strategy == castle-drop)
=>
(chat-local-to-self "castle drop script running")
(up-full-reset-search)
(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
(up-set-target-point gl-self-x)
(up-find-remote c: gate-class c: 40)
(up-find-remote c: wall-class c: 40)
(up-clean-search search-remote 44 1)
(up-get-search-state gl-local-total)
)

(defrule
(up-timer-status castle-build-timer != timer-running)
(building-type-count-total castle < 1)
(can-build castle)
(map-type arena)
(up-compare-goal gl-game-strategy == castle-drop)
(up-compare-goal gl-remote-total > 0)
=>
(up-modify-goal gl-rule-loops g:= gl-remote-total)
(up-modify-goal gl-current-list-number c:= 0)
(up-modify-goal gl-tile-high-score c:= 0)
)

(defrule
(up-timer-status castle-build-timer != timer-running)
(building-type-count-total castle < 1)
