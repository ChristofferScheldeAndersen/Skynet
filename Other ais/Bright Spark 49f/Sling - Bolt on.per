(defrule
(up-compare-goal gl-game-strategy == slinger)
;(up-allied-goal any-ally gl-game-strategy == boom)
=>
(up-find-player ally find-closest gl-sling-target)
(up-modify-sn sn-focus-player-number g:= gl-sling-target)
)

(defrule
(up-compare-goal gl-game-strategy == slinger)
;(up-allied-goal any-ally gl-game-strategy == boom)
(or(players-building-type-count focus-player town-center > 0)
(players-unit-type-count focus-player villager > 0))
(or(and(up-allied-goal focus-player gl-game-strategy != boom)
(up-allied-goal focus-player gl-game-strategy != castle-drop))
(and(players-unit-type-count focus-player villager >= 120)
(players-current-age == focus-player imperial-age)))
=>
(up-find-player ally find-closest gl-sling-target)
(up-find-next-player ally find-closest gl-sling-target)
(up-modify-sn sn-focus-player-number g:= gl-sling-target)
)

