(defrule
(false); removing temp for 45
(up-compare-goal gl-game-strategy == flush)
(current-age == feudal-age)
(or(up-compare-goal 10 >= mc-v-high)
(game-time >= castle-age-up-time))
(up-compare-goal gl-position-line == flank)
(up-allied-goal any-ally gl-game-strategy == castle-military)
(or(up-allied-goal this-any-ally gl-starting-game-strategy == castle-military)
(up-allied-goal every-ally gl-starting-game-strategy == flush))
(up-players-in-game ally == 3)
=>
(chat-to-allies "I'm switching to sling the fast castler!")
(up-modify-goal gl-game-strategy c:= slinger)
(up-modify-goal halt-production c:= off)
)

(defrule
(false); removing temp for 45
(up-compare-goal gl-game-strategy == slinger)
(up-compare-goal gl-starting-game-strategy == flush)
(players-current-age any-ally >= castle-age)
(players-current-age-time this-any-ally > 180)
(or(up-allied-goal this-any-ally gl-starting-game-strategy == castle-military)
(up-allied-goal every-ally gl-starting-game-strategy == flush))
(up-players-in-game ally == 3)
=>
(chat-to-allies "I'm switching to castle age!")
(up-modify-goal gl-game-strategy c:= castle-military)
(up-modify-goal halt-production c:= on)
)

(defrule
(false); removing temp for 45
(up-compare-goal gl-game-strategy == flush)
(current-age == feudal-age)
(or(up-compare-goal 10 >= mc-v-high)
(game-time >= castle-age-up-time))
(up-compare-goal gl-position-line == flank)
(up-allied-goal any-ally gl-game-strategy == boom)
(players-current-age this-any-ally < imperial-age)
(up-players-in-game ally == 4)
=>
(chat-to-allies "I'm switching to sling the boomer!")
(up-modify-goal gl-game-strategy c:= slinger)
(up-modify-goal halt-production c:= off)
)

(defrule
(false); removing temp for 45
(up-compare-goal gl-starting-game-strategy == flush)
(up-compare-goal gl-game-strategy == slinger)
(current-age == feudal-age)
(up-compare-goal gl-position-line == flank)
(up-allied-goal any-ally gl-game-strategy == boom)
(players-current-age this-any-ally >= imperial-age)
(up-players-in-game ally == 4)
=>
(chat-to-allies "I'm switching back to aggression!")
(up-modify-goal gl-game-strategy c:= flush)
)

(defrule
(up-compare-goal gl-game-strategy == slinger)
(current-age == castle-age)
=>
(up-modify-goal gl-game-strategy c:= castle-military)
)

