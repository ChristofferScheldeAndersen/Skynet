(defrule
(up-compare-goal gl-game-strategy == slinger)
;(up-allied-goal focus-player gl-position-line == flank)
=>
(release-escrow food)
(release-escrow wood)
(release-escrow gold)
(release-escrow stone)
)

(defrule
(up-compare-goal gl-game-strategy == slinger)
(or(players-building-type-count focus-player town-center > 0)
(players-unit-type-count focus-player villager > 0))
;(up-allied-goal focus-player gl-position-line == flank)
;(players-current-age focus-player < castle-age)
(food-amount >= 200)
(up-allied-resource-amount focus-player food < 1000)
(building-type-count market >= 1)
(up-allied-goal focus-player gl-game-strategy != slinger)
=>
(tribute-to-player focus-player food 100)
;(up-jump-rule -1)
)

