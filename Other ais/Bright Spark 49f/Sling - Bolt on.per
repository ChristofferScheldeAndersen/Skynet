(defrule
(or(up-allied-goal focus-player gl-game-strategy == boom)
(up-allied-goal focus-player gl-game-strategy == castle-drop))
(or(players-building-type-count focus-player town-center > 0)
(players-unit-type-count focus-player villager > 0))
(not(players-unit-type-count focus-player villager >= 120))
(not(players-current-age focus-player == imperial-age))
=>
(up-jump-rule 7)
)

