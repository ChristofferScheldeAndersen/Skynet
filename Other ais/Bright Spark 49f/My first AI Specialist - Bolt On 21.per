#load-if-defined VICTORY-STANDARD

(defrule
(false)
(or(not(up-compare-goal ally-wonder-count > 0))
(up-players-in-game ally < 2))
(building-type-count-total wonder < 1)
(not(players-building-type-count any-ally wonder > 0))
(can-build wonder)
(or(up-compare-goal 10 >= mc-low);high
(or(up-compare-goal 19 > 35)
(population >= max-population-limit)))
=>
(up-set-placement-data my-player-number -1 c: -20)
(set-strategic-number sn-placement-zone-size 3)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 0)
(up-build 2 0 c: wonder)
(up-assign-builders c: wonder c: 40)
)

(defrule
(false)
;(or(not(up-compare-goal ally-wonder-count > 0))
;(up-players-in-game ally < 2))
;(building-type-count-total wonder < 1)
;(not(players-building-type-count any-ally wonder > 0))
;(not(can-build wonder))
;(can-build-with-escrow wonder)
;(or(up-compare-goal 10 >= mc-low);high
;(or(up-compare-goal 19 > 35)
;(population >= max-population-limit)))
=>
(up-reset-cost-data required-food)
(up-get-fact escrow-amount wood escrowed-wood)
(up-get-fact escrow-amount gold escrowed-gold)
(up-get-fact escrow-amount stone escrowed-stone)
(up-add-object-cost c: wonder c: 1)
(up-modify-goal escrowed-wood g:- required-wood)
(up-modify-goal escrowed-gold g:- required-gold)
(up-modify-goal escrowed-stone g:- required-stone)
(up-modify-escrow wood g:= escrowed-wood)
(up-modify-escrow gold g:= escrowed-gold)
(up-modify-escrow stone g:= escrowed-stone)
(up-set-placement-data my-player-number -1 c: -20)
(set-strategic-number sn-placement-zone-size 3)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 0)
(up-build 2 28 c: wonder)
(up-assign-builders c: wonder c: 40)
)

#end-if

