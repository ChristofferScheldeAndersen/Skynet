(up-compare-goal gl-game-strategy == castle-military)
(or(up-compare-goal 10 < mc-high)
(current-age-time < 300))
(current-age == castle-age)
=>
(up-jump-rule 4)
)

(defrule
(building-type-count-total town-center < 4)
(up-compare-goal gl-game-strategy == castle-military)
(food-amount >= 400)
(stone-amount >= 200)
(not(can-build town-center))
(wood-amount >= 175)
(not(can-buy-commodity wood))
(can-sell-commodity stone)
(current-age == castle-age)
=>
(sell-commodity stone)
;(up-jump-rule -1)
)

(defrule
(building-type-count-total town-center < 4)
(up-compare-goal gl-game-strategy == castle-military)
(food-amount >= 400)
(stone-amount >= 200)
(not(can-build town-center))
(wood-amount >= 175)
(not(can-buy-commodity wood))
(can-sell-commodity stone)
(current-age == castle-age)
=>
(sell-commodity stone)
;(up-jump-rule -1)
)

(defrule
(building-type-count-total town-center < 4)
(up-compare-goal gl-game-strategy == castle-military)
(food-amount >= 400)
(stone-amount >= 100)
(not(can-build town-center))
(wood-amount >= 175)
(can-buy-commodity wood)
(current-age == castle-age)
=>
(buy-commodity wood)
)

(defrule
(game-time > 600)
(building-type-count-total town-center < 4)
(up-compare-goal gl-game-strategy != boom)
(up-compare-goal gl-game-strategy != fast-imp)
(food-amount >= 200)
(can-build town-center)
=>
(set-strategic-number sn-town-center-placement mining-camp);removing for 45
(up-get-rule-id gl-last-rule-save);removing for 45
(up-jump-direct g: gl-last-rule-save-two);removing for 45
)

(defrule
;(goal 199 4)
(current-age == castle-age)
(up-compare-goal house-wall-count < 5)
(can-build siege-workshop)
;(building-type-count-total monastery >= 1)
(building-type-count-total siege-workshop < 1)
(up-point-explored gl-wall-x != 0)
=>
(up-build-line gl-wall-x gl-wall-x c: siege-workshop)
(up-lerp-tiles gl-wall-x gl-wall2-x c: 1)
)

(defrule
;(goal 199 4)
(current-age == castle-age)
(up-compare-goal house-wall-count < 5)
(not(can-build siege-workshop))
(can-build-with-escrow siege-workshop)
;(building-type-count-total monastery >= 1)
(building-type-count-total siege-workshop < 1)
(up-point-explored gl-wall-x != 0)
=>
(up-reset-cost-data required-food)
(up-get-fact escrow-amount food escrowed-food)
(up-get-fact escrow-amount wood escrowed-wood)
(up-get-fact escrow-amount gold escrowed-gold)
(up-get-fact escrow-amount stone escrowed-stone)
(up-add-object-cost c: siege-workshop c: 1)
(up-modify-goal escrowed-food g:- required-food)
(up-modify-goal escrowed-wood g:- required-wood)
(up-modify-goal escrowed-gold g:- required-gold)
(up-modify-goal escrowed-stone g:- required-stone)
(up-modify-escrow food g:= escrowed-food)
(up-modify-escrow wood g:= escrowed-wood)
(up-modify-escrow gold g:= escrowed-gold)
(up-modify-escrow stone g:= escrowed-stone)
(up-build-line gl-wall-x gl-wall-x c: siege-workshop)
(up-lerp-tiles gl-wall-x gl-wall2-x c: 1)
)

(defrule
;(goal 199 4)
(current-age == castle-age)
(up-compare-goal house-wall-count == 5)
(can-build siege-workshop)
(up-compare-goal gl-game-strategy == castle-military)
;(building-type-count-total monastery >= 1)
(building-type-count-total siege-workshop < 1)
=>
(up-set-placement-data my-player-number town-center c: 6)
(up-modify-sn sn-placement-zone-size c:= 2)
(up-modify-sn sn-placement-fail-delta c:= 1)
(up-build 2 0 c: siege-workshop)
)

