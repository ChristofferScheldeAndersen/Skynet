(defrule
(up-players-in-game ally > 1)
(building-type-count market > 0)
=>
(up-modify-sn sn-focus-player-number c:= 1)
)

(defrule
(up-players-in-game ally > 1)
(building-type-count market > 0)
(up-compare-sn sn-focus-player-number < 9)
(or(not(player-in-game focus-player))
(not(players-stance focus-player ally)))
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -1)
)

(defrule
(up-players-in-game ally > 1)
(up-compare-sn sn-focus-player-number < 9)
(player-in-game focus-player)
(players-stance focus-player ally)
(players-unit-type-count focus-player villager < 10)
(players-building-type-count focus-player town-center > 0)
(up-allied-resource-amount focus-player amount-food < 50)
(building-type-count market > 0)
(food-amount >= 1500);200
=>
(chat-local-to-self "sending food to help ally rebuild")
(tribute-to-player focus-player food 100)
)

(defrule
(up-players-in-game ally > 1)
(building-type-count market > 0)
(up-compare-sn sn-focus-player-number < 9)
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -3)
)

(defrule
(up-players-in-game ally > 1)
(building-type-count market > 0)
=>
(generate-random-number 8)
(up-get-fact 33 0 gl-random-number)
(up-modify-sn sn-focus-player-number g:= gl-random-number)
)

(defrule
(up-players-in-game ally > 1)
(building-type-count market > 0)
(up-compare-sn sn-focus-player-number < 9)
(or(not(player-in-game focus-player))
(or(up-compare-sn sn-focus-player-number == my-player-number)
(not(players-stance focus-player ally))))
=>
(up-modify-sn sn-focus-player-number c:+ 8)
(up-jump-rule -1)
)

(defrule
(up-players-in-game ally > 1)
