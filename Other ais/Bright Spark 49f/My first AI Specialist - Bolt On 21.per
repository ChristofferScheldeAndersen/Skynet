(defconst gl-wonder-y 491)

(defrule
(true)
=>
(set-goal research-farm-upgrades off)
(set-goal research-fortification-upgrades off)
(set-goal research-wood-upgrades off)
(set-goal research-gold-upgrades off)
(set-goal research-stone-upgrades off)
(set-goal research-dock-upgrades off)
(set-goal research-villager-upgrades off)
(set-goal research-town-centre-upgrades off)
(set-goal research-military-expansion-upgrades on)
(set-goal research-trade-upgrades off)
(set-goal research-military-upgrades on)
(set-goal 495 0)
(set-goal 496 0)
(set-goal 51 0)
(set-goal 330 0)
(set-goal 331 0)
(set-goal 316 0)
(set-goal 317 0)
(set-goal 318 0)
(set-goal 319 0)
(set-goal building-type-goal2 archery-range)
(disable-self)
)

(defrule
(up-compare-goal gl-game-strategy c:== flush)
=>
(set-goal research-wood-upgrades on)
(disable-self)
)

(defrule
(up-compare-goal gl-game-strategy c:!= flush)
(up-research-status c: castle-age >= research-pending)
=>
(set-goal research-wood-upgrades on)
(disable-self)
)

(defrule
(game-time > 30)
(or(goal chosen-military-unit -1)
(goal chosen-military-unit 0))
=>
(set-goal chosen-military-unit starting-unit)
)

(defrule
(game-time > 30)
(or(goal supporting-military-unit 0)
(goal supporting-military-unit -1))
=>
(up-modify-goal supporting-military-unit g:= chosen-military-unit)
(up-modify-goal building-type-goal2 g:= building-type-goal)
)

