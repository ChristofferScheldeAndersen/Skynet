;###### Unit Production ######

(defrule
(false); swapped for below v43
(goal halt-production off)
(current-age == feudal-age)
(or(research-available castle-age)
(building-type-count-total market < 1))
;(or(players-current-age any-enemy >= castle-age)
(or(up-compare-goal 10 >= mc-v-high)
(or(up-compare-goal gl-game-strategy != flush)
(game-time >= castle-age-up-time)))
