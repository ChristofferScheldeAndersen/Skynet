(current-age >= castle-age)
(can-build bombard-tower)
(up-compare-goal 10 < mc-v-high)
(building-type-count-total castle >= 1)
(up-compare-const spare-stone == towers)
=>
(up-set-placement-data my-player-number -1 c: 16)
(set-strategic-number sn-placement-zone-size 3)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 0)
(up-build 2 0 c: bombard-tower)
(up-assign-builders c: bombard-tower c: 4)
)

(defrule
(false)
(current-age >= castle-age)
(not(can-build bombard-tower))
(can-build thingy-tower-line)
(up-compare-goal 10 < mc-v-high)
(building-type-count-total castle >= 1)
(up-compare-const spare-stone == towers)
=>
(up-set-placement-data my-player-number -1 c: 16)
(set-strategic-number sn-placement-zone-size 3)
(set-strategic-number sn-placement-fail-delta 1)
(set-strategic-number sn-placement-to-center 0)
(up-build 2 0 c: thingy-tower-line)
(up-assign-builders c: thingy-tower c: 4)
)

