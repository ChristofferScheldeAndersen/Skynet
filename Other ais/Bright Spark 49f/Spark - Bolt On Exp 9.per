(defrule
(player-in-game focus-player)
(players-stance focus-player enemy)
(up-compare-goal sn-focus-player-number > 0)
(up-compare-goal sn-focus-player-number < 9)
=>
(up-full-reset-search)
(up-find-remote c: -1 c: 1)
(up-get-search-state gl-local-total)
)

(defrule
(player-in-game focus-player)
(players-stance focus-player enemy)
(up-compare-goal sn-focus-player-number > 0)
(up-compare-goal sn-focus-player-number < 9)
(up-compare-goal gl-remote-total > 0)
=>
(up-set-target-object search-remote c: 0)
)

(defrule
(player-in-game focus-player)
(players-stance focus-player enemy)
(up-compare-goal sn-focus-player-number > 0)
(up-compare-goal sn-focus-player-number < 9)
(up-compare-goal gl-remote-total > 0)
(up-object-data 64 == 1)
(up-compare-goal monk-votes > 0)
=>
(up-modify-goal monk-votes c:/ 2)
(up-modify-sn sn-focus-player-number c:= 9)
)

(defrule
(player-in-game focus-player)
(players-stance focus-player enemy)
(up-compare-goal sn-focus-player-number > 0)
(up-compare-goal sn-focus-player-number < 9)
(up-compare-goal gl-remote-total > 0)
(up-object-data 64 == 1)
(up-compare-goal monk-votes < 0)
=>
(up-modify-goal monk-votes c:* 2)
(up-modify-sn sn-focus-player-number c:= 9)
)

(defrule
(player-in-game focus-player)
(players-stance focus-player enemy)
(up-compare-goal sn-focus-player-number > 0)
(up-compare-goal sn-focus-player-number < 9)
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -5)
)

