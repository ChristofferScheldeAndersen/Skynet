;###### Define Constants ######

(defconst ml-danger -25)
(defconst ml-low -10)
(defconst ml-equal 0)
(defconst ml-high 4)
(defconst ml-v-high 15)
(defconst ml-dominant 50)

(defconst mc-danger -3)
(defconst mc-v-low -2)
(defconst mc-low -1)
(defconst mc-equal 0)
(defconst mc-high 1)
(defconst mc-v-high 2)
(defconst mc-dominant 3)

(defconst counter-mode 403)
(defconst anti-infantry 1)
(defconst anti-archery 2)
(defconst anti-cavalry 3)

(defconst anti-archer 2)

(defconst preferred 5)

(defconst towers 1)
(defconst forward-castles 2)
(defconst sell -1)

(defconst halt-production 404)
(defconst halt-unit-production 405)

(defconst retreat-timer 14)
(defconst retreat-mode 512)
(defconst need-siege 511)

(defconst feudal-food 45)
(defconst feudal-wood 35)
(defconst feudal-gold 20)
(defconst feudal-stone 0)

(defconst castle-food 35)
(defconst castle-wood 25)
(defconst castle-gold 35)
(defconst castle-stone 5)

(defconst imperial-food 35)
(defconst imperial-wood 25)
(defconst imperial-gold 35)
(defconst imperial-stone 5)

#load-if-not-defined VIKING-CIV

(defconst preferred-boat fire-ship-line)

#else

(defconst preferred-boat galley-line)

#end-if

(defconst castle-vote-offset 248)
(defconst imperial-vote-offset 249)

(defconst remain-weight-bonus 229)

(defconst remain-militiaman-weight 230)
(defconst remain-spearman-weight 231)
(defconst remain-archer-weight 232)
(defconst remain-skirmisher-weight 233)
(defconst remain-cavalry-archer-weight 234)
(defconst remain-scout-cavalry-weight 235)
(defconst remain-knight-weight 236)
(defconst remain-camel-weight 237)
(defconst remain-battle-elephant-weight 238)
(defconst remain-monk-weight 239)
(defconst remain-eagle-warrior-weight 240)
(defconst remain-hand-cannoneer-weight 241)
(defconst remain-scorpion-weight 242)
(defconst remain-genitour-weight 243)
(defconst remain-mangonel-weight 244)
(defconst remain-elephant-archer-weight 245)
(defconst remain-condottiero-weight 246)
(defconst remain-fire-lancer-weight 247)
(defconst remain-mounted-trebuchet-weight 541)
(defconst remain-my-special-unit-weight 567)

;(load "Bright Spark 49f\Spark - Constants 4")
;(load "MFA - Constants")

(defrule
(unit-type-count villager > 0)
=>
(set-goal 49 1);3 when multiplayer
;(chat-local-to-self "Yay! I'm working!")
;(chat-to-enemies "Bright Spark is operational.")
;(chat-to-allies "Bright Spark is operational")
(disable-self)
)

(defrule
(unit-type-count monk >= 100)
=>
(chat-to-enemies "Wololo motherflippers.")
(disable-self)
)

(defrule
(current-age >= castle-age)
(or(up-gaia-type-count c: gold < 4)
(wood-amount >= 1000))
(or(players-building-type-count any-ally market >= 1)
(and(map-type michi)
(up-players-in-game ally == 1)))
(building-type-count-total town-center >= 3)
(building-type-count-total market < 3)
(can-build market)
=>
(up-set-target-point gl-market-x)
(set-strategic-number sn-placement-zone-size 5)
(up-build 3 0 c: market)
)

(defrule
(false)
(players-building-type-count any-ally market > 0)
(unit-type-count trade-cart < 120)
(can-train trade-cart)
=>
(train trade-cart)
)

(defrule
(up-research-status c: castle-age < research-pending)
(or(up-compare-goal gl-game-strategy == flush)
(up-compare-goal gl-game-strategy == drush))
(not(goal castle-vote-offset 800))
=>
(set-goal castle-vote-offset 800)
)

(defrule
(or(up-research-status c: castle-age >= research-pending)
(and(up-compare-goal gl-game-strategy != flush)
(up-compare-goal gl-game-strategy != drush)))
(not(goal castle-vote-offset 0))
=>
(set-goal castle-vote-offset 0)
)

(defrule
;(up-research-status c: ri-chemistry != research-complete)
;(not(civ-selected bohemians))
(up-research-status c: imperial-age < research-pending)
(not(goal imperial-vote-offset 800))
=>
(set-goal imperial-vote-offset 800)
)

(defrule
;(up-research-status c: ri-chemistry == research-complete)
;(civ-selected bohemians))
(up-research-status c: imperial-age >= research-pending)
(not(goal imperial-vote-offset 0))
=>
(set-goal imperial-vote-offset 0)
)

(defrule
(up-compare-goal gl-game-strategy == fast-imp)
(civ-selected turkish)
(not(goal imperial-vote-offset 0))
=>
(set-goal imperial-vote-offset 0)
)

(defrule
(up-compare-goal gl-game-strategy == fast-imp)
(or(civ-selected italian)
(players-civ any-ally italian))
(not(goal imperial-vote-offset 0))
=>
(set-goal imperial-vote-offset 0)
)

(defrule
(true)
=>
(up-modify-goal remain-weight-bonus c:= 0)
)

(defrule
(current-age <= feudal-age)
=>
(up-modify-goal remain-weight-bonus c:+ 10)
)

(defrule
(current-age == castle-age)
=>
(up-modify-goal remain-weight-bonus c:+ 15)
)

(defrule
(current-age == imperial-age)
=>
(up-modify-goal remain-weight-bonus c:+ 20)
)

(defrule
(current-age >= castle-age)
=>
(up-get-fact 42 ally gl-dot-x)
(up-modify-goal gl-dot-x c:+ 1)
(up-modify-goal remain-weight-bonus g:* gl-dot-x)
(disable-self)
)

(defrule
(up-compare-goal 10 >= mc-v-high)
=>
(up-modify-goal remain-weight-bonus c:+ 50);100
)

(defrule
(up-compare-goal military-mode == assault)
=>
(up-modify-goal remain-weight-bonus c:+ 50);100
)

(defrule
(current-age == castle-age)
=>
(up-modify-goal remain-weight-bonus c:= 0)
(disable-self)
)

(defrule
(goal chosen-military-unit militiaman-line)
(up-compare-goal remain-militiaman-weight == 0)
=>
(up-modify-goal remain-militiaman-weight g:= remain-weight-bonus)
)

(defrule
(not(goal chosen-military-unit militiaman-line))
(up-compare-goal remain-militiaman-weight != 0)
=>
(up-modify-goal remain-militiaman-weight c:= 0)
)

