(defrule
(up-compare-goal deer-luring == 1)
=>
;(chat-local-to-self "Scout Found")
(up-full-reset-search)
(up-get-point position-self gl-self-x)
(up-set-target-point gl-self-x)
(set-strategic-number sn-focus-player-number 0)
(up-set-group search-local c: 0)
(up-filter-distance c: -1 c: deer-luring-distance)
(up-find-remote c: 909 c: 40)
(up-remove-objects search-remote 1 == 1955)
(up-remove-objects search-remote 1 == 1958)
(up-remove-objects search-remote 1 == 2084)
(up-remove-objects search-remote 1 == 2086)
(up-remove-objects search-remote 1 == 2088)
(up-remove-objects search-remote 1 == 2098)
(up-remove-objects search-remote 1 == 2099)
(up-remove-objects search-remote 1 == 2100)
(up-remove-objects search-remote 10 < 1)
;(up-remove-objects search-remote 13 < 30)
(up-clean-search search-remote 44 1)
(up-get-search-state gl-local-total)
)

(defrule
(goal deer-luring 1)
(up-compare-goal gl-local-total >= 1)
(up-compare-goal gl-remote-total >= 1)
(up-compare-sn sn-number-explore-groups != 0)
=>
(up-modify-sn sn-number-explore-groups c:= 0)
)

(defrule
(goal deer-luring 1)
(up-compare-goal gl-local-total >= 1)
(up-compare-goal gl-remote-total > 0)
=>
;(chat-local-to-self "deer found")
;(set-strategic-number sn-number-explore-groups 0)
(up-set-target-object search-remote c: 0)
;(up-get-point position-object gl-deer-x)
(up-get-object-data 38 gl-deer-x)
(up-get-object-data 39 gl-deer-y)
(up-modify-goal gl-dot-x c:* 100)
(up-modify-goal gl-dot-y c:* 100)
(up-get-point position-self gl-self-x)
)

(defrule
(false)
(goal deer-luring 1)
(up-compare-goal gl-local-total >= 1)
(up-compare-goal gl-remote-total > 0)
(up-compare-goal gl-dot-x g:>= gl-deer-x)
=>
(up-modify-goal gl-deer-x c:- 70)
)

(defrule
(false)
(goal deer-luring 1)
(up-compare-goal gl-local-total >= 1)
(up-compare-goal gl-remote-total > 0)
(up-compare-goal gl-dot-x g:< gl-deer-x)
=>
(up-modify-goal gl-deer-x c:+ 70)
)

(defrule
(false)
