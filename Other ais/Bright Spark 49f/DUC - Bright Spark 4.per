(defrule
(false)
(goal deer-luring 1)
(up-compare-goal gl-local-total >= 1)
(up-compare-goal gl-remote-total > 0)
(up-compare-goal gl-dot-y g:< gl-deer-y)
=>
(up-modify-goal gl-deer-y c:+ 70)
)

(defrule
(goal deer-luring 1)
(up-compare-goal gl-local-total >= 1)
(up-compare-goal gl-remote-total > 0)
=>
(up-lerp-tiles gl-deer-x gl-dot-x c: -70)
(up-bound-precise-point gl-deer-x 1 c: 0)
(up-modify-sn sn-target-point-adjustment c:= 6)
(up-target-point gl-deer-x action-move -1 -1)
