(defrule
(false)
=>
(up-full-reset-search)
(up-find-local c: scout-cavalry-line c: 1)
(up-get-search-state gl-state-1)
(disable-self)
)

(defrule
(goal deer-luring 0)
=>
(set-goal gl-deer-x -1)
(set-goal gl-deer-y -1)
)

(defrule
(unit-type-count villager-forager >= 6)
(building-type-count mill > 0)
=>
(up-full-reset-search)
(up-find-local c: mill c: 240)
(up-get-point position-self gl-self-x)
(up-set-target-point gl-self-x)
(up-clean-search search-local 44 1)
(up-set-target-object search-local c: 0)
(up-get-point position-object gl-dot-x)
)

(defrule
(or(unit-type-count villager-forager < 6)
(building-type-count mill == 0))
=>
(up-full-reset-search)
(up-get-point position-self gl-dot-x)
)

(defrule
(true)
=>
(up-full-reset-search)
(up-get-point position-self gl-home-x)
;(up-target-point gl-home-x action-move -1 -1)
(up-get-point position-self gl-self-x)
)

