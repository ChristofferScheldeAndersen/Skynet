(defrule
(goal military-mode raid)
=>
(up-full-reset-search)
(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
(up-find-remote c: town-center c: 1)
(up-find-remote c: farm c: 1)
(up-find-remote c: house c: 1)
(up-find-remote c: lumber-camp c: 1)
(up-find-remote c: mining-camp c: 1)
(up-find-remote c: mill c: 1)
(up-find-remote c: barracks c: 1)
(up-remove-objects search-remote 20 == my-player-number)
)

(defrule
(goal military-mode raid)
(up-set-target-object search-remote c: 0)
=>
(up-get-point position-object gl-raid-target-x)
)

(defrule
;(false)
(goal military-mode raid)
(or(up-compare-goal gl-raid-target-x < 10)
(up-point-explored gl-raid-target-x != 0))
(not(up-set-target-object search-remote c: 0))
=>
(up-get-point position-enemy gl-raid-target-x)
(generate-random-number double-pocket-base-search-variance);40
(up-get-fact 33 0 gl-dot-x)
(generate-random-number double-pocket-base-search-variance);40
(up-get-fact 33 0 gl-dot-y)
(up-modify-goal gl-dot-x c:- pocket-base-search-variance);20
(up-modify-goal gl-dot-y c:- pocket-base-search-variance);20
(up-modify-goal gl-raid-target-x g:+ gl-dot-x)
(up-modify-goal gl-raid-target-y g:+ gl-dot-y)
(up-bound-point gl-raid-target-x gl-raid-target-x)
;(up-send-flare gl-raid-target-x)
)

(defrule
(goal military-mode raid)
(not(up-set-target-object search-remote c: 0))
=>
(up-get-point position-center gl-center-x)
(up-copy-point gl-dot-x gl-center-x)
(up-lerp-tiles gl-dot-x gl-self-x g: gl-map-x)
(up-bound-point gl-dot-x gl-dot-x)
)

(defrule
(goal military-mode raid)
(not(up-set-target-object search-remote c: 0))
(up-point-explored gl-dot-x == 0)
=>
(up-full-reset-search)
(up-set-group search-local c: 0)
(up-target-point gl-dot-x action-move -1 stance-no-attack)
;(up-send-flare gl-dot-x)
)

(defrule
(goal military-mode raid)
(not(up-set-target-object search-remote c: 0))
(up-point-explored gl-dot-x != 0)
=>
(up-cross-tiles gl-dot-x gl-self-x c: 10)
(up-bound-point gl-dot-x gl-dot-x)
)

(defrule
(goal military-mode raid)
(not(up-set-target-object search-remote c: 0))
(up-point-explored gl-dot-x != 0)
=>
(up-cross-tiles gl-dot-x gl-self-x c: -20)
(up-bound-point gl-dot-x gl-dot-x)
(up-copy-point gl-raid-target-x gl-dot-x)
)

#end-if

