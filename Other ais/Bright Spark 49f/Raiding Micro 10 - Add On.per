(defconst gl-temp-id 82)

(defconst gl-raid-target-x 410)
(defconst gl-raid-target-y 411)

(defconst gl-danger-x 416)
(defconst gl-danger-y 417)

(defconst gl-current-raiders-x 414)
(defconst gl-current-raiders-y 415)

(defconst gl-unit-range 418)
(defconst gl-enemy-building-range 419)
(defconst gl-temp-x 420)
(defconst gl-temp-y 421)
(defconst gl-range-variable 422)

(defconst mini-raid-timer 42)
(defconst monk-timer 43)

(defrule
(goal military-mode raid)
(true)
=>
(up-modify-goal gl-danger-x c:= -255)
(up-modify-goal gl-danger-y c:= -255)
(disable-self)
)

(defrule
;(goal military-mode raid)
(true)
=>
(enable-timer mini-raid-timer 1)
(disable-self)
)

(defrule
(goal military-mode raid)
(true)
=>
(up-full-reset-search)
(up-find-local c: town-center c: 1)
(up-get-search-state gl-local-total)
)

(defrule
(goal military-mode raid)
(up-compare-goal gl-local-total < 1)
=>
(up-full-reset-search)
(up-find-local c: lumber-camp c: 1)
(up-get-search-state gl-local-total)
)

(defrule
(goal military-mode raid)
(up-compare-goal gl-local-total < 1)
=>
(up-full-reset-search)
(up-find-local c: villager-class c: 1)
(up-get-search-state gl-local-total)
)

(defrule
(goal military-mode raid)
(up-set-target-object search-local c: 0)
=>
(up-get-point position-object gl-self-x)
)

(defrule
(goal military-mode raid)
=>
(up-full-reset-search)
(up-modify-sn sn-focus-player-number s:= sn-target-player-number)
(up-find-remote c: town-center c: 1)
(up-get-search-state gl-local-total)
;(up-chat-data-to-self "target player %d" s: sn-target-player-number)
)

(defrule
(goal military-mode raid)
(up-compare-goal gl-remote-total < 1)
=>
(up-find-remote c: farm c: 1)
(up-find-remote c: house c: 1)
(up-find-remote c: lumber-camp c: 1)
(up-find-remote c: mining-camp c: 1)
(up-find-remote c: mill c: 1)
(up-find-remote c: barracks c: 1)
(up-remove-objects search-remote 20 == my-player-number)
)

(defrule
(false)
(goal military-mode raid)
(up-compare-goal gl-remote-total < 1)
(game-time > 1500)
=>
(up-find-remote c: -1 c: 1)
)

(defrule
(goal military-mode raid)
(up-set-target-object search-remote c: 0)
=>
(up-get-point position-object gl-raid-target-x)
(up-jump-rule 1)
)

(defrule
;(true)
(goal military-mode raid)
=>
(up-get-point position-flank gl-raid-target-x)
)

(defrule
(up-compare-goal gl-position-line c:== flank)
=>
(up-get-point position-flank gl-find-target-x)
(up-bound-point gl-find-target-x gl-find-target-x)
(disable-self)
)

(defrule
(up-compare-goal gl-position-line c:== flank)
(up-point-explored gl-find-target-x != 0)
=>
(up-get-point position-flank gl-find-target-x)
(up-modify-goal gl-find-target-x c:- base-search-variance);10
(up-modify-goal gl-find-target-y c:- base-search-variance);10
(generate-random-number double-base-search-variance);20
(up-get-fact 33 0 gl-dot-x)
(generate-random-number double-base-search-variance)
(up-get-fact 33 0 gl-dot-y)
(up-modify-goal gl-find-target-x g:+ gl-dot-x);10
(up-modify-goal gl-find-target-y g:+ gl-dot-y);10
(up-bound-point gl-find-target-x gl-find-target-x)
)

(defrule
(up-compare-goal gl-position-line c:== pocket)
(building-type-count town-center > 0)
=>
(up-get-point position-self gl-dot-x)
(up-get-point position-center gl-find-target-x)
(up-lerp-percent gl-find-target-x gl-dot-x c: -100)
(up-bound-point gl-find-target-x gl-find-target-x)
;(up-send-flare gl-find-target-x)
(disable-self)
)

(defrule
(up-compare-goal gl-position-line c:== pocket)
(up-point-explored gl-find-target-x != 0)
(building-type-count town-center > 0)
=>
(up-get-point position-self gl-dot-x)
(up-get-point position-center gl-find-target-x)
(up-lerp-percent gl-find-target-x gl-dot-x c: -100)
(up-modify-goal gl-find-target-x c:- base-search-variance)
(up-modify-goal gl-find-target-y c:- base-search-variance)
(generate-random-number double-base-search-variance)
(up-get-fact 33 0 gl-dot-x)
(generate-random-number double-base-search-variance)
(up-get-fact 33 0 gl-dot-y)
(up-modify-goal gl-find-target-x g:+ gl-dot-x)
(up-modify-goal gl-find-target-y g:+ gl-dot-y)
(up-bound-point gl-find-target-x gl-find-target-x)
;(up-send-flare gl-find-target-x)
)

(defrule
(up-compare-goal gl-position-line c:== pocket)
(building-type-count town-center < 1)
=>
(up-copy-point gl-dot-x gl-starting-home-x)
(up-get-point position-center gl-find-target-x)
(up-lerp-percent gl-find-target-x gl-dot-x c: -100)
(up-bound-point gl-find-target-x gl-find-target-x)
;(up-send-flare gl-find-target-x)
(disable-self)
)

(defrule
(up-compare-goal gl-position-line c:== pocket)
(up-point-explored gl-find-target-x != 0)
(building-type-count town-center < 1)
=>
(up-copy-point gl-dot-x gl-starting-home-x)
(up-get-point position-center gl-find-target-x)
(up-lerp-percent gl-find-target-x gl-dot-x c: -100)
(up-modify-goal gl-find-target-x c:- base-search-variance)
(up-modify-goal gl-find-target-y c:- base-search-variance)
(generate-random-number double-base-search-variance)
(up-get-fact 33 0 gl-dot-x)
(generate-random-number double-base-search-variance)
(up-get-fact 33 0 gl-dot-y)
(up-modify-goal gl-find-target-x g:+ gl-dot-x)
(up-modify-goal gl-find-target-y g:+ gl-dot-y)
(up-bound-point gl-find-target-x gl-find-target-x)
;(up-send-flare gl-find-target-x)
)

