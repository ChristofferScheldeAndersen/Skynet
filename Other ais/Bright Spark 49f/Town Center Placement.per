(defrule
;(false)
(true)
=>
(up-get-rule-id gl-last-rule-save-two)
;(up-chat-data-to-all "last-rule-save-two-id %d" g: gl-last-rule-save-two)
(up-reset-placement c: town-center)
(up-jump-rule 52);was off
)

(defrule
(true)
=>
(up-modify-goal gl-dot-x c:= 0)
)

(defrule
(or(building-type-count-total town-center >= 4)
(not(map-type arena)))
=>
(up-full-reset-search)
(up-modify-sn sn-focus-player-number c:= my-player-number)
(up-find-remote c: town-center c: 40)
(up-get-search-state gl-local-total)
(up-modify-goal gl-dot-x g:= gl-remote-total)
(up-modify-goal gl-dot-x c:* 15)
)

(defrule
(or(building-type-count-total town-center == 3)
(and(building-type-count-total town-center > 3)
(up-compare-sn sn-town-center-placement == lumber-camp)))
=>
(up-modify-goal gl-wanted-resource c:= wood)
)

(defrule
(or(building-type-count-total town-center == 1)
(and(up-compare-sn sn-town-center-placement == mining-camp)
(and(up-compare-sn sn-gold-gatherer-percentage s:>= sn-stone-gatherer-percentage)
(building-type-count-total town-center > 3))))
=>
(up-modify-goal gl-wanted-resource c:= gold)
)

(defrule
(or(building-type-count-total town-center == 2)
(and(up-compare-sn sn-town-center-placement == mining-camp)
(and(up-compare-sn sn-gold-gatherer-percentage s:< sn-stone-gatherer-percentage)
(building-type-count-total town-center > 3))))
=>
(up-modify-goal gl-wanted-resource c:= stone)
)

(defrule
(building-type-count-total town-center >= 1)
(can-build town-center)
;(up-compare-goal gl-tile-checker-x c:== -2000)
=>
(up-full-reset-search)
(up-modify-goal gl-tile-score c:= 0)
(up-modify-goal gl-tile-high-score c:= -1)
(up-get-point position-center gl-enemy-area-x)
(up-copy-point gl-tile-checker-x gl-self-x)
(up-lerp-percent gl-tile-checker-x gl-enemy-area-x g: gl-dot-x)
;(up-lerp-tiles gl-tile-checker-x gl-enemy-area-x s: sn-maximum-town-size)
(up-copy-point gl-tile-target-x gl-tile-checker-x)
;(up-modify-goal gl-tile-checker-x c:- 20);14
;(up-modify-goal gl-tile-checker-y c:- 20);14
;(up-modify-goal gl-tile-target-x c:+ 20);14
;(up-modify-goal gl-tile-target-y c:+ 20);14
(up-modify-goal gl-dot-x c:= 20);30
(up-modify-goal gl-dot-x s:min sn-maximum-town-size)
(up-modify-goal gl-tile-checker-x g:- gl-dot-x)
(up-modify-goal gl-tile-checker-y g:- gl-dot-x)
(up-modify-goal gl-tile-target-x g:+ gl-dot-x)
(up-modify-goal gl-tile-target-y g:+ gl-dot-x)
;(up-modify-goal gl-tile-checker-x s:- sn-maximum-town-size)
;(up-modify-goal gl-tile-checker-y s:- sn-maximum-town-size)
;(up-modify-goal gl-tile-target-x s:+ sn-maximum-town-size)
;(up-modify-goal gl-tile-target-y s:+ sn-maximum-town-size)
;(chat-local-to-self "tc rule 1")
;(up-send-flare gl-tile-checker-x)
;(up-send-flare gl-tile-target-x)
)

