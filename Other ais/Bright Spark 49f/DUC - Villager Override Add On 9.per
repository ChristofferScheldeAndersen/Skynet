(defrule
(true)
=>
(set-goal gl-need-lumber-camp 0)
(set-goal gl-need-gold-mining-camp 0)
(set-goal gl-need-stone-mining-camp 0)
(enable-timer res-loop-timer 5)
(disable-self)
)

(defrule
(true)
;(up-compare-goal gl-chosen-tree-id == -1)
=>
(up-full-reset-search)
(up-find-local c: town-center c: 200)
(up-find-local c: lumber-camp c: 200)
(up-find-local c: mule-cart c: 200)
(up-filter-status c: 0 c: 0)
(up-find-status-local c: town-center c: 200)
(up-find-status-local c: lumber-camp c: 200)
(up-find-local c: mule-cart c: 200)
(up-get-search-state gl-local-total)
)

(defrule
(true)
=>
(up-modify-goal gl-rule-loops g:= gl-local-total)
(up-modify-goal gl-current-list-number c:= 0)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-reset-search 0 0 1 1)
(up-modify-sn sn-focus-player-number c:= 1)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(stance-toward focus-player enemy)
=>
(up-reset-filters)
(up-set-target-object search-local g: gl-current-list-number)
(up-get-point position-object gl-dot-x)
(up-set-target-point gl-dot-x)
(up-filter-distance c: -1 c: 10)
(up-find-remote c: -1 c: 40)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-compare-sn sn-focus-player-number < 8)
=>
(up-modify-sn sn-focus-player-number c:+ 1)
(up-jump-rule -2)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-compare-sn sn-focus-player-number >= 8)
=>
(up-get-search-state gl-local-total)
)

(defrule
(up-compare-sn sn-focus-player-number >= 8)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-compare-goal gl-remote-total >= 2)
=>
(up-remove-objects search-local -1 == gl-current-list-number)
;(up-get-search-state gl-local-total)
(up-modify-goal gl-rule-loops c:- 1);changed from increase current list number to decrease rule loops
(up-jump-rule -5)
)

(defrule
(up-compare-sn sn-focus-player-number >= 8)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-compare-goal gl-remote-total < 2)
=>
(up-modify-goal gl-current-list-number c:+ 1)
(up-jump-rule -6)
)

(defrule
(up-compare-sn sn-focus-player-number >= 8)
(up-compare-goal gl-current-list-number g:>= gl-rule-loops)
=>
(up-get-search-state gl-local-total)
(up-reset-search 0 0 1 1)
(up-reset-filters)
(up-modify-sn sn-focus-player-number c:= 0)
)

(defrule
(up-compare-goal gl-local-total < 1)
(goal gl-need-lumber-camp 0)
=>
(set-goal gl-need-lumber-camp 1)
)

(defrule
(or(current-age >= castle-age)
(up-compare-const age-up-strategy == feudal-rush))
(unit-type-count villager-wood > 12)
(up-compare-goal gl-local-total < 3)
(goal gl-need-lumber-camp 0)
=>
(set-goal gl-need-lumber-camp 1)
)

(defrule
(or(current-age >= castle-age)
(up-compare-const age-up-strategy == feudal-rush))
(unit-type-count villager-wood > 24)
(up-compare-goal gl-local-total < 4)
(goal gl-need-lumber-camp 0)
=>
(set-goal gl-need-lumber-camp 1)
)

(defrule
(or(current-age >= castle-age)
(up-compare-const age-up-strategy == feudal-rush))
(unit-type-count villager-wood > 36)
(up-compare-goal gl-local-total < 5)
(goal gl-need-lumber-camp 0)
=>
(set-goal gl-need-lumber-camp 1)
)

(defrule
(timer-triggered res-loop-timer)
;(up-compare-goal gl-chosen-tree-id == -1)
(up-compare-goal gl-local-total > 0)
=>
;(chat-to-all "res-loop")
(up-modify-goal gl-wood-drop-off-count g:= gl-local-total)
(up-modify-goal gl-rule-loops g:= gl-wood-drop-off-count)
(up-modify-goal gl-current-list-number c:= 0)
(up-modify-goal gl-shortest-tree-distance c:= 10000)
)

(defrule
(false)
(up-compare-goal gl-chosen-tree-id == -1)
(up-compare-goal gl-local-total > 0)
=>
(up-chat-data-to-self "Wood drop off count %d" g: gl-wood-drop-off-count)
(up-chat-data-to-self "Shortest tree distance %d" g: gl-shortest-tree-distance)
)

(defrule
(timer-triggered res-loop-timer)
;(up-compare-goal gl-chosen-tree-id == -1)
(up-compare-goal gl-local-total > 0)
(up-set-target-object search-local g: gl-current-list-number)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
;(chat-local-to-self "Current wood drop off found")
(up-reset-filters);new
(up-get-point position-object gl-current-wood-scan-point-x)
(up-set-target-point gl-current-wood-scan-point-x)
;(up-send-flare gl-current-wood-scan-point-x)
(up-modify-sn sn-focus-player-number c:= 0)
(up-filter-distance c: 1 c: 20)
(up-filter-status c: 3 c: 0)
(up-find-resource c: wood c: 10);20
(up-remove-objects search-remote 16 < 1)
(up-remove-objects search-remote 32 >= 3)
(up-clean-search search-remote 44 1)
(up-remove-objects search-remote -1 > 0)
(up-find-resource c: wood c: 10);20
(up-reset-filters)
(up-set-target-point gl-current-wood-scan-point-x)
(up-filter-distance c: 1 c: 20)
(up-filter-status c: 2 c: 0)
(up-find-resource c: wood c: 500)
(up-remove-objects search-remote 16 < 1)
(up-remove-objects search-remote 32 >= 3)
(up-clean-search search-remote 44 1)
(up-remove-objects search-remote -1 > 0)
(up-find-resource c: wood c: 500)
(up-remove-objects search-remote 16 < 1)
(up-remove-objects search-remote 32 >= 3)
(up-clean-search search-remote 44 1)
(up-get-search-state gl-local-total)
)

(defrule
(timer-triggered res-loop-timer)
;(up-compare-goal gl-chosen-tree-id == -1)
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-remote-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
;(up-chat-data-to-self "Trees found %d" g: gl-remote-total)
;(chat-local-to-self "Closest tree found")
(up-set-target-object search-remote c: 0)
)

(defrule
(timer-triggered res-loop-timer)
;(up-compare-goal gl-chosen-tree-id == -1)
(up-compare-goal gl-local-total > 0)
(up-compare-goal gl-remote-total > 0)
(up-object-data 44 g:< gl-shortest-tree-distance)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
;(chat-local-to-self "Shorter tree found")
(up-get-object-data 44 gl-shortest-tree-distance)
(up-get-object-data 0 gl-chosen-tree-id)
;(up-chat-data-to-self "Shortest tree distance %d" g: gl-shortest-tree-distance)
)

(defrule
(timer-triggered res-loop-timer)
;(up-compare-goal gl-chosen-tree-id == -1)
(up-compare-goal gl-local-total > 0)
;(up-compare-goal gl-remote-total > 0)
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
;(chat-local-to-self "Looping rule")
(up-modify-goal gl-current-list-number c:+ 1)
(up-reset-search 0 0 1 1)
(up-jump-rule -4)
)

(defrule
(timer-triggered res-loop-timer)
(up-compare-goal gl-chosen-tree-id != -1)
(up-compare-goal gl-current-list-number g:>= gl-rule-loops)
(up-set-target-by-id g: gl-chosen-tree-id)
=>
;(chat-local-to-self "Preparing flare")
(up-get-point position-object gl-chosen-tree-location-x)
)

(defrule
(timer-triggered res-loop-timer)
;(false)
(up-compare-goal gl-chosen-tree-id != -1)
=>
(up-set-target-by-id g: gl-chosen-tree-id)
(up-get-point position-object gl-chosen-tree-location-x)
;(up-send-flare gl-chosen-tree-location-x)
;(up-chat-data-to-all "wood dist %d" s: sn-maximum-wood-drop-distance)
)

(defrule
(false);we always want a tree to go to
(up-object-data 0 g:== gl-chosen-tree-id)
(or(up-object-data 32 >= 4)
(up-object-data 16 < 1))
;)
=>
;(chat-local-to-self "Sending flare")
;(up-send-flare gl-chosen-tree-location-x)
(up-modify-goal gl-chosen-tree-id c:= -1)
)

(defrule
(timer-triggered res-loop-timer)
(up-compare-goal gl-shortest-tree-distance >= 5)
(goal gl-need-lumber-camp 0)
=>
(set-goal gl-need-lumber-camp 1)
)

(defrule
(false)
(up-compare-goal gl-chosen-tree-id == -1)
=>
(up-full-reset-search)
(up-find-local c: town-center c: 200)
