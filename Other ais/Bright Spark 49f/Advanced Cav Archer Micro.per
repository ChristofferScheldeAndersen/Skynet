(up-compare-flag gl-anti-lag-flag c:== anti-lag-level4);)
=>
(up-jump-rule 33)
)

(defrule
(true)
=>
(up-modify-goal gl-closest-enemy-id c:= -1)
(up-full-reset-search)
(up-find-local c: mameluke-line c: 240)
(up-remove-objects search-local 73 == 7)
(up-remove-objects search-local 82 == elite-mameluke)
(up-get-search-state gl-local-total)
)

(defrule
(up-compare-goal gl-local-total > 0)
=>
(up-modify-goal gl-rule-loops g:= gl-local-total)
;(up-chat-data-to-self "archers found %d" g: gl-rule-loops)
(up-modify-goal gl-current-list-number c:= 0)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-full-reset-search)
(up-find-local c: mameluke-line c: 240)
(up-remove-objects search-local 73 == 7)
(up-remove-objects search-local 82 == elite-mameluke)
(up-get-search-state gl-local-total)
(up-modify-goal gl-temp-range c:= 1);1
)

(defrule ;new segment starts here
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
(up-set-target-object search-local g: gl-current-list-number)
=>
(up-modify-goal gl-closest-enemy-id c:= -1)
(up-get-object-data 0 gl-selected-unit-id)
(up-get-point position-object gl-dot-x)
(up-set-target-point gl-dot-x)
(up-get-object-data 54 gl-reload-time)
(up-modify-goal gl-reload-time c:- 400)
(up-get-object-data 55 gl-next-attack)
(up-get-object-data 13 gl-unit-speed)
(up-modify-goal gl-unit-speed c:+ 10)
(up-modify-goal gl-close-slower-units c:= -1)
(up-get-object-data 0 gl-direction)
(up-modify-goal gl-direction c:mod 2);5
(up-modify-goal gl-direction c:* 2)
(up-modify-goal gl-direction c:- 1);- 3
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
=>
(up-modify-sn sn-focus-player-number c:= 0)
(up-filter-distance c: 0 c: 4)
(up-find-remote c: 910 c: 40)
(up-remove-objects search-remote 1 == 48)
(up-remove-objects search-remote 1 == 1139)
(up-remove-objects search-remote 1 == 822)
(up-remove-objects search-remote 1 == 1301)
(up-clean-search search-remote 44 1)
(up-remove-objects search-remote -1 > 0)
(up-modify-sn sn-focus-player-number c:+ 1)
)

(defrule
(up-compare-goal gl-current-list-number g:< gl-rule-loops)
