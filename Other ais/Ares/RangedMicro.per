
;Much of the ranged micro is based largely off Fireball's rangedmicro snippet (although mostly unrecognizable now)

(defconst TCRetreatDistance 9) ;closer than this distance group will retreat from TCs
(defconst TCRetreatResetDistance 13) ;distance at which group will stop retreat from TCs

(defconst CastleRetreatDistance 11) ;closer than this distance group will retreat from Castles
(defconst CastleRetreatResetDistance 15) ;distance at which group will stop retreat from Castles

(defconst TowerRetreatDistance 8) ;closer than this distance group will retreat from Towers 
(defconst TowerRetreatResetDistance 12)  ;distance at which group will stop retreat from Towers



