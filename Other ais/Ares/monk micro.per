;Monk micro
(defconst g-convert-list-1 211)
;keep this space empty for the list
(defconst g-convert-list-final 241)


(defrule
	(timer-triggered t-29-sec)
=>
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(up-filter-exclude -1 actionid-convert 731 siege-weapon-class)
	(up-find-local c: monastery-class c: 80)
	(up-remove-objects search-local object-data-action == actionid-heal)	
	(set-strategic-number sn-focus-player-number my-player-number)
	(up-get-search-state lt)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-find-remote c: -1 c: 100)
	(up-set-target-point p-safety-x)
	(up-clean-search search-local object-data-full-distance search-order-asc)
	(up-clean-search search-remote object-data-full-distance search-order-asc)
	(up-clean-search search-remote object-data-maxhp search-order-desc)
	(up-clean-search search-remote object-data-hitpoints search-order-asc)
	(up-remove-objects search-remote object-data-index g:>= lt)
	(up-target-objects 0 action-default -1 -1)
)

