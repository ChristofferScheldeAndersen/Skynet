;real monk micro begins here
;goals
;g-math-1: monk index
;g-math-2: monk id
;g-math-3: target id
;g-math-4: acts as a check goal for monks converting units too far

(defrule
	(true)
=>
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(set-goal g-math-1 0)
	(set-goal check-goal 0)
	(up-get-rule-id g-jump-direct-1)
	(up-modify-goal g-jump-direct-1 c:+ 1)
	(up-filter-exclude -1 -1 731 -1)
	(up-find-local c: monastery-class c: 80)
	(up-remove-objects search-local object-data-carry != 100)
	(up-clean-search search-local -1 search-order-asc)
	(up-reset-group c: monk-ready-group)
	(up-create-group 0 0 c: monk-ready-group)
)

(defrule
	(unit-type-count monastery-class > 0)
	(research-completed ri-atonement)
	(up-set-target-object search-local g: g-math-1)
=>
	(set-strategic-number sn-focus-player-number 1)
	(set-goal g-list-counter g-convert-list-1)
	(up-get-indirect-goal g: g-list-counter g-list-manager)
	(up-get-object-data object-data-id g-math-2)
	(up-get-object-data object-data-range g-monk-range)
	(up-get-object-data object-data-precise-x p-x-3)
	(up-get-object-data object-data-precise-y p-y-3)
	(up-get-object-data object-data-precise-move-x p-x-2)
	(up-get-object-data object-data-precise-move-y p-y-2)
	(up-get-point position-object p-x-1)
	(up-set-target-point p-x-1)
	(up-filter-distance c: -1 g: g-monk-range)
	(up-modify-goal g-monk-range c:* 100)
	(set-goal check-goal 1))

(defrule
	(goal check-goal 1)
	(research-completed ri-atonement)
	(up-set-target-object search-local g: g-math-1)
	(up-object-data object-data-target != building-class)
	(up-object-data object-data-target != villager-class)
	(up-object-data object-data-order == orderid-convert)
	(up-point-distance p-x-2 p-x-3 g:<= g-monk-range)
=>
	(up-modify-goal g-math-1 c:+ 1)
	(set-goal check-goal 0)
	(up-jump-rule -2)
)


(defrule
	(goal check-goal 1)
	(research-completed ri-atonement)
	(stance-toward focus-player enemy)
=>
	(up-find-remote c: monastery-class c: 50)
	(up-find-remote c: monk-with-relic-class c: 5)
)

(defrule
	(goal check-goal 1)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2))

;remove targetted units
(defrule
	(goal check-goal 1)
	(up-compare-goal g-list-manager != -1)
	(up-compare-goal g-list-counter < g-convert-list-final)
=>
	(up-get-indirect-goal g: g-list-counter g-list-manager)
	(up-remove-objects search-remote object-data-id g:== g-list-manager)
	(up-modify-goal g-list-counter c:+ 1)
	(up-jump-rule -1)
)

(defrule
	(goal check-goal 1)
=>
	(up-clean-search search-remote object-data-hitpoints search-order-desc)
	(up-clean-search search-remote object-data-carry search-order-desc)
)

(defrule
	(goal check-goal 1)
	(up-set-target-object search-remote c: 0)
=>
	(up-get-object-data object-data-id g-math-3)
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
;	(chat-to-player my-player-number "Convert monk")
	(up-add-object-by-id search-local g: g-math-2)
	(up-add-object-by-id search-remote g: g-math-3)
	(up-target-objects 0 action-default -1 -1)
	(set-goal g-list-counter g-convert-list-1)
	(up-get-indirect-goal g: g-list-counter g-list-manager)
	(set-goal check-goal 2)
)

(defrule
	(goal check-goal 2)
	(up-compare-goal g-list-manager != -1)
	(up-compare-goal g-list-counter < g-convert-list-final)
=>
	(up-modify-goal g-list-counter c:+ 1)
	(up-get-indirect-goal g: g-list-counter g-list-manager)
	(up-jump-rule -1)
)

(defrule
	(goal check-goal 2)
	(goal g-list-manager -1)
	(up-compare-goal g-list-counter >= g-convert-list-1)
	(up-compare-goal g-list-counter <= g-convert-list-final)
=>
	(up-set-indirect-goal g: g-list-counter g: g-math-3)
)

(defrule
	(goal check-goal 2)
=>
	(set-goal check-goal 0)
	(up-modify-goal g-math-1 c:+ 1)
	(up-full-reset-search)
	(up-set-group search-local c: monk-ready-group)
	(up-jump-direct g: g-jump-direct-1)
)




;----------------------------------CONVERT MILITARY

(defrule
	(up-compare-goal check-goal != 2)
	(unit-type-count monastery-class > 0)
	(up-set-target-object search-local g: g-math-1)
=>
	(set-strategic-number sn-focus-player-number 1)
	(set-goal g-list-counter g-convert-list-1)
	(up-get-indirect-goal g: g-list-counter g-list-manager)
	(up-get-object-data object-data-id g-math-2)
	(up-get-object-data object-data-range g-monk-range)
	(up-get-object-data object-data-precise-x p-x-3)
	(up-get-object-data object-data-precise-y p-y-3)
	(up-get-object-data object-data-precise-move-x p-x-2)
	(up-get-object-data object-data-precise-move-y p-y-2)
	(up-get-point position-object p-x-1)
	(up-set-target-point p-x-1)
	(up-filter-distance c: -1 g: g-monk-range)
	(up-filter-include cmdid-military -1 -1 -1)
	(up-modify-goal g-monk-range c:* 100)
	(set-goal check-goal 4))

(defrule
	(goal check-goal 4)
	(up-set-target-object search-local g: g-math-1)
	(up-object-data object-data-target != building-class)
	(up-object-data object-data-target != villager-class)
	(up-object-data object-data-order == orderid-convert)
	(up-point-distance p-x-2 p-x-3 g:<= g-monk-range)
=>
	(up-modify-goal g-math-1 c:+ 1)
	(set-goal check-goal 0)
	(up-jump-rule -2)
)


(defrule
	(goal check-goal 4)
	(stance-toward focus-player enemy)
=>
	(up-find-remote c: -1 c: 80)
)
(defrule
	(goal check-goal 4)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2))

;remove targetted units
(defrule
	(goal check-goal 4)
	(up-compare-goal g-list-manager != -1)
	(up-compare-goal g-list-counter < g-convert-list-final)
=>
	(up-get-indirect-goal g: g-list-counter g-list-manager)
	(up-remove-objects search-remote object-data-id g:== g-list-manager)
	(up-modify-goal g-list-counter c:+ 1)
	(up-jump-rule -1)
)
(defrule
	(goal check-goal 4)
	(up-research-status c: ri-redemption != research-complete)
=>
	(up-remove-objects search-remote object-data-class == scorpion-class)
	(up-remove-objects search-remote object-data-class == siege-weapon-class))
(defrule
	(goal check-goal 4)
=>
	(up-remove-objects search-remote object-data-type == battering-ram)
	(up-remove-objects search-remote object-data-class == tower-class)
	(up-remove-objects search-remote object-data-class == wall-class)
	(up-remove-objects search-remote object-data-class == gate-class)
	(up-remove-objects search-remote object-data-class == building-class)
	(up-remove-objects search-remote object-data-class == farm-class)
	(up-clean-search search-remote object-data-full-distance search-order-asc)
	(up-clean-search search-remote object-data-hitpoints search-order-desc)
)

(defrule
	(goal check-goal 4)
	(up-set-target-object search-remote c: 0)
=>
	(up-get-object-data object-data-id g-math-3)
;	(up-reset-search 1 1 1 1)
;	(up-reset-filters)
	(up-remove-objects search-local object-data-id g:!= g-math-2)
;	(chat-to-player my-player-number "Convert military")
;	(up-add-object-by-id search-local g: g-math-2)
;	(up-add-object-by-id search-remote g: g-math-3)
	(up-target-objects 1 action-default -1 -1)
	(set-goal g-list-counter g-convert-list-1)
	(up-get-indirect-goal g: g-list-counter g-list-manager)
	(set-goal check-goal 2)
)

