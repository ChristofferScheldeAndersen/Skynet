	(set-goal g-escrow ri-heavy-plow))


(defrule
	(research-available ri-wheel-barrow)
	(goal g-escrow no)
	(or	(unit-type-count-total villager >= 56)
		(and	(up-compare-goal g-rush-aggression <= rush-low)
			(building-type-count-total town-center > 1)))
	(unit-type-count-total villager >= 34)
=>
	(set-goal g-escrow ri-wheel-barrow))

(defrule
	(research-available ri-wheel-barrow)
	(goal g-escrow no)
	(up-compare-goal g-rush-aggression <= rush-medium)
	(building-type-count-total town-center > 1)
	(unit-type-count-total villager >= 34)
=>
	(set-goal g-enable-escrow-vills with-escrow)
	(set-goal g-escrow ri-wheel-barrow))

(defrule
	(research-available ri-wheel-barrow)
	(up-compare-goal g-town-under-attack != yes)
	(strategic-number sn-military-superiority >= -5)
	(up-compare-goal g-research-status >= rush-done)
	(or	(goal g-rushing-age feudal-age)
		(building-type-count-total town-center > 1))
	(goal g-escrow no)
	(unit-type-count-total villager >= 34)
=>
	(set-goal g-enable-escrow-vills with-escrow)
	(set-goal g-escrow ri-wheel-barrow))

(defrule
	(up-compare-goal g-research-status >= rush-done)
	(or	(up-compare-goal g-town-under-attack != yes)
	(or	(gold-amount >= 200)
		(strategic-number sn-military-superiority >= 6)))
	(or	(strategic-number sn-military-superiority >= -12)
		(goal g-town-under-attack no))
	(research-available castle-age)
	(goal g-escrow no)
	(civilian-population >= 34)
	(military-population >= 11)
=>
	(set-goal g-enable-escrow-vills with-escrow)
	(set-goal g-escrow castle-age))


(defrule
	(research-available ri-hand-cart)
