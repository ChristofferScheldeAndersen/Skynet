	(goal g-archer-rush yes)
	(unit-type-count villager > 40)
	(research-available my-second-unique-research)
=>
	(set-goal g-escrow my-second-unique-research))
#end-if

#load-if-defined DRAVIDIANS-CIV
(defrule
	(goal g-escrow no)
	(building-type-count castle > 0)
	(research-available my-unique-research)
	(or	(goal g-infantry-rush yes)
		(goal g-cavalry-rush yes))
	(unit-type-count villager > 60)
=>
	(set-goal g-escrow my-unique-research)
)
(defrule
	(goal g-escrow no)
	(building-type-count castle > 0)
	(or	(unit-type-count elephant-archer-line > 2);commented out for genitours
		(unit-type-count armored-elephant-line > 5))
	(unit-type-count villager > 40)
	(research-available my-second-unique-research)
=>
	(set-goal g-escrow my-second-unique-research))
#end-if


#load-if-defined INCAN-CIV
(defrule
	(goal g-escrow no)
	(building-type-count castle > 0)
	(research-available my-unique-research)
	(unit-type-count villager >= 60)
=>
	(set-goal g-escrow my-unique-research)
)
(defrule
	(goal g-escrow no)
	(building-type-count castle > 0)
	(unit-type-count villager >= 40)
	(research-available my-second-unique-research)
=>
	(set-goal g-escrow my-second-unique-research))
#end-if

(defrule
	(goal g-escrow no)
	(research-available imperial-age)
	(up-compare-goal g-research-status >= castle-done)
	(or	(nand	(goal g-position flank)
			(goal g-town-under-attack yes))
		(and	(escrow-amount food >= 700)
			(escrow-amount gold >= 500)))
	(civilian-population >= 110)
	(military-population >= 31)
	(strategic-number sn-military-superiority >= -5)
=>
	(set-goal g-enable-escrow-vills with-escrow)
	(set-goal g-escrow imperial-age))



(defrule
	(goal g-escrow no)
	(civilian-population >= 40)
	(stone-amount >= 100)
	(building-type-count monastery > 0)
	(building-type-count-total town-center g:< g-number-town-centers)
	(strategic-number sn-military-superiority > -4)
	(military-population >= 10)
=>
	(set-goal g-escrow town-center)
)

(defrule
	(building-type-count-total town-center == 0)
=>
	(set-goal g-escrow town-center)
)
	

(defrule
	(up-compare-goal g-escrow != no)
	(up-compare-goal g-escrow != town-center)
=>
	(up-setup-cost-data 1 g-food-escrow)
	(up-add-research-cost g: g-escrow c: 1) 
	(up-modify-escrow food g:= g-food-escrow)
	(up-modify-escrow wood g:= g-wood-escrow)
	(up-modify-escrow gold g:= g-gold-escrow)
	(up-modify-escrow stone g:= g-stone-escrow)
	(set-goal g-math-1 with-escrow)
)
(defrule
	(goal g-escrow town-center)
=>
	(up-setup-cost-data 1 g-food-escrow)
	(up-add-object-cost g: g-escrow c: 1) 
	(up-modify-escrow food g:= g-food-escrow)
	(up-modify-escrow wood g:= g-wood-escrow)
	(up-modify-escrow gold g:= g-gold-escrow)
	(up-modify-escrow stone g:= g-stone-escrow)
	(set-goal g-math-1 with-escrow)
)

(defrule
	(up-compare-goal g-escrow != no)
	(up-can-research g-math-1 g: g-escrow)
=>
	(up-research g-math-1 g: g-escrow))
(defrule
	(goal g-escrow no)
=>
	(release-escrow food)
	(release-escrow wood)
	(release-escrow gold)
	(release-escrow stone)
)