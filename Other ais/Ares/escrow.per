(defrule
	(goal g-escrow no)
	(research-available ri-bow-saw)
	(or	(nand	(goal g-position flank)
			(goal g-town-under-attack yes))
		(escrow-amount food >= 125))
	(building-type-count-total town-center > 1)
	(civilian-population >= 34)
=>
	(set-goal g-enable-escrow-vills with-escrow)
	(set-goal g-escrow ri-bow-saw))


(defrule
	(goal g-escrow no)
	(research-available ri-heavy-plow)
	(or	(nand	(goal g-position flank)
			(goal g-town-under-attack yes))
		(escrow-amount food >= 125))
	(building-type-count-total town-center > 1)
	(civilian-population >= 34)
=>
	(set-goal g-enable-escrow-vills with-escrow)
