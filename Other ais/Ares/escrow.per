


;Escrow rules here

(defrule
	(true)
=>
	(set-goal g-build no)
	(set-goal g-escrow no)
	(up-reset-cost-data g-food-escrow)
	(set-goal g-enable-escrow-vills without-escrow)
	(set-goal g-food-escrow 0)
	(set-goal g-wood-escrow 0)
	(set-goal g-gold-escrow 0)
	(set-goal g-stone-escrow 0)
	(set-escrow-percentage food 0)
	(set-escrow-percentage wood 0)
	(set-escrow-percentage gold 0)
	(set-escrow-percentage stone 0))

;Heresy because monks

(defrule
	(goal g-escrow no)
	(research-available ri-heresy)
	(building-type-count-total town-center > 0)
	(strategic-number sn-monks > 9)
	(civilian-population >= 20)
=>
	(set-goal g-escrow ri-heresy))



;eco escrow

(defrule
	(goal g-escrow no)
	(up-compare-goal g-research-status >= rush-done)
	(unit-type-count-total villager >= 20)
	(research-available ri-double-bit-axe)
=>
	(set-goal g-escrow ri-double-bit-axe)
	(set-goal g-enable-escrow-vills with-escrow))

(defrule
	(goal g-escrow no)
	(strategic-number sn-military-superiority > 0)
	(up-research-status g: g-rushing-age >= research-pending)
	(building-type-count-total farm > 0)
	(building-type-count-total blacksmith > 0)
	(building-type-count-total town-center > 0)
	(up-research-status c: ri-double-bit-axe >= research-pending)
	(research-available ri-horse-collar)
=>
	(set-goal g-escrow ri-horse-collar)
	(set-goal g-enable-escrow-vills with-escrow))

(defrule
	(goal g-escrow no)
	(building-type-count-total farm > 14)
	(current-age >= castle-age)
	(research-available ri-horse-collar)
	(research-completed ri-double-bit-axe)
	(strategic-number sn-military-superiority >= -6)
	(building-type-count-total town-center > 1)
	(military-population > 15)
=>
	(set-goal g-enable-escrow-vills with-escrow)
	(set-goal g-escrow ri-horse-collar))

#load-if-not-defined BERBERS-CIV
(defrule
	(goal g-escrow no)
	(research-available ri-elite-skirmisher)
	(building-type-count town-center > 0)
	(or	(building-type-count-total town-center g:>= g-number-town-centers)
		(and	(unit-type-count skirmisher > 3)
			(strategic-number sn-military-superiority < -3)))
	(strategic-number sn-ranged > 4)
	(nand	(unit-available genitour-line)
		(unit-type-count skirmisher-line < 7))
=>
	(set-goal g-escrow ri-elite-skirmisher))
#load-if-not-defined HUN-CIV


(defrule
	(goal g-archer-rush yes)
	(goal g-rushing-unit archer)
	(building-type-count archery-range > 0)
	(research-available ri-crossbow)
	(civilian-population > 30)
	(up-research-status g: g-rushing-age >= research-pending)
	(or	(unit-type-count archer > 1)
		(current-age-time > 40))
	(goal g-escrow no)
=>
	(set-goal g-escrow ri-crossbow)
)

#end-if
#end-if

#load-if-defined BERBERS-CIV
(defrule
	(goal g-escrow no)
	(civilian-population > 63)
	(goal g-archer-rush yes)
	(unit-type-count-total my-unique-unit-line >= 3)
	(up-compare-goal g-research-status >= imperial-done)
	(unit-type-count villager g:>= g-dark-vills-2)
	(research-available my-unique-unit-upgrade)
	(building-type-count castle > 0)
=>
	(set-goal g-escrow my-unique-unit-upgrade)
)
#end-if

