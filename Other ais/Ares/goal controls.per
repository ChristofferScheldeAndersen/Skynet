
#load-if-defined AZTEC-CIV
(defrule
	(true)
=>
	(up-modify-flag f-enable-infantry c:+ fv-uu)
	(up-modify-flag f-enable-infantry c:+ fv-eagles)
	(up-modify-flag f-enable-infantry c:+ fv-spears)
	(up-modify-flag f-enable-archers c:+ fv-archers)
	(up-modify-flag f-enable-archers c:+ fv-skirms)
	(up-modify-flag f-enable-archers c:+ fv-genitour)
	(up-modify-flag f-enable-monks c:+ fv-monks)
	(up-modify-flag f-enable-siege c:+ fv-rams)
	(up-modify-flag f-enable-siege c:+ fv-mangonels)
	(set-goal g-dark-vills 23)
	(set-goal g-dark-vills-2 21)
	(set-goal g-rushing-unit eagle-warrior)
	(set-goal g-rush-aggression rush-high)
	(set-goal g-number-barracks 1)
	(set-goal g-number-ranges 1)
	(set-goal g-number-stables 0)
	(set-goal g-number-monasteries 0)
	(set-goal g-number-siege-workshops 0)
	(set-goal g-number-town-centers 1)
	(set-goal g-archer-rush no)
	(set-goal g-infantry-rush yes)
	(set-goal g-cavalry-rush no)
	(set-goal g-monk-rush no)
	(set-goal g-siege-rush no)
	(disable-self)
)

;likely to go archers or skirmishers
;(defrule
;	(goal g-rushing-unit militiaman)
;	(or	(players-civ target-player mayan)
;	(or	(players-civ target-player vietnamese)
;	(or	(players-civ target-player italian)
;	(or	(players-civ target-player ethiopian)
;	(or	(players-civ target-player portuguese)
;	(or	(players-civ target-player korean)
;		(players-civ target-player byzantine)))))))
;		
;=>
;	(set-goal g-number-barracks 2)
;	(set-goal g-rushing-unit eagle-warrior)
;	(disable-self)
;)

(defrule
	(goal g-enemy-flusher yes)
	(not	(goal g-rushing-unit archer))
	(players-military-population target-player > 1)
	(players-current-age target-player == dark-age)
=>
;	(set-goal g-number-ranges 2)
;	(set-goal g-number-barracks 1)
	(set-goal g-rushing-unit archer)
	(set-goal g-archer-rush yes)
;	(set-goal g-infantry-rush no)
)

(defrule
	(current-age == feudal-age)
	(goal g-rushing-age feudal-age)
	(goal g-rushing-unit militiaman)
	(strategic-number sn-archers s:>= sn-spears)
	(players-military-population target-player > 8)
	(or	(strategic-number sn-ranged > 5)
	(or	(players-unit-type-count any-enemy monk > 1)
		(gold-amount >= 245)))
=>
	(set-goal g-number-barracks 1)
	(set-goal g-archer-rush yes)
	(set-goal g-rushing-unit eagle-warrior)
)
(defrule
	(current-age == feudal-age)
	(building-type-count archery-range > 0)
	(goal g-archer-rush no)
=>
;	(set-goal g-infantry-rush no)
;	(set-goal g-rushing-unit -1)
	(set-goal g-archer-rush yes)
)
(defrule
	(goal g-rushing-unit -1)
	(up-research-status c: imperial-age < research-pending)
	(up-research-status c: castle-age >= research-pending)
	(strategic-number sn-infantry < 9)
=>
	(set-goal g-number-barracks 3)
	(set-goal g-infantry-rush yes)
	(set-goal g-rushing-unit eagle-warrior)
)
(defrule
	(unit-type-count eagle-warrior-line > 11)
	(goal g-initial-attack -1)
=>
	(set-goal g-initial-attack eagle-warrior)
	(disable-self)
)

(defrule
	(goal g-initial-attack eagle-warrior)
	(unit-type-count eagle-warrior-line <= 11)
=>
	(set-goal g-initial-attack -1)
	(disable-self)
)
(defrule
	(goal g-monk-rush no)
	(up-research-status c: imperial-age >= research-pending)
	(strategic-number sn-heavy-cavalry > 7)
=>
	(set-goal g-number-monasteries 3)
	(set-goal g-monk-rush yes)
	(set-goal g-rushing-unit -1)
)
(defrule
	(goal g-rushing-unit eagle-warrior)
	(strategic-number sn-infantry > 10)
=>
	(set-goal g-monk-rush yes)
	(set-goal g-archer-rush yes)
	(set-goal g-rushing-unit -1)
)
(defrule
	(current-age == feudal-age)
	(or	(strategic-number sn-cavalry > 5)
		(strategic-number sn-eagles > 6))
	(goal g-infantry-rush no)
=>
	(set-goal g-infantry-rush yes))
	
;---------------------------------Research status
(defrule
	(up-research-status g: g-rushing-age >= research-pending)
	(goal g-rushing-age feudal-age)
	(research-completed ri-double-bit-axe)
=>
	(set-goal g-research-status rush-done)
	(disable-self)
)
(defrule
	(up-research-status g: g-rushing-age >= research-pending)
	(goal g-rushing-age castle-age)
	(research-completed ri-double-bit-axe)
	(research-completed ri-bow-saw)
=>
	(set-goal g-research-status rush-done)
	(disable-self)
)
(defrule
	(up-research-status c: castle-age >= research-pending)
	(or	(research-completed ri-bodkin-arrow)
		(goal g-archer-rush no))
	(or	(research-completed ri-chain-mail)
		(goal g-infantry-rush no))
	(or	(research-completed ri-sanctity)
		(goal g-monk-rush no))
	(research-completed ri-double-bit-axe)
	(research-completed ri-bow-saw)
=>
	(set-goal g-research-status castle-done)
	(disable-self)
)
(defrule
	(goal g-research-status castle-done)
	(up-research-status c: imperial-age >= research-pending)
	(or	(research-completed ri-bracer)
		(goal g-archer-rush no))
	(or	(research-completed ri-plate-mail)
		(goal g-infantry-rush no))
	(or	(research-completed ri-illumination)
		(goal g-monk-rush no))
	(research-completed ri-double-bit-axe)
	(research-completed ri-bow-saw)
=>
	(set-goal g-research-status imperial-done)
	(disable-self)
)
(defrule
	(research-completed my-unique-research)
	(research-completed ri-elite-eagle-warrior)
	(goal g-research-status imperial-done)
	(up-research-status c: imperial-age >= research-pending)
	(or	(research-completed ri-bracer)
		(goal g-archer-rush no))
	(or	(research-completed ri-plate-mail)
		(goal g-infantry-rush no))
	(or	(research-completed ri-illumination)
		(goal g-monk-rush no))
	(research-completed ri-double-bit-axe)
	(research-completed ri-bow-saw)
=>
	(set-goal g-research-status research-complete)
	(disable-self)
)
;reset desired buildings in castle age
(defrule
	(current-age >= feudal-age)
=>
	(set-goal g-number-town-centers 1)
	(set-goal g-number-barracks 1)
	(set-goal g-number-ranges 1)
	(set-goal g-number-stables 0)
	(set-goal g-number-monasteries 0)
	(set-goal g-number-siege-workshops 0)
	(disable-self)
)
(defrule
	(current-age >= castle-age)
=>
	(set-goal g-number-town-centers 4)
	(set-goal g-number-barracks 1)
	(set-goal g-number-ranges 1)
	(set-goal g-number-stables 0)
	(set-goal g-number-monasteries 2)
	(set-goal g-number-siege-workshops 1)
	(up-modify-goal g-number-town-centers g:- g-rush-aggression)
	(disable-self)
)
#end-if


#load-if-defined BERBERS-CIV
(defrule
	(true)
=>
	(set-goal g-dark-vills 23)
	(set-goal g-dark-vills-2 21)
	(set-goal g-rushing-unit skirmisher)
	(set-goal g-rush-aggression rush-medium)
	(set-goal g-number-barracks 1)
	(set-goal g-number-ranges 1)
	(set-goal g-number-stables 0)
	(set-goal g-number-monasteries 0)
	(set-goal g-number-siege-workshops 0)
	(set-goal g-number-town-centers 1)
	(set-goal g-archer-rush yes)
	(set-goal g-infantry-rush no)
	(set-goal g-cavalry-rush no)
	(set-goal g-monk-rush no)
	(set-goal g-siege-rush no)
	(disable-self)
)

(defrule
	(current-age == feudal-age)
	(goal g-number-stables 0)
	(goal g-rushing-age feudal-age)
	(goal g-rushing-unit militiaman)
	(strategic-number sn-archers s:>= sn-skirms)
	(strategic-number sn-archers s:>= sn-spears)
	(players-military-population target-player > 13)
	(or	(players-unit-type-count any-enemy archer-line > 2)
	(or	(players-unit-type-count any-enemy monk > 1)
		(gold-amount >= 245)))
=>
	(set-goal g-number-barracks 1)
	(set-goal g-archer-rush yes)
	(set-goal g-rushing-unit -1)
)
(defrule
	(current-age == feudal-age)
	(building-type-count archery-range > 0)
	(goal g-archer-rush no)
=>
	(set-goal g-number-stables 1)
	(set-goal g-archer-rush yes)
)

(defrule
	(current-age == feudal-age)
	(building-type-count stable > 0)
	(goal g-number-ranges 0)
=>
	(set-goal g-infantry-rush no)
	(set-goal g-cavalry-rush yes)
	(set-goal g-number-ranges yes)
)

(defrule
	(current-age == feudal-age)
	(or	(building-type-count stable > 0)
		(strategic-number sn-skirms > 9))
	(goal g-cavalry-rush no)
=>
	(set-goal g-cavalry-rush yes)
)

(defrule
	(current-age == feudal-age)
	(goal g-rushing-age feudal-age)
	(goal g-infantry-rush yes)
	(strategic-number sn-archers > 4)
	(strategic-number sn-cavalry < 8)
	(building-type-count archery-range > 0)
=>
	(set-goal g-number-barracks 1)
	(set-goal g-infantry-rush no)
	(set-goal g-archer-rush yes)
	(set-goal g-rushing-unit -1)
)

(defrule
	(goal g-cavalry-rush no)
	(up-research-status c: castle-age >= research-pending)
=>
	(set-goal g-number-stables 1)
	(set-goal g-number-barracks 1)
	(set-goal g-cavalry-rush yes)
	(set-goal g-rushing-unit knight)
)

(defrule
	(or	(and	(goal g-rushing-unit scout-cavalry)
			(strategic-number sn-spears > 4))
		(and	(goal g-rushing-unit militiaman)
			(building-type-count stable > 0)))
=>
	(set-goal g-rushing-unit -1)
)
(defrule
	(unit-type-count knight-line > 11)
	(goal g-initial-attack -1)
=>
	(set-goal g-initial-attack knight)
	(disable-self)
)

(defrule
	(goal g-initial-attack knight-line)
	(unit-type-count knight-line <= 11)
=>
	(set-goal g-initial-attack -1)
	(disable-self)
)
(defrule
	(goal g-rushing-unit knight)
	(or	(players-unit-type-count any-enemy spearman-line > 5)
	(or	(players-unit-type-count any-enemy monk > 3)
		(players-unit-type-count any-enemy camel-line > 2)))
=>
	(set-goal g-archer-rush yes)
	(set-goal g-rushing-unit -1)
)
(defrule
	(or	(research-completed ri-heavy-camel)
		(strategic-number sn-cavalry < 3))
	(or	(current-age >= castle-age)
		(and	(strategic-number sn-cavalry < 3)
		(and	(strategic-number sn-spears < 3)
			(strategic-number sn-eagles < 4))))
	(not	(goal g-rushing-unit militiaman))
	(goal g-infantry-rush yes)
=>
	(set-goal g-number-barracks 1)
	(set-goal g-infantry-rush no))
(defrule
	(up-research-status c: castle-age < research-pending)
	(or	(strategic-number sn-cavalry > 5)
		(strategic-number sn-eagles > 6))
	(goal g-infantry-rush no)
=>
	(set-goal g-infantry-rush yes))
	
;---------------------------------Research status
(defrule
	(up-research-status g: g-rushing-age >= research-pending)
	(goal g-rushing-age feudal-age)
	(research-completed ri-double-bit-axe)
=>
	(set-goal g-research-status rush-done)
	(disable-self)
)
(defrule
	(up-research-status g: g-rushing-age >= research-pending)
	(goal g-rushing-age castle-age)
