;=========================================================
; End
;=========================================================
;Reasoning

;spears are separate from infantry because they are specialised anit-cavalry that is weak to everything else
;thus spears don't fit infantry evaluations
;eagle warriors and huskarls have different matchups from classical infantry and require separate evaluation
;camels have cavalry armor class, so they can fit cavalry evaluations but sn-camels is separate from sn-cavalry
;cataphracts have a positive matchup against traditional anti-cavalry, they don't fit cavalry evaluations
;gunpowder and cavalry archers are still weak to skirmishers so they fit archer evaluation
;gunpowder can be considered separate due to a vastly different matchup against anti-archer infantry
;however as of now gunpowder is counted as archers
;skirmishers are the usual anti archer unit, so counting skirmishers as archers means training skirmishers to counter skirmishers
;thus skirmishers are ommitted from archer evaluation, but kept within ranged evaluation

(defrule
	(strategic-number sn-target-player-number > 0); (strategic-number sn-focus-player-number > 0)
=>
	(up-modify-sn sn-heavy-cavalry s:= sn-cavalry)
	(up-modify-sn sn-heavy-cavalry s:- sn-light-cavalry)
	(up-modify-sn sn-ranged s:+ sn-gunpowder)
	(up-modify-sn sn-ranged s:+ sn-cavalry-archers)
	(up-modify-sn sn-ranged s:+ sn-archers)
	(up-modify-sn sn-ranged s:+ sn-skirms)
	(up-modify-sn sn-monksiege s:+ sn-monks)
	(up-modify-sn sn-monksiege s:+ sn-siege)
	(up-modify-sn sn-soldiers s:+ sn-ranged)
	(up-modify-sn sn-soldiers s:+ sn-monksiege)
	(up-modify-sn sn-soldiers s:+ sn-cavalry)
	(up-modify-sn sn-soldiers s:+ sn-infantry)
	(up-modify-sn sn-soldiers s:+ sn-cataphracts)
	(up-modify-sn sn-soldiers s:+ sn-spears)
	(up-modify-sn sn-soldiers s:+ sn-eagles)
	(up-modify-sn sn-soldiers s:+ sn-husks)
	(up-modify-sn sn-soldiers s:+ sn-camels)

	(up-modify-sn sn-ranged-percentage s:= sn-ranged)
	(up-modify-sn sn-ranged-percentage c:* 100)
	(up-modify-sn sn-ranged-percentage s:/ sn-soldiers)

	(up-modify-sn sn-cavalry-percentage s:= sn-cavalry)
	(up-modify-sn sn-cavalry-percentage s:+ sn-camels)
	(up-modify-sn sn-cavalry-percentage c:* 100)
	(up-modify-sn sn-cavalry-percentage s:/ sn-soldiers)

	(up-modify-sn sn-infantry-percentage s:= sn-infantry)
	(up-modify-sn sn-infantry-percentage s:+ sn-eagles)
	(up-modify-sn sn-infantry-percentage c:* 100)
	(up-modify-sn sn-infantry-percentage s:/ sn-soldiers)

	(up-modify-sn sn-monk-percentage s:= sn-monks)
	(up-modify-sn sn-monk-percentage c:* 100)
	(up-modify-sn sn-monk-percentage s:/ sn-soldiers)

)
;=========================================================
; End 2
;=========================================================
