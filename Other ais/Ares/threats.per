	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count knight-line temporary-goal)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count centurion-line temporary-goal)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count iron-pagoda-line temporary-goal)
	(up-modify-sn sn-cavalry g:+ temporary-goal))
(defrule
	(strategic-number sn-target-player-number > 0); (strategic-number sn-focus-player-number > 0)
=>
	(up-get-target-fact unit-type-count scout-cavalry-line temporary-goal)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count war-elephant-line temporary-goal)
	(up-modify-goal temporary-goal c:* 3)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count cataphract-line temporary-goal)
	(up-modify-sn sn-cataphracts g:+ temporary-goal)
	(up-get-target-fact unit-type-count battle-elephant-line temporary-goal)
	(up-modify-goal temporary-goal c:* 2)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count shrivamsha-rider-line temporary-goal)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count armored-elephant-line temporary-goal)
	(up-modify-goal temporary-goal c:%* 70)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
