(defrule
	(strategic-number sn-husks < 3)
	(strategic-number sn-eagles < 3)
	(strategic-number sn-infantry < 3)
	(strategic-number sn-spears < 3)
	(strategic-number sn-cavalry < 3)
	(strategic-number sn-archers < 3)
	(strategic-number sn-gunpowder < 3)
	(strategic-number sn-cavalry-archers < 3)
	(strategic-number sn-skirms < 3)
