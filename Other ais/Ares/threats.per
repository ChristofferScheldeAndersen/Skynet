;I coped my threat counting from promiskuitiv
;many thanks for allowing me to do so
(defrule
	(true)
=>
;	(up-chat-data-to-self "jumpgoal: %d" g: jump-rule-goal)
	(set-strategic-number sn-soldiers 0)
	(set-strategic-number sn-camels 0)
	(set-strategic-number sn-cavalry 0)
	(set-strategic-number sn-infantry 0)
	(set-strategic-number sn-spears 0)
	(set-strategic-number sn-husks 0)
	(set-strategic-number sn-eagles 0)
	(set-strategic-number sn-archers 0)
	(set-strategic-number sn-cavalry-archers 0)
	(set-strategic-number sn-skirms 0)
	(set-strategic-number sn-ranged 0)
	(set-strategic-number sn-gunpowder 0)
	(set-strategic-number sn-siege 0)
	(set-strategic-number sn-monks 0)
	(set-strategic-number sn-monksiege 0)
	(set-strategic-number sn-light-cavalry 0)
	(set-strategic-number sn-cataphracts 0)
	(set-strategic-number sn-heavy-cavalry 0)
	(set-strategic-number sn-scorpions 0)
)

;=========================================================
; Cavalry
;=========================================================
(defrule
	(strategic-number sn-target-player-number > 0); (strategic-number sn-focus-player-number > 0)
=>
	(up-get-target-fact unit-type-count magyar-huszar-line temporary-goal)
	(up-modify-sn sn-light-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count scout-cavalry-line temporary-goal)
	(up-modify-sn sn-light-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count steppe-lancer-line temporary-goal)
	(up-modify-sn sn-light-cavalry g:+ temporary-goal)
