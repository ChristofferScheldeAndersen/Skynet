	(up-get-target-fact unit-type-count mameluke-line temporary-goal)
	(up-modify-sn sn-camels g:+ temporary-goal)
	(up-get-target-fact unit-type-count boyar-line temporary-goal)
	(up-modify-sn sn-cavalry g:+ temporary-goal)
	(up-get-target-fact unit-type-count magyar-huszar-line temporary-goal)
