;
;--------------------------BLACKSMITH-------------------------------------------------

(defrule
	(unit-type-count trade-cart > 3)
	(players-building-type-count any-ally market > 0)
	(can-research ri-caravan)
=>
	(research ri-caravan)
)
(defrule
	(unit-type-count fishing-ship > 6)
	(up-research-status g: g-rushing-age >= research-pending)
=>
	(research ri-fishing-lines)
	(research ri-gillnets)
	(research ri-clinker-construction)
)
(defrule
	(up-research-status g: g-rushing-age >= research-pending)
	(can-research ri-double-bit-axe)
=>
	(research ri-double-bit-axe)
)
(defrule
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-double-bit-axe != research-available)
	(building-type-count-total farm > 0)
	(can-research ri-horse-collar)
=>
	(research ri-horse-collar)
)

(defrule
	(unit-type-count villager >= 33)
	(up-research-status c: ri-double-bit-axe != research-available)
=>
	(research ri-crop-rotation)
	(research ri-heavy-plow)
)

(defrule
	(unit-type-count villager >= 33)
	(up-research-status c: ri-horse-collar != research-available)
=>
	(research ri-two-man-saw)
	(research ri-bow-saw)
)

(defrule
	(unit-type-count villager >= 25)
	(strategic-number sn-gold-gatherer-percentage > 0)
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-double-bit-axe != research-available)
	(up-research-status c: ri-horse-collar != research-available)
	(can-research ri-gold-mining)
=>
	(research ri-gold-mining)
)

(defrule
	(unit-type-count villager >= 38)
	(strategic-number sn-gold-gatherer-percentage > 0)
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-double-bit-axe != research-available)
	(up-research-status c: ri-two-man-saw != research-available)
	(up-research-status c: ri-horse-collar != research-available)
	(up-research-status c: ri-heavy-plow != research-available)
	(can-research ri-gold-shaft-mining)
=>
	(research ri-gold-shaft-mining)
)

(defrule
	(unit-type-count villager >= 40)
	(strategic-number sn-stone-gatherer-percentage > 0)
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-double-bit-axe != research-available)
	(up-research-status c: ri-two-man-saw != research-available)
	(up-research-status c: ri-horse-collar != research-available)
	(up-research-status c: ri-heavy-plow != research-available)
	(can-research ri-stone-shaft-mining)
=>
	(research ri-stone-shaft-mining)
)

(defrule
	(unit-type-count villager >= 27)
	(strategic-number sn-stone-gatherer-percentage > 0)
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-gold-mining != research-available)
	(up-research-status c: ri-double-bit-axe != research-available)
	(up-research-status c: ri-horse-collar != research-available)
	(can-research ri-stone-mining)
=>
