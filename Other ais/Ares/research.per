)


(defrule
	(unit-type-count trade-cart > 4)
	(can-research ri-caravan)
=>
	(research ri-caravan)
)

(defrule
	(unit-type-count villager >= 30)
	(can-research ri-guilds)
	(current-age-time > 100)
=>
	(research ri-guilds)
)

(defrule
	(player-in-game any-ally)
	(up-compare-goal g-research-status >= imperial-done)
=>
	(research ri-coinage)
	(research ri-banking)
)

(defrule
	(unit-type-count villager >= 34)
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-double-bit-axe != research-available)
	(up-research-status c: ri-horse-collar != research-available)
