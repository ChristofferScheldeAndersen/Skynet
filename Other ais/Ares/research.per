;------------------------------------------------------MILITARY TECHS---------------------------------------
;barracks
(defrule
	(goal g-infantry-rush yes)
	(strategic-number sn-cavalry > 3)
	(up-research-status g: g-rushing-age >= research-pending)
	(unit-type-count villager g:>= g-dark-vills-2)
=>
	(research ri-pikeman)
	(research ri-halberdier)
)

(defrule
	(goal g-infantry-rush yes)
	(or	(goal g-rushing-unit eagle-warrior)
	(or	(strategic-number sn-monksiege > 4)
		(unit-type-count-total eagle-warrior-line > 0)))
	(up-research-status g: g-rushing-age >= research-pending)
	(unit-type-count villager g:>= g-dark-vills-2)
=>
	(research ri-eagle-warrior)
	(research ri-elite-eagle-warrior)
)

(defrule
	(goal g-infantry-rush yes)
	(or	(goal g-rushing-unit militiaman)
	(or	(strategic-number sn-spears > 4)
	(or	(unit-type-count militiaman-line > 3)
		(up-compare-goal g-research-status >= imperial-done))))
	(up-research-status g: g-rushing-age >= research-pending)
	(unit-type-count villager g:>= g-dark-vills-2)
	(nand	(unit-available jaguar-man-line)
		(building-type-count castle > 0))
=>
	(research ri-man-at-arms)
	(research ri-long-swordsman)
	(research ri-two-handed-swordsman)
	(research ri-champion)
	(research ri-gambesons)
)

(defrule
	(goal g-infantry-rush yes)
	(or	(goal g-rushing-unit champi-line)
	(or	(strategic-number sn-ranged > 4)
	(or	(unit-type-count champi-line > 1)
		(up-compare-goal g-research-status >= imperial-done))))
	(up-research-status g: g-rushing-age >= research-pending)
	(unit-type-count villager g:>= g-dark-vills-2)
=>
	(research ri-champi-warrior)
	(research ri-champi-runner)
	(research ri-elite-champi-warrior)
	(research ri-gambesons)
)

(defrule
	(goal g-infantry-rush yes)
	(research-completed ri-scale-mail)
	(unit-type-count villager g:>= g-dark-vills-2)
	(up-compare-goal g-research-status >= rush-done)
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-forging != research-available)
	(up-research-status c: ri-iron-casting != research-available)
	(up-research-status c: ri-chain-mail != research-available)
	(can-research ri-squires)
=>
	(research ri-squires)
)

(defrule
	(goal g-infantry-rush yes)
	(research-completed ri-scale-mail)
	(unit-type-count villager g:>= g-dark-vills)
	(up-compare-goal g-research-status >= rush-done)
	(up-compare-goal g-attack >= tsa)
	(or	(players-building-type-count target-player watch-tower > 0)
	(or	(players-building-type-count target-player palisade-wall > 0)
		(players-building-type-count target-player stone-wall-line > 0)))
	(can-research ri-arson)
=>
	(research ri-arson))

(defrule
	(goal g-infantry-rush yes)
	(research-completed ri-scale-mail)
	(unit-type-count villager g:>= g-dark-vills-2)
	(up-compare-goal g-research-status >= rush-done)
	(up-research-status g: g-rushing-age >= research-pending)
	(up-research-status c: ri-forging != research-available)
	(up-research-status c: ri-iron-casting != research-available)
	(up-research-status c: ri-chain-mail != research-available)
	(up-research-status c: ri-squires != research-available)
	(can-research ri-arson)
=>
	(research ri-arson)
)
;archery
(defrule
	(goal g-archer-rush yes)
