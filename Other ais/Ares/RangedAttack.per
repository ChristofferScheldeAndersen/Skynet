	(up-group-size c: 5 > 0)
	(goal check-goal 1)
;	(goal g-math-6 0)
	(player-valid focus-player)
=>
	(up-modify-sn sn-focus-player-number c:+ 1)
	(up-jump-rule -2)
)
(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
;	(goal g-math-6 0)
=>
	(up-set-precise-target-point p-x-1)
;	(up-remove-objects search-remote object-data-to-precise g:< g-full-min-range)
	(up-remove-objects search-remote object-data-class == wall-class)
;	(up-remove-objects search-remote object-data-to-precise g:> g-full-max-range)
	(up-clean-search search-remote object-data-precise-distance search-order-asc)
	(up-clean-search search-remote object-data-hitpoints search-order-asc)
)
(defrule
	(goal g-math-6 1)
=>
	(up-remove-objects search-remote object-data-class == gate-class)
	(up-remove-objects search-remote object-data-class == building-class)
;	(up-remove-objects search-remote object-data-class == farm-class)
	(up-remove-objects search-remote object-data-class == tower-class)
)
(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
;	(goal g-math-6 0)
	(up-set-target-object search-remote c: 0)
=>

	(up-get-object-data object-data-precise-x p-x-3)
	(up-get-object-data object-data-precise-y p-y-3)
	(up-get-object-data object-data-precise-move-x p-destination-x)
	(up-get-object-data object-data-precise-move-y p-destination-y)
	(up-get-object-data object-data-speed g-math-3)
	(up-get-object-data object-data-range g-math-4)
	(up-modify-goal g-math-4 c:* 100)
	(up-modify-goal g-math-4 g:+ g-math-3)
	(up-get-point-distance p-x-3 p-destination-x g-math-10)
	(up-modify-goal g-math-10 c:max 260)
	(up-copy-point p-x-4 p-x-3)
 	(up-copy-point p-x-5 p-x-3)
	(up-cross-tiles p-x-4 p-x-1 g: g-math-10)
	(up-modify-goal g-math-10 c:* -1)
	(up-cross-tiles p-x-5 p-x-1 g: g-math-10)
	(up-get-point-distance p-x-4 p-destination-x g-math-8)
	(up-get-point-distance p-x-5 p-destination-x g-math-9)
)
(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
;	(goal g-math-6 0)
	(up-set-target-object search-remote c: 0)
=>
	(up-modify-goal delta-x-1 g:= p-x-1)
	(up-modify-goal delta-x-1 g:max p-x-3)
	(up-modify-goal delta-x-2 g:= p-x-1)
	(up-modify-goal delta-x-2 g:min p-x-3)
	(up-modify-goal delta-y-1 g:= p-y-1)
	(up-modify-goal delta-y-1 g:max p-y-3)
	(up-modify-goal delta-y-2 g:= p-y-1)
	(up-modify-goal delta-y-2 g:min p-y-3)
	(up-modify-goal delta-x-1 g:- delta-x-2)
	(up-modify-goal delta-y-1 g:- delta-y-2)
	(up-modify-goal delta-x-1 g:* delta-x-1)
	(up-modify-goal delta-y-1 g:* delta-y-1)
	(up-modify-goal delta-x-1 g:+ delta-y-1)
;	(up-get-point-distance p-x-1 p-x-3 delta-x-1)
	(set-goal check-goal 3)
)

