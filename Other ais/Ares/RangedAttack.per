	(up-group-size c: 5 > 0)
	(goal check-goal 1)
;	(goal g-math-6 0)
=>
	(set-strategic-number sn-focus-player-number 1)
	(up-reset-search 0 0 1 1)
	(up-set-target-point p-x-2)
	(up-filter-distance c: -1 c: g-math-1)
)
