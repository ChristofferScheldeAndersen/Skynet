(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 3)
	(or	(up-compare-goal delta-x-1 g:< g-full-min-range)
		(up-compare-goal delta-x-1 g:> g-full-max-range))
=>
	(set-goal check-goal 1)
	(up-remove-objects search-remote object-data-index == 0)
	(up-jump-rule -3)
)

;(defrule
;	(up-group-size c: 5 > 0)
;	(goal g-math-6 1)
;	(goal check-goal 2)
;=>
;	(chat-to-all "target acquired"))

(defrule
	(up-group-size c: 5 > 0)
	(up-compare-goal check-goal >= 2)
=>
;	(chat-to-player my-player-number "Shoot now")
	(up-remove-objects search-local object-data-id g:!= g-math-5)
	(set-strategic-number sn-keystates 2)
	(up-target-objects 1 action-default -1 stance-defensive)
	(set-strategic-number sn-keystates 0)
	(up-reset-group c: 6)
	(up-create-group 0 0 c: 6)
	(up-modify-group-flag 1 c: 6)
)
(defrule
	(up-group-size c: 5 > 0)
	(up-compare-goal check-goal > 0)
=>
	(set-goal check-goal 0)
	(up-modify-goal g-math-7 c:+ 1)
	(up-full-reset-search)
	(up-set-group search-local c: 5)
	(up-jump-direct g: g-jump-direct-1)
)
