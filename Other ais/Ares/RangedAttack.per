
;ranged-group-3--------------------------------------------------
(defrule
	(up-group-size g: g-current-ranged-group > 0)
=>
	(set-goal g-math-7 0)
	(set-goal check-goal 0)
	(up-full-reset-search)
	(up-set-group search-local g: g-current-ranged-group)
	(up-remove-objects search-local object-data-next-attack != 0)
	(up-remove-objects search-local object-data-group-flag == 6)
	(up-clean-search search-local object-data-hitpoints search-order-asc)
	(up-clean-search search-local object-data-attacker-count search-order-desc)
	(up-reset-group c: 5)
	(up-create-group 0 0 c: 5)
)

(defrule
	(or	(up-group-size g: g-current-ranged-group > 7)
		(goal g-archer-mode retreat-from-fort))
	(up-group-size g: g-current-ranged-group > 0)
	(up-set-target-object search-local c: 0)
	(up-object-data object-data-attacker-count > 0)
	(or	(up-compare-goal g-archer-mode != sidling-push)
		(up-group-size g: g-current-ranged-group > 28))
	(up-compare-goal g-archer-mode != g-enemy-vills-nearby)
	(up-compare-goal g-archer-mode != p-march-x)
	(up-compare-goal g-archer-mode != p-march-y)
=>
	(set-goal g-math-7 1)
)

(defrule
	(up-group-size c: 5 > 0)
	(up-set-target-object search-local g: g-math-7)
=>
	(set-goal g-math-6 0)
	(up-get-rule-id g-jump-direct-1)
	(set-goal check-goal 1)
	(up-get-object-data object-data-range g-math-1)
	(up-get-object-data object-data-range g-full-max-range)
	(up-get-object-data object-data-min-range g-full-min-range)
	(up-get-object-data object-data-id g-math-5)
	(up-get-object-data object-data-precise-x p-x-1)
	(up-get-object-data object-data-precise-y p-y-1)
	(up-get-point position-object p-x-2)
	(up-modify-goal g-full-max-range c:* 100)
	(up-modify-goal g-full-min-range c:* 100)
;	(up-modify-goal g-full-max-range c:+ 10)
	(up-modify-goal g-full-max-range g:* g-full-max-range)
	(up-modify-goal g-full-min-range g:* g-full-min-range)
	(up-modify-goal g-math-2 g:= g-math-1)
	(up-modify-goal g-math-1 c:+ 3)
	(up-modify-goal g-math-2 c:- 1)
	(up-set-target-point p-x-2)
	(up-filter-distance c: -1 c: g-math-1)
	(set-strategic-number sn-focus-player-number 1)
)
(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
	(stance-toward focus-player enemy)
=>
	(up-find-remote c: all-units-class c: 50)

)

(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2)
)

(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
=>
;	(chat-to-player my-player-number "we remove objects")
;	(up-set-precise-target-point p-x-1)
;	(up-remove-objects search-remote object-data-to-precise g:< g-full-min-range)
	(up-remove-objects search-remote object-data-pierce-armor >= 10)
	(up-remove-objects search-remote object-data-class == wall-class)
	(up-remove-objects search-remote object-data-class == gate-class)
	(up-remove-objects search-remote object-data-class == building-class)
	(up-remove-objects search-remote object-data-class == farm-class)
	(up-remove-objects search-remote object-data-class == tower-class)
;	(up-remove-objects search-remote object-data-to-precise g:> g-full-max-range)
	(up-clean-search search-remote object-data-precise-distance search-order-asc)
	(up-clean-search search-remote object-data-hitpoints search-order-asc)
)
