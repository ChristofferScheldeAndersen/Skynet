(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
	(up-set-target-object search-remote c: 0)
=>

    ; --- get target data ---
	(up-get-object-data object-data-precise-x p-x-3)
	(up-get-object-data object-data-precise-y p-y-3)
	(up-get-object-data object-data-precise-move-x p-destination-x)
	(up-get-object-data object-data-precise-move-y p-destination-y)
	(up-get-object-data object-data-speed g-math-3)
	(up-get-object-data object-data-range g-math-4)
	(up-modify-goal g-math-4 c:* 100)
	(up-modify-goal g-math-4 g:+ g-math-3)
	(up-get-point-distance p-x-3 p-destination-x g-math-10)
	(up-modify-goal g-math-10 c:max 190)
	(up-copy-point p-x-4 p-x-3)
 	(up-copy-point p-x-5 p-x-3)
	(up-cross-tiles p-x-4 p-x-1 g: g-math-10)
	(up-modify-goal g-math-10 c:* -1)
	(up-cross-tiles p-x-5 p-x-1 c: g-math-10)
	(up-get-point-distance p-x-4 p-destination-x g-math-8)
	(up-get-point-distance p-x-5 p-destination-x g-math-9)

	(up-modify-goal g-math-3 c:/ 2)

    ; --- compute movement vector ---
	(up-modify-goal move-x g:= p-destination-x)
	(up-modify-goal move-x g:- p-x-3)

	(up-modify-goal move-y g:= p-destination-y)
	(up-modify-goal move-y g:- p-y-3)

    ; --- compute squared vector length ---
	(up-modify-goal len2-x g:= move-x)
	(up-modify-goal len2-x g:* move-x)

	(up-modify-goal len2-y g:= move-y)
	(up-modify-goal len2-y g:* move-y)

	(up-modify-goal len2-x g:+ len2-y)   ; len2-x = L^2

)
(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 1)
	(up-set-target-object search-remote c: 0)
=>

    ; --- compute scaled movement numerator (integer-safe) ---
	(up-modify-goal move-x g:* g-math-3)
	(up-modify-goal move-x g:* g-math-3)  ; move-x * s^2

	(up-modify-goal move-y g:* g-math-3)
	(up-modify-goal move-y g:* g-math-3)  ; move-y * s^2

    ; --- divide at the end to get scaled movement ---
	(up-modify-goal move-x g:/ len2-x)
	(up-modify-goal move-y g:/ len2-x)

    ; --- compute next tick target position ---
	(up-modify-goal next-x g:= p-x-3)
	(up-modify-goal next-x g:+ move-x)

	(up-modify-goal next-y g:= p-y-3)
	(up-modify-goal next-y g:+ move-y)

    ; --- compute squared distance to shooting unit ---
	(up-modify-goal delta-x-1 g:= next-x)
	(up-modify-goal delta-x-1 g:- p-x-1)
	(up-modify-goal delta-x-1 g:* delta-x-1)

	(up-modify-goal delta-y-1 g:= next-y)
	(up-modify-goal delta-y-1 g:- p-y-1)
	(up-modify-goal delta-y-1 g:* delta-y-1)
	
	(up-modify-goal delta-x-1 g:+ delta-y-1)   ; final squared distance
	(set-goal check-goal 2)
)

