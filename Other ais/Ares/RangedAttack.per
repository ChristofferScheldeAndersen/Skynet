(defrule
	(up-group-size c: 5 > 0)
	(goal check-goal 2)
	(or	(up-compare-goal delta-x-1 g:< g-full-min-range)
		(up-compare-goal delta-x-1 g:> g-full-max-range))

=>
	(set-goal g-math-6 1)
	(set-goal check-goal 1)
	(up-remove-objects search-remote object-data-index == 0)
	(up-jump-rule -3)
)

