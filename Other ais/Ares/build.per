(defrule
	(goal g-math-2 town-center)
	(up-compare-goal g-math-4 < 5)
	(goal check-goal 2)
=>
	(up-copy-point p-x-1 p-x-2)
	(up-modify-goal g-math-4 c:+ 1)
	(up-modify-goal p-x-1 c:+ -4)
	(up-modify-goal p-y-1 c:+ -1)
	(up-jump-rule -14))


