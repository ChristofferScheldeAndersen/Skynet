#load-if-defined INCAN-CIV
(defconst civ-mill settlement)
(defconst x-mill-1 0)
(defconst y-mill-1 3)
(defconst x-mill-2 0)
(defconst y-mill-2 -3)
(defconst x-mill-3 3)
(defconst y-mill-3 0)
(defconst x-mill-4 -3)
(defconst y-mill-4 0)
(defconst x-mill-5 -3)
(defconst y-mill-5 -3)
(defconst x-mill-6 -3)
(defconst y-mill-6 3)
(defconst x-mill-7 3)
(defconst y-mill-7 -3)
(defconst x-mill-8 3)
(defconst y-mill-8 3)
#end-if
#load-if-not-defined INCAN-CIV
(defconst civ-mill mill)

(defconst x-mill-1 0);4
(defconst y-mill-1 2)

(defconst x-mill-2 2);5
(defconst y-mill-2 -1)

(defconst x-mill-3 -3);9
(defconst y-mill-3 0)

(defconst x-mill-4 -1);10
(defconst y-mill-4 -3)

(defconst x-mill-5 3);13
(defconst y-mill-5 2)

(defconst x-mill-6 -3);18
(defconst y-mill-6 3)

(defconst x-mill-7 2);20
(defconst y-mill-7 -4)

(defconst x-mill-8 -4);25
(defconst y-mill-8 -3)
#end-if
(defrule
	(unit-type-count fishing-ship g:< n-fishboats)
=>
	(up-modify-flag f-map-type c:- fv-fish-map)
	(disable-self)
)
(defrule
	(true)
=>
	(set-goal check-goal 0)
	(set-strategic-number sn-town-center-placement lumber-camp)
	(up-get-fact unit-type-count fishing-ship n-fishboats)
	(up-get-fact unit-type-count villager g-farms-required)
	(up-modify-goal g-farms-required s:* sn-food-gatherer-percentage)
	(up-modify-goal g-farms-required c:/ 100)
	(up-get-fact building-type-count-total town-center g-math-1)
	(up-get-fact building-type-count-total mill g-math-2)
	(up-modify-goal g-math-1 g:+ g-math-2)
	(up-modify-goal g-math-1 c:* 8)
	(up-modify-goal g-math-2 g:= g-math-1)
	(up-modify-goal g-math-2 c:- 8)
	(up-modify-goal n-docks g:= n-fishboats)
	(up-modify-goal n-docks c:/ 8)
)
(defrule
	(timer-triggered t-29-sec)
=>
	(set-strategic-number sn-camp-max-distance 300)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-gold-dropsite-distance 3)
	(set-strategic-number sn-stone-dropsite-distance 3)
	(set-strategic-number sn-wood-dropsite-distance 3))

(defrule
	(goal g-second-turn 0)
	(building-type-count town-center > 0)
=>
	(set-strategic-number sn-town-center-placement mining-camp))

;-------------------------------building controls



(defrule
	(goal g-escrow town-center)
	(up-can-build g-with-escrow g: g-escrow)
=>
	(up-modify-goal g-build g:= g-escrow)
	(up-build place-normal g-with-escrow g: g-escrow))

(defrule
	(up-pending-objects c: town-center < 2)
	(up-gaia-type-count-total c: wood > 19)
	(building-type-count-total town-center < 5)
	(can-build town-center-foundation)
	(goal g-build no)
=>
	(set-goal g-build town-center-foundation))
(defrule
	(goal g-build no)
	(up-pending-objects c: house < 2)
	(building-type-count town-center > 0)
	(or	(up-pending-objects c: house < 1)
		(game-time < 5))
	(or	(housing-headroom < 4)
	(or	(up-research-status g: g-rushing-age >= research-pending)
		(and	(unit-type-count fishing-ship > 0)
			(building-type-count dock > 0))))
	(or	(housing-headroom < 10)
		(building-type-count town-center > 1))
	(housing-headroom < 15)
	(population-headroom > 0)
	(can-build-with-escrow house)
=>
	(set-goal g-build house))

(defrule
	(goal g-build no)
	(up-can-build 0 c: dock)
	(building-type-count town-center > 0)
	(or	(building-type-count-total dock == 0)
		(building-type-count-total dock g:< n-docks))
	(or	(up-compare-flag f-map-type == fv-fish-map)
		(unit-type-count fishing-ship >= 10))
	(dropsite-min-distance wood < 5)
	(or	(building-type-count-total lumber-camp > 0)
		(building-type-count-total settlement > 0))
=>
	(set-goal g-build dock))

(defrule
	(can-build settlement)
	(goal g-build no)
	(up-pending-objects c: settlement < 1)
	(building-type-count town-center > 0)
	(unit-type-count villager-forager > 0)
	(building-type-count settlement > 0)
	(or	(sheep-and-forage-too-far)
		(building-type-count settlement == 1))
=>
	(up-assign-builders c: settlement c: 2)
	(set-strategic-number sn-town-center-placement mill)
	(set-strategic-number sn-preferred-settlement-placement 6)
	(set-goal g-build settlement))
(defrule
	(can-build mill)
	(goal g-build no)
;	(game-time >= 46)
	(up-pending-objects c: mill < 1)
	(building-type-count town-center > 0)
	(building-type-count-total mill == 0)
	(or	(unit-type-count-total villager-forager > 0)
	(or	(and	(game-time > 90)
			(sheep-and-forage-too-far))
		(and	(building-type-count lumber-camp > 0)
			(or	(up-compare-flag f-map-type != fv-fish-map)
				(building-type-count dock > 0)))))
=>
	(set-strategic-number sn-town-center-placement mill)
	(set-strategic-number sn-preferred-mill-placement 0)
	(set-goal g-build mill)) 

(defrule
	(can-build mill)
	(goal g-build no)
	(game-time >= 31)
	(sheep-and-forage-too-far)
	(building-type-count town-center > 0)
	(building-type-count-total mill == 0)
	(up-pending-objects c: mill < 1)
	(resource-found food)
=>
	(set-goal check-goal 0)
	(set-strategic-number sn-town-center-placement mill)
	(set-strategic-number sn-preferred-mill-placement 0)
	(set-goal g-build mill))
(defrule
	(or	(research-available castle-age)
		(building-type-count town-center > 3))
	(goal g-build no)
	(can-build mill)
	(building-type-count town-center > 0)
	(up-compare-goal g-math-1 g:< g-farms-required)
	(building-type-count farm g:> g-math-2)
=>
	(set-strategic-number sn-town-center-placement mill)
	(set-strategic-number sn-dropsite-separation-distance 9)
	(set-strategic-number sn-preferred-mill-placement 0)
	(up-modify-sn sn-mill-max-distance s:max sn-maximum-town-size)
	(up-modify-sn sn-mill-max-distance c:min 35)
	(set-goal g-build mill))


