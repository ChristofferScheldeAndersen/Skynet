(defrule
	(goal g-build settlement)
	(strategic-number sn-preferred-settlement-placement >= 4)
	(strategic-number sn-preferred-settlement-placement <= 5)
=>
	(up-modify-sn sn-camp-max-distance s:= sn-mining-camp-max-distance))

(defrule
	(goal g-build settlement)
