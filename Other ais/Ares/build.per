	(up-modify-goal p-y-1 c:+ -4)
	(up-jump-rule -17))


(defrule
	(goal check-goal 2)
=>
	(set-goal check-goal 1)
	(up-modify-goal g-math-1 c:+ 1)
	(up-jump-direct g: g-jump-direct-1)
)
(defrule
	(up-compare-goal check-goal != 3)
	(goal g-build farm)
	(can-build farm)
=>
	(chat-to-player my-player-number "normal farm placement")
	(build farm))

(defrule
	(goal g-build market)
	(can-build market)
=>
	(set-strategic-number sn-placement-to-center 1)
	(set-strategic-number sn-placement-fail-delta 0)
	(set-strategic-number sn-placement-zone-size 40)
	(up-set-placement-data my-player-number -1 c: -120)
	(up-build place-control 0 c: market))


(defrule
	(goal g-build university)
	(can-build university)
=>
	(build university))

;-------------------------------------FISH TRAPS-------------------------------------

(defrule
;	(goal g-fifth-turn 1)
	(unit-type-count fishing-ship > 0)
	(goal g-build no)
=>
	(up-full-reset-search)
	(set-strategic-number sn-focus-player-number 0)
	(up-filter-exclude -1 actionid-gather orderid-build -1)
)

(defrule
;	(goal g-fifth-turn 1)
	(unit-type-count fishing-ship > 0)
	(goal g-build no)
	(up-find-local c: fishing-ship c: 1)
=>
	(set-goal g-build fish-trap)
	(up-set-target-object search-local c: 0)
	(up-get-object-data object-data-map-zone-id g-math-1)
	(up-get-object-data object-data-id g-current-unit-id)
;	(up-chat-data-to-player my-player-number "zone id %d" g: g-math-1)
	(up-get-point position-object p-x-1)
	(up-set-target-point p-x-1)
	(up-reset-filters)
	(up-filter-distance c: -1 c: 40)
	(up-filter-status c: status-gather c: list-inactive)
	(up-find-resource c: ocean-fish-class c: 30)
	(up-find-resource c: shore-fish-class c: 10)
	(set-strategic-number sn-focus-player-number my-player-number)
	(up-filter-status c: status-ready c: list-active)
	(up-find-status-remote c: fish-trap c: 40)
	(up-filter-status c: status-pending c: list-active)
	(up-find-status-remote c: fish-trap c: 40)
	(up-remove-objects search-remote object-data-tasks-count > 0)
	(up-remove-objects search-remote object-data-under-attack == 1)
	(up-remove-objects search-remote object-data-map-zone-id g:!= g-math-1)
	(up-clean-search search-remote object-data-full-distance search-order-asc)
)

(defrule
	(goal g-build fish-trap)
	(up-set-target-object search-remote c: 0)
=>
	(set-goal g-build no)
	(chat-to-player my-player-number "found fish or trap")
	(set-strategic-number sn-keystates 2)
	(up-target-objects 1 action-default -1 -1)
	(set-strategic-number sn-keystates 0)
)
(defrule
	(goal g-build fish-trap)
	(unit-type-count fishing-ship > 4)
=>
	(up-modify-flag f-map-type c:- fv-fish-map)
	(disable-self)
)
(defrule
	(goal g-build fish-trap)
	(research-completed ri-crop-rotation)
	(population > 190)
=>
	(up-target-point p-self-x action-delete -1 -1)
	(set-goal g-build no)
)
(defrule
	(goal g-build fish-trap)
	(can-afford-building fish-trap)
	(building-available fish-trap)
	(building-type-count dock > 0)
	(building-type-count town-center > 0)
	(or	(strategic-number sn-food-wood-comparison >= -250)
		(wood-amount >= 300))
=>
	(set-goal check-goal -1)
	(set-goal g-math-1 0)
	(up-reset-search 1 1 1 1)
	(up-set-target-point p-x-1)
	(up-filter-status c: status-ready c: list-active)
	(up-find-status-local c: dock c: 10)
	(up-remove-objects search-local object-data-under-attack == 1)
	(up-remove-objects search-remote object-data-map-zone-id g:!= g-math-1)
	(up-clean-search search-local object-data-full-distance search-order-asc)
)
(defrule
	(goal g-build fish-trap)
	(goal check-goal -1)
	(up-set-target-object search-local g: g-math-1)
=>
	(set-goal check-goal 1)
	(set-goal g-math-2 0)
	(up-get-rule-id g-jump-direct-1)
	(up-get-rule-id g-jump-direct-2)
	(up-modify-goal g-jump-direct-2 c:+ 1)
	(up-get-point position-object p-x-1)
	(up-copy-point p-x-2 p-x-1))

