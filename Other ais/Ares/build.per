(defrule
	(or	(goal g-build mill)
		(goal g-build settlement))
	(wood-amount < 150)
	(up-compare-flag f-map-type == fv-fish-map)
	(building-type-count-total dock == 0)
=>
	(set-goal g-build no))

(defrule
	(goal g-build no)
	(or	(up-compare-goal g-attack > maybe)
		(building-type-count-total bombard-tower < 3))
	(building-type-count-total castle > 3)
	(building-type-count-total town-center > 0)
	(up-pending-objects c: bombard-tower < 2)
	(can-build bombard-tower)
=>
	(set-goal g-build bombard-tower))

(defrule
	(goal g-build no)
	(building-type-count town-center > 0)
	(up-pending-objects c: castle < 2)
	(can-build castle)
=>
	(set-goal g-build castle))

(defrule
	(goal g-build no)
	(can-build blacksmith)
	(building-type-count-total town-center > 0)
	(unit-type-count-total villager g:>= g-dark-vills-2)
	(building-type-count-total archery-range g:>= g-number-ranges)
	(building-type-count-total stable g:>= g-number-stables)
	(building-type-count-total blacksmith == 0)
	(up-pending-objects c: blacksmith < 1)
=>
	(set-goal g-build blacksmith))

(defrule
	(can-build settlement)
	(goal g-build no)
	(up-pending-objects c: settlement < 1)
	(building-type-count town-center > 0)
	(building-type-count-total settlement < 60)
	(or	(dropsite-min-distance wood > 3)
		(and	(building-type-count-total settlement == 0)
			(unit-type-count villager-wood > 2)))
	(strategic-number sn-wood-gatherer-percentage > 0)
=>
	(up-assign-builders c: settlement c: 0)
;	(chat-to-all "build wood settlement")
	(set-strategic-number sn-town-center-placement lumber-camp)
	(set-strategic-number sn-dropsite-separation-distance 5)
	(set-strategic-number sn-preferred-settlement-placement 3)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-goal g-build settlement))

(defrule
	(up-pending-objects c: lumber-camp < 1)
	(building-type-count-total lumber-camp < 50)
	(or	(dropsite-min-distance wood > 3)
		(and	(building-type-count-total lumber-camp == 0)
			(unit-type-count villager-wood > 1)))
	(strategic-number sn-wood-gatherer-percentage > 0)
;	(nand	(sheep-and-forage-too-far)
;		(building-type-count mill == 0))
	(cc-players-unit-type-count 0 trees-class >= 20)
	(goal g-build no)
	(can-build lumber-camp)
=>
	(set-strategic-number sn-town-center-placement lumber-camp)
	(set-strategic-number sn-wood-dropsite-distance 3)
	(set-strategic-number sn-dropsite-separation-distance 5)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-goal g-build lumber-camp))

(defrule
	(up-pending-objects c: lumber-camp < 1)
	(building-type-count-total lumber-camp == 1)
	(building-type-count barracks > 0)
	(building-type-count mining-camp > 0)
	(building-type-count mill > 0)
	(cc-players-unit-type-count 0 trees-class >= 20)
	(goal g-build no)
	(can-build lumber-camp)
=>
	(set-strategic-number sn-town-center-placement lumber-camp)
	(set-strategic-number sn-wood-dropsite-distance 3)
	(set-strategic-number sn-dropsite-separation-distance 4)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-goal g-build lumber-camp))

;idea from Promi
(defrule
	(goal g-build no)
	(up-pending-objects c: lumber-camp < 1)
	(up-timer-status t-upwood != timer-running)
	(resource-found wood)
	(unit-type-count villager-wood >= 22)
	(game-time >= 2060)
	(dropsite-min-distance wood > 2)
	(dropsite-min-distance wood < 255); 128?
	(building-type-count-total lumber-camp < 59)
	(can-build lumber-camp)
=>
	(set-strategic-number sn-town-center-placement lumber-camp)
	(set-strategic-number sn-wood-dropsite-distance 3)
	(set-strategic-number sn-allow-adjacent-dropsites 1)
	(set-strategic-number sn-dropsite-separation-distance 5)
	(set-goal g-build lumber-camp)
	(enable-timer t-upwood 380))




(defrule
	(can-build settlement)
	(goal g-build no)
	(up-pending-objects c: settlement < 1)
	(building-type-count town-center > 0)
	(building-type-count-total settlement < 60)
	(dropsite-min-distance gold > 3)
	(dropsite-min-distance gold < 100)
	(strategic-number sn-gold-gatherer-percentage > 0)
=>
	(set-strategic-number sn-town-center-placement mining-camp)
	(up-assign-builders c: settlement c: 0)
	(set-strategic-number sn-gold-dropsite-distance 3)
	(set-strategic-number sn-dropsite-separation-distance 4)
	(set-strategic-number sn-preferred-settlement-placement 4)
	(set-strategic-number sn-allow-adjacent-dropsites 0)
	(set-goal g-build settlement))

(defrule
	(goal g-build no)
	(can-build mining-camp)
	(up-pending-objects c: mining-camp < 1)
	(building-type-count-total mining-camp < 3)
	(building-type-count-total town-center > 0)
	(building-type-count-total lumber-camp > 1)
	(building-type-count-total blacksmith > 0)
	(building-type-count-total archery-range g:>= g-number-ranges)
	(building-type-count-total stable g:>= g-number-stables)
	(building-type-count-total barracks g:>= g-number-barracks)
	(unit-type-count-total villager > 20)
	(strategic-number sn-gold-gatherer-percentage > 0)
	(dropsite-min-distance gold < 100)
=>
	(set-goal check-goal 0)
	(set-strategic-number sn-town-center-placement mining-camp)
	(set-strategic-number sn-dropsite-separation-distance 6)
	(set-strategic-number sn-allow-adjacent-dropsites 0)
	(set-goal g-build mining-camp))

(defrule
	(goal g-build no)
	(can-build mining-camp)
	(up-pending-objects c: mining-camp < 1)
	(building-type-count-total mining-camp < 23)
	(building-type-count-total town-center > 0)
	(unit-type-count-total villager > 20)
	(strategic-number sn-gold-gatherer-percentage > 0)
	(or	(dropsite-min-distance gold > 4)
		(building-type-count-total mining-camp == 0))
	(dropsite-min-distance gold < 100)
=>
	(set-goal check-goal 0)
	(set-strategic-number sn-town-center-placement mining-camp)
	(set-strategic-number sn-gold-dropsite-distance 3)
	(set-strategic-number sn-stone-dropsite-distance 200)
	(set-strategic-number sn-dropsite-separation-distance 6)
	(set-strategic-number sn-allow-adjacent-dropsites 0)
	(set-goal g-build mining-camp))

(defrule
	(goal g-enemy-flusher yes)
	(or	(building-type-count-total watch-tower == 0)
	(or	(strategic-number sn-military-superiority < -4)
		(up-compare-goal g-attack > yes)))
	(current-age == feudal-age)
	(goal g-build no)
	(can-build watch-tower)
=>
	(set-goal g-build watch-tower))


(defrule
	(can-build settlement)
	(goal g-build no)
	(up-pending-objects c: settlement < 1)
	(building-type-count town-center > 0)
	(building-type-count-total settlement < 60)
	(dropsite-min-distance stone > 3)
	(dropsite-min-distance stone < 100)
	(strategic-number sn-stone-gatherer-percentage > 0)
=>
	(up-assign-builders c: settlement c: 0)
	(set-strategic-number sn-town-center-placement mining-camp)
	(set-strategic-number sn-stone-dropsite-distance 3)
	(set-strategic-number sn-dropsite-separation-distance 4)
	(set-strategic-number sn-preferred-settlement-placement 5)
	(set-strategic-number sn-allow-adjacent-dropsites 0)
	(set-goal g-build settlement))

(defrule
	(goal g-build no)
	(can-build mining-camp)
	(up-pending-objects c: mining-camp < 1)
	(building-type-count-total mining-camp < 23)
	(building-type-count-total town-center > 0)
	(unit-type-count-total villager > 20)
	(strategic-number sn-stone-gatherer-percentage > 0)
	(dropsite-min-distance stone > 4)
	(dropsite-min-distance stone < 100)
=>
	(set-goal check-goal 0)
	(set-strategic-number sn-town-center-placement mining-camp)
	(set-strategic-number sn-stone-dropsite-distance 3)
	(set-strategic-number sn-dropsite-separation-distance 6)
	(set-strategic-number sn-gold-dropsite-distance 200)
	(set-strategic-number sn-allow-adjacent-dropsites 0)
	(set-goal g-build mining-camp))


(defrule
	(goal g-build no)
	(can-build monastery)
	(up-pending-objects c: monastery < 2)
	(building-type-count-total town-center > 0)
	(building-type-count-total farm > 0)
	(dropsite-min-distance wood < 5)
	(building-type-count-total monastery g:< g-number-monasteries)
=>
	(set-goal g-build monastery))

(defrule
	(up-pending-objects c: university < 1)
	(building-type-count-total town-center > 2)
	(building-type-count-total university == 0)
	(goal g-build no)
	(can-build university)
=>
	(set-goal g-build university))

(defrule
	(up-pending-objects c: market < 1)
	(or	(building-type-count-total university > 0)
		(up-compare-goal g-wood-available >= 400))
	(up-research-status c: castle-age != research-pending)
	(building-type-count-total market == 0)
	(can-build market)
	(goal g-build no)
=>
	(set-goal g-build market))



(defrule
	(goal g-build no)
	(can-build archery-range)
	(unit-type-count villager > 19)
	(up-pending-objects c: archery-range < 1)
	(building-type-count-total town-center > 0)
	(or	(and	(building-type-count-total mill > 0)
			(building-type-count-total lumber-camp > 0))
		(building-type-count-total settlement > 0))
	(building-type-count-total archery-range g:< g-number-ranges)
=>
	(set-goal g-build archery-range))

(defrule
	(goal g-build no)
	(can-build stable)
	(unit-type-count villager > 19)
	(up-pending-objects c: stable < 1)
	(building-type-count-total town-center > 0)
	(or	(and	(building-type-count-total mill > 0)
				(building-type-count-total lumber-camp > 0))
		(building-type-count-total settlement > 0))
	(building-type-count-total stable g:< g-number-stables)
=>
	(set-goal g-build stable))

(defrule
	(goal g-build no)
	(can-build barracks)
	(unit-type-count villager > 19)
	(up-pending-objects c: barracks < 1)
	(building-type-count-total town-center > 0)
	(or	(and	(building-type-count-total mill > 0)
				(building-type-count-total lumber-camp > 0))
		(building-type-count-total settlement > 0))
	(building-type-count-total barracks g:< g-number-barracks)
=>
	(set-goal g-build barracks))

(defrule
	(goal g-build no)
	(can-build siege-workshop)
	(unit-type-count villager > 19)
	(up-pending-objects c: siege-workshop < 1)
	(building-type-count-total monastery g:>= g-number-monasteries)
	(building-type-count-total town-center g:>= g-number-town-centers)
	(building-type-count-total farm > 0)
	(dropsite-min-distance wood < 5)
	(building-type-count-total siege-workshop g:< g-number-siege-workshops)
=>
	(set-goal g-build siege-workshop))

(defrule
	(goal g-build no)
	(up-can-build 0 c: farm)
	(wood-amount > 200)
	(or	(research-available feudal-age)
		(wood-amount > 400))
	(building-type-count town-center > 0)
	(or	(building-type-count-total lumber-camp > 0)
		(building-type-count-total settlement > 0))
	(dropsite-min-distance wood < 6)
	(or	(idle-farm-count < 1)
		(building-type-count-total farm < 3))
	(or	(unit-type-count villager g:< g-dark-vills-2)
		(building-type-count-total barracks > 0))
=>
	(set-goal g-build farm)
)
(defrule
	(goal g-build no)
	(up-can-build 0 c: farm)
	(building-type-count-total barracks g:>= g-number-barracks)
	(building-type-count-total archery-range g:>= g-number-ranges)
	(building-type-count-total stable g:>= g-number-stables)
	(building-type-count-total monastery g:>= g-number-monasteries)
	(building-type-count-total blacksmith > 0)
	(building-type-count town-center > 0)
	(or	(dropsite-min-distance wood < 6)
		(strategic-number sn-food-wood-comparison > 100))
	(or	(building-type-count-total farm g:< g-farms-required)
		(idle-farm-count < 3))
	(or	(building-type-count town-center g:>= g-number-town-centers)
		(strategic-number sn-food-wood-comparison > 0))
	(or	(dropsite-min-distance gold < 6)
	(or	(strategic-number sn-gold-gatherer-percentage == 0)
		(wood-amount > 300)))
=>
	(set-goal g-build farm)
)

(defrule
	(goal g-build farm)
	(or	(strategic-number sn-food-wood-comparison < -160)
		(up-compare-flag f-map-type == fv-fish-map))
	(wood-amount < 135)
=>
	(set-goal g-build no))

(defrule
	(goal g-build farm)
	(or	(building-type-count-total farm < 23)
		(up-pending-objects c: farm > 1))
	(or	(up-pending-objects c: farm > 0)
		(and	(sheep-and-forage-too-far)
			(unit-type-count villager-forager > 0)))
=>
	(set-goal g-build no))



(defrule
	(true)
=>
	(set-strategic-number sn-focus-player-number 0)
	(up-reset-search 1 1 1 1)
	(up-reset-filters)
	(set-goal check-goal 0)
	(set-goal g-math-1 10)
	(set-goal g-math-2 0)
	(set-goal g-math-3 0))
;-------------------------------------mill-max distance
(defrule
	(or	(goal g-build mill)
	(or	(and	(goal g-build settlement)
			(strategic-number sn-preferred-settlement-placement == 6))
		(and	(goal g-build town-center-foundation)
			(strategic-number sn-town-center-placement == mill))))
	(strategic-number sn-preferred-mill-placement == 0)
=>
	(up-full-reset-search)
