;-----------------------------DODGE RANGED ATTACKS-----------------------------


(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
=>
	(up-full-reset-search)
	(up-set-target-point p-x-1)
	(set-strategic-number sn-focus-player-number 1)
	(up-filter-include -1 actionid-attack -1 -1)
	(up-filter-distance c: 3 c: 8)
)

(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
	(up-object-data object-data-pierce-armor < 8)
	(stance-toward focus-player enemy)
=>
	(up-find-remote c: archery-class c: 20)
	(up-find-remote c: cavalry-archer-class c: 20)
	(up-find-remote c: scorpion-class c: 5)
)

(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2)
)
(defrule
	(goal temporary-goal 1)
	(up-set-target-by-id g: g-current-unit-id)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
=>
;	(up-remove-objects search-remote object-data-next-attack < 1500)
	(up-remove-objects search-remote object-data-target-id g:!= g-current-unit-id)
)

(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-remote c: 1)
=>
	(up-modify-goal split-melee-turn c:* -1)
	(up-get-point position-object p-enemy-ranged-group-x)
	(up-copy-point p-x-2 p-x-1)
	(up-copy-point p-order-x p-x-1)
	(up-cross-tiles p-x-2 p-enemy-ranged-group-x c: 3)
	(up-cross-tiles p-order-x p-enemy-ranged-group-x c: -3)
	(up-bound-point p-x-2 p-x-2)
	(up-bound-point p-order-x p-order-x)
	(up-set-target-by-id g: g-current-unit-id)
	(up-get-path-distance p-x-2 1 g-enemy-elevation)
	(up-get-path-distance p-order-x 1 g-my-elevation)
	(set-goal temporary-goal -4)
)
(defrule
	(goal temporary-goal -4)
	(or	(goal split-melee-turn 1)
		(up-compare-goal g-enemy-elevation g:< g-my-elevation))
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-compare-goal g-enemy-elevation g:<= g-my-elevation)
	(up-set-target-object search-remote c: 1)
=>
	(up-copy-point p-order-x p-x-2)
	(up-modify-goal g-my-elevation g:= g-enemy-elevation)
)
(defrule
	(goal temporary-goal -4)
	(up-set-target-by-id g: g-current-unit-id)
	(up-compare-goal g-my-elevation > 3)
=>
	(set-goal temporary-goal 1)
;	(chat-to-all "cancel dodge")
)
