
;Inspired by brightspark
; temp goal -1: retreat to point
; temp goal 1: no retreat necessary
; temp goal 0: no unit found


(defrule
	(up-compare-goal g-ranged-group-size < 1)
=>
	(up-copy-point p-destination-x p-march-x)
	(up-copy-point p-safety-x p-self-x)
)
(defrule
	(up-compare-goal g-ranged-group-size > 0)
=>
	(up-copy-point p-destination-x p-largest-ranged-group-x)
	(up-copy-point p-safety-x p-largest-ranged-group-x)
)

(defrule
	(goal g-fifth-turn 1)
=>
	(up-set-attack-stance infantry-class c: stance-aggressive)
	(up-set-attack-stance cavalry-class c: stance-aggressive)
	(up-set-attack-stance scout-cavalry-class c: stance-aggressive)
)


(defrule
	(true)
=>
	(up-full-reset-search)
	(up-get-rule-id g-jump-direct-1)
	(up-modify-goal g-jump-direct-1 c:+ 2)
	(set-goal g-current-list-number 0)
	(set-goal g-rule-loops -1))
(defrule
	(goal g-second-turn 1)
=>
	(up-find-local c: cavalry-class c: 60)
	(up-find-local c: infantry-class c: 60)
	(up-find-local c: scout-cavalry-class c: 60)
	(up-remove-objects search-local object-data-type == armored-elephant)
	(up-get-search-state lt)
	(set-goal g-math-1 50)
	(up-modify-goal g-math-1 g:- lt)
	(up-modify-goal g-math-1 c:max 0)
	(up-find-local c: villager-class g: g-math-1)

	(up-clean-search search-local object-data-hitpoints search-order-desc)
	(up-remove-objects search-local object-data-index > 60)
	(up-clean-search search-local object-data-next-attack search-order-desc)
	(up-create-group 0 0 c: melee-group)
	(up-get-search-state lt)
	(up-modify-goal lt c:/ 2)
	(up-remove-objects search-local object-data-index g:>= lt)
	(up-create-group 0 0 c: sub-melee-group-1)
	(up-full-reset-search)
	(up-set-group search-local c: melee-group)
	(up-remove-objects search-local object-data-index g:< lt)
	(up-create-group 0 0 c: sub-melee-group-2)
)

(defrule
	(goal g-second-turn 1)
=>
	(set-goal check-goal 0)
	(set-goal g-next-attack -1)
	(set-goal g-my-elevation -100)
	(set-goal g-enemy-elevation -100)
	(set-goal temporary-goal 0)
	(set-goal g-closest-enemy-id -1)
	(set-goal p-danger-x -255)
	(set-goal p-danger-y -255)
	(set-goal g-current-unit-id 0)
	(up-full-reset-search)
;	(up-filter-exclude -1 actionid-explore -1 -1)
	(up-set-group search-local c: sub-melee-group-1)
	(up-get-search-state lt)
	(up-modify-goal g-rule-loops g:= lt)
)
(defrule
	(goal g-second-turn 0)
=>
	(set-goal check-goal 0)
	(set-goal g-next-attack -1)
	(set-goal g-my-elevation -100)
	(set-goal g-enemy-elevation -100)
	(set-goal temporary-goal 0)
	(set-goal g-closest-enemy-id -1)
	(set-goal p-danger-x -255)
	(set-goal p-danger-y -255)
	(set-goal g-current-unit-id 0)
	(up-full-reset-search)
;	(up-filter-exclude -1 actionid-explore -1 -1)
	(up-set-group search-local c: sub-melee-group-2)
	(up-get-search-state lt)
	(up-modify-goal g-rule-loops g:= lt)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-local g: g-current-list-number)
=>
	(set-goal temporary-goal 1)
	(set-goal g-closest-enemy-id -1)
	(up-get-object-data object-data-id g-current-unit-id)
	(up-get-object-data object-data-target-id g-current-target-id)
	(up-get-point position-object p-x-1)
	(up-set-target-point p-x-1)
	(up-get-point-elevation p-x-1 g-my-elevation)
	(up-get-object-data object-data-next-attack g-next-attack)
	(up-get-object-data object-data-speed g-unit-speed)
	(up-modify-goal g-unit-speed c:+ 10)

	(up-set-target-by-id g: g-current-target-id)
	(up-get-point position-object p-x-3)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-local g: g-current-list-number)
	(up-object-data object-data-class == villager-class)
=>
	(up-modify-goal g-unit-speed c:* 2)
	(set-strategic-number sn-focus-player-number 1)
	(up-filter-distance c: -1 c: 5)
	(up-jump-rule 1)
)


(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-local g: g-current-list-number)
=>
	(set-strategic-number sn-focus-player-number 1)
	(up-filter-distance c: -1 c: 4)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-local g: g-current-list-number)
	(up-object-data object-data-strike-armor < 3)
	(stance-toward focus-player enemy)
=>

	(up-find-remote c: cavalry-class c: 10)
	(up-find-remote c: infantry-class c: 20)
	(up-find-remote c: villager-class c: 20)
	(up-find-remote c: scout-cavalry-class c: 5)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-local g: g-current-list-number)
	(up-object-data object-data-strike-armor >= 3)
	(up-object-data object-data-strike-armor < 10)
	(stance-toward focus-player enemy)
=>
	(up-find-remote c: teutonic-knight-line c: 10)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-local g: g-current-list-number)
	(up-object-data object-data-strike-armor >= 3)
	(stance-toward focus-player enemy)
	(or	(up-object-data object-data-class == cavalry-class)
		(up-object-data object-data-class == scout-cavalry-class))
=>
	(up-find-remote c: spearman-line c: 10)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-local g: g-current-list-number)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -4)
)
(defrule
	(up-set-target-object search-local g: g-current-list-number)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
=>
	(set-goal temporary-goal 1)
	(up-remove-objects search-remote object-data-range > 1)
	(up-remove-objects search-remote object-data-speed g:>= g-unit-speed)
	(up-remove-objects search-remote object-data-target-id g:!= g-current-unit-id)
	(up-clean-search search-remote object-data-full-distance search-order-asc)
)

(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-remote c: 0)
=>
	(up-get-object-data object-data-id g-closest-enemy-id)
	(up-get-point position-object p-enemy-melee-group-x)
	(up-copy-point p-x-2 p-x-1)
	(up-lerp-tiles p-x-2 p-enemy-melee-group-x c: 1)
	(up-get-point-elevation p-x-2 g-enemy-elevation)
)
(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-remote c: 0)
	(up-compare-goal g-enemy-elevation g:>= g-my-elevation)
=>
	(up-copy-point p-order-x p-x-1)
	(up-lerp-tiles p-order-x p-enemy-melee-group-x c: -6)
	(up-bound-point p-order-x p-order-x)
	(set-goal temporary-goal -1)
)
(defrule
	(goal temporary-goal -1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-point-distance p-order-x p-safety-x > 4)
=>
	(up-lerp-tiles p-order-x p-safety-x c: 4)
	(up-lerp-tiles p-order-x p-x-1 c: -2)
	(up-bound-point p-order-x p-order-x)
)
;-------------------------------------

(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
	(up-object-data object-data-pierce-armor < 5)
=>
	(up-full-reset-search)
	(up-set-target-point p-x-1)
	(set-strategic-number sn-focus-player-number 1)
	(up-filter-distance c: -1 c: 12)
	(up-filter-status c: status-ready c: list-active)
)

(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(stance-toward focus-player enemy)
	(up-set-target-by-id g: g-current-unit-id)
	(up-object-data object-data-pierce-armor < 4)
	(up-projectile-detected projectile-town-center < 5000)
=>
	(up-find-status-remote c: town-center c: 10)
)

(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(stance-toward focus-player enemy)
	(up-set-target-by-id g: g-current-unit-id)
	(up-object-data object-data-pierce-armor < 5)
=>
	(up-find-status-remote c: castle c: 10)
	(up-find-status-remote c: krepost c: 5)
)
(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
	(up-object-data object-data-pierce-armor < 5)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -3)
)
(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
=>
	(up-clean-search search-remote object-data-full-distance search-order-asc)
)
(defrule
	(goal temporary-goal 1)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-object search-remote c: 0)
;	(up-object-data object-data-target-id g:== g-current-unit-id)
=>
;	(chat-to-player my-player-number "retreat from fortifications: we are targeted")
	(set-goal temporary-goal -2)
	(up-get-point position-object p-danger-x)
	(up-copy-point p-order-x p-x-1)
	(up-lerp-tiles p-order-x p-danger-x c: -5)
	(up-copy-point p-x-2 p-order-x)
	(up-cross-tiles p-order-x p-danger-x c: 10)
	(up-cross-tiles p-x-2 p-danger-x c: -10)
	(up-bound-point p-x-2 p-x-2)
	(up-bound-point p-order-x p-order-x)
	(up-get-point-distance p-x-2 p-destination-x g-math-1)
	(enable-timer t-melee-retreat 3)
)
(defrule
	(goal g-attack tsa-raid)
	(goal temporary-goal -2)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
;	(up-object-data object-data-target-id g:== g-current-unit-id)
	(up-point-distance p-order-x p-destination-x g:> g-math-1)
=>
	(up-copy-point p-order-x p-x-2)
)

