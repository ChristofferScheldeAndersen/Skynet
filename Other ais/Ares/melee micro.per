(defrule
	(goal temporary-goal 1)
	(goal g-defend yes)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
	(up-point-distance p-x-1 p-march-x > 4)
	(up-object-data object-data-action == -1)
	(up-object-data object-data-class != villager-class)
=>
	(set-goal temporary-goal 2)
	(up-copy-point p-order-x p-x-1)
	(up-lerp-tiles p-order-x p-march-x c: 5)
	(up-bound-point p-order-x p-order-x)
)

(defrule
	(game-time >= 720)
	(goal temporary-goal 1)
	(goal g-defend no)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(strategic-number sn-maximum-town-size < 40)
	(up-set-target-by-id g: g-current-unit-id)
	(up-point-distance p-x-1 p-self-x s:> sn-maximum-town-size)
	(up-object-data object-data-action == -1)
	(up-object-data object-data-class != villager-class)
=>
	(set-goal temporary-goal 2)
;	(chat-to-player my-player-number "send melee to defend")
	(up-copy-point p-order-x p-x-1)
	(up-lerp-tiles p-order-x p-march-x c: 5)
	(up-bound-point p-order-x p-order-x)
)

;--------------------------Avoid Trees

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(or	(up-compare-goal temporary-goal < 0)
		(goal temporary-goal 2))
	(up-point-contains p-order-x c: trees-class)
=>
	(set-goal g-math-1 3)
	(set-goal g-math-2 -3)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(or	(up-compare-goal temporary-goal < 0)
		(goal temporary-goal 2))
	(up-point-contains p-order-x c: trees-class)
=>
	(up-copy-point p-x-1 p-order-x)
	(up-copy-point p-x-2 p-order-x)
	(up-cross-tiles p-x-1 p-ranged-group-x g: g-math-1)
	(up-cross-tiles p-x-2 p-ranged-group-x g: g-math-2)
	(up-bound-point p-x-1 p-x-1)
	(up-bound-point p-x-2 p-x-2)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(not	(up-point-contains p-x-1 c: trees-class))
	(or	(up-compare-goal temporary-goal < 0)
		(goal temporary-goal 2))
	(up-point-contains p-order-x c: trees-class)
=>
	(up-copy-point p-order-x p-x-1)
	(up-jump-rule 2)
)
(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(not	(up-point-contains p-x-2 c: trees-class))
	(or	(up-compare-goal temporary-goal < 0)
		(goal temporary-goal 2))
	(up-point-contains p-order-x c: trees-class)
=>
	(up-copy-point p-order-x p-x-2)
	(up-jump-rule 1)
)

(defrule
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-compare-goal g-math-1 < 25)
	(or	(up-compare-goal temporary-goal < 0)
		(goal temporary-goal 2))
	(up-point-contains p-order-x c: trees-class)
=>
	(up-modify-goal g-math-1 c:+ 2)
	(up-modify-goal g-math-2 c:- 2)
	(up-jump-rule -4)
)

(defrule
	(goal temporary-goal 2)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
=>
	(up-full-reset-search)
	(up-add-object-by-id search-local g: g-current-unit-id)
	(up-target-point p-order-x action-attack-move -1 stance-aggressive)
)

(defrule
	(up-compare-goal temporary-goal < 0)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
=>
	(up-full-reset-search)
;	(up-chat-data-to-self "p-x-1 %d" g: p-x-1)
;	(up-chat-data-to-self "p-y-1 %d" g: p-y-1)
;	(up-chat-data-to-self "p-danger-x %d" g: p-danger-x)
;	(up-chat-data-to-self "p-danger-y %d" g: p-danger-y)
;	(up-chat-data-to-self "p-order-x %d" g: p-order-x)
;	(up-chat-data-to-self "p-order-y %d" g: p-order-x)
;	(up-chat-data-to-self "p-enemy-melee-group-x %d" g: p-danger-x)
;	(up-chat-data-to-self "p-enemy-melee-group-y %d" g: p-danger-y)
	(up-add-object-by-id search-local g: g-current-unit-id)
;	(up-set-target-object search-local c: 0)
;	(set-strategic-number sn-keystates 2)
	(up-target-point p-order-x action-move -1 stance-no-attack)
;	(set-strategic-number sn-keystates 1)
;	(up-target-objects 0 -1 -1 stance-aggressive)
;	(set-strategic-number sn-keystates 0)
)

(defrule
	(up-compare-goal temporary-goal != 0)
=>
	(set-goal temporary-goal 0)
	(up-modify-goal g-current-list-number c:+ 1)
	(up-jump-direct g: g-jump-direct-1)
)