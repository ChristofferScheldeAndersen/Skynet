(defrule
	(up-compare-goal temporary-goal != 0)
	(up-compare-goal temporary-goal != -2)
	(up-compare-goal g-current-list-number g:< g-rule-loops)
	(up-set-target-by-id g: g-current-unit-id)
	(or	(goal g-next-attack 0)
		(up-compare-goal temporary-goal > -1))
	(or	(up-object-data object-data-hitpoints > 20)
		(up-object-data object-data-class != villager-class))
=>
	(up-get-point position-object p-x-1)
	(up-set-target-point p-x-1)
	(set-goal g-math-1 0)
	(set-goal g-math-2 1)
	(set-goal check-goal jump-to-attack-function)
)
(load "Ares/melee attack")
