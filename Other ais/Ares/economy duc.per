(defrule
	(current-age < castle-age)
=>
	(up-full-reset-search)
	(up-set-target-point p-self-x)
	(up-filter-distance c: 33 c: -1)
	(up-filter-exclude -1 actionid-build -1 -1)
	(up-find-local c: villager-class c: 60)
	(up-remove-objects search-local object-data-tasks-count <= 0)
	(up-get-search-state lt)
)

(defrule
	(current-age < castle-age)
	(up-compare-goal lt > 0)
=>
	(up-full-reset-search)
	(up-get-point position-self p-self-x)
	(up-set-target-point p-self-x)
	(up-filter-distance c: 33 c: -1)
	(up-filter-exclude -1 actionid-build -1 -1)
	(up-find-local c: villager-class c: 60)
	(up-remove-objects search-local object-data-tasks-count <= 0)
	(up-clean-search search-local object-data-full-distance search-order-desc)
	(up-remove-objects search-local object-data-index > 0)
	(up-set-target-object search-local c: 0)
	(up-get-point position-object p-x-1)
	(up-lerp-tiles p-x-1 p-self-x c: 5)
	(chat-to-player my-player-number "Villagers going too far")
	(up-target-point p-x-1 action-move -1 -1)
)


