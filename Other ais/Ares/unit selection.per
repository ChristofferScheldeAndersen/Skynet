(defrule
	(goal check-goal knight-line)
=>
	(set-goal g-math-4 6);this value reduces weight of units weakness in computation
;---------------------------------------------- negative - 2
	(up-modify-goal g-math-1 s:= sn-camels)
	(up-modify-goal g-math-1 s:+ sn-spears)
	(up-modify-goal g-math-1 s:+ sn-monks)
	(up-modify-goal g-math-1 c:* 2)
