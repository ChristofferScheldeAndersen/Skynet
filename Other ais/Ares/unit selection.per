	(up-setup-cost-data 1 temp-food)
	(up-add-object-cost g: check-goal c: 1)
	(up-modify-goal g-math-1 g:= temp-food)
	(up-modify-goal g-math-1 g:+ temp-wood)
	(up-modify-goal g-math-1 g:+ temp-gold)
	(up-add-object-cost g: check-goal c: 99)
	(up-modify-goal temp-food g:* g-food-available)
