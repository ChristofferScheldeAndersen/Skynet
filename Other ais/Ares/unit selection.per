;Unit comparison
; longswords (neutral) vs Pikes (Counter) == +0.717 -> +2
; longswords (neutral) vs knights (neutral strong) == -0.225 -> -1
; longswords (neutral) vs light cav (neutral weak) == +0.410 -> +1
; pikes (counter) vs knights (counter target) == +0.693 -> +2
; pikes (counter) vs eagle warrior (neutral weak) == -0.466 -> -1

(defconst rw 30); lower value reduces influence of resource amount (min 1)

(defrule
	(true)
=>
	(up-setup-cost-data 1 g-food-buffer)
	(up-add-object-cost c: villager c: 1)
	(up-add-object-cost c: house c: 1)
	(up-add-object-cost g: g-want-siege c: 1)
	(up-add-object-cost g: my-best-melee-unit c: 2)
	(up-add-object-cost g: my-best-ranged-unit c: 2)
	(set-goal g-want-melee -1)
	(set-goal g-want-ranged -1)
	(set-goal g-want-siege -1)
	(set-goal my-best-melee-unit -1)
	(set-goal my-best-ranged-unit -1)
	(set-goal my-backup-melee-unit -1)
	(set-goal my-backup-ranged-unit -1)

	(set-goal g-melee-score -10000)
	(set-goal g-ranged-score -10000)
	(set-goal temporary-goal -10000)

	(set-goal check-goal 0)

	(up-get-fact soldier-count 0 g-math-2)
	(set-goal g-math-3 50)
	(up-modify-goal g-math-3 g:- g-math-2)
	(up-modify-goal g-math-3 c:max 1)
)
(defrule
	(up-compare-flag f-map-type == fv-fish-map)
=>
	(up-add-object-cost c: fishing-ship c: 2))
;step 0: find siege cost

(defrule
	(goal g-want-siege -1)
	(unit-available trebuchet)
	(military-population > 20)
	(unit-type-count-total trebuchet-set < 3)
	(unit-type-count-total ram-unit < 4)
	(unit-type-count-total bombard-cannon < 4)
	(up-compare-flag f-siege-allowed == fv-trebs)
=>
	(set-goal g-want-siege trebuchet))

(defrule
	(goal g-want-siege -1)
	(unit-available bombard-cannon)
	(military-population > 20)
	(unit-type-count-total trebuchet-set < 3)
	(unit-type-count-total ram-unit < 4)
	(unit-type-count-total bombard-cannon < 4)
	(up-compare-flag f-siege-allowed == fv-bombard-cannons)
=>
	(set-goal g-want-siege bombard-cannon))

(defrule
	(goal g-want-siege -1)
	(unit-available ram-unit)
	(military-population > 20)
	(unit-type-count-total trebuchet-set < 3)
	(unit-type-count-total ram-unit < 4)
	(unit-type-count-total bombard-cannon < 4)
	(up-compare-flag f-siege-allowed == fv-rams)
=>
	(set-goal g-want-siege ram-unit))

(defrule
	(goal g-want-siege -1)
	(unit-available monk)
	(unit-type-count-total monk < 2)
	(military-population > 20)
	(up-compare-flag f-monks-allowed == fv-monks)
=>
	(set-goal g-want-siege monk))



;step 0: find civs best and backup units
;step 1: find ideal ranged unit
;step 2: find ideal melee unit
;step 3: find siege cost

;step 4: choose priority unit (siege, melee or ranged), regardless of eco
;step 5: choose ideal units if eco affords it, otherwise choose budget units



;step 1: find best melee unit

(defrule
	(up-compare-flag f-cavalry-allowed == fv-camels)
=>
	(set-goal temporary-goal 1);this value reduces weight of units strength in computation
;--------------------------------------- positive + 2
	(up-modify-goal g-math-1 s:= sn-cavalry)
	(up-modify-goal g-math-1 s:+ sn-cavalry-archers)
	(up-modify-goal g-math-1 c:* 2)
	(up-modify-goal temporary-goal g:+ g-math-1)
;--------------------------------------- positive + 1
	(up-modify-goal temporary-goal s:+ sn-skirms)
	(up-modify-goal temporary-goal s:+ sn-siege)
;----------------------------------------------------------------
	(set-goal check-goal camel-line)
)
(defrule
	(goal check-goal camel-line)
=>
;--------------------------Diversity evaluation-------------
	(up-get-fact unit-type-count camel-line g-math-1) 
	(up-modify-goal g-math-1 c:* 100)
	(up-modify-goal g-math-1 g:/ g-math-2);g-math-2 == soldier-count
	(set-goal g-math-4 100)
	(up-modify-goal g-math-4 g:+ g-math-3);this value reduces weight of unit diversity in computation
	(up-modify-goal g-math-4 g:- g-math-1)
	(up-modify-goal temporary-goal g:* g-math-4)

;---------------------------Cost evaluation----------------
	(up-setup-cost-data 1 temp-food)
	(up-add-object-cost g: check-goal c: 1)
	(up-modify-goal g-math-1 g:= temp-food)
	(up-modify-goal g-math-1 g:+ temp-wood)
	(up-modify-goal g-math-1 g:+ temp-gold)
	(up-add-object-cost g: check-goal c: 99)
	(up-modify-goal temp-food g:* g-food-available)
	(up-modify-goal temp-wood g:* g-wood-available)
	(up-modify-goal temp-gold g:* g-gold-available)

	(up-modify-goal g-math-1 g:* g-max-res-available)

	(up-modify-goal temp-food g:+ temp-wood)
	(up-modify-goal temp-food g:+ temp-gold)

	(up-modify-goal temp-food c:+ rw);This value reduces weight of resources in computation
	(up-modify-goal g-math-1 c:+ 1)

	(up-modify-goal temp-food g:/ g-math-1)
	(up-modify-goal temporary-goal g:* temp-food)
)

(defrule
	(goal check-goal camel-line)
=>
	(set-goal g-math-4 6);this value reduces weight of units weakness in computation
;---------------------------------------------- negative - 2
	(up-modify-goal g-math-1 s:= sn-infantry)
	(up-modify-goal g-math-1 s:+ sn-archers)
	(up-modify-goal g-math-1 s:+ sn-spears)
	(up-modify-goal g-math-1 s:+ sn-eagles)
	(up-modify-goal g-math-1 c:* 2)
	(up-modify-goal g-math-4 g:+ g-math-1)
;---------------------------------------------- negative - 1
	(up-modify-goal g-math-4 s:+ sn-gunpowder)
	(up-modify-goal g-math-4 s:+ sn-cataphracts)
	(up-modify-goal temporary-goal g:/ g-math-4)
)
(defrule
	(up-compare-goal temporary-goal g:> g-melee-score)
	(goal check-goal camel-line)
=>
	(up-modify-goal g-melee-score g:= temporary-goal)
	(set-goal my-best-melee-unit camel-line))


(defrule
	(up-compare-flag f-cavalry-allowed == fv-knights)
=>
	(set-goal temporary-goal 1);this value reduces weight of units strength in computation
;--------------------------------------- positive + 2
	(up-modify-goal g-math-1 s:= sn-husks)
	(up-modify-goal g-math-1 c:* 2)
	(up-modify-goal temporary-goal g:+ g-math-1)
;--------------------------------------- positive + 1
	(up-modify-goal temporary-goal s:+ sn-skirms)
	(up-modify-goal temporary-goal s:+ sn-siege)
	(up-modify-goal temporary-goal s:+ sn-infantry)
	(up-modify-goal temporary-goal s:+ sn-light-cavalry)
	(up-modify-goal temporary-goal s:+ sn-eagles)
	(up-modify-goal temporary-goal s:+ sn-archers)
	(up-modify-goal temporary-goal s:+ sn-cataphracts)
