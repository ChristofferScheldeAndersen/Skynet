;function loop

(defrule
	(goal g-math-1 0)
	(up-compare-goal temporary-goal > -1)
	(up-object-data object-data-action != actionid-explore)
	(goal check-goal jump-to-attack-function)
	(up-compare-goal g-math-2 < 4)
	(or	(up-compare-goal g-math-2 < 2)
		(up-object-data object-data-class != villager-class))
	(or	(up-point-distance p-x-1 p-x-3 g:> g-math-2)
		(goal g-current-target-id -1))
=>
	(up-modify-goal g-math-2 c:+ 1)
	(up-set-target-point p-x-1)
	(up-jump-direct g: jump-to-attack-function); not the problem
)

;(defrule
;	(goal g-math-1 1)
;	(goal g-math-2 0)
;	(goal check-goal jump-to-attack-function)
;=>
;	(chat-to-all "enemy super close"))

;attack
(defrule
	(goal g-math-1 1)
	(goal check-goal jump-to-attack-function)
=>
;	(chat-to-all "melee attack")
	(up-reset-search 1 1 0 0)
	(up-add-object-by-id search-local g: g-current-unit-id)
	(up-clean-search search-remote object-data-full-distance search-order-asc)
;	(up-clean-search search-remote object-data-attacker-count search-order-asc)
	(up-clean-search search-remote object-data-hitpoints search-order-asc)
	(up-set-target-object search-remote c: 0)
	(up-target-objects 1 action-default -1 stance-aggressive)

	(up-modify-goal g-current-list-number c:+ 1)
	(up-jump-direct g: g-jump-direct-1)
)

