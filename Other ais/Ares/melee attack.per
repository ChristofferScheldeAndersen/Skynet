;function start
(defrule
	(goal check-goal jump-to-attack-function)
	(up-compare-goal temporary-goal >= 1)
	(up-compare-goal g-next-attack > 800)
=>
	(set-goal g-math-2 2)
)
(defrule
	(goal check-goal jump-to-attack-function)
=>
	(up-get-rule-id jump-to-attack-function)
	(set-strategic-number sn-focus-player-number 1)
	(up-filter-exclude -1 -1 -1 building-class)
	(up-filter-distance c: -1 g: g-math-2)
)

(defrule
	(stance-toward focus-player enemy)
	(goal check-goal jump-to-attack-function)
	(or	(up-object-data object-data-type == cataphract)
		(up-object-data object-data-type == jaguar-man))
	(up-find-remote c: infantry-class c: 5)
=>
	(set-goal g-math-1 1)
)
(defrule
	(goal check-goal jump-to-attack-function)
	(or	(up-object-data object-data-type == cataphract)
		(up-object-data object-data-type == jaguar-man))
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2)
)
(defrule
	(goal g-math-1 0)
	(goal check-goal jump-to-attack-function)
=>
	(set-strategic-number sn-focus-player-number 1)
)



(defrule
	(stance-toward focus-player enemy)
	(goal check-goal jump-to-attack-function)
	(or	(up-object-data object-data-type == spearman)
	(or	(up-object-data object-data-type == camel)
		(up-object-data object-data-type == kamayuk)))
	(or	(up-find-remote c: cavalry-class c: 5)
	(or	(up-find-remote c: cavalry-archer-class c: 5)
		(up-find-remote c: scout-cavalry-class c: 5)))
=>
	(set-goal g-math-1 1)
)
(defrule
	(or	(up-object-data object-data-type == spearman)
	(or	(up-object-data object-data-type == camel)
		(up-object-data object-data-type == kamayuk)))
	(goal check-goal jump-to-attack-function)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2)
)
(defrule
	(goal g-math-1 0)
	(goal check-goal jump-to-attack-function)
=>
	(set-strategic-number sn-focus-player-number 1)
)

(defrule
	(goal check-goal jump-to-attack-function)
	(stance-toward focus-player enemy)
	(or	(up-find-remote c: monastery-class c: 5)
		(up-find-remote c: monk-with-relic-class c: 2))
=>
	(set-goal g-math-1 1)
)

(defrule
	(goal check-goal jump-to-attack-function)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2)
)

(defrule
	(goal g-math-1 0)
	(goal check-goal jump-to-attack-function)
=>
	(set-strategic-number sn-focus-player-number 1)
	(up-filter-include cmdid-military -1 -1 -1)
)

(defrule
	(goal check-goal jump-to-attack-function)
	(stance-toward focus-player enemy)
	(up-find-remote c: -1 c: 15)
=>
	(set-goal g-math-1 1)
)

(defrule
	(goal check-goal jump-to-attack-function)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2)
)
(defrule
	(goal g-math-1 0)
	(goal check-goal jump-to-attack-function)
=>
	(set-strategic-number sn-focus-player-number 1)
	(up-filter-include -1 -1 -1 -1)
)

(defrule
	(goal check-goal jump-to-attack-function)
	(stance-toward focus-player enemy)
	(or	(up-find-remote c: villager-class c: 5)
		(up-find-remote c: trade-cart c: 5))
=>
	(set-goal g-math-1 1)
)

(defrule
	(goal check-goal jump-to-attack-function)
	(up-modify-sn sn-focus-player-number c:+ 1)
	(player-valid focus-player)
=>
	(up-jump-rule -2)
)
