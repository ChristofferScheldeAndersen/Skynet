	; Rule #3426
	; Purpose: Recreate work group 1 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal varTmp5407 c:== 1)
		=>
		(up-create-group 0 0 c: 1)
		(up-modify-group-flag _true c: 1)
		(up-reset-group c: 1))

	; Rule #3427
	; Purpose: Recreate work group 2 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal varTmp5407 c:== 2)
		=>
		(up-create-group 0 0 c: 2)
		(up-modify-group-flag _true c: 2)
		(up-reset-group c: 2))

	; Rule #3428
	; Purpose: Recreate work group 3 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal varTmp5407 c:== 3)
		=>
		(up-create-group 0 0 c: 3)
		(up-modify-group-flag _true c: 3)
		(up-reset-group c: 3))

	; Rule #3429
	; Purpose: Recreate work group 4 so the villager can be reassigned into the correct bucket.
	(defrule
		(up-compare-goal varTmp5407 c:== 4)
		=>
		(up-create-group 0 0 c: 4)
		(up-modify-group-flag _true c: 4)
		(up-reset-group c: 4))

	; Rule #3430
	; Purpose: Derive the first local search radius from the villager's current movement distance and the configured limits.
	(defrule
		(up-modify-goal varTmp5408 g:= varTmp5405)
		(up-modify-goal varTmp5408 g:/ var178)
		(up-modify-goal varTmp5408 g:min var176)
		(up-compare-goal var178 c:<= 0)
		=>
		(up-modify-goal varTmp5408 g:= var176))

	; Rule #3431
	; Purpose: Start a local anchor search around the villager using the computed search radius.
	(defrule
