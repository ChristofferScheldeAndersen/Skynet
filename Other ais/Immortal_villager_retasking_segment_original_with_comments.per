	; Rule #3408
	; Purpose: Abort early when food retasking is blocked by the idle-farm check or when no valid villager ID was supplied.
	(defrule
		(up-modify-goal varTmp5402 s:= 71)
		(up-modify-goal varTmp5402 c:/ 70)
		(or (and (and (up-compare-goal var174 c:== food)
					(up-compare-flag boolvar499 c:== 1048576))
				(idle-farm-count g:<= varTmp5402))
			(up-compare-goal var175 c:< 0))
		=>
		(up-modify-goal var186 c:= -1)
		(up-jump-direct g: ___ra1___))

	; Rule #3409
	; Purpose: Mark wood retasking as structure-constrained when lumber-camp support is missing.
	(defrule
		(up-compare-sn 71 c:< 30)
		(or (building-type-count-total mule-cart c:== 0)
			(up-compare-goal vec46_W c:== 0))
		(building-type-count-total lumber-camp c:== 0)
		=>
		(up-modify-goal var179 c:= 1))

	; Rule #3410
	; Purpose: Initialize the resource-balance weight for food retasking.
	(defrule
		(up-compare-goal var174 c:== food)
		(up-compare-goal var181 c:== -1)
		=>
		(up-modify-goal var181 c:= 1))

	; Rule #3411
	; Purpose: Initialize the resource-balance weight for wood retasking.
	(defrule
		(up-compare-goal var174 c:== wood)
		(up-compare-goal var181 c:== -1)
		=>
		(up-modify-goal var181 c:= 7))

	; Rule #3412
	; Purpose: Initialize the resource-balance weight for stone retasking.
	(defrule
		(up-compare-goal var174 c:== stone)
		(up-compare-goal var181 c:== -1)
		=>
		(up-modify-goal var181 c:= 1))

	; Rule #3413
	; Purpose: Initialize the resource-balance weight for gold retasking.
	(defrule
		(up-compare-goal var174 c:== gold)
		(up-compare-goal var181 c:== -1)
		=>
		(up-modify-goal var181 c:= 1))

	; Rule #3414
	; Purpose: Load the chosen villager's current state and initialize temporary values used by the rest of the retask search.
	(defrule
		(up-modify-goal var186 c:= 0)
		=>
		(up-set-target-by-id g: var175)
		(up-get-point position-curr-object vec2Tmp674)
		(up-get-object-data object_data-villager-type varTmp5403)
		(up-get-object-data object_data-gather-type varTmp5404)
		(up-get-object-data object_data-move-x vec2Tmp675_x)
		(up-get-object-data object_data-move-y vec2Tmp675_y)
		(up-get-point position-curr-object vec2Tmp676)
		(up-get-point-distance vec2Tmp676 vec2Tmp675 varTmp5405)
		(up-get-object-data object_data-tag varTmp5406)
		(up-modify-goal var3859 c:= 1)
		(up-modify-goal varTmp5407 c:= 1)
		(up-modify-goal varTmp5407 g:+ var174))

	; Rule #3415
	; Purpose: Reject villagers whose tag makes them ineligible for this retask routine.
	(defrule
		(nor (and (up-compare-goal varTmp5406 c:>= 1)
				(up-compare-goal varTmp5406 c:<= 4))
			(up-compare-goal varTmp5406 c:<= -1))
		=>
		(up-chat-data-to-all "!! ERROR: vill to be reassigned is not allowable %d" g: varTmp5406)
		(up-modify-goal var186 c:= -2)
		(up-jump-direct g: ___ra1___))

	; Rule #3416
	; Purpose: Allow farmers to count as already-good food workers over a larger distance before forcing a retask.
	(defrule
		(up-compare-goal var185 c:== 0)
		(up-compare-goal var174 c:== food)
		(up-compare-goal varTmp5403 c:== lid_villager-farmer)
		=>
		(up-modify-goal var177 c:max 32))

	; Rule #3417
	; Purpose: Allow an already-food villager to stay put during the active timer window unless the mismatch is meaningful.
	(defrule
		(up-compare-goal var185 c:== 0)
		(up-compare-goal var174 c:== food)
		(up-compare-goal varTmp5404 c:== food)
		(up-timer-status 15 c:== timer-running)
		=>
		(up-modify-goal var177 c:max 28))

	; Rule #3418
	; Purpose: Allow foragers to count as already-good food workers with a smaller tolerance window.
	(defrule
		(up-compare-goal var185 c:== 0)
		(up-compare-goal var174 c:== food)
		(up-compare-goal varTmp5403 c:== lid_villager-forager)
		=>
		(up-modify-goal var177 c:max 22))

	; Rule #3419
	; Purpose: Normalize farmer, forager, and shepherd roles into the shared food category for later comparisons.
	(defrule
		(or (or (up-compare-goal varTmp5403 c:== lid_villager-farmer)
				(up-compare-goal varTmp5403 c:== lid_villager-forager))
			(up-compare-goal varTmp5403 c:== lid_villager-shepherd))
		=>
		(up-modify-goal varTmp5404 c:= food))

	; Rule #3420
	; Purpose: Normalize lumberjacks into the shared wood category for later comparisons.
	(defrule
		(up-compare-goal varTmp5403 c:== lid_villager-lumberjack)
		=>
		(up-modify-goal varTmp5404 c:= wood))

	; Rule #3421
	; Purpose: Normalize stone miners into the shared stone category for later comparisons.
	(defrule
		(up-compare-goal varTmp5403 c:== lid_villager-stone-miner)
		=>
		(up-modify-goal varTmp5404 c:= stone))

