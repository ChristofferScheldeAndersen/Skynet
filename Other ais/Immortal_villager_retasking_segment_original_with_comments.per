		=>
		(up-get-search-state vec41))

	; Rule #3524
	; Purpose: Skip the unload-support action when no eligible garrisoned town center exists.
	(defrule
		(up-compare-goal vec41_F c:== 0)
		=>
		(up-jump-direct c: 3531))

	; Rule #3525
	; Purpose: Select the first eligible garrisoned town center for the unload-support action.
	(defrule
		(true)
		=>
		(up-set-target-object search-local c: 0))

	; Rule #3526
	; Purpose: Shorten the unload timer once a valid town center has already been selected.
	(defrule
		(up-timer-status 46 c:!= timer-running)
		=>
		(up-set-timer c: 46 c: 4))
