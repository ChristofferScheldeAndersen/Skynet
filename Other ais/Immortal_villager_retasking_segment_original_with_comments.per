		(up-get-object-data object_data-distance varTmp5410)
		(up-get-object-data object_data-class-id varTmp5411)
		(up-modify-goal varTmp5412 g:= varTmp5411)
		(up-modify-goal varTmp5412 c:- class-farm)
		(up-modify-goal varTmp5412 g:* varTmp5412)
		(up-modify-goal varTmp5412 c:min 1)
		(up-get-point position-curr-object vec2Tmp677)
		(up-set-precise-target-point vec2Tmp677)
		(up-modify-goal var3863 c:= -4))

