	(defrule
		(up-compare-goal varTmp5403 c:== lid_villager-gold-miner)
		=>
		(up-modify-goal varTmp5404 c:= gold))

	; Rule #3423
	; Purpose: Abort same-resource retasking when the villager is already close enough to a suitable target.
	(defrule
		(up-compare-goal var177 c:> 0)
		(up-compare-goal varTmp5404 g:== var174)
		(up-compare-goal varTmp5405 g:< var177)
		=>
		(up-modify-goal var186 c:= -3)
		(up-jump-direct g: ___ra1___))

