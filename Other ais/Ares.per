(defrule
	(unit-type-count ram-unit > 2)
=>
	(set-strategic-number sn-disable-tower-priority 0)
	(disable-self)
)



(defrule
	(unit-type-count villager > 14)
	(up-pending-objects c: house == 0)
	(can-afford-building house)
	(building-available house)
	(not	(can-build-with-escrow house))
	(strategic-number sn-maximum-town-size < 33)
=>
	(up-jump-rule 2)
	(chat-to-player my-player-number "increase ts to build")
	(up-modify-sn sn-maximum-town-size c:+ 1))
(defrule
	(unit-type-count villager > 14)
	(up-pending-objects c: barracks == 0)
	(or	(and	(can-afford-building barracks)
			(building-available barracks))
		(and	(current-age >= feudal-age)
			(strategic-number sn-maximum-town-size < 10)))
	(not	(can-build-with-escrow barracks))
	(strategic-number sn-maximum-town-size < 33)
=>
	(up-jump-rule 1)
	(chat-to-player my-player-number "increase ts to build")
	(up-modify-sn sn-maximum-town-size c:+ 1))
(defrule
	(unit-type-count villager > 14)
	(up-pending-objects c: market == 0)
	(can-afford-building market)
	(building-available market)
	(not	(can-build-with-escrow market))
	(strategic-number sn-maximum-town-size < 33)
=>
	(chat-to-player my-player-number "increase ts to build")
	(up-modify-sn sn-maximum-town-size c:+ 1))

(defrule
	(unit-type-count villager > 14)
	(up-pending-objects c: town-center-foundation == 0)
	(can-afford-building town-center-foundation)
	(building-available town-center-foundation)
	(not	(can-build-with-escrow town-center-foundation))
	(strategic-number sn-maximum-town-size < 33)
=>
	(chat-to-player my-player-number "increase ts to build")
	(up-modify-sn sn-maximum-town-size c:+ 1))

(defrule
	(goal g-second-turn 0)
	(unit-type-count villager > 14)
	(up-pending-objects c: lumber-camp == 0)
	(can-afford-building lumber-camp)
	(building-available lumber-camp)
	(not	(can-build-with-escrow lumber-camp))
	(strategic-number sn-lumber-camp-max-distance < 133)
=>
	(chat-to-player my-player-number "increase lumber camp distance to build")
	(up-modify-sn sn-lumber-camp-max-distance c:+ 7))

(defrule
	(goal g-second-turn 1)
	(unit-type-count villager > 24)
	(up-pending-objects c: mining-camp == 0)
	(can-afford-building mining-camp)
	(building-available mining-camp)
	(not	(can-build-with-escrow mining-camp))
	(strategic-number sn-mining-camp-max-distance < 133)
=>
	(chat-to-player my-player-number "increase mining camp distance to build")
	(up-modify-sn sn-mining-camp-max-distance c:+ 4))

(defrule
	(unit-type-count villager > 24)
	(building-type-count-total mining-camp > 1)
	(strategic-number sn-mining-camp-max-distance < 33)
=>
	(chat-to-player my-player-number "increase mining camp distance to build")
	(set-strategic-number sn-mining-camp-max-distance 33)
	(up-modify-sn sn-lumber-camp-max-distance c:max 33))

(defrule
	(soldier-count > 20)
	(strategic-number sn-maximum-town-size < 20)
	(strategic-number sn-military-superiority > -3)
=>
	(set-strategic-number sn-maximum-town-size 23))

(defrule
	(true)
=>
	(up-modify-goal g-turn-count c:+ 1)
	(up-modify-goal g-second-turn g:= g-turn-count)
	(up-modify-goal g-second-turn c:mod 2)
	(up-modify-goal g-fifth-turn g:= g-turn-count)
	(up-modify-goal g-fifth-turn c:mod 5)
	(up-get-point position-self p-self-x)
	(up-full-reset-search)
)
(defrule
	(building-type-count town-center == 0)
	(up-find-local c: villager c: 1)
=>
	(up-set-target-object search-local c: 0)
	(up-get-point position-object p-self-x)
)
(defrule
	(timer-triggered t-29-sec)
=>
	(up-set-attack-stance -1 c: stance-aggressive)
)
