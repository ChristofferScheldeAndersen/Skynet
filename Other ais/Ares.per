(defrule
	(or	(cc-players-unit-type-count 0 sea-fish >= min-fishing) 
		(cc-players-unit-type-count 0 shore-fish >= min-fishing))
=>
	(up-modify-flag f-map-type c:+ fv-fish-map)
	(chat-to-player my-player-number "some fish found on map")
	(disable-self))
#else
(defrule
	(true)
=>
	(up-modify-flag f-map-type c:+ fv-fish-map)
	(chat-to-player my-player-number "some fish found on map")
	(disable-self))
#end-if
#end-if
#end-if


(defrule
	(building-type-count town-center > 1)
=>
	(up-assign-builders c: town-center-foundation c: 3)
	(disable-self)
)
(defrule
	(building-type-count town-center > 0)
	(or	(civ-selected hun)
		(building-type-count-total house > 1))
=>
	(up-assign-builders c: house c: 0)
	(disable-self)
)
(defrule
	(building-type-count mill > 0)
	(building-type-count town-center > 0)
=>
	(up-assign-builders c: mill c: 0)
	(disable-self)
)
(defrule
	(building-type-count archery-range > 0)
	(building-type-count town-center > 0)
=>
	(up-assign-builders c: archery-range c: 0)
	(disable-self)
)
(defrule
	(building-type-count stable > 0)
	(building-type-count town-center > 0)
=>
	(up-assign-builders c: stable c: 0)
	(disable-self)
)
(defrule
	(building-type-count mining-camp > 0)
	(building-type-count town-center > 0)
=>
	(up-assign-builders c: mining-camp c: 0)
	(disable-self)
)

