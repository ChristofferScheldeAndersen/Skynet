(defrule
	(unit-type-count livestock-class g:> g-previous-sheep)
=>
	(up-get-fact unit-type-count livestock-class g-math-1)
	(up-modify-goal g-math-1 g:- g-previous-sheep)
	(up-modify-goal g-current-sheep g:+ g-math-1)
	(up-chat-data-to-player my-player-number ".%d sheep found" g: g-current-sheep))
(defrule
	(up-gaia-type-count c: wild-animals-class g:> g-previous-boar)
=>
	(up-get-fact gaia-type-count wild-animals-class g-math-1)
	(up-modify-goal g-math-1 g:- g-previous-boar)
	(up-modify-goal g-current-boar g:+ g-math-1)
	(up-chat-data-to-player my-player-number ".%d boar found" g: g-current-boar))
;should be at bottom of script for g-current-vils and g-enemy-units-in-town comparisons
(defrule
	(true)
=>
	(up-get-fact gaia-type-count wild-animals-class g-previous-boar)
	(up-get-fact unit-type-count livestock-class g-previous-sheep)
	(up-get-fact unit-type-count dead-female-builder g-math-1)
	(up-get-fact unit-type-count dead-male-builder g-math-2)
	(up-modify-goal g-math-1 g:+ g-math-2)
	(up-modify-goal g-math-1 c:* 15)
	(set-strategic-number sn-percent-building-cancellation 40)
	(up-modify-sn sn-percent-building-cancellation g:+ g-math-1)
	(up-modify-sn sn-percent-building-cancellation c:min 100)
	(set-goal g-town-under-attack no)
	(up-find-player enemy find-closest g-math-1)
	(up-modify-sn sn-target-player-number g:= g-math-1)
)
(defrule
	(strategic-number sn-maximum-town-size < 40)
	(up-enemy-units-in-town > 3)
	(town-under-attack)
=>
	(set-goal g-town-under-attack yes)
	(up-find-player enemy find-attacker g-math-1)
	(up-modify-sn sn-target-player-number g:= g-math-1))
(defrule
	(or	(unit-type-count villager g:> g-current-vils)
		(up-pending-objects c: villager > 1))
=>
	(enable-timer t-drop-food 21))
(defrule
	(true)
=>
	(up-get-fact unit-type-count villager g-current-vils)
	(up-get-fact enemy-units-in-town 0 g-enemy-units-in-town)

	(up-get-fact military-population 0 g-math-1)
	(up-get-player-fact target-player military-population 0 g-math-2)
	(up-modify-goal g-math-1 g:- g-math-2)
	(up-modify-sn sn-military-superiority g:= g-math-1)

	(up-get-fact civilian-population 0 g-math-1)
	(up-get-player-fact target-player civilian-population 0 g-math-2)
	(up-modify-goal g-math-1 g:- g-math-2)
	(up-modify-sn sn-civilian-superiority g:= g-math-1)


	(up-get-fact wood-amount 0 g-math-1)
	(up-get-fact food-amount 0 g-math-2)
	(up-modify-goal g-math-1 g:- g-math-2)
	(up-modify-sn sn-food-wood-comparison g:= g-math-1)


	(up-get-fact gold-amount 0 g-math-1)
	(up-get-fact food-amount 0 g-math-2)
	(up-modify-goal g-math-1 g:- g-math-2)
	(up-modify-sn sn-food-gold-comparison g:= g-math-1)


	(up-get-fact gold-amount 0 g-math-1)
	(up-get-fact wood-amount 0 g-math-2)
	(up-modify-goal g-math-1 g:- g-math-2)
	(up-modify-sn sn-wood-gold-comparison g:= g-math-1)
)

