(defrule
	(taunt-detected my-player-number 100)
=>
	(up-chat-data-to-all "lumber camp distance %d" s: sn-lumber-camp-max-distance)
	(up-chat-data-to-all "Civilian superiority %d" s: sn-civilian-superiority)
	(up-chat-data-to-all "Military superiority %d" s: sn-military-superiority)
	(up-chat-data-to-all "Town size: %d" s: sn-maximum-town-size)
	(up-chat-data-to-all "sn target player %d" s: sn-target-player-number)
	(up-chat-data-to-all "mining camp distance %d" s: sn-mining-camp-max-distance)
	(up-chat-data-to-all "Escrow: %d" g: g-escrow)
	(up-chat-data-to-all "Attack type %d" g: g-attack)
	(acknowledge-taunt my-player-number 100))

(defrule
	(taunt-detected my-player-number 101)
=>
	(up-get-fact unit-type-count villager-food g-math-1)
	(up-get-fact unit-type-count villager-wood g-math-2)
	(up-get-fact unit-type-count villager-gold g-math-3)
	(up-modify-goal g-math-1 g:+ g-math-2)
	(up-modify-goal g-math-1 g:+ g-math-3)
	(up-get-fact unit-type-count villager-stone g-math-2)
	(up-modify-goal g-math-1 g:+ g-math-2)
	(up-modify-goal g-math-2 c:* 100)
	(up-modify-goal g-math-3 c:* 100)
	(up-modify-goal g-math-2 g:/ g-math-1)
	(up-modify-goal g-math-3 g:/ g-math-1)
	(up-chat-data-to-all "Stone Gatherers %: %d" g: g-math-2)
	(up-chat-data-to-all "Gold Gatherers %: %d" g: g-math-3)
	(up-get-fact unit-type-count villager-food g-math-3)
	(up-get-fact unit-type-count villager-wood g-math-2)
	(up-modify-goal g-math-2 c:* 100)
	(up-modify-goal g-math-3 c:* 100)
	(up-modify-goal g-math-2 g:/ g-math-1)
	(up-modify-goal g-math-3 g:/ g-math-1)
	(up-chat-data-to-all "Wood Gatherers %: %d" g: g-math-2)
	(up-chat-data-to-all "Food Gatherers %: %d" g: g-math-3)
	(up-chat-data-to-all "sn food %d" s: sn-food-gatherer-percentage)
	(up-chat-data-to-all "sn gold %d" s: sn-gold-gatherer-percentage)
	(up-chat-data-to-all "sn stone %d" s: sn-stone-gatherer-percentage)
	(up-chat-data-to-all "sn wood %d" s: sn-wood-gatherer-percentage)
