(defrule
	(true)
=>
	(up-get-precise-time g-lag-check g-lag-rest)

	(up-modify-goal g-lag-rest g:- g-lag-monk)
	(up-modify-goal g-lag-monk g:- g-lag-melee)
	(up-modify-goal g-lag-melee g:- g-lag-ranged)
	(up-modify-goal g-lag-ranged g:- g-lag-eco)

	(up-get-precise-time g-lag-check  g-lag-check)
)
(defrule
	(or	(and	(goal g-fifth-turn 2)
			(up-compare-goal g-lag-check > 20))
	(or	(goal g-lag-test 1)
		(taunt-detected my-player-number 254)))
=>
	(chat-to-player my-player-number "----------------")
	(up-chat-data-to-self "path check pass? %d" g: g-lag-test)
	(up-chat-data-to-self "LAG LAG LAG %d" g: g-lag-check)
	(up-chat-data-to-self "eco lag %d" g: g-lag-eco)
	(up-chat-data-to-self "ranged lag %d" g: g-lag-ranged)
	(up-chat-data-to-self "melee lag %d" g: g-lag-melee)
	(up-chat-data-to-self "monk lag %d" g: g-lag-monk)
	(up-chat-data-to-self "remaining lag %d" g: g-lag-rest)
	(acknowledge-taunt my-player-number 254)
)

