; Lag detection - start
        (defrule
            (true)
        =>
            (set-goal gl-time-since-last-tick 0)
            (set-goal gl-script-start-time 0)
            (set-goal gl-script-end-time 0)
            (set-goal gl-total-tick-counter 0)
            (set-goal gl-25-tick-counter 0)
            (set-goal gl-script-time 0)
            (set-goal gl-script-time-for-tick-group 0)
            (set-goal gl-total-script-time 0)
            (set-goal gl-script-time-avg-for-tick-group 0)
            (set-goal gl-final-avg-script-time 0)
            (set-goal gl-time-between-ticks-for-tick-group 0)
            (set-goal gl-total-time-between-ticks 0)
            (set-goal gl-time-between-ticks-avg-for-group 0)
            (set-goal gl-final-avg-time-between-ticks 0)
            (set-goal gl-time-since-last-full-script-read 666)
            (set-goal gl-lowest-avg-tick-interval 999999)
            (set-goal gl-highest-avg-tick-interval -999999)
            (set-goal gl-lowest-avg-script-time 999999)
            (set-goal gl-highest-avg-script-time -999999)
            (disable-self)
        )

        (defrule
            (game-time > 25)
        =>
            (set-goal gl-lowest-avg-tick-interval 999999)
            (set-goal gl-highest-avg-tick-interval -999999)
            (set-goal gl-lowest-avg-script-time 999999)
            (set-goal gl-highest-avg-script-time -999999)
            (disable-self)
        )

        (defrule
            (true)
        =>
            (up-set-timer c: lag-timer c: 0)
            (up-get-timer c: lag-timer gl-script-start-time)
            (up-modify-goal gl-time-since-last-tick g:= gl-script-start-time)
            (up-modify-goal gl-time-since-last-tick g:- gl-script-end-time)
            (up-modify-goal gl-time-since-last-full-script-read g:+ gl-time-since-last-tick)
            (up-get-precise-time 0 gl-script-start-time)
        )

        (defrule
            (up-compare-goal gl-time-since-last-full-script-read < 510)
            (up-compare-goal gl-end-of-script-rule-for-real != -1)
            =>
            (up-jump-direct g: gl-end-of-script-rule-for-real)
        )

        (defrule
            (up-compare-goal gl-time-since-last-full-script-read >= 510)
            (up-compare-goal gl-end-of-script-rule-for-real != -1)
            =>
            (set-goal gl-time-since-last-full-script-read 0)
        )
    
; Global setup
    ; Set commonly used goals

        (defrule
            (true)
            =>
            (up-get-point position-self gl-position-self-x)
            (up-get-fact unit-type-count-total villager gl-vill-nr)
        )
    ; Set strategic numbers once
        (defrule
		(true)
		=>
		(set-strategic-number sn-maximum-food-drop-distance -2)
        (set-strategic-number sn-maximum-wood-drop-distance -2)
        (set-strategic-number sn-maximum-gold-drop-distance -2)
        (set-strategic-number sn-maximum-stone-drop-distance -2)
        (set-strategic-number sn-maximum-hunt-drop-distance -2)
        (set-strategic-number sn-minimum-boar-hunt-group-size 0)
        (set-strategic-number sn-food-gatherer-percentage 0)
        (set-strategic-number sn-stone-gatherer-percentage 0)
        (set-strategic-number sn-gold-gatherer-percentage 0)
        (set-strategic-number sn-wood-gatherer-percentage 0)
        (set-strategic-number sn-cap-civilian-explorers 0)
        (set-strategic-number sn-percent-civilian-explorers 0)
        (set-strategic-number sn-percent-civilian-gatherers 0)

        (set-strategic-number sn-percent-civilian-builders 0)
        (set-strategic-number sn-cap-civilian-builders 0)


        (set-strategic-number sn-allow-civilian-offense 1)
        (set-strategic-number sn-allow-civilian-defense 0)
        (set-strategic-number sn-number-civilian-militia 0)
        (set-strategic-number sn-disable-villager-garrison 3)
        (set-strategic-number sn-maximum-town-size 220) ; vills attacked outside of maximum town size might still attempt to garrison.
            (disable-self)
        )
